diagnose.sh
logs.sh
create_test_users.mjs

# Deployment scripts with credentials
deploy_backend.py
deploy_frontend.py
run_ssh.py
server_db_setup.py
add_priority_column.py
verify_schema.py

# Utility scripts (local only)
close_issues.py
director_agent.py
monitor_issues.py
test_login.py
screenshot.py
checked_issues.json

# Test result artifacts
e2e/result*.txt
e2e/results.json
e2e/results.txt
e2e/final_run.txt
e2e/verified_run.txt
e2e/auth_test.txt
e2e/test_results.txt
e2e/test_phase4.txt
e2e/test_phase4_final.txt
result_final.txt
uncommitted_diff.txt
test-results/

# Build artifacts
frontend/dist.zip
screenshot77.png

# Local scratch (Fathom transcript dumps, etc.)
e2e/fathom_*.txt
e2e/fathom_*.html
e2e/fetch_fathom.js

# Claude session runtime — directory ignored EXCEPT settings.json
# (project-shared permissions) and skills/ (project-shared skill library).
# settings.local.json stays gitignored for personal overrides.
.claude/*
!.claude/settings.json
!.claude/skills/
!.claude/skills/**

# Local coverage snapshot dump (downloaded artifact for backend/scripts/coverage-analysis.js)
backend/coverage-snapshot/

# Local vitest / c8 coverage output
backend/coverage/
backend/.c8tmp/

.env
.env.docker

# Local-only operator scripts (SSH helper reads .env creds; never commit)
.scripts/

# Local-stack runtime state (PID files, backend logs from local-stack-up.ps1)
.scripts-state/

# Local triage scratch (gate.json dumps, agent output buffers — never commit)
e2e/.scratch/
.release-draft-v3.4.14.md

# One-shot local data-migration kit (Zylu → Enhanced Wellness tenantId=2).
# TSVs contain real PII (employee emails, salaries, customer phone numbers,
# invoices); the importer is local-DB only and not used in prod. Kept on
# disk for re-runs, never committed.
data-imports/

# Travel CRM client docs — source-of-truth PDFs/DOCX from Yasin's team. Stay
# local for review; the synthesized PRD lives at docs/TRAVEL_CRM_PRD.md.
travel-crm/

# Audit reports generated by automated agents — local only, never commit
staging_crm_audit_report*.md

# Parallel-agent tmp commit-message files (per Windows-tmp-msg pattern in
# CLAUDE.md — agents write `.tmp-agent-<slice>-msg.txt` instead of /tmp/
# paths since Windows git doesn't write to /tmp).
.tmp-agent-*-msg.txt

# Dr. Haror's external marketing site — separate static site that runs on
# its own server (enhancewellness.globusdemos.com). Kept on disk for the
# CRM ↔ marketing-site handoff work but never pushed to this repo.
drharors-wellness/
