# ─────────────────────────────────────────────────────────────────────────────
# Agentic OS — environment configuration
# Copy to `.env` and fill in. The orchestrator demo runs with ONLY a provider key.
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider keys ────────────────────────────────────────────────────────────
# Configure ANY subset. The ModelRouter automatically uses whichever providers
# have a key set, and falls back across them per capability tier.
# Moonshot / Kimi (primary). Use the base URL for your region:
#   Global:  https://api.moonshot.ai/v1
#   China:   https://api.moonshot.cn/v1
# IMPORTANT: this must be a DEVELOPER API key from platform.moonshot.ai /
# platform.kimi.ai (API Keys). A "Kimi coding plan" / Kimi Code (kimi.com/code)
# subscription key is a DIFFERENT product and will return 401 here.
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Optional additional providers (adapters are stubbed; add a key to enable).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# xAI / Grok — OpenAI-compatible, first-class. A single key is enough; the base
# URL defaults to https://api.x.ai/v1 (override with XAI_BASE_URL if needed).
# IMPORTANT: use a DEVELOPER API key from console.x.ai (API Keys, starts with
# "xai-"). A SuperGrok / Grok chat subscription is a different product — it does
# not grant API access on its own. When set, Grok takes priority over the
# generic OPENAI_COMPATIBLE_* slot. Then set MODEL_* below to grok-4 (or grok-3 /
# grok-3-mini for cheaper tiers).
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Groq — OpenAI-compatible, first-class. A single key is enough; the base URL
# defaults to https://api.groq.com/openai/v1 (override with GROQ_BASE_URL).
# Key from console.groq.com (starts with "gsk_"). The free plan caps throughput
# (≈12K tokens/min, 100K/day) which truncates large outputs; the PAID Developer
# tier lifts that. Then set MODEL_* below to llama-3.3-70b-versatile.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Generic OpenAI-compatible provider (DeepSeek, Together, Groq, local vLLM, …).
# Set both to enable an extra routed provider with no extra code.
# Example A — Google Gemini (FREE tier, no credit card; key from aistudio.google.com):
#   OPENAI_COMPATIBLE_API_KEY=<gemini key>
#   OPENAI_COMPATIBLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   then set MODEL_* below to gemini-2.5-flash
#   (use 2.5, not 3.x: Gemini 3.x requires a tool-call thought_signature the
#    generic OpenAI-compatible adapter doesn't preserve)
# Example B — Groq (free plan, 30 req/min — best FREE fit for multi-agent;
#   key from console.groq.com):
#   OPENAI_COMPATIBLE_API_KEY=gsk_...
#   OPENAI_COMPATIBLE_BASE_URL=https://api.groq.com/openai/v1
#   then set MODEL_* below to llama-3.3-70b-versatile (or llama-3.1-8b-instant)
# Example C — DeepSeek (cheapest paid; platform.deepseek.com, requires balance):
#   OPENAI_COMPATIBLE_API_KEY=sk-...
#   OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com      (no /v1 needed)
#   then set MODEL_* below to deepseek-v4-flash / deepseek-v4-pro
# NOTE: leave MOONSHOT_API_KEY blank when using these, or moonshot wins priority.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=

# ── Model routing overrides (optional) ───────────────────────────────────────
# Capability tier -> concrete model id, for whichever provider is ACTIVE.
# Set these to model ids your active provider exposes. Defaults are Kimi ids;
# for DeepSeek use e.g. deepseek-reasoner / deepseek-chat.
MODEL_REASONING=kimi-k2-thinking
MODEL_BALANCED=kimi-k2.6
MODEL_FAST=kimi-k2-turbo-preview
MODEL_WRITING=kimi-k2.6

# ── Force one provider for ALL tiers (optional A/B knob) ──────────────────────
# Normally the ModelRouter picks the highest-priority provider that has a key.
# PROVIDER_OVERRIDE forces a single provider for every tier, IGNORING priority —
# so you can try a provider without touching your other keys. Leave blank = off.
# Valid ids: moonshot | xai | groq | openai-compatible | openai
# PROVIDER_OVERRIDE=
#
# ── QUICK-START: try OpenAI gpt-5.4-mini for the whole system (easy revert) ──
# 1) set OPENAI_API_KEY above to your OpenAI key
# 2) uncomment the block below
# To REVERT: re-comment this block (the line PROVIDER_OVERRIDE= alone is enough) —
# your Groq/Kimi keys + MODEL_* above are untouched, so it goes straight back.
# PROVIDER_OVERRIDE=openai
# MODEL_REASONING=gpt-5.4-mini
# MODEL_BALANCED=gpt-5.4-mini
# MODEL_WRITING=gpt-5.4-mini
# MODEL_FAST=gpt-5.4-mini          # (or gpt-5.4-nano for cheaper helper agents)

# ── Asset / media APIs (ALL optional — keyless fallbacks are used when blank) ──
# Brochure imagery. With NO keys the system uses Openverse + Wikimedia Commons
# (keyless) for real photos and Pollinations/Flux for AI images. Add a free key
# for higher-quality real photos:
#   Pexels   — free, instant key:  https://www.pexels.com/api/
#   Unsplash — free key:           https://unsplash.com/developers
PEXELS_API_KEY=
UNSPLASH_API_KEY=
# Optional — Hugging Face token for FLUX.1-schnell image gen (else Pollinations).
HUGGINGFACE_API_KEY=
# Route maps for the travel brochure. Geoapify Static Maps is FREE (3000/day) and
# is used FIRST; get a key at https://www.geoapify.com (Sign Up → copy API key).
GEOAPIFY_API_KEY=
# MapTiler is only a fallback — its Static Maps need a PAID plan (free tier 403s).
MAPTILER_API_KEY=

# ── Orchestration policy ─────────────────────────────────────────────────────
# 'autonomous' (default — minimal human-in-loop) | 'supervised' (gate 'ask' tools)
ORCHESTRATION_MODE=autonomous
# Which sector pack to load by default (the web picker pre-selects this).
DEFAULT_SECTOR=travel
# Hard ceiling on delegation depth / total agent steps (runaway protection).
MAX_DELEGATION_DEPTH=3
MAX_AGENT_STEPS=24
# Max times one coordinator may delegate to the SAME specialist before the engine
# forces it to finalize (anti-loop guard; default 5).
MAX_DELEGATIONS_PER_PAIR=5

# ── Billing ──────────────────────────────────────────────────────────────────
# Markup multiplier applied to provider cost when billing tenants (1.5 = +50%).
BILLING_MARKUP=1.5

# ── Security / safety limits ─────────────────────────────────────────────────
# Max characters accepted for a goal (abuse / cost cap).
MAX_GOAL_CHARS=8000
# Hard ceiling on billed USD per run; the run aborts if exceeded (0 = disabled).
MAX_RUN_BUDGET_USD=1.0
# Max orchestrations running at once (cost + load protection).
MAX_CONCURRENT_RUNS=5
# Per-client API requests allowed per minute.
RATE_LIMIT_PER_MINUTE=20

# ── Persistence (optional) ───────────────────────────────────────────────────
# If unset, the web app and demo use an in-memory store (great for local dev).
# Set to enable Postgres-backed persistence + analytics.
DATABASE_URL=
