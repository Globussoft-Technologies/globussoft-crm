# ═══════════════════════════════════════════════════════════════════════════════
# Globussoft Enterprise CRM — backend/.env.example
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to `backend/.env` and fill in real values BEFORE booting the
# backend. The Prisma client reads DATABASE_URL at generate-time; everything
# else is read at server start (and a few cron + script entry-points).
#
# ⚠  NEVER COMMIT REAL VALUES. The real `backend/.env` is gitignored. Treat any
#    secret you paste here as production credentials and route them through your
#    secret manager (Vault / SSM / 1Password) — not a chat window, not a PR diff.
#
# Variable count: 73 env-vars referenced by backend code (see
# docs/AUDIT_2026-05-17_code.md for provenance).
#
# Required-vs-optional convention:
#   REQUIRED → the server REFUSES to boot, or a critical feature is broken.
#   OPTIONAL → unset is fine; the feature degrades gracefully (logs + skip).
#
# ═══════════════════════════════════════════════════════════════════════════════
# ─── Core (REQUIRED) ──────────────────────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════

# MySQL connection string. Used by Prisma (backend/prisma/schema.prisma) at
# generate-time + run-time. Format: mysql://USER:PASS@HOST:PORT/DB
DATABASE_URL="mysql://user:pass@localhost:3306/gbscrm"

# JWT signing secret for the main `Authorization: Bearer …` flow.
# REQUIRED in production — backend/server.js:6-9 hard-exits on boot if unset
# and NODE_ENV=production. Dev fallback exists but is a public string; treat
# unset == compromised.
JWT_SECRET="change-me-to-a-strong-random-string"

# Separate JWT secret for the wellness patient portal (phone+OTP flow).
# REQUIRED in production — backend/server.js:10-12 hard-exits on boot.
PORTAL_JWT_SECRET="change-me-to-a-second-distinct-random-string"

# HTTP port the Express app binds to. Defaults to 5000.
PORT=5000

# Express + lib behaviour switch. One of: development | production | test
# Affects: log verbosity, Sentry env tag, rate-limit caps (10000 in test).
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════════════
# ─── URLs + CORS (REQUIRED for cross-origin flows) ───────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════

# The frontend's public URL. Added to the CORS allowlist
# (backend/server.js:101). Example: https://crm.globusdemos.com
FRONTEND_URL=

# Additional CORS origins, comma-separated. Backend/server.js:102 splits on `,`.
# Use for staging / preview deploys / extra dev hosts.
CORS_ALLOWED_ORIGINS=

# Public origin the backend itself serves under. Read by SSO callback URLs
# (backend/routes/sso.js:27) when building OAuth redirect_uri.
BACKEND_URL=

# Public origin used in SMS / WhatsApp / email links pointing back at the CRM.
# Read by wellnessOpsEngine.js + a few public-link emitters. Defaults to
# https://crm.globusdemos.com when unset.
PUBLIC_BASE_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── SendGrid (transactional email — OPTIONAL but feature-gating) ─────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/lib/notificationService.js + backend/lib/eventBus.js
# When unset, every email is a no-op + warning logged. The route still returns
# 200 to the caller — no crash, just no delivery.

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL="noreply@example.com"

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Email-OTP enforcement on self-service registration (OPTIONAL) ────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/lib/emailOtp.js (enforceRegistrationOtp) on the anonymous
# self-signup endpoints — POST /api/auth/register, /api/auth/signup,
# /api/auth/customer/register, /api/portal/register.
#
# When "1": those endpoints REQUIRE a verified-email token (the 6-digit code
#           sent via SendGrid) — a direct API POST can no longer skip OTP.
# When unset/"0" (default): backward-compatible — token validated if present,
#           but not required. The UI still walks users through OTP either way.
#
# Team invitation (an authenticated admin via Settings) is ALWAYS exempt — only
# anonymous public signup is gated.
#
# ⚠ Before flipping to "1": GetStarted.jsx is a second anonymous signup page
#   with no OTP step and would start returning 403 — add OTP there (or retire it)
#   first. Safe to leave unset until then.
REQUIRE_EMAIL_OTP=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Mailgun (legacy email — OPTIONAL) ────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: routes/marketing.js, routes/document_templates.js,
# routes/signatures.js, routes/surveys.js. Kept for backwards-compat; new
# code should prefer SendGrid above.

MAILGUN_API_KEY=
MAILGUN_DOMAIN="crm.globusdemos.com"

# Generic "From:" header used by cron/lowStockEngine.js when sending stock
# alerts via SMTP/Mailgun (defaults to no-reply@globusdemos.com).
MAIL_FROM="no-reply@example.com"

# ═══════════════════════════════════════════════════════════════════════════════
# ─── SMTP fallback (OPTIONAL, used by report email delivery) ─────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/cron/reportEngine.js. If SMTP_HOST is left at the default
# `smtp.ethereal.email`, the engine sends to Ethereal's preview inbox (safe
# for dev). Set a real host to deliver report emails.

SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=demo
SMTP_PASS=demo123
SMTP_FROM="Globussoft CRM <noreply@example.com>"

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Twilio (SMS + voice — OPTIONAL) ──────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/services/smsProvider.js (Twilio is the tertiary SMS
# fallback after MSG91 → Fast2SMS).

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM="+1XXXXXXXXXX"

# ═══════════════════════════════════════════════════════════════════════════════
# ─── MSG91 (India SMS — OPTIONAL, preferred provider) ────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/services/smsProvider.js. When both AUTH_KEY + SENDER_ID
# are present, MSG91 wins over Fast2SMS + Twilio. SENDER_ID must be exactly
# 6 chars (validator at routes/sms.js).

MSG91_AUTH_KEY=
MSG91_SENDER_ID=GBSCRM

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Fast2SMS (India SMS — OPTIONAL, secondary provider) ─────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/services/smsProvider.js. Falls back when MSG91 is absent.

FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=FSTSMS

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Generic SMS overrides (OPTIONAL) ─────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: routes/marketing.js for outbound-marketing SMS dispatch. Lets a
# campaign override the global default provider without re-deploying.

SMS_PROVIDER=msg91
SMS_API_KEY=
SMS_SENDER_ID=GCRM

# ═══════════════════════════════════════════════════════════════════════════════
# ─── WhatsApp Cloud API (OPTIONAL) ────────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: routes/whatsapp.js. The verify token is what Meta posts to confirm
# your webhook endpoint. Per-tenant credentials live in the WhatsAppConfig
# model — this env-var is the fallback for the webhook-verify handshake only.

WHATSAPP_VERIFY_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Razorpay (payments — OPTIONAL) ───────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: routes/payments.js. Required for INR / Indian-vertical billing.

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Stripe (payments — OPTIONAL) ─────────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: routes/payments.js. Required for USD / EUR / international billing.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Google OAuth + Calendar (OPTIONAL) ───────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: routes/sso.js (Google login), routes/calendar_google.js (CalDAV
# sync), controllers/calendarEventController.js. routes/calendar_google.js
# falls back GOOGLE_CLIENT_ID → GOOGLE_OAUTH_CLIENT_ID — set whichever your
# OAuth tooling prefers; both names work.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_CALENDAR_REDIRECT_URI=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Microsoft OAuth + Outlook Calendar (OPTIONAL) ───────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Two separate var sets — `MICROSOFT_*` is read by routes/sso.js for SSO
# login; `MS_*` is read by routes/calendar_outlook.js +
# controllers/calendarEventController.js for calendar sync. Same Azure AD app
# can be reused; populate both pairs with the same values if so.

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT=common

MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Zoom meetings (OPTIONAL) ─────────────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Powers the "Add a Zoom meeting link" option on the Calendar → Create Event
# modal (works alongside Google Meet / Teams). Read by backend/services/zoomClient.js.
# Create a "Server-to-Server OAuth" app at https://marketplace.zoom.us, grant the
# `meeting:write:admin` scope, then copy the three values from its App Credentials
# tab. When ANY of these is blank, the Zoom option is a no-op (no link attached) —
# the rest of event creation is unaffected.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Google Gemini (AI — OPTIONAL) ────────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/lib/leadJunkFilter.js (AI fallback for borderline junk
# scores) + routes/voice_transcription.js (audio → text).

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_AUDIO_MODEL=gemini-2.0-flash

# Set to "1" to enable the optional Gemini fallback inside the junk-lead
# classifier (off by default — pure rules-only).
LEAD_JUNK_AI=0

# ═══════════════════════════════════════════════════════════════════════════════
# ─── OpenAI (voice transcription fallback — OPTIONAL) ────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: routes/voice_transcription.js as a Whisper fallback when Gemini
# audio transcription fails or is unavailable.

OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Cloudflare Turnstile (CAPTCHA — OPTIONAL) ───────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: routes/landing_pages.js public form submissions. Optional — when
# unset, the route skips CAPTCHA verification (acceptable for dev/staging,
# NOT for production landing pages exposed to the open web).

TURNSTILE_SECRET_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Web Push / VAPID (OPTIONAL) ──────────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/services/pushService.js. Generate the keypair once with
# `npx web-push generate-vapid-keys` and keep them stable forever — rotating
# invalidates every existing browser subscription.

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Sentry (error tracking — OPTIONAL) ───────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/lib/sentry.js. Initialised at server boot if DSN is set.

SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Wellness vertical (OPTIONAL — needed only if Tenant.vertical=wellness) ───
# ═══════════════════════════════════════════════════════════════════════════════

# AES-256-GCM key (32 bytes / 64 hex chars) for encrypting patient PII fields
# at rest. Used by backend/lib/fieldEncryption.js. Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠ Rotating this key without a re-encryption migration makes existing rows
# unreadable. Store the historic keys forever.
WELLNESS_FIELD_KEY=

# Default SLA window (in minutes) for telecaller queue routing. Used by
# backend/cron/orchestratorEngine.js. Defaults to 30.
WELLNESS_LEAD_SLA_MINUTES=30

# ──────────────────────────────────────────────────────────────────
# DigiLocker / APISetu — Travel Aadhaar verification
# ──────────────────────────────────────────────────────────────────
# Used by backend/services/digilockerClient.js. You only need TWO values
# for the modern (APISetu-partner) path: the partner API key + client id.
# When BOTH are set the client makes real APISetu DigiLocker calls; if
# either is blank the client falls back to STUB mode (returns synthetic
# Aadhaar last-4 "9999"). Stub mode is fine for dev + demo; real values
# are needed in production.
#
# Provisioning steps (from your APISetu partner dashboard — the
# partners.apisetu.gov.in/home<partner-id> URL is the dashboard, NOT a key):
#   1. Sign in at https://partners.apisetu.gov.in/
#   2. My Apps → create a new app or open an existing one
#   3. Copy the partner API key + client id into the two vars below
#   4. Register the redirect URIs below in the app, byte-for-byte
#
# Three consumers, all sharing this client:
#   - Customer-portal KYC (logged-in customer)  → routes/portal.js
#   - Trip-participant KYC (staff/admin side)    → routes/travel_trips.js
#   - Public microsite KYC (parent, no login)    → routes/travel_microsites.js
#
# After setting these, restart the backend; GET /api/portal/kyc/status
# reports mode "apisetu-partner" instead of "stub".
APISETU_PARTNER_API_KEY=
APISETU_CLIENT_ID=

# Redirect URI for the logged-in CUSTOMER-PORTAL flow. Register this exact
# value in the APISetu app. For production use your live domain, e.g.
# https://globuscrm.globussoft.com/travel/portal/kyc/callback
DIGILOCKER_REDIRECT_URI=http://localhost:5173/travel/portal/kyc/callback

# Redirect URI for the PUBLIC MICROSITE parent flow. A DIFFERENT path from
# the portal one (a static page that reads ?state&code). Register this too.
# Production: https://globuscrm.globussoft.com/travel/kyc/callback
DIGILOCKER_MICROSITE_REDIRECT_URI=http://localhost:5173/travel/kyc/callback

# Legacy DigiLocker OAuth2 — only set these if you DON'T have an
# APISetu partner key (older partner integrations). With a partner key you
# can leave BOTH blank. The client picks OAuth2 mode automatically only if
# APISETU_PARTNER_API_KEY is blank AND these two are set.
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────
# OpenTripMap — POI catalog seeder for Travel itinerary tooling
# ──────────────────────────────────────────────────────────────────
# Used by backend/scripts/seedOpenTripMapPois.js to seed the TravelPoi
# catalog with real points-of-interest (~500 POIs across ~10 destinations
# in LIVE mode). Self-serve signup at opentripmap.io takes ~5 minutes;
# free tier allows 1000 requests/day which is plenty for periodic re-seeds.
#
# Leave as __PLACEHOLDER__ to keep the seeder in FIXTURE mode — reads
# backend/test/fixtures/opentripmap-sample-response.json (20 sample POIs
# across 10 destinations). Fixture mode is the default for `prisma db seed`
# runs in dev + CI; LIVE mode is opt-in by setting a real key.
#
# Cred chase: tracked in docs/CREDS_TRACKER.md (Q-IT-3, Yasin self-serve).
OPENTRIPMAP_API_KEY=__PLACEHOLDER__

# Demo-only OTP bypass for the patient-portal login flow. Set to a 6-digit
# string (e.g. "123456") to short-circuit phone verification for the phones
# listed in WELLNESS_DEMO_OTP_PHONES. Used by routes/wellness.js. MUST stay
# unset in production unless WELLNESS_DEMO_OTP_ALLOW_PROD=1 is ALSO set
# (explicit opt-in). The deploy.yml api_tests gate sets this in CI so the
# wellness-portal-dsar spec can verify-OTP without a real phone provider.
WELLNESS_DEMO_OTP=
WELLNESS_DEMO_OTP_ALLOW_PROD=0
WELLNESS_DEMO_OTP_PHONES="9876500001"

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Backup engine (OPTIONAL — overrides for cron/backupEngine.js) ────────────
# ═══════════════════════════════════════════════════════════════════════════════

# Absolute path where nightly mysqldumps land. Defaults to ./backups.
BACKUP_DIR=

# Days to retain dump files before the engine prunes them. Default 30.
BACKUP_RETENTION_DAYS=30

# Override the mysqldump binary path. Useful when the system mysqldump is
# version-skewed against the server (e.g. mysql client 5.7 vs server 8.0).
MYSQLDUMP_BIN=

# If the MySQL server runs in a docker container, name the container here
# and the engine will `docker exec` into it to run mysqldump.
MYSQLDUMP_DOCKER_CONTAINER=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Demo / staging cron hygiene (OPTIONAL) ──────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/cron/demoHygieneEngine.js. The engine purges test-pattern
# rows (E2E_*, _teardown_*, IsoTest *) off the demo box on a schedule.

DEMO_HYGIENE_AGE_HOURS=24
DEMO_HYGIENE_DISABLED=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Free-trial signup window (OPTIONAL) ──────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: routes/auth.js signup handler. Default 15 days.

FREE_TRIAL_DAYS=15

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Callified.ai / AdsGPT / GlobusPhone sandbox (OPTIONAL, dev-only) ────────
# ═══════════════════════════════════════════════════════════════════════════════
# Used by: backend/scripts/sandbox/*-mock.js (local sister-product simulators)
# + routes/integrations.js (Callified SSO). Production deploys do NOT set
# these — they exist for local end-to-end testing of the External Partner API.

CALLIFIED_MOCK_PORT=5101
CALLIFIED_SSO_SECRET=
CALLIFIED_DASHBOARD_URL="https://app.callified.ai"

ADSGPT_MOCK_PORT=5102
ADSGPT_SANDBOX_SECRET=sandbox_secret

GLOBUSPHONE_MOCK_PORT=5103

# Base URL of the CRM as the sandbox mock servers see it (defaults to
# http://localhost:5000). Used by sandbox/callified-mock.js +
# sandbox/globusphone-mock.js to call BACK into the CRM.
CRM_BASE_URL=http://localhost:5000

# API key the sandbox mocks present to the CRM's /api/v1/external/* surface.
# Defaults to glbs_sandbox_<product>; only override if you've reseeded the
# Enhanced Wellness tenant with custom ApiKey rows.
CRM_SANDBOX_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Outbound webhook HMAC signing — LEGACY GLOBAL FALLBACK ──────────────────
# ═══════════════════════════════════════════════════════════════════════════════
# DEPRECATED as the primary mechanism. Signing is now PER-TENANT: each CRM admin
# generates their own secret from the dashboard (Settings → Webhook Signing
# Credential), stored as a WebhookCredential row (encrypted at rest). Delivery is
# also gated on an active subscription/trial — see lib/webhookEntitlement.js.
#
# This env var is now only a FALLBACK used by lib/webhookEntitlement.js's
# resolveTenantWebhookSecret() when a tenant has NO active WebhookCredential —
# it keeps the single pre-migration GlobusPhone integration working until that
# tenant generates its own credential. Once every tenant has a credential, this
# can be removed. The signing wire format is unchanged:
#   X-Globussoft-Signature: t=<unix_epoch_sec>,v1=<hmac_sha256_hex>  over "<t>.<rawBody>"
# Receivers (e.g. GlobusPhone) still configure the secret as WEBHOOK_HMAC_SECRET_CRM.
# Generate a fresh 64-hex value with: openssl rand -hex 32
WEBHOOK_HMAC_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# ─── Test / CI / local-stack flags (OPTIONAL — NOT for production envs) ──────
# ═══════════════════════════════════════════════════════════════════════════════

# Set to "1" to skip cron-engine initialisation at server boot. Used by the
# api_tests gate (deploy.yml) + local 4/4 mirror to keep test data clean.
# DO NOT set in production — cron engines won't run.
DISABLE_CRONS=

# S117 (FR-3.7) — CSP enforce-mode flip. Default keeps the strict CSP in
# Content-Security-Policy-Report-Only mode (browser logs violations but does
# NOT block). Set to 1 to flip to Content-Security-Policy (browser BLOCKS
# violators — full XSS-via-inline defense lights up). Read at request time
# by backend/middleware/security.js → helmetStrictReportOnlyMiddleware, so
# changing the value + restarting the backend is the only operational step.
# DEPLOYMENT GATE: only flip to 1 AFTER 24h of clean Report-Only violation
# logs (POST /api/csp/report → AuditLog entity='CSPViolation'). Premature
# flip will block any inline <script>/<style> the SPA hasn't yet migrated
# to nonce-tagged form. Default 0 is safe.
CSP_ENFORCE=0

# Set to "1" or "true" to expose the SLA breach-test helper endpoints. Used
# by sla-api gate spec. Off in production.
SLA_TEST_HELPERS=

# Used by backend/scripts/check-migration-safety.js (lint hook). Lets CI
# override the commit message the check inspects. Set automatically by the
# pre-push hook; leave unset locally.
MIGRATION_SAFETY_COMMIT_MSG=

# Used by backend/scripts/check-audit.js (npm-audit gate). Comma-separated
# list of severities that fail the build. Defaults to "critical,high".
AUDIT_FAIL_LEVELS=

# Used by maintenance scripts (cleanup-orchestrator-dupes.js,
# find-phone-collisions.js, merge-duplicate-patients.js) to target one
# tenant. Pure ops-side; never read by the running server.
TENANT_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# ═══ TRAVEL CRM — CLIENT-PENDING CREDENTIALS (ask Yasin / Travel Stall) ═══════════
# ═══════════════════════════════════════════════════════════════════════════════
#
# Every key below is TRAVEL-vertical only. Leaving it BLANK keeps the matching
# integration in safe "stub mode" (synthetic data) — the app boots + runs fine
# without them and NOTHING in the wellness or generic verticals is affected.
# Each key is annotated with: the client-doc reference + what filling it unlocks.
# Plain-language client doc: docs/TRAVEL_CRM_WHAT_WE_NEED_FROM_YOU.md
# Technical reference:        docs/TRAVEL_CRM_CLIENT_REQUIREMENTS.md
#
# A blank value = stub mode. A real value = live mode. That's the only switch.

# ─── Q9 · WhatsApp Web (QR-scan) — ACTIVE TRAVEL vertical transport ───────────
# The travel vertical now sends/receives over WhatsApp Web (whatsapp-web.js +
# puppeteer) — an operator scans the QR from the chat UI (Travel → WhatsApp →
# Connect) to link the number; thereafter the 7 travel crons + chat endpoints
# dispatch on it (services/whatsappWebClient.js). NO API keys needed.
#   - Session credentials persist to backend/.wwebjs_auth/ (gitignored).
#   - WHATSAPP_WEB_DISABLED=1 hard-disables launching a browser (CI/dev).
#   - WHATSAPP_WEB_CHROME_PATH overrides the puppeteer Chromium executable
#     (set this on servers that already have a system Chromium installed).
WHATSAPP_WEB_DISABLED=
WHATSAPP_WEB_CHROME_PATH=

# Travel WhatsApp → auto-lead capture (2026-06-19). For TRAVEL tenants, inbound
# 1:1 WhatsApp chats are analyzed (LLM "whatsapp-lead-qualify" task, or a
# keyword heuristic when no LLM key) and a Travel lead is auto-created when the
# chat reads as a business enquiry. Reads lib/travelWhatsappLeadCapture.js.
#   - TRAVEL_WHATSAPP_AUTOLEADS=0 turns the feature OFF (default ON for travel).
#   - TRAVEL_WA_LEAD_MIN_MSGS = how many inbound messages before analyzing (default 3).
# Generic/wellness tenants are never affected (gated on tenant.vertical=travel).
TRAVEL_WHATSAPP_AUTOLEADS=
TRAVEL_WA_LEAD_MIN_MSGS=

# ─── Q9 · WhatsApp / Wati (TRAVEL vertical transport — LEGACY, DISABLED) ───────
# DEPRECATED: the Wati REST transport has been COMMENTED OUT in the travel
# crons/route (the require() lines are disabled; services/watiClient.js is kept
# on disk for reference). These vars no longer take effect. Left here so a
# future re-enable has the documented shape. Values came from the Wati
# dashboard → API Docs page.
# NOTE: this is the TRAVEL track only — the wellness/generic vertical keeps
# its own direct Meta Cloud API path (whatsappProvider.js + WhatsAppConfig)
# and is unaffected by these vars.
# API Endpoint shown by Wati, e.g. https://live-mt-server.wati.io/<accountId>
WATI_API_ENDPOINT=
# The long-lived Bearer access token from the Wati dashboard
WATI_ACCESS_TOKEN=
# The WhatsApp business number on the Wati account (digits with country
# code, e.g. 9198xxxxxx00). Optional on single-number accounts.
WATI_CHANNEL_NUMBER=
# Meta Cloud API alternative (3 WABAs: TMC / RFU / ops-shared):
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID_TMC=
WHATSAPP_PHONE_NUMBER_ID_RFU=
WHATSAPP_PHONE_NUMBER_ID_OPS=
WHATSAPP_WABA_ID_TMC=
WHATSAPP_WABA_ID_RFU=
WHATSAPP_WABA_ID_OPS=

# ─── Q11 · LLM provider keys ──────────────────────────────────────────────────
# Unlocks REAL output (vs [STUB-*] text) for: talking-points, form-vs-call,
# itinerary draft + the new itinerary-suggest, TMC report narrative.
# GEMINI_API_KEY + OPENAI_API_KEY already defined above. Add the other two:
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
# Real provider model IDs per routing label (lib/llmRouter.js). OPTIONAL —
# sensible defaults are built in; override only when a provider renames a model
# (a rename becomes a config change, never a code change). When the matching key
# above is set AND NODE_ENV is not "test", the router calls the REAL provider
# automatically — no code change needed.
LLM_MODEL_CLAUDE_OPUS=
LLM_MODEL_CLAUDE_HAIKU=
LLM_MODEL_GPT=
LLM_MODEL_GEMINI=
LLM_MODEL_PERPLEXITY=

# ─── TBO · flight + hotel SEARCH (quote/proposal builder) ────────────────────
# Unlocks LIVE flight + hotel search in the Flight quick-quote (and the upcoming
# proposal builder) via services/tboClient.js. DATA ONLY — search, not booking.
#
# Provider precedence (no code change to switch — keys are the only dependency):
#   1. TBO        → set the four TBO_* vars below (the real inventory).
#   2. AI web     → else, if a web-grounded LLM key is set (PERPLEXITY_API_KEY
#                   preferred, GEMINI_API_KEY fallback — both defined above) the
#                   builder fetches live-ish options as JSON. Backup until TBO.
#   3. Sample     → else canned sample data so the UI works with no keys.
#
# TBO credentials (from your TBO / TravelBoutiqueOnline account):
TBO_USERNAME=
TBO_PASSWORD=
# TBO Air + Hotel + Transfer search endpoint URLs (from TBO API docs for your account/region).
TBO_FLIGHT_SEARCH_URL=
TBO_HOTEL_SEARCH_URL=
TBO_TRANSFER_SEARCH_URL=
# Optional — outbound search timeout in ms (default 12000).
TBO_TIMEOUT_MS=

# ─── Q19 · RateHawk (hotel wholesaler) ───────────────────────────────────────
# Unlocks: live lowest-rate hotel results in the RFU/holiday quote engine.
RATEHAWK_API_KEY=
RATEHAWK_API_ID=
RATEHAWK_BASE_URL=https://api.worldota.net/api/b2b/v3

# ─── Q1 · Callified.ai (AI qualification calling) ────────────────────────────
# Unlocks: real auto-calls + transcript/summary. Sandbox keys above are dev-only.
CALLIFIED_API_KEY=
CALLIFIED_API_BASE_URL=https://api.callified.ai
CALLIFIED_WEBHOOK_SECRET=
CALLIFIED_TENANT_TOKEN=

# ─── Q1 · AdsGPT (marketing reports) ─────────────────────────────────────────
# Unlocks: real ad spend / leads / CPL on the marketing dashboard.
ADSGPT_API_KEY=
ADSGPT_ACCOUNT_ID=
ADSGPT_API_BASE_URL=https://api.adsgpt.io
# Per-platform ad-account IDs (comma-separated or per-platform):
ADSGPT_META_ACCOUNT_ID=
ADSGPT_GOOGLE_ACCOUNT_ID=
ADSGPT_LINKEDIN_ACCOUNT_ID=
ADSGPT_YOUTUBE_ACCOUNT_ID=

# ─── Q3 · DigiLocker (Aadhaar) — CLIENT_ID/SECRET already defined above ──────
# (see DIGILOCKER_CLIENT_ID / DIGILOCKER_CLIENT_SECRET). Filling them swaps the
# Aadhaar verification flow from stub to real.

# ─── Passport OCR (vendor pick PC-1) ─────────────────────────────────────────
# Unlocks: real passport field extraction. Choose google OR azure.
PASSPORT_OCR_PROVIDER=stub
GOOGLE_DOCUMENT_AI_KEY=
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
AZURE_FORM_RECOGNIZER_KEY=
AZURE_FORM_RECOGNIZER_ENDPOINT=

# ─── Booking.com direct (Phase 1.5) ──────────────────────────────────────────
# Unlocks: extra hotel inventory alongside RateHawk. 2-4 wk vendor onboarding.
BOOKING_AFFILIATE_ID=
BOOKING_API_KEY=
BOOKING_API_SECRET=

# ─── RFU ground services (Q-RFUG-1 / Q-RFUG-7) ───────────────────────────────
# Unlocks: real Saudi cab (Zikr) + high-speed-train (Haramain) prices/booking.
ZIKR_CABS_API_KEY=
ZIKR_CABS_API_SECRET=
ZIKR_CABS_WEBHOOK_SECRET=
ZIKR_CABS_BASE_URL=
HARAMAIN_RAIL_API_KEY=
HARAMAIN_RAIL_BASE_URL=

# ─── Q8 · Excel Software for Travel (accounting bridge) ──────────────────────
# Unlocks: auto-push invoices into the client's accountant system.
# Mode: "api" | "csv" | "stub" (default stub until vendor docs land).
EXCEL_SOFTWARE_MODE=stub
EXCEL_SOFTWARE_API_KEY=
EXCEL_SOFTWARE_BASE_URL=

# ─── Short-URL provider for SMS flyer attachments (S87) ──────────────────────
# Selects the backing provider for backend/services/shortUrl.js — the helper
# that turns a rendered flyer buffer into a short URL the sequenceEngine SMS
# branch appends to the message body.
#   stub        — deterministic content-addressed URL (no network I/O). Safe
#                 for dev + demo + CI. Default when unset / blank.
#   bitly       — NOT YET IMPLEMENTED — pending product call.
#   cloudflare  — NOT YET IMPLEMENTED — pending product call.
#   internal    — NOT YET IMPLEMENTED — pending product call.
# Setting to any non-stub value before the provider lands will fail-loud at
# call time; the SMS branch catches the throw fail-soft (SMS still sends, no
# link). Cred chase: docs/CREDS_TRACKER.md (Q-marker pending).
SHORT_URL_PROVIDER=stub

# ─── Marketing Flyer Studio — asset storage (DD-5.2) ─────────────────────────
# Flyer image uploads (POST /api/travel/flyer-templates/upload). When
# AWS_S3_BUCKET_NAME is set, services/s3Service uploads to S3 (public-read —
# appropriate for shareable marketing flyers); otherwise the endpoint writes to
# local disk under backend/uploads/flyer-assets/ (works with zero config). These
# are the exact names s3Service.js reads.
AWS_S3_BUCKET_NAME=
AWS_S3_URL=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AI image generation for flyers (DD-5.3): "stub" | "openai" (DALL·E, reuses
# OPENAI_API_KEY) | "stability". Not yet wired — a later slice.
AI_IMAGE_PROVIDER=stub
STABILITY_API_KEY=

# ─── Itinerary visual editor map (optional — Leaflet/OSM is free default) ────
# Only needed if you want premium Mapbox tiles or auto POI seeding.
MAPBOX_TOKEN=
OPENTRIPMAP_API_KEY=

# ─── Airline web check-in automation (P1B) — feature flag ────────────────────
# Leave OFF until DC-1 (Playwright vs MCP) + DC-5 (airline ToS counsel review)
# are decided. When "1", the (stubbed) per-airline adapters become callable.
AIRLINE_AUTOMATION_ENABLED=

# ─── TMC booking CTA (T18 · Google Workspace) ────────────────────────────────
# Unlocks: real Google Meet slot-picker on the readiness report. Falls back to
# VITE_TMC_BOOKING_URL (a static link) when blank.
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_CALENDAR_IDS=

# Same shape as TENANT_ID but slug-based. Used by
# backend/scripts/seed-fast2sms-config.js to find the tenant by slug.
TENANT_SLUG=

# ──────────────────────────────────────────────────────────────────
# Staff Attendance — shift policy (backend/routes/attendance.js)
# ──────────────────────────────────────────────────────────────────
# Drives the Early / On-Time / Late Arrival + Departure KPIs returned
# by /api/attendance/summary. All times are UTC (Attendance.date is
# anchored to 00:00 UTC of the calendar day). The same tolerance
# applies to BOTH the arrival and departure windows:
#   - Arrival before  (start - tolerance) → EARLY
#   - Arrival within  ±tolerance of start → ON_TIME
#   - Departure before (end - tolerance)  → EARLY_DEPARTURE
#   - Departure within ±tolerance of end  → ON_TIME_DEPARTURE
#   - Departure after  (end + tolerance)  → LATE_DEPARTURE
ATTENDANCE_SHIFT_START_HOUR=9
ATTENDANCE_SHIFT_START_MINUTE=0
ATTENDANCE_SHIFT_END_HOUR=18
ATTENDANCE_SHIFT_END_MINUTE=0
ATTENDANCE_ON_TIME_TOLERANCE_MIN=15

# ═══════════════════════════════════════════════════════════════════════════════
# End of file. If you added a new env-var to backend code, append it here in
# the appropriate section + write a one-line comment explaining where it's
# read. The 2026-05-17 audit grep is the authoritative reference:
#   grep -rEho "process\.env\.[A-Z_][A-Z0-9_]+" backend/ --include="*.js" \
#     --exclude-dir=node_modules | sort -u
