{
  "name": "globussoft-crm-backend",
  "version": "3.7.8",
  "description": "Backend API for Globussoft CRM",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "coverage:start": "DISABLE_CRONS=1 PORT=5098 c8 node server.js",
    "coverage:report": "c8 report",
    "coverage:check": "c8 check-coverage --lines 50 --functions 40 --branches 50 --statements 50",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint lib middleware services utils test --max-warnings 0",
    "audit:check": "node scripts/check-audit.js",
    "audit:verify": "node scripts/verify-audit-chain.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.4.1",
    "@sentry/node": "^10.48.0",
    "@twilio/voice-sdk": "^2.18.1",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "form-data": "^4.0.5",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "imap": "^0.8.19",
    "jsonwebtoken": "^9.0.3",
    "mailgun.js": "^13.0.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "sanitize-html": "^2.17.3",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^22.0.2",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^4.1.5",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "msw": "^2.14.2",
    "nodemon": "^3.0.1",
    "prisma": "^6.4.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
