  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// KB article slug uniqueness is tenant-scoped; "/getting-started" is a perfectly valid slug for tenant A's article AND tenant B's article. Slugs feed public KB URLs (/portal/kb/<slug>) so collisions only matter within one tenant's portal.
  @@unique([slug, tenantId])
}

