  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ── Meeting Scheduler ────────────────────────────────────────────

model BookingPage {
  id                 Int      @id @default(autoincrement())
  slug               String
  title              String
  description        String?
  ownerId            Int
  durationMins       Int      @default(30)
  bufferMins         Int      @default(0)
  availability       String   @db.Text // JSON: weekly schedule
  isActive           Boolean  @default(true)
  // Wave 7D — PRD Gap §6 item 8 — Mini Website rich content editor.
  // logoUrl + heroImageUrl point at uploaded files under /uploads/booking-pages/.
  // featuredServiceIds is a JSON-string column (back-compat, no native JSON
  // required) with the ordered list of Service ids to feature on the public
  // booking page. hoursJson is a JSON-string of weekday → "HH:MM-HH:MM" rows
  // so the public page can show "Mon-Sat 9:00-19:00" alongside the contact
  // block. All optional — pre-Wave-7D rows have null for every new field.
  logoUrl            String?  @db.Text
  heroImageUrl       String?  @db.Text
  heroHeadline       String?
  heroSubheadline    String?  @db.Text
  featuredServiceIds String?  @db.Text
  contactPhone       String?
  contactEmail       String?
  hoursJson          String?  @db.Text
  tenantId           Int      @default(1)
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Booking {
  id                   Int                   @id @default(autoincrement())
  bookingPageId        Int
  contactName          String
  contactEmail         String
  contactPhone         String?
  scheduledAt          DateTime
  durationMins         Int
  meetingUrl           String?
  notes                String?
  status               String                @default("CONFIRMED") // CONFIRMED, CANCELED, COMPLETED
  contactId            Int?
  // Travel vertical — Day 2 schema migration. Optional links to the
  // travel-side trip + itinerary so a Booking can be the operational
  // anchor for a TMC school trip or a Travel Stall family holiday.
  // Nullable: non-travel bookings (calendar bookings, wellness visits
  // routed through BookingPage) ignore both. Soft FK — no @relation
  // block to keep the additive migration purely additive.
  tripId               Int?
  itineraryId          Int?
  tenantId             Int                   @default(1)
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now())
  travelPurchaseOrders TravelPurchaseOrder[]

  @@index([tenantId, scheduledAt])
}

// ── Email Scheduling + Signatures ────────────────────────────────

model ScheduledEmail {
  id           Int       @id @default(autoincrement())
  to           String
  subject      String
  body         String    @db.Text
  scheduledFor DateTime
  status       String    @default("PENDING") // PENDING, SENT, FAILED, CANCELED
  sentAt       DateTime?
  // #524 follow-up: was String? (VARCHAR(191) default) → P2000 on SendGrid
  // rejection bodies which routinely exceed 191 chars. Widened to @db.Text
  // (~64KB) so the FAILED-path can persist the upstream provider's full
  // error response. The SSH probe on 2026-05-06 evening confirmed the slice
  // at routes/email_scheduling.js:298 was hitting P2000 (column too long)
  // BEFORE reaching the SENDGRID_REJECTED response code path.
  errorMessage String?   @db.Text
  contactId    Int?
  userId       Int?
  tenantId     Int       @default(1)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([tenantId, status, scheduledFor])
  @@index([tenantId])
}

// ── Custom Dashboards ────────────────────────────────────────────

model Dashboard {
  id        Int      @id @default(autoincrement())
  name      String
  isDefault Boolean  @default(false)
  layout    String   @db.LongText // JSON: array of widgets {type, x, y, w, h, config}
  userId    Int?
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

