  contactId     Int?
  contact       Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userId        Int?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaignId    Int?
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

model SmsTemplate {
  id            Int      @id @default(autoincrement())
  name          String
  body          String   @db.Text
  category      String   @default("Promotional") // Promotional, Transactional, OTP
  dltTemplateId String?
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId      Int      @default(1)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SmsConfig {
  id          Int      @id @default(autoincrement())
  provider    String   // "msg91", "twilio"
  apiKey      String?
  authToken   String?
  senderId    String?
  dltEntityId String?
  isActive    Boolean  @default(false)
  settings    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
}

// ── WhatsApp ──────────────────────────────────────────────────────

model WhatsAppMessage {
  id              Int      @id @default(autoincrement())
  to              String
  from            String?
  body            String?  @db.Text
  mediaUrl        String?
  mediaType       String?
  direction       String   @default("OUTBOUND")
  status          String   @default("QUEUED") // QUEUED, SENT, DELIVERED, READ, FAILED
