  updatedAt       DateTime @updatedAt
}

// ── Marketing Attribution ────────────────────────────────────────

model Touchpoint {
  id         Int      @id @default(autoincrement())
  contactId  Int
  channel    String // "email", "social", "search", "direct", etc.
  campaignId Int?
  source     String?
  medium     String?
  url        String?
  timestamp  DateTime @default(now())
  tenantId   Int      @default(1)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // #571 follow-up: lead scoring engine includes contact.touchpoints in
  // its scoring fan-out; the back-relation must be declared explicitly or
  // Prisma rejects the `include: { touchpoints: ... }` validator.
