  id          Int      @id @default(autoincrement())
  externalId  String // provider's event ID
  provider    String
  title       String
  description String?  @db.Text
  startTime   DateTime
  endTime     DateTime
  location    String?
  attendees   String?  @db.Text // JSON
  meetingUrl  String?
  userId      Int
  contactId   Int?
  dealId      Int?
  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Dedup key for inbound calendar sync. Originally `@@unique([provider, externalId])` on the load-bearing assumption that Google/Microsoft event IDs are globally unique by construction — but that put CalendarEvent as the ONLY tenant-scoped model in the codebase whose unique key didn't include tenantId, and a hostile or buggy provider that re-used an externalId across tenants would silently collide. Adding tenantId as the first key field is strictly more permissive than the old constraint (every prior unique pair is still unique under the new one) so no migration risk. Provider-globally-unique IDs still work; tenant-local provider IDs no longer collide. (#424, wave 17.)
  @@unique([tenantId, provider, externalId])
}

