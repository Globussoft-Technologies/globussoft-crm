// ─────────────────────────────────────────────────────────────────────────────
// Schema invariants — read before adding/editing models.
//
// 1. Multi-tenancy gate. Every model that holds tenant-owned data MUST have
//    `tenantId Int @default(1)` and `tenant Tenant @relation(fields: [tenantId],
//    references: [id], onDelete: Cascade)`. The vitest schema-invariants test
//    enforces the column; the formal `@relation` is a separate cleanup tracked
//    under #413 (49 legacy models without `@relation` — being closed in batches
//    of ~10 by criticality, financial / PHI first). Globally-shared models
//    (Tenant itself, IndustryTemplate, junction tables that derive scope from
//    a parent) are listed in NON_TENANT_MODELS in the test.
//
// 2. Uniqueness gate. `@@unique([...])` constraints on tenant-scoped models
//    MUST include tenantId as one of the keyed fields, otherwise a single row
//    can collide across tenants. The CalendarEvent fix (#424, wave 17) was the
//    last known violator — kept the historical regression in mind when adding
//    new uniqueness constraints.
//
// 3. Soft-delete gate. Any `deletedAt` column MUST be `DateTime?` (nullable) —
//    the codebase's filter pattern is `{ deletedAt: null }` for live rows.
//
// 4. Relation criticality batching for #413. Batches add `tenant` @relation in
//    PHI/financial-first order so future reads (and onDelete: Cascade) work
//    correctly even before the umbrella issue closes. Wave 17 batch 1: Payment,
//    AccountingSync, Forecast, Quota, Currency, DealInsight, PatientOtp,
//    ConsentRecord, DataExportRequest, SignatureRequest. Remaining 39 models
//    in subsequent batches. See `backend/test/schema/schema-invariants.test.js`.
//
// 5. onDelete risk policy (#413 close). All 107 tenant-scoped models declare
//    `tenant Tenant @relation(... onDelete: ...)`. The default is `Cascade`
//    (deleting a Tenant cascade-deletes its rows). The HIGH-VALUE tables
//    listed below override that with `Restrict` so a misclick on
//    `tenant.delete()` is REJECTED if any row exists — the operator must
//    explicitly drain the high-value table before the tenant can be deleted.
//    This prevents irrecoverable loss of compliance / financial / PHI data:
//      Invoice       — financial record-of-record
//      Payment       — gateway charges + refunds
//      AuditLog      — GDPR + security forensics
//      Patient       — PHI (the parent of Visit/Prescription/Consent cascades)
//      Visit         — PHI clinical encounter
//      Prescription  — controlled-substance regulatory record
//    Adding another high-value model to this set: flip its `tenant @relation`
//    to `onDelete: Restrict`, add a docstring on the model citing #413, and
//    extend this list. The default Cascade rule continues to apply to all
//    other tenant-scoped models — ordinary CRM data is safe to bulk-delete
//    when a tenant offboards.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 Int       @id @default(autoincrement())
  name               String
  slug               String    @unique
  plan               String    @default("starter") // starter, professional, enterprise
  vertical           String    @default("generic") // generic, wellness (more verticals later)
  emailVerifiedAt    DateTime? // set when the org owner verified their email via OTP at signup (null for pre-feature tenants)
  // Geographic + monetary defaults — used to default currency on Deal/Payment
  // and to drive money formatting in the UI. ISO-3166-1-alpha-2 + ISO-4217.
  country            String    @default("US")
  defaultCurrency    String    @default("USD")
  locale             String    @default("en-US") // BCP-47 for date/number formatting
  // #902 slice 3 — Operator's GST-registration state for place-of-supply
  // decisions in the travel-vertical GST module. ISO 3166-2 like "IN-MH".
  // Nullable; backend/lib/gstStateCodeResolver.js falls back to "IN-MH"
  // (legacy default) when null. Set per-tenant during onboarding.
  gstStateCode       String?
  // Agent C: white-label branding
  logoUrl            String? // path to uploaded logo, e.g. /uploads/branding/tenant-2/logo.png
  brandColor         String? // hex like #265855, overrides theme accent when set
  // #611: when true, OUTBOUND EmailMessage rows are persisted on send
  // (industry default — Sent folder, threading, audit trail). Admins
  // may opt out for storage / compliance reasons; existing tenants
  // pre-flag default to true at first read of the column.
  emailRetention     Boolean   @default(true)
  isActive           Boolean   @default(true)
  ownerEmail         String?
  adsgptLogin        String? // AdsGPT aMember username or email for SSO
  // #921 slice S39 — per-tenant iframe-embed allowlist (FR-3.6). JSON array of
  // allowed-origin strings, e.g. ["https://partner-a.com","https://partner-b.com"].
  // Consumed by readTenantEmbedAllowlist() in backend/middleware/security.js to
  // splice frame-ancestors via allowIframeEmbedding(). Null = no per-tenant
  // override (fall back to wildcard or route-level allowList).
  embedAllowlistJson String?   @db.Text
  // W4.C G098 — Tenant-wide default sub-brand fallback (FR-3.4.f). When a
  // travel-vertical tenant has multiple sub-brands but a consumer surface
  // (PDF / email / portal / microsite) lands without a sub-brand context,
  // resolvers fall back here BEFORE the tenant-wide (subBrand=null) BrandKit.
  // Null = no fallback configured; resolver behaviour unchanged (subBrand=null
  // bucket wins). Validated against VALID_SUB_BRANDS at write time.
  defaultSubBrand    String?   @db.VarChar(50)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  users                 User[]
  contacts              Contact[]
  activities            Activity[]
  deals                 Deal[]
  tickets               Ticket[]
  campaigns             Campaign[]
  automationRules       AutomationRule[]
  emailMessages         EmailMessage[]
  callLogs              CallLog[]
  attachments           Attachment[]
  apiKeys               ApiKey[]
  webhooks              Webhook[]
  webhookCredential     WebhookCredential?
  patientNotifications  PatientNotification[]
  invoices              Invoice[]
  integrations          Integration[]
  customEntities        CustomEntity[]
  customRecords         CustomRecord[]
  sequences             Sequence[]
  sequenceEnrollments   SequenceEnrollment[]
  products              Product[]
  quotes                Quote[]
  tasks                 Task[]
  expenses              Expense[]
  contracts             Contract[]
  estimates             Estimate[]
  projects              Project[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  llmCalls              LlmCallLog[]
  pipelineStages        PipelineStage[]
  emailTemplates        EmailTemplate[]
  reportSchedules       ReportSchedule[]
  marketplaceLeads      MarketplaceLead[]
  marketplaceConfigs    MarketplaceConfig[]
  smsMessages           SmsMessage[]
  smsTemplates          SmsTemplate[]
  smsConfigs            SmsConfig[]
  whatsappMessages      WhatsAppMessage[]
  whatsappTemplates     WhatsAppTemplate[]
  whatsappConfigs       WhatsAppConfig[]
  whatsappThreads       WhatsAppThread[]
  whatsappOptOuts       WhatsAppOptOut[]
  telephonyConfigs      TelephonyConfig[]
  paymentGatewayConfigs PaymentGatewayConfig[]
  pushSubscriptions     PushSubscription[]
  pushNotifications     PushNotification[]
  pushTemplates         PushTemplate[]
  landingPages          LandingPage[]
  landingPageAnalytics  LandingPageAnalytics[]
  landingPageVersions   LandingPageVersion[]
  contactAttachments    ContactAttachment[]
  emailTrackings        EmailTracking[]

  // Wellness vertical
  patients             Patient[]
  services             Service[]
  visits               Visit[]
  prescriptions        Prescription[]
  consentForms         ConsentForm[]
  consentTemplates     ConsentTemplate[]
  treatmentPlans       TreatmentPlan[]
  serviceConsumptions  ServiceConsumption[]
  agentRecommendations AgentRecommendation[]
  locations            Location[]
  // Agent B: waitlist
  waitlists            Waitlist[]
  // Agent D: loyalty + referrals
  loyaltyTransactions  LoyaltyTransaction[]
  referrals            Referral[]
  // #614: per-tenant earn/burn rule config (one-to-one)
  loyaltyConfig        LoyaltyConfig?

  // Travel vertical — Day 2 schema migration. Back-relations only (FK
  // cascade behavior lives on each child via @relation onDelete).
  travelDiagnostics                   TravelDiagnostic[]
  travelDiagQuestionBanks             TravelDiagnosticQuestionBank[]
  itineraries                         Itinerary[]
  // #907 slice 4 — Itinerary template library (Pre-loaded ~50, expand over time).
  // Subsequent slices: CRUD route + admin library UI + "Create from template" hook.
  itineraryTemplates                  ItineraryTemplate[]
  travelCostMasters                   TravelCostMaster[]
  // #907 slice 1 — Sightseeing master (destination → POIs). Future slices
  // wire CRUD route + admin UI page + Cost Master "6th category" surface.
  travelSightseeing                   TravelSightseeing[]
  travelSeasonCalendars               TravelSeasonCalendar[]
  travelMarkupRules                   TravelMarkupRule[]
  tmcTrips                            TmcTrip[]
  webCheckins                         WebCheckin[]
  travelTripReviews                   TravelTripReview[]
  travelPortalNotifications           TravelPortalNotification[]
  supplierCredentials                 SupplierCredential[]
  visaApplications                    VisaApplication[]
  // G107 — RejectionRecoveryProgram back-relation (PRD_VISA_SURE_PHASE_3 §FR-7).
  rejectionRecoveryPrograms           RejectionRecoveryProgram[]
  embassyRules                        EmbassyRule[]
  rfuLeadProfiles                     RfuLeadProfile[]
  religiousGuidancePackets            ReligiousGuidancePacket[]
  tripMicrosites                      TripMicrosite[]
  // Travel-vertical financial fork (PRD_TRAVEL_{QUOTE_BUILDER,BILLING,
  // SUPPLIER_MASTER} DD-5.1 [RESOLVED 2026-05-24]) — fork models alongside
  // the generic Quote / Invoice / Vendor. See model docs at bottom of file.
  travelQuotes                        TravelQuote[]
  travelQuoteLines                    TravelQuoteLine[]
  travelQuoteTemplates                TravelQuoteTemplate[]
  travelInvoices                      TravelInvoice[]
  travelInvoiceLines                  TravelInvoiceLine[]
  travelPaymentSchedules              TravelPaymentSchedule[]
  travelSuppliers                     TravelSupplier[]
  travelSupplierPayables              TravelSupplierPayable[]
  // PRD_TRAVEL_BILLING G022 (FR-3.5.e) — supplier-payable batch runs.
  travelSupplierPayableBatches        TravelSupplierPayableBatch[]
  // PRD_TRAVEL_SUPPLIER_MASTER G045 — supplier-side commission ledger per FY
  // (FR-3.5.a, FR-3.5.b).
  travelSupplierCommissionEntries     TravelSupplierCommissionEntry[]
  // PRD_TRAVEL_SUPPLIER_MASTER G038 + G039 — KYC + dispute log.
  travelSupplierKycs                  TravelSupplierKyc[]
  travelSupplierKycChecks             TravelSupplierKycChecklistItem[]
  travelSupplierDisputes              TravelSupplierDispute[]
  // PRD_TRAVEL_SUPPLIER_MASTER G044 (FR-3.4.a-c) — supplier-statement
  // reconciliation batches + PNR-keyed line match + tolerance auto-match.
  travelSupplierReconciliationBatches TravelSupplierReconciliationBatch[]
  travelSupplierReconciliationLines   TravelSupplierReconciliationLine[]
  // PRD_TRAVEL_SUPPLIER_MASTER G046 (FR-3.3.c) — supplier-invoice PDF
  // uploads with optional match-to-payable linkage.
  travelSupplierInvoiceUploads        TravelSupplierInvoiceUpload[]
  // S33 (#920) — PRD_TRAVEL_BILLING FR-3.7 cancellation policies.
  cancellationPolicies                CancellationPolicy[]
  // PRD_TRAVEL_B2B_AGENT_PORTAL #905 slice 2 — commission profiles
  // (additive; consumes lib/agentCommissionCalculator.js from slice 1
  // commit cb284098). Each row is one named operator-facing pricing
  // profile (flat_percent | tiered | per_pax_flat | hybrid).
  travelCommissionProfiles            TravelCommissionProfile[]
  // PRD_TRAVEL_MARKETING_FLYER #908 slice 3 — saved flyer templates
  // (additive; consumes lib/flyerTemplateValidator.js from slice 1
  // commit 28146498). Each row is one operator-composed flyer (palette
  // + layout + asset placeholders) validated before persistence.
  travelFlyerTemplates                TravelFlyerTemplate[]
  // TMC curriculum→destination mapping (PRD_TMC_CURRICULUM_MAPPING PC-1
  // RESOLVED 2026-05-24). 100-200 starter rows seeded by GS; TMC academic
  // team validates + extends over 6-week window.
  curriculumMappings                  TravelCurriculumMapping[]
  // TMC school term/holiday/exam windows for trip scheduling. Baseline seeded;
  // each school's actual dates captured by asking them (no public API exists).
  travelSchoolTerms                   TravelSchoolTerm[]
  // Per-sub-brand brand kits (PRD_TRAVEL_PER_SUBBRAND_BRANDING DD-5.2
  // [RESOLVED 2026-05-24]) — versioned brand-asset storage forked out of
  // subBrandConfigJson. See BrandKit model at bottom of file.
  brandKits                           BrandKit[]
  // Sub-brand config (Q9, Q14, Q21) — JSON keyed by sub-brand storing
  // per-brand WhatsApp number / Wati WABA id / legal entity / GSTIN /
  // Drive folder root / microsite domain. Nullable; sub-brands without
  // an entry inherit tenant-level defaults.
  subBrandConfigJson                  String?                             @db.Text
  /// Per-sub-brand default theme. Resolved at runtime by chain:
  /// user.themePreference → tenant.subBrandThemes[activeSubBrand] → 'system'.
  /// Per #876 + DD-5.3 RESOLVED 2026-05-24. JSON-string column per
  /// CLAUDE.md convention (call site stringifies; sanitizeJson preserves shape).
  /// Shape: { "tmc": "light", "rfu": "dark", "travelstall": "system", "visasure": "light" }
  subBrandThemes                      String?                             @db.Text

  // PRD_TRAVEL_MULTICHANNEL_LEADS G009 (FR-3.7.1) — per-channel enable/disable
  // toggles surfaced on /settings/lead-capture. JSON-string column per
  // CLAUDE.md convention. Shape: { "voyagr": true, "web_form": true, ... }.
  // Null = default-enabled for all known channels (ingress is opt-in via
  // platform-wide allowlist, not per-tenant). Consumed by the lead-capture
  // settings route + downstream intake handler.
  leadCaptureChannelsJson  String?              @db.Text
  /// PRD_TRAVEL_MULTICHANNEL_LEADS G009 (FR-3.7.2) — per-channel cooldown
  /// window in seconds. JSON-string column. Shape:
  /// { "voyagr": 3600, "whatsapp": 0, ... }. Null/missing-key = 0 (cooldown
  /// disabled for that channel). Range guard 0-86400 enforced in the route.
  leadCaptureCooldownsJson String?              @db.Text
  formRoutingMappings      FormRoutingMapping[]

  // Subscriptions
  subscriptions Subscription[]

  // #413 batch 1 (wave 17): financial / PHI back-relations. Required because
  // each child model now declares `tenant Tenant @relation`; Prisma rejects
  // one-sided relations.
  payments           Payment[]
  accountingSyncs    AccountingSync[]
  forecasts          Forecast[]
  quotaRows          Quota[]
  currenciesList     Currency[]
  dealInsights       DealInsight[]
  patientOtps        PatientOtp[]
  consentRecords     ConsentRecord[]
  dataExportRequests DataExportRequest[]
  signatureRequests  SignatureRequest[]

  // #413 batch 2 (wave 18): security / auth / integration back-relations.
  // RevokedToken + ScimToken + SsoConfig are the high-leverage auth ones; the
  // rest are integration / RBAC / sandbox cleanup. Same one-sided-relation
  // rule applies.
  ssoConfigs        SsoConfig[]
  retentionPolicies RetentionPolicy[]
  pipelines         Pipeline[]
  approvalRequests  ApprovalRequest[]
  bookingPages      BookingPage[]
  fieldPermissions  FieldPermission[]
  scimTokens        ScimToken[]
  playbooks         Playbook[]
  sandboxSnapshots  SandboxSnapshot[]
  revokedTokens     RevokedToken[]

  // #413 batch 3 (wave 18): calendar + scheduled-email + sales-config + KB + SLA
  // back-relations. Calendar cluster (CalendarIntegration / CalendarEvent /
  // ScheduledEmail / Booking) plus sales config (WinLossReason / LeadRoutingRule
  // / Territory) plus support (KbCategory / KbArticle / SlaPolicy).
  calendarIntegrations CalendarIntegration[]
  gmailIntegrations    GmailIntegration[]
  calendarEvents       CalendarEvent[]
  scheduledEmails      ScheduledEmail[]
  bookings             Booking[]
  winLossReasons       WinLossReason[]
  leadRoutingRules     LeadRoutingRule[]
  territories          Territory[]
  kbCategories         KbCategory[]
  kbArticles           KbArticle[]
  slaPolicies          SlaPolicy[]

  // #413 PlaybookProgress audit (wave 18): added defensively after the batch-2
  // deferral. The model's tenancy was implicit via dealId; routes already
  // passed tenantId in every where-clause. Now the schema matches the queries
  // and the @@unique includes tenantId to guard against future id-allocation
  // changes. See PlaybookProgress model docstring for the full rationale.
  playbookProgress PlaybookProgress[]

  // #413 batch 4 (wave 19): voice / chat-and-live / marketing-attribution /
  // dashboards+reports / social / scheduled / shared-inbox back-relations.
  // Closes out the remaining 18 drifters; data-leak gate already covered by
  // the tenantId column itself, this just makes Prisma aware of the FK so
  // joins/cascades work uniformly with the rest of the schema.
  voiceSessions        VoiceSession[]
  abTests              AbTest[]
  touchpoints          Touchpoint[]
  webVisitors          WebVisitor[]
  chatbots             Chatbot[]
  chatbotConversations ChatbotConversation[]
  cannedResponses      CannedResponse[]
  surveys              Survey[]
  surveyResponses      SurveyResponse[]
  // Parent-child review system — Survey owns ordered SurveyQuestion rows
  // and per-question SurveyAnswer rows. Survey itself already has its
  // back-relation above; the two child tables need their own so the
  // Prisma client validates.
  surveyQuestions      SurveyQuestion[]
  surveyAnswers        SurveyAnswer[]
  documentTemplates    DocumentTemplate[]
  dashboards           Dashboard[]
  customReports        CustomReport[]
  sharedInboxes        SharedInbox[]
  liveChatSessions     LiveChatSession[]
  liveChatMessages     LiveChatMessage[]
  documentViews        DocumentView[]
  socialPosts          SocialPost[]
  socialMentions       SocialMention[]

  // #592 — Find Duplicates dismiss persistence (DismissedDuplicateGroup model
  // at the bottom of this file). Per-tenant scoped.
  dismissedDuplicateGroups DismissedDuplicateGroup[]

  // Wave 11 Agent EE — Memberships (time-bound packages of services).
  // Per-tenant scoped; rows cascade-delete with the tenant.
  membershipPlans       MembershipPlan[]
  memberships           Membership[]
  membershipRedemptions MembershipRedemption[]

  // Wave 11 Agent HH — Inventory backbone (Google Doc audit, 8 May 2026).
  productCategories    ProductCategory[]
  vendors              Vendor[]
  inventoryReceipts    InventoryReceipt[]
  inventoryAdjustments InventoryAdjustment[]
  autoConsumptionRules AutoConsumptionRule[]

  // Wave 11 Agent FF — Composite ledger system: Wallet + WalletTransaction
  // (per-Patient append-only ledger), GiftCard (purchasable codes that
  // credit a wallet on redeem), Coupon (percent/flat discount applied at
  // checkout), CashbackRule (% of paid amount → wallet credit on visit
  // completion). Per-tenant scoped; cascade-delete on tenant removal so
  // the demo box / sandbox snapshots stay clean. See models at the bottom
  // of this file.
  wallets            Wallet[]
  walletTransactions WalletTransaction[]
  giftCards          GiftCard[]
  coupons            Coupon[]
  cashbackRules      CashbackRule[]
  // D16 Wallet Top-up (PRD_WALLET_TOPUP §3 + DD-5.2 round-2 RESOLVED 2026-05-25):
  // operator-configurable bonus rules + FIFO redemption-tracking credit
  // batches. See WalletBonusRule + WalletCreditBatch models below.
  walletBonusRules   WalletBonusRule[]
  creditBatches      WalletCreditBatch[]

  // Wave 11 Agent GG — Resource availability (Resource / Holiday /
  // WorkingHours). Cascade-delete with the tenant.
  resources    Resource[]
  holidays     Holiday[]
  workingHours WorkingHours[]

  // Wave 2 Agent JJ — Staff Attendance + Biometric stub + Leave Management.
  attendances      Attendance[]
  biometricDevices BiometricDevice[]
  leavePolicies    LeavePolicy[]
  leaveBalances    LeaveBalance[]
  leaveRequests    LeaveRequest[]

  // Wave 2 Agent II — POS / cash register / shift / sale backbone.
  registers       Register[]
  shifts          Shift[]
  sales           Sale[]
  invoiceCounters InvoiceCounter[]
  saleLineItems   SaleLineItem[]
  // #779 — petty-cash deposits/withdrawals against open shifts.
  pettyCashLedger PettyCashLedger[]

  // Wave 7 Agent A — Service Catalogue depth (PRD Gap §10):
  //   ServiceCategory — hierarchical taxonomy for Service.
  //   Drug            — drug catalogue used by prescription writing.
  serviceCategories ServiceCategory[]
  drugs             Drug[]

  // PRD Gap §1.5 / §1.6 — staff commission profiles + per-staff revenue
  // goals. Both per-tenant scoped, cascade-delete with the tenant.
  commissionProfiles CommissionProfile[]
  staffRevenueGoals  StaffRevenueGoal[]
  commissionData     CommissionData[]

  // Notification preferences (per-user opt-in/out)
  notificationPreferences NotificationPreference[]

  // RBAC — roles + permissions
  roles Role[]

  // Wave 3 — Staff availability blocks (breaks, leave, etc.)
  blockTimes BlockTime[] @relation("TenantBlockTimes")

  // Patient tag system — tenant-scoped labels assignable to many patients.
  tags Tag[]

  // WhatsApp SaaS (P1+P3 scaffolding) — back-relations for multi-tenant routing,
  // webhook idempotency, async outbound queue, and media-download pipeline.
  webhookEvents  WebhookEvent[]
  waOutboundJobs WaOutboundJob[]
  waMediaJobs    WaMediaJob[]

  // Phase 2 (PRD §4.7) — per-tenant key/value settings table. First
  // consumer is the travel advance-ratio (`travel.advanceRatio.<subBrand>`
  // override + `travel.advanceRatio.default`); future per-tenant tunables
  // can land here without adding a column to Tenant for each one.
  settings TenantSetting[]

  // PRD §4.5 + §4.7 — DigiLocker OAuth sessions for Aadhaar verification
  // (currently stub-mode pending Q3 cred drop from Travel Stall). Per-
  // tenant scoped + cascade-deletes with the tenant.
  digilockerSessions DigilockerSession[]

  // Per-tenant wellness role catalog (replaces the hard-coded
  // VALID_WELLNESS_ROLES whitelist; admins can add custom roles).
  wellnessRoleTypes WellnessRoleType[]

  // TMC Diagnostic & Sales-Routing Engine (PRD_TMC_DIAGNOSTIC_SALES_ROUTING_ENGINE
  // §3.2 + §3.8, DD-5.1 RESOLVED 2026-06-08). Distinct from TmcTrip /
  // Itinerary lifecycle — TmcTripCatalogue rows are the curated
  // active/archived catalogue the engine recommends from; EngineWeights is
  // the single tunable config row per tenant (one-to-one — singular
  // back-relation type per @@unique([tenantId]) on EngineWeights).
  tmcTripCatalogues TmcTripCatalogue[]
  engineWeights     EngineWeights?

  // PRD_TRAVEL_SECURITY_ARCHITECTURE FR-3.7 (S5) — security telemetry sink.
  // CSP violation reports + cross-tenant intercepts + future incident classes
  // all land in SecurityIncident. tenantId on the child is nullable (CSP
  // reports often arrive before auth resolves), so the back-relation only
  // ties together rows where the tenant could be attributed.
  securityIncidents    SecurityIncident[]
  travelPurchaseOrders TravelPurchaseOrder[]
}

model User {
  id              Int       @id @default(autoincrement())
  // Email is unique PER TENANT, not globally — the same person can hold a
  // separate account in multiple organisations (e.g. a customer of both a
  // travel agency and a wellness clinic). Composite uniqueness lives in
  // @@unique([email, tenantId]) at the bottom of the model. Because email is
  // no longer a standalone unique key, all lookups use findFirst (often
  // scoped by tenantId) rather than findUnique({ where: { email } }).
  email           String
  password        String
  emailVerifiedAt DateTime? // set when a self-registered user verified their email via OTP (null for staff/invited/pre-feature users)
  role            String    @default("USER") // ADMIN, USER, MANAGER
  userType        String    @default("STAFF") // STAFF | OWNER | CUSTOMER
  name            String
  createdAt       DateTime  @default(now())

  // 2FA
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  backupCodes      String? @db.Text // JSON array of hashed codes

  // Personalization
  emailSignature String? @db.Text
  language       String  @default("en")
  timezone       String  @default("UTC")
  profilePicture String? // S3 URL — uploaded via POST /api/auth/me/profile-picture; old key deleted from S3 on replace

  // SSO
  googleId    String? @unique
  microsoftId String? @unique
  ssoProvider String? // "google", "microsoft", null = local

  // Wellness sub-role (orthogonal to RBAC role)
  // Per user directive: keep staging_crm's wellness sub-role list; do NOT
  // pull main's stylist/cashier additions (wellness rebuild is being done
  // separately on staging_crm).
  wellnessRole String? // doctor, professional, telecaller, helper
  specialty    String? // e.g., Dermatology, Cardiology, General Practice (for doctors)

  // #870 — server-side theme persistence so user choice roams across browsers
  // and devices. DD-5.2 RESOLVED 2026-05-24: user preference wins; tenant
  // default applies only when this column is null. Permitted values:
  // 'light' | 'dark' | 'system'. Read/written via GET/PUT /api/user/theme.
  themePreference String? // 'light' | 'dark' | 'system' — null = use tenant default

  // Travel vertical sub-brand access (Q25 — single tenant + sub-brand
  // tagging). JSON array of sub-brand codes the user can see/act on,
  // e.g. ["tmc","rfu"] or ["travelstall","visasure"]. Empty/null = all
  // sub-brands (admin-tier). Enforced at route level via a helper that
  // reads this column + filters queries by Contact.subBrand /
  // Deal.subBrand / etc.
  subBrandAccess String? @db.Text

  // #618 — soft-deactivation. Set to now() when an admin clicks Deactivate
  // in the Staff Directory; cleared back to null on Reactivate. Reversible
  // alternative to DELETE so the row stays in the directory + audit trail.
  deactivatedAt DateTime?

  // PRD_TRAVEL_MULTICHANNEL_LEADS G008 (FR-3.3.5) — soft "step away" flag
  // that the lead-router consults before assigning an inbound lead. Defaults
  // to true so every legacy User keeps receiving assignments unchanged. The
  // user toggles their OWN availability via PUT /api/users/me/availability;
  // a manager/admin can toggle another user's via PUT /api/users/:userId/
  // availability. Distinct from deactivatedAt (HR-driven; permanent until
  // reactivated by an admin) — isAvailable is the staff member's own
  // moment-to-moment switch ("on lunch, don't route new leads to me").
  isAvailable Boolean @default(true)

  // Subscription trial + billing
  trialStartDate     DateTime?
  trialEndsAt        DateTime?
  subscriptionStatus String    @default("TRIAL") // TRIAL | ACTIVE | EXPIRED | CANCELLED

  // RBAC — multi-role via UserRole junction table
  userRoles             UserRole[]
  // RBAC Hardening Phase 4 — back-reference for permission-history
  // attribution. SetNull on delete preserves the version row even if
  // the changer's account is later removed (audit trail integrity).
  rolePermissionChanges RolePermissionVersion[]

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  deals              Deal[]              @relation("OwnerDeals")
  tickets            Ticket[]            @relation("AssignedTickets")
  apiKeys            ApiKey[]
  webhooks           Webhook[]
  webhookCredentials WebhookCredential[] @relation("UserWebhookCredentials")
  tasks              Task[]
  expenses           Expense[]
  approvedExpenses   Expense[]           @relation("ExpenseApprover")
  projects           Project[]           @relation("ProjectOwner")
  notifications      Notification[]
  auditLogs          AuditLog[]
  assignedContacts   Contact[]           @relation("AssignedContacts")
  activities         Activity[]
  callLogs           CallLog[]
  emailMessages      EmailMessage[]
  reportSchedules    ReportSchedule[]
  smsMessages        SmsMessage[]
  whatsappMessages   WhatsAppMessage[]
  whatsappThreads    WhatsAppThread[]    @relation("WhatsAppThreadAssignee")
  pushSubscriptions  PushSubscription[]
  landingPages       LandingPage[]

  // Wellness vertical
  doctorVisits        Visit[]        @relation("DoctorVisits")
  doctorPrescriptions Prescription[] @relation("DoctorPrescriptions")
  // One self-booking User → many Patient rows (one per tenant the user
  // is registered at). Enforcement that there's at most ONE Patient per
  // (tenantId, userId) lives in the @@unique constraint on the Patient
  // model. Singular `Patient?` here would force a 1-to-1 globally and
  // contradict the multi-tenant intent.
  patientProfiles     Patient[]      @relation("PatientUser")

  // Wave 11 Agent GG — per-practitioner availability.
  doctorHolidays     Holiday[]      @relation("DoctorHolidays")
  doctorWorkingHours WorkingHours[] @relation("DoctorWorkingHours")

  // Wave 2 Agent JJ — Attendance + Leave back-relations.
  attendances    Attendance[]
  leaveRequests  LeaveRequest[] @relation("LeaveRequester")
  leaveApprovals LeaveRequest[] @relation("LeaveApprover")
  leaveBalances  LeaveBalance[]

  // Wave 2 Agent II — POS cashier shifts.
  cashierShifts Shift[] @relation("CashierShifts")

  // PRD Gap §1.5 — Commission profile assignment. Optional FK; staff
  // without a profile fall back to whatever default the organisation
  // applies in payroll calculations.
  commissionProfileId Int?
  commissionProfile   CommissionProfile? @relation(fields: [commissionProfileId], references: [id], onDelete: SetNull)

  // PRD Gap §1.6 — Per-staff revenue goals (distinct from generic Quota).
  staffRevenueGoals StaffRevenueGoal[]

  // Commission data — historical payroll/commission records.
  commissionData CommissionData[] @relation("commissionData")

  // Subscriptions
  subscriptions Subscription[]

  // Notification preferences
  notificationPreference NotificationPreference?

  // Wave 3 — Staff availability blocks (breaks, leave, etc.)
  blockTimes BlockTime[] @relation("UserBlockTimes")

  // Travel vertical — Visa Sure embassy-rule authorship (PC-3 RESOLVED 2026-05-24).
  embassyRulesCreated EmbassyRule[] @relation("EmbassyRuleCreator")

  // Travel vertical — TMC curriculum-mapping advisor authorship
  // (PRD_TMC_CURRICULUM_MAPPING PC-1 RESOLVED 2026-05-24).
  curriculumMappingsCreated TravelCurriculumMapping[] @relation("CurriculumMappingCreator")

  // Email is unique within a tenant, not globally — see the comment on the
  // email field. Lets the same email register/log in across multiple orgs.
  @@unique([email, tenantId])
  @@index([tenantId, role])
}

model Contact {
  id                    Int       @id @default(autoincrement())
  name                  String
  email                 String?   // nullable (2026-06-19): WhatsApp auto-leads land WITHOUT an email — it's asked for in the chat + filled later. All other creators still set it. @@unique([email, tenantId]) tolerates multiple NULLs in MySQL.
  emailVerifiedAt       DateTime? // set when a self-registered portal customer verified their email via OTP
  phone                 String?
  company               String?
  title                 String?
  status                String    @default("Lead") // Lead, Prospect, Customer, Churned
  source                String?   @default("Organic")
  // Travel vertical sub-brand tag — nullable so generic + wellness Contacts
  // ignore it. Set to "tmc" | "rfu" | "travelstall" | "visasure" when the
  // Contact entered through a travel-vertical funnel. Drives analytics
  // (per-sub-brand lead counts) + UI badge.
  subBrand              String?
  aiScore               Int       @default(0) // 1-100 predictive close probability
  /// Last time leadScoringEngine wrote aiScore for this contact. Used as
  /// the recompute-window key so the cron only re-scores contacts whose
  /// score is older than RECOMPUTE_WINDOW_HOURS (default 24h). Without
  /// this, every tick re-scored every contact (#421 gap 2). Nullable so
  /// pre-existing rows backfill on first tick.
  aiScoreLastComputedAt DateTime?

  // Data enrichment
  industry       String?
  companySize    String?
  linkedin       String?
  website        String?
  lastEnrichedAt DateTime?

  // Marketing attribution
  firstTouchSource String?
  lastTouchSource  String?

  // Territory
  territoryId Int?

  // Customer portal
  portalPasswordHash String?
  // Travel customer-portal profile avatar (S3 URL). Nullable + additive —
  // only the travel customer portal reads/writes it; inert for every other
  // vertical (wellness never touches this column).
  avatarUrl          String?

  // #600 — wellness vertical extras. Optional + nullable so generic CRM
  // tenants ignore them entirely. Mirrors the Patient intake form (treatment
  // of interest + preferred clinic + preferred practitioner) so wellness
  // marketing attribution can tie a lead to the channel/service that
  // brought them in. preferredLocationId / preferredPractitionerId stay
  // unwired Int columns (no FK relation) to dodge cascade-delete coupling
  // — a deleted Location or User shouldn't tombstone a Lead's analytics row.
  treatmentOfInterest     String?
  preferredLocationId     Int?
  preferredPractitionerId Int?

  // PRD Gap §1.1a / §1.1c / §1.1d / §1.1e — Contact foundation extras.
  // All four fields are nullable + back-compat (existing rows ignore them):
  //   - birthDate     : DateTime? — birthday-marketing automations (greeting
  //                     cards, age-tier campaigns). Patient.dob is the
  //                     wellness analogue; this column lets generic CRM
  //                     contacts carry the same data point.
  //   - anniversary   : DateTime? — anniversary-marketing automations
  //                     (loyalty rewards, "thanks for X years" emails).
  //   - gst           : String?  — B2B GST identifier (India). Validated
  //                     server-side against the canonical 15-char format
  //                     `^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z][0-9][Z][0-9A-Z]$`
  //                     in routes/contacts.js. Stored verbatim once
  //                     validated; not a uniqueness key (a single GSTIN
  //                     can legitimately appear on multiple contact rows
  //                     for different employees of the same business).
  //   - walletBalance : Float?   — denorm of the contact's running wallet
  //                     balance. Computed-on-read approach: GET /contacts/:id
  //                     surfaces the value via a SUM(WalletTransaction)
  //                     aggregation when the contact has a linked Patient
  //                     (Patient.contactId == Contact.id) with a wallet.
  //                     Generic-only contacts stay null. The column itself
  //                     is reserved for a future write-side denorm hook —
  //                     keeping it on the schema now keeps the migration
  //                     surface stable. Wave 11 FF Wallet remains the
  //                     source of truth.
  birthDate     DateTime?
  anniversary   DateTime?
  gst           String?
  walletBalance Float?

  // #902 slice 3 — Customer's place-of-supply state for travel-vertical
  // GST decisions. ISO 3166-2 like "IN-KA". Nullable; the resolver
  // mirrors Tenant.gstStateCode (intra-state default) when null.
  stateCode String?

  // PRD_TRAVEL_GST_COMPLIANCE FR-3.5.2 (G034) — billing-address state code
  // distinct from residence-state. A traveller may live in Karnataka
  // (stateCode='IN-KA') but bill to a corporate AP desk in Maharashtra
  // ('IN-MH'); GST place-of-supply rules tax based on billing-address,
  // not residence. The resolver (lib/gstStateCodeResolver.js) prefers
  // billingStateCode when populated and falls back to stateCode when
  // NULL — back-compat with pre-G034 rows.
  billingStateCode String?

  // PRD_TRAVEL_B2B_AGENT_PORTAL #905 slice 6 — TravelCommissionProfile
  // assignment for B2B agent contacts. Nullable so generic + wellness +
  // travel-direct-consumer Contacts ignore it entirely. Set via
  // POST /api/travel/commission-profiles/:id/assign (bulk-assign endpoint).
  // No FK relation declared — keeps the column free of cascade-delete
  // coupling and mirrors the same shape choice as preferredLocationId /
  // preferredPractitionerId above. Profile deletion just leaves stale
  // references; the calculator skips contacts whose profile id no longer
  // resolves to a row in TravelCommissionProfile.
  commissionProfileId Int?

  // Travel CRM — customer-portal DigiLocker / Aadhaar verification.
  // PRD §4.5 extended for end-user self-service KYC. Stub-mode until
  // APISETU_PARTNER_API_KEY is set in .env; then routes/portal.js's
  // DigiLocker flow calls APISetu and writes verified=true here.
  // All fields nullable so non-travel + non-customer Contacts ignore them.
  //   kycStatus       — "unverified" | "initiated" | "verified" | "failed"
  //   kycInitiatedAt  — when the customer opened the OAuth flow
  //   kycVerifiedAt   — when the callback succeeded
  //   aadhaarLast4    — last 4 digits, safe to show in UI (Aadhaar Act §29)
  //   kycTokenId      — opaque APISetu/DigiLocker token, NEVER returned in
  //                     responses (server-side only; audit / re-fetch use)
  kycStatus      String?   @default("unverified")
  kycInitiatedAt DateTime?
  kycVerifiedAt  DateTime?
  aadhaarLast4   String?
  kycTokenId     String?

  // [GP-CRM integration] Opaque external ID set by partner systems (e.g.
  // GlobusPhone lead ULID). Lets a partner push a stable ID at create time so
  // outbox retries never create duplicate contacts within a tenant. Nullable;
  // NULL != NULL in MySQL unique indexes, so un-linked contacts are unaffected
  // by the @@unique([tenantId, externalId]) constraint below.
  externalId String?

  // PRD_TRAVEL_MULTICHANNEL_LEADS G002 (FR-3.1.7, FR-3.2.6) — Caller-supplied
  // dedupe key for multi-channel intake. When a producer (Voyagr microsite,
  // Meta lead-ads webhook, Wati WhatsApp, voice/IVR, CRM walk-in) retries the
  // same POST, the second call trips the @@unique([tenantId, source,
  // idempotencyKey]) constraint and the route returns
  // `action: duplicate_suppressed` + the existing contactId (idempotent
  // semantics). NULL != NULL in MySQL — Contacts without an idempotencyKey
  // (every legacy Contact + every intake without one) never collide.
  idempotencyKey String?

  // PRD_TRAVEL_MULTICHANNEL_LEADS G012 (FR-3.4.5) — referrer chain. When the
  // intake `channel=referral`, this column links to the Contact who referred
  // them so attribution reporting can roll up "leads from referrals" + reward
  // the referrer downstream. Loose Int reference (no FK) to dodge cascade-
  // delete coupling — a deleted referrer leaves stale references but doesn't
  // tombstone the referred Contact's analytics row.
  referrerContactId Int?

  createdAt DateTime  @default(now())
  // #167: soft-delete column. Routes filter `deletedAt: null` on list/detail.
  // DELETE flips this column instead of hard-deleting; restore endpoint clears it.
  deletedAt DateTime?

  // PRD §6.4: Lead-side SLA timer ("first response in <5 min for high-ticket
  // services"). Stamped at lead-create time using the matched service tier
  // (see backend/cron/leadSlaEngine.js + backend/lib/leadSla.js). When an
  // Activity is logged against the contact, firstResponseAt is set; the cron
  // flips slaBreached + slaBreachedAt for any past-due lead that still has
  // firstResponseAt IS NULL. Idempotent on the slaBreached=false gate.
  firstResponseDueAt DateTime?
  firstResponseAt    DateTime?
  slaBreached        Boolean   @default(false)
  slaBreachedAt      DateTime?

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assignedToId Int?
  assignedTo   User? @relation("AssignedContacts", fields: [assignedToId], references: [id], onDelete: SetNull)

  activities                Activity[]
  deals                     Deal[]
  emails                    EmailMessage[]
  callLogs                  CallLog[]
  invoices                  Invoice[]
  sequenceEnrollments       SequenceEnrollment[]
  tasks                     Task[]
  expenses                  Expense[]
  contracts                 Contract[]
  estimates                 Estimate[]
  projects                  Project[]
  marketplaceLeads          MarketplaceLead[]
  smsMessages               SmsMessage[]
  whatsappMessages          WhatsAppMessage[]
  whatsappThreads           WhatsAppThread[]
  pushSubscriptions         PushSubscription[]
  touchpoints               Touchpoint[]
  attachments               ContactAttachment[]
  // Travel customer-portal DigiLocker sessions (PRD §4.5 extended).
  digilockerSessions        DigilockerSession[]
  // Travel customer-portal in-app notification inbox (2026-06-17).
  travelPortalNotifications TravelPortalNotification[]

  /// One Contact per email-per-tenant; same email may exist in different tenants (each tenant maintains its own CRM). Allows a single person to legitimately appear as a contact in multiple customers' CRMs without collision.
  @@unique([email, tenantId])
  /// [GP-CRM integration] One Contact per externalId-per-tenant. NULL != NULL in
  /// MySQL unique indexes, so the many contacts with no externalId never collide;
  /// only partner-linked rows (e.g. GlobusPhone lead ULID) are deduplicated.
  @@unique([tenantId, externalId])
  /// PRD_TRAVEL_MULTICHANNEL_LEADS G002 — (tenantId, source, idempotencyKey)
  /// composite unique gates the multi-channel intake's idempotency-key check.
  /// `source` carries the channel (e.g. "inbound:voyagr") so the constraint
  /// is scoped per-channel per-tenant (same idempotencyKey from voyagr vs
  /// webform don't collide). NULL != NULL in MySQL — every Contact without
  /// an idempotencyKey is unaffected, so legacy + non-intake rows are free.
  @@unique([tenantId, source, idempotencyKey], name: "tenant_source_idempkey")
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, assignedToId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, status, slaBreached])
  @@index([tenantId, name])
  @@index([tenantId, phone])
}

model Activity {
  id          Int      @id @default(autoincrement())
  type        String // Email, Call, Meeting, Note
  description String   @db.Text
  createdAt   DateTime @default(now())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([contactId, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
}

model Deal {
  id              Int       @id @default(autoincrement())
  title           String
  amount          Float     @default(0.0)
  currency        String    @default("USD")
  probability     Int       @default(50)
  stage           String    @default("lead") // lead, contacted, proposal, won, lost
  pipelineId      Int? // links to Pipeline.id
  expectedClose   DateTime?
  lostReason      String?
  winLossReasonId Int?
  // Travel vertical — Day 2 schema migration. Nullable so non-travel deals
  // (generic, wellness) ignore both columns. subBrand mirrors Contact.subBrand;
  // diagnosticId links the deal to its originating TravelDiagnostic (one
  // diagnostic per deal — soft FK, no @relation block to keep edits minimal).
  subBrand        String?
  diagnosticId    Int?
  createdAt       DateTime  @default(now())
  // #167: soft-delete column (see Contact).
  deletedAt       DateTime?

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  ownerId     Int?
  owner       User?        @relation("OwnerDeals", fields: [ownerId], references: [id], onDelete: SetNull)
  attachments Attachment[]
  invoices    Invoice[]
  quotes      Quote[]
  contracts   Contract[]
  estimates   Estimate[]
  projects    Project[]

  @@index([tenantId, stage])
  @@index([tenantId, ownerId])
  @@index([tenantId, contactId])
  @@index([tenantId, probability])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
}

model Ticket {
  id              Int       @id @default(autoincrement())
  subject         String
  description     String?
  status          String    @default("Open") // Open, Pending, Resolved, Closed
  priority        String    @default("Low") // Low, Medium, High, Urgent
  slaResponseDue  DateTime?
  slaResolveDue   DateTime?
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  breached        Boolean   @default(false)
  breachedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assigneeId Int?
  assignee   User? @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, priority])
}

model Campaign {
  id        Int      @id @default(autoincrement())
  name      String
  channel   String   @default("EMAIL") // EMAIL, SMS, PUSH, WHATSAPP
  status    String   @default("Draft") // Draft, Active, Completed
  sent      Int      @default(0)
  opened    Int      @default(0)
  clicked   Int      @default(0)
  budget    Float    @default(0.0)
  createdAt DateTime @default(now())

  // Schedule persistence (#412): replaces in-memory global._campaignSchedules
  // map which silently dropped pending schedules on backend restart and could
  // not survive multi-instance deploys. All three columns are nullable so
  // existing rows survive `prisma db push --accept-data-loss` without a
  // backfill.
  //
  //   scheduledAt     — when the campaign should dispatch (UTC). Null on
  //                     Draft rows. The cron engine queries `lte: now()`.
  //   scheduleStatus  — 'PENDING' (waiting on cron) | 'SENT' (cron
  //                     dispatched successfully) | 'CANCELLED' (paused
  //                     before dispatch) | null. Cron matches PENDING.
  //   scheduleFilters — JSON-serialised audience filter (formerly
  //                     schedule.filters in the in-memory map). Read by
  //                     sendCampaign via campaign._audienceFilter.
  scheduledAt     DateTime?
  scheduleStatus  String?
  scheduleFilters String?   @db.Text

  // #932 — Campaign → Sequence linkage (follow-up to #898 acceptance #4).
  // When sequenceId is set, sendCampaign auto-enrolls every recipient into
  // the linked Sequence after dispatch completes. Nullable so existing rows
  // survive `prisma db push` without a backfill; onDelete: SetNull keeps
  // the campaign row valid if the linked sequence is later removed.
  sequenceId Int?
  sequence   Sequence? @relation(fields: [sequenceId], references: [id], onDelete: SetNull)

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  smsMessages       SmsMessage[]
  pushNotifications PushNotification[]

  @@index([sequenceId])
  @@index([tenantId])
}

model AutomationRule {
  id          Int     @id @default(autoincrement())
  name        String
  triggerType String
  actionType  String
  targetState String?
  // #20: optional JSON-encoded array of clauses, AND-joined.
  // Format: [{"field":"deal.amount","op":"gt","value":50000}, ...]
  // Operators: eq, neq, gt, gte, lt, lte, in, nin, contains, startsWith.
  // Empty/null = always-fire (backwards compat with pre-#20 rules).
  condition   String? @db.Text
  isActive    Boolean @default(true)

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model EmailMessage {
  id                   Int       @id @default(autoincrement())
  subject              String
  body                 String    @db.Text
  from                 String
  to                   String
  // #623 — cc/bcc are comma-separated lists, persisted exactly as the
  // composer's parseRecipients() returns them (deduped, lowercase-keyed).
  // Null when no carbon-copy / blind-carbon-copy recipients were attached.
  cc                   String?   @db.Text
  bcc                  String?   @db.Text
  direction            String    @default("INBOUND") // INBOUND, OUTBOUND
  read                 Boolean   @default(false)
  sentiment            String? // positive, neutral, negative
  sentimentScore       Float? // -1 to 1
  threadId             String? // for conversation threading
  // #7 — set by sequenceEngine.processInboundReplies() once an inbound row
  // matching a `seq-<enrollmentId>` thread has paused its enrollment. Acts
  // as the dedup gate so a single reply only pauses once, even if the cron
  // tick fires repeatedly.
  sequenceReplyHandled DateTime?
  createdAt            DateTime  @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, direction])
  @@index([tenantId, contactId])
  @@index([tenantId, threadId])
  @@index([tenantId, createdAt])
}

model CallLog {
  id             Int      @id @default(autoincrement())
  duration       Int // seconds
  notes          String?
  direction      String   @default("OUTBOUND")
  recordingUrl   String?
  provider       String? // "myoperator", "knowlarity", "twilio", "webrtc"
  providerCallId String?
  status         String   @default("COMPLETED") // INITIATED, RINGING, CONNECTED, COMPLETED, MISSED, FAILED
  callerNumber   String?
  calleeNumber   String?
  createdAt      DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, contactId])
}

model Attachment {
  id        Int      @id @default(autoincrement())
  filename  String
  fileUrl   String
  createdAt DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  dealId Int
  deal   Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, dealId])
}

model ApiKey {
  id        Int       @id @default(autoincrement())
  keySecret String    @unique // Hashed or raw token
  name      String
  // #899 Part A: per-sub-brand key scoping (Travel vertical).
  // null = tenant-wide key (legacy / generic); 'tmc'|'rfu'|'travelstall'|'visasure'
  // = scoped to one Travel sub-brand. Enforced by externalAuth/voyagrAuth via
  // req.requireSubBrandMatch(targetSubBrand) helper — a key with subBrand='tmc'
  // posting a lead with subBrand='rfu' is rejected 403 SUB_BRAND_MISMATCH.
  subBrand  String?
  // #908 (PRD_FLIGHT_PLUGIN_CHROME_EXTENSION FR-4/FR-5) — scopes a key to a
  // specific consumer. null = tenant-wide (legacy / partner API); when set
  // (e.g. "flight-plugin") the matching endpoint enforces it. Additive nullable
  // so existing keys keep working unchanged.
  purpose   String?
  createdAt DateTime  @default(now())
  lastUsed  DateTime?

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Webhook {
  id        Int      @id @default(autoincrement())
  event     String // e.g. "deal.*", "contact.created"
  targetUrl String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Per-tenant HMAC signing credential for outbound webhooks (the lead-sync
// stream GlobusPhone consumes). Replaces the single global
// `process.env.WEBHOOK_HMAC_SECRET`: each tenant's outbound webhooks are
// signed with THIS tenant's `secret` instead. One row per tenant
// (`tenantId @unique`) — rotation/regeneration overwrites `secret` in place;
// revoke flips `status` to REVOKED (kept for audit, but delivery stops).
//
// Show-once model (Stripe/GitHub/AWS): the raw secret is only ever returned
// in the generate/rotate HTTP response — never re-served afterwards. It is
// stored encrypted-at-rest via lib/fieldEncryption.js (AES-256-GCM, opt-in
// via WELLNESS_FIELD_KEY) because the SERVER still needs it to sign; the
// `ENC:v1:...` wrapper means a plaintext secret (key unset) and an encrypted
// one coexist transparently. Delivery is also subscription-gated — see
// lib/webhookEntitlement.js + lib/webhookDelivery.js deliverWebhooks().
model WebhookCredential {
  id            Int       @id @default(autoincrement())
  tenantId      Int       @unique // one signing secret per tenant
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  secret        String    @db.Text // raw 64-hex OR "ENC:v1:..." (fieldEncryption)
  signingId     String    @unique // public, non-secret ref e.g. "whid_<hex>"
  status        String    @default("ACTIVE") // ACTIVE | REVOKED
  lastRotatedAt DateTime?
  createdById   Int
  createdBy     User      @relation("UserWebhookCredentials", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
}

model Invoice {
  id              Int       @id @default(autoincrement())
  invoiceNum      String    @unique
  amount          Float
  status          String    @default("UNPAID") // UNPAID, PAID, OVERDUE, VOIDED
  dueDate         DateTime
  issuedDate      DateTime  @default(now())
  paidAt          DateTime? // set by /pay route when status flips to PAID — drives "Paid This Month" KPI
  isRecurring     Boolean   @default(false)
  recurFrequency  String? // "monthly", "quarterly", "yearly"
  nextRecurDate   DateTime?
  parentInvoiceId Int? // original invoice this was generated from
  // Travel vertical — Day 2 schema migration. A single tenant can issue
  // invoices under different GST registrations (TMC vs Travel Stall vs
  // RFU each operate under separate legal entities per Q-meta). Nullable;
  // non-travel invoices ignore. e.g. "tmc_nexus", "labbaik_travels",
  // "travel_stall_parent".
  legalEntityCode String?

  // #413 — Restrict (not Cascade) on Tenant deletion. Invoices are financial
  // records of record; a misclick on tenant.delete() must NOT silently nuke
  // billing history. Operator must explicitly drain Invoice rows first.
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  dealId    Int?
  deal      Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contactId Int
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Restrict)

  // #601 — wellness visit linkage. Optional so generic CRM invoices don't
  // need it. SetNull on visit delete; Invoice itself stays Restrict-on-tenant.
  // Drives the per-visit revenue rollup on /api/wellness/reports/visit.
  visitId Int?
  visit   Visit? @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@index([tenantId, isRecurring])
  @@index([tenantId, nextRecurDate])
  @@index([tenantId, parentInvoiceId])
  @@index([visitId, status])
}

