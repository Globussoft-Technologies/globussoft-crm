// ── Multi-Currency ───────────────────────────────────────────────

model Currency {
  id           Int      @id @default(autoincrement())
  code         String // "USD", "INR", "EUR"
  symbol       String
  name         String
  exchangeRate Float    @default(1.0) // relative to base
