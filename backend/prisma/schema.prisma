  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// WhatsApp template names are tenant-scoped. Meta itself enforces uniqueness within a Business Account, so a tenant cannot have two templates named "appointment_reminder", but tenant A and tenant B can each independently register a template named "appointment_reminder" against their own WABA.
  @@unique([tenantId, name])
}

model WhatsAppConfig {
  id                 Int       @id @default(autoincrement())
  provider           String // "meta_cloud", "twilio_whatsapp", "gupshup"
  phoneNumberId      String?
  businessAccountId  String?
  // #651 — accessToken widened to @db.Text for AES-256-GCM ciphertext.
  accessToken        String?   @db.Text
  webhookVerifyToken String?
  isActive           Boolean   @default(false)
  settings           String?   @db.Text
  // #651 — see SmsConfig.lastRotatedAt
  lastRotatedAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One WhatsApp credentials row per (tenant, provider). A tenant connects to Meta Cloud API once with their WABA + phone number ID. Different tenants own different WABAs and operate independently.
  @@unique([tenantId, provider])
}

