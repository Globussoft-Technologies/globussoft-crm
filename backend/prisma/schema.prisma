// ── WhatsApp ──────────────────────────────────────────────────────

model WhatsAppMessage {
  id            Int       @id @default(autoincrement())
  to            String
  from          String?
  body          String?   @db.Text
  mediaUrl      String?
  mediaType     String?
  direction     String    @default("OUTBOUND")
  status        String    @default("QUEUED") // QUEUED, SENT, DELIVERED, READ, FAILED
  providerMsgId String?
  templateName  String?
  errorMessage  String?
  read          Boolean   @default(false)
  // Soft-delete for "Delete for me" — hides the message from the
  // operator's CRM view but preserves the row for audit / compliance.
  // Note: Meta WhatsApp Cloud API does NOT support deleting messages
  // on the recipient phone, so "delete for everyone" is intentionally
  // not modelled — operators see this caveat in the UI confirm dialog.
  deletedAt     DateTime?
  // Emoji reactions attached to THIS message. JSON-stringified array of
  // shape `[{ emoji, fromPhone, byUserId?, addedAt }]`. Reactions arrive
  // as separate Meta webhook events with `type: "reaction"`; the handler
  // dereferences them to the target message via `providerMsgId` instead
  // of creating standalone rows. Empty emoji = reaction-removed.
  reactionsJson String?   @db.Text
  createdAt     DateTime  @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Wave 2 Agent KK: 2-way messaging - thread keyed by (tenantId, contactPhone).
  threadId Int?
  thread   WhatsAppThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)

  // WhatsApp SaaS P3: 1:1 child rows for async outbound delivery + media download.
  // Either can be null (templates with no media, status updates with no job, etc.).
  outboundJob WaOutboundJob?
  mediaJob    WaMediaJob?

  // WhatsApp SaaS P3: metaType captures the original Meta payload shape so the
  // client/UI can render image/document/interactive correctly without re-parsing
  // the provider response. Distinct from `direction` (in/out) and `status`
  // (lifecycle). Free-form to accommodate future Meta event types without
  // schema churn.
  metaType        String?
  interactiveJson String? @db.Text

  // S124: full multi-attachment refs list (mediaUrl/mediaType only surface
  // the first attachment due to single-column legacy schema; mediaRefsJson
  // holds JSON-stringified array of all resolved attachment refs for
  // multi-attachment WhatsApp sends from the sequence engine). Additive
  // nullable — existing rows + single-attachment callers unaffected.
  mediaRefsJson String? @db.Text

  @@index([tenantId, createdAt])
  @@index([threadId, createdAt])
  // P1 hot path: webhook status updates filter by providerMsgId; current code
  // does a full-tenant scan on every delivery status event. Indexing this
  // closes a measurable latency leak.
  @@index([providerMsgId])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, contactId])
}

// -- WhatsApp 2-way: Thread aggregation + opt-out (Wave 2 Agent KK) --
model WhatsAppThread {
  id            Int       @id @default(autoincrement())
  contactPhone  String
  // WhatsApp display name (saved contact name / pushname) captured at import
  // or first inbound so the inbox shows names — not just numbers — like
  // WhatsApp Web. Nullable; falls back to contactPhone when unknown.
  contactName   String?
  // WhatsApp profile picture (DP) URL captured at import. Nullable (privacy /
  // no DP). Refreshed on re-import; UI falls back to initials when absent.
  contactAvatar String?   @db.Text
  // WhatsApp-Web-style per-chat flags (CRM-side, not synced to WhatsApp):
  isPinned      Boolean   @default(false)
  isArchived    Boolean   @default(false)
  isMuted       Boolean   @default(false)
  status        String    @default("OPEN")
  lastMessageAt DateTime  @default(now())
  lastInboundAt DateTime?
  snoozedUntil  DateTime?
  unreadCount   Int       @default(0)
  labels        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  patientId Int?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  assignedToId Int?
  assignedTo   User? @relation("WhatsAppThreadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  messages WhatsAppMessage[]

  @@unique([tenantId, contactPhone])
  @@index([tenantId, status, lastMessageAt])
  @@index([assignedToId, status])
}

model WhatsAppOptOut {
  id           Int      @id @default(autoincrement())
  contactPhone String
  reason       String   @default("USER_REQUESTED")
  capturedAt   DateTime @default(now())
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contactPhone])
  @@index([tenantId, capturedAt])
}

model WhatsAppTemplate {
  id             Int       @id @default(autoincrement())
  name           String
  language       String    @default("en")
  category       String    @default("MARKETING") // MARKETING, UTILITY, AUTHENTICATION
  headerType     String? // TEXT, IMAGE, DOCUMENT, VIDEO, NONE
  headerContent  String?
  body           String    @db.Text
  footer         String?
  buttons        String?   @db.Text // JSON
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED
  metaTemplateId String?
  // WhatsApp SaaS P4: template-quality + sync tracking.
  // qualityScore — driven by `message_template_quality_update` webhook.
  // lastSyncedAt — bumped by /api/whatsapp/templates/sync (P4) and by the
  //   nightly whatsappTemplateSyncEngine safety net for tenants whose webhook
  //   delivery silently broke.
  qualityScore   String? // 'HIGH' | 'MEDIUM' | 'LOW' | null
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// WhatsApp template names are tenant-scoped. Meta itself enforces uniqueness within a Business Account, so a tenant cannot have two templates named "appointment_reminder", but tenant A and tenant B can each independently register a template named "appointment_reminder" against their own WABA.
  @@unique([tenantId, name])
}

model WhatsAppConfig {
  id                 Int       @id @default(autoincrement())
  provider           String // "meta_cloud", "twilio_whatsapp", "gupshup"
  // WhatsApp SaaS P1: phoneNumberId is the inbound webhook tenant key.
  // `value.metadata.phone_number_id` on every Meta webhook event is matched
  // against this column to route to the owning tenant — replaces the old
  // contact-phone-substring lookup that defaulted to tenantId=1 on miss.
  // Nullable for legacy rows that pre-date onboarding; @unique enforces that
  // no two tenants can claim the same Meta phone-number-id (which Meta itself
  // forbids — one phone_number_id belongs to one WABA at a time).
  phoneNumberId      String?   @unique
  businessAccountId  String?
  // #651 — accessToken widened to @db.Text for AES-256-GCM ciphertext.
  accessToken        String?   @db.Text
  webhookVerifyToken String?
  isActive           Boolean   @default(false)
  settings           String?   @db.Text
  // #651 — see SmsConfig.lastRotatedAt
  lastRotatedAt      DateTime?

  // WhatsApp SaaS P1+P4: integration lifecycle + health state.
  // tokenExpiresAt — read from Graph /debug_token; null = "never expires"
  //   (system-user-tied tokens issued via Embedded Signup Solution-Partner mode).
  // qualityRating / messagingLimitTier — driven by Meta webhook events
  //   `phone_number_quality_update` and `business_capability_update`.
  // businessRestricted — set true on `account_update` webhook with restriction;
  //   the outbound queue suspends sends for the tenant while this is true.
  // webhookVerified — set true after the embedded-signup `subscribed_apps`
  //   call confirms Meta will deliver webhooks to us for this WABA.
  // disconnectedAt — soft-disconnect marker; set by /onboard/disconnect or by
  //   the runtime auth-failure catch (code=190 from Meta).
  // onboardedAt — first successful onboard timestamp; persists across reconnects.
  // lastHealthCheckAt — daily /debug_token probe wakes this column.
  tokenExpiresAt     DateTime?
  qualityRating      String? // 'GREEN' | 'YELLOW' | 'RED' | 'UNKNOWN'
  messagingLimitTier String? // 'TIER_50' | 'TIER_250' | 'TIER_1K' | 'TIER_10K' | 'TIER_100K' | 'UNLIMITED'
  businessRestricted Boolean   @default(false)
  webhookVerified    Boolean   @default(false)
  disconnectedAt     DateTime?
  onboardedAt        DateTime?
  lastHealthCheckAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One WhatsApp credentials row per (tenant, provider). A tenant connects to Meta Cloud API once with their WABA + phone number ID. Different tenants own different WABAs and operate independently.
  @@unique([tenantId, provider])
  @@index([businessAccountId])
}

// ── Payment gateway (per-tenant BYOK) ─────────────────────────────
//
// #848 (PRD_PAYMENT_GATEWAY_CONFIG.md, minimal slice). The PLATFORM's own
// Razorpay account (RAZORPAY_KEY_* env vars) is used ONLY for subscription
// billing — when a tenant pays Globussoft (routes/subscriptions.js +
// services/razorpayService.js). This model holds each TENANT's OWN Razorpay
// merchant keys so their customers' payments (invoices, memberships, gift
// cards) settle into the TENANT's account, not ours. BYOK — Bring Your Own
// Key. Loaded by lib/tenantPaymentGateway.js at customer-payment time.
//
// keySecret + webhookSecret are AES-256-GCM-encrypted at rest via
// credentialMasking.encryptCredential() (opt-in WELLNESS_FIELD_KEY; graceful
// plaintext fallback for local dev) — same posture as SmsConfig /
// WhatsAppConfig credentials. keyId is the public `rzp_live_…` identifier and
// is stored plaintext (it ships to the browser checkout anyway).
model PaymentGatewayConfig {
  id            Int       @id @default(autoincrement())
  provider      String // "razorpay" (only provider in the v1 slice; Stripe/etc. follow the PRD)
  keyId         String? // public key id (rzp_live_… / rzp_test_…) — not secret
  keySecret     String?   @db.Text // encrypted
  webhookSecret String?   @db.Text // encrypted; verifies this tenant's Razorpay webhooks
  isActive      Boolean   @default(false)
  lastRotatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One gateway credential row per (tenant, provider). A tenant configures its own Razorpay merchant account once; reconfiguring updates the row. Different tenants settle to their own banks independently.
  @@unique([tenantId, provider])
}

// ── WhatsApp SaaS P1 — webhook idempotency + audit ───────────────────
//
// Every inbound Meta webhook event is recorded here BEFORE the handler runs.
// The (source, metaEventId) unique index closes the duplicate-delivery hole:
// Meta retries aggressively on any non-2xx, and the previous code path
// would happily create duplicate WhatsAppMessage rows on retry. With this
// table, the handler short-circuits on P2002 (unique violation) and returns
// 200 immediately, telling Meta to stop retrying.
//
// `tenantId` is nullable because the routing layer determines tenant from
// `value.metadata.phone_number_id` AFTER the event is recorded — events for
// unknown phone-number-ids land here with tenantId=null + status=IGNORED so
// you can audit what's being delivered to your webhook without a tenant
// association.
//
// `rawPayload` is the full JSON for forensic replay. Kept @db.LongText so
// large payloads (interactive messages, batched statuses) fit. Retention
// policy: 14 days, swept by the existing retentionEngine cron.
model WebhookEvent {
  id           Int       @id @default(autoincrement())
  source       String // 'meta_whatsapp', future: 'twilio_whatsapp', 'gupshup_whatsapp'
  metaEventId  String?   @db.VarChar(200) // composite: phoneNumberId + ':' + (msg.id || status.id)
  tenantId     Int?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  rawPayload   String    @db.LongText
  signatureOk  Boolean
  status       String    @default("RECEIVED") // RECEIVED, PROCESSED, FAILED, IGNORED, DUPLICATE
  errorMessage String?   @db.Text
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?

  @@unique([source, metaEventId])
  @@index([tenantId, receivedAt])
  @@index([status, receivedAt])
}

// ── WhatsApp SaaS P3 — async outbound queue (DB-backed) ───────────────
//
// One row per outbound WhatsAppMessage. The whatsappOutboundEngine cron
// (cron/whatsappOutboundEngine.js) claims PENDING rows whose runAt <= now,
// calls Meta, and updates status + WhatsAppMessage.status atomically.
//
// `lockedAt` + `lockedBy` is the pessimistic claim — when this codebase
// eventually scales past one PM2 instance, only one worker takes a given
// job. Stale locks (>60s) get reclaimed at the next tick. This is the
// poor-man's BullMQ until the queue-driver abstraction in
// lib/whatsappQueue.js is swapped to a real broker.
//
// Status lifecycle:
//   PENDING   → claimed → IN_FLIGHT → DONE | (retry → PENDING) | FAILED
//   FAILED    → final on 4xx (auth/template/policy) — do not retry
//   DEAD      → 5+ retry attempts on 5xx/network — manual replay required
model WaOutboundJob {
  id        Int             @id @default(autoincrement())
  messageId Int             @unique
  message   WhatsAppMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  tenantId  Int
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  status    String    @default("PENDING") // PENDING | IN_FLIGHT | DONE | FAILED | DEAD
  attempts  Int       @default(0)
  lastError String?   @db.Text
  runAt     DateTime  @default(now())
  lockedAt  DateTime?
  lockedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, runAt])
  @@index([tenantId, status])
}

// ── WhatsApp SaaS P3 — media download pipeline ────────────────────────
//
// Meta media URLs are short-lived (~5 min) and the underlying media itself
// is retained for ~30 days. The webhook handler stores the bare media id;
// the whatsappMediaEngine cron downloads it within minutes and uploads to
// S3 under `whatsapp/{tenantId}/media/`, then rewrites the parent message's
// `mediaUrl` column to the permanent S3 URL.
//
// Reuses the existing s3Service (backend/services/s3Service.js) — same
// bucket, same credentials. Cleanup is bucket-side via lifecycle policy.
model WaMediaJob {
  id        Int             @id @default(autoincrement())
  messageId Int             @unique
  message   WhatsAppMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  tenantId  Int
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  metaMediaId String
  mimeType    String?
  status      String  @default("PENDING") // PENDING | DONE | FAILED
  attempts    Int     @default(0)
  s3Url       String? @db.Text
  lastError   String? @db.Text

  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([status, createdAt])
  @@index([tenantId, status])
}

// ── Telephony ─────────────────────────────────────────────────────

model TelephonyConfig {
  id            Int       @id @default(autoincrement())
  provider      String // "myoperator", "knowlarity", "twilio"
  // #651 — apiKey + apiSecret widened to @db.Text for AES-256-GCM ciphertext.
  apiKey        String?   @db.Text
