  tenantId       Int       @default(1)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  campaignId     Int?
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

model PushTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  title     String
  body      String   @db.Text
  icon      String?
  url       String?
  category  String   @default("General")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── Landing Pages ─────────────────────────────────────────────────

model LandingPage {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  description     String?
  templateType    String?
  content         String?   @db.LongText // JSON component array
  cssOverrides    String?   @db.Text
  metaTitle       String?
  metaDescription String?
  status          String    @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  visits          Int       @default(0)
  submissions     Int       @default(0)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenantId        Int       @default(1)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId          Int?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  analytics       LandingPageAnalytics[]
}

model LandingPageAnalytics {
  id            Int         @id @default(autoincrement())
  landingPageId Int
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  eventType     String      // VISIT, FORM_SUBMIT, BUTTON_CLICK
  visitorIp     String?
  userAgent     String?
  referrer      String?
  metadata      String?     @db.Text
  createdAt     DateTime    @default(now())

  tenantId      Int         @default(1)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── Contact Attachments ───────────────────────────────────────────

model ContactAttachment {
  id          Int      @id @default(autoincrement())
  filename    String
  fileUrl     String
  fileSize    Int?     // bytes
  mimeType    String?
  createdAt   DateTime @default(now())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── Email Tracking ────────────────────────────────────────────────

model EmailTracking {
  id          Int      @id @default(autoincrement())
  emailId     Int      // references EmailMessage.id
  trackingId  String   @unique // UUID for tracking pixel/link
  type        String   // "open", "click"
  url         String?  // original URL for click tracking
  openedAt    DateTime?
  clickedAt   DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── SSO Configuration ────────────────────────────────────────────

model SsoConfig {
  id           Int      @id @default(autoincrement())
  provider     String   // "google", "microsoft"
  clientId     String?
  clientSecret String?
  redirectUri  String?
  isActive     Boolean  @default(false)
  tenantId     Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, provider])
}

// ── Calendar Integration ─────────────────────────────────────────

model CalendarIntegration {
  id           Int      @id @default(autoincrement())
  userId       Int
  provider     String   // "google", "microsoft"
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  calendarId   String?  // primary calendar id
  syncEnabled  Boolean  @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId     Int      @default(1)

  @@unique([userId, provider])
}

model CalendarEvent {
  id              Int      @id @default(autoincrement())
  externalId      String   // provider's event ID
  provider        String
  title           String
  description     String?  @db.Text
  startTime       DateTime
  endTime         DateTime
  location        String?
  attendees       String?  @db.Text // JSON
  meetingUrl      String?
  userId          Int
  contactId       Int?
  dealId          Int?
  tenantId        Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([provider, externalId])
}

// ── GDPR / Compliance ────────────────────────────────────────────

model ConsentRecord {
  id          Int      @id @default(autoincrement())
  contactId   Int
  type        String   // "marketing_email", "marketing_sms", "marketing_whatsapp", "data_processing"
  granted     Boolean
  ipAddress   String?
  userAgent   String?
  source      String?  // where consent was captured
  createdAt   DateTime @default(now())

  tenantId    Int      @default(1)
}

model DataExportRequest {
  id          Int      @id @default(autoincrement())
  contactId   Int?     // can be for a contact's data
  userId      Int?     // or a user's own data
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETE, FAILED
  fileUrl     String?  // download URL when complete
  requestedAt DateTime @default(now())
  completedAt DateTime?

  tenantId    Int      @default(1)
}

model RetentionPolicy {
  id          Int      @id @default(autoincrement())
  entity      String   // "EmailMessage", "CallLog", "Activity", etc.
  retainDays  Int      // delete records older than this
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    Int      @default(1)

  @@unique([tenantId, entity])
}

// ── Voice / Telephony Sessions ───────────────────────────────────

model VoiceSession {
  id          Int      @id @default(autoincrement())
  sessionId   String   @unique // Twilio call SID or provider session
  status      String   @default("INITIATED") // INITIATED, RINGING, IN_PROGRESS, COMPLETED, FAILED
  fromNumber  String?
  toNumber    String?
  duration    Int?     // seconds
  recordingUrl String?
  transcript   String?  @db.Text
  userId      Int?
  contactId   Int?
  tenantId    Int      @default(1)
  createdAt   DateTime @default(now())
  endedAt     DateTime?
}

// ── Multiple Sales Pipelines ─────────────────────────────────────

model Pipeline {
  id          Int      @id @default(autoincrement())
  name        String
  isDefault   Boolean  @default(false)
  description String?
  tenantId    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Forecasting + Win/Loss ───────────────────────────────────────

model Forecast {
  id              Int      @id @default(autoincrement())
  period          String   // "2026-Q1", "2026-04"
  expectedRevenue Float    @default(0)
  committedRevenue Float   @default(0)
  bestCaseRevenue  Float   @default(0)
  closedRevenue   Float    @default(0)
  userId          Int?
  tenantId        Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WinLossReason {
  id        Int      @id @default(autoincrement())
  type      String   // "won" or "lost"
  reason    String
  count     Int      @default(0)
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
}

// ── Sales Quotas ─────────────────────────────────────────────────

model Quota {
  id        Int      @id @default(autoincrement())
  userId    Int
  period    String   // "2026-Q1"
  target    Float
  achieved  Float    @default(0)
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, period, tenantId])
}

// ── Lead Routing ─────────────────────────────────────────────────

model LeadRoutingRule {
  id         Int      @id @default(autoincrement())
  name       String
  conditions String   @db.Text // JSON
  assignType String   @default("round_robin") // round_robin, specific_user, territory
  assignTo   Int?     // userId if specific_user
  priority   Int      @default(100)
  isActive   Boolean  @default(true)
  tenantId   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Territory Management ─────────────────────────────────────────

model Territory {
  id            Int      @id @default(autoincrement())
  name          String
  regions       String?  @db.Text // JSON array
  assignedUserIds String?  @db.Text // JSON array
  tenantId      Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Approval Workflows ───────────────────────────────────────────

model ApprovalRequest {
  id          Int      @id @default(autoincrement())
  entity      String   // "Deal", "Quote", "Discount", etc.
  entityId    Int
  reason      String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedBy Int
  approvedBy  Int?
  comment     String?
  requestedAt DateTime @default(now())
  approvedAt  DateTime?
  tenantId    Int      @default(1)
}

// ── A/B Testing ──────────────────────────────────────────────────

model AbTest {
  id              Int      @id @default(autoincrement())
  name            String
  campaignId      Int?
  variantA        String   @db.Text // JSON
  variantB        String   @db.Text // JSON
  variantASent    Int      @default(0)
  variantBSent    Int      @default(0)
  variantAClicked Int      @default(0)
  variantBClicked Int      @default(0)
  winningVariant  String?  // "A" or "B"
  status          String   @default("DRAFT") // DRAFT, RUNNING, COMPLETED
  tenantId        Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Marketing Attribution ────────────────────────────────────────

model Touchpoint {
  id         Int      @id @default(autoincrement())
  contactId  Int
  channel    String   // "email", "social", "search", "direct", etc.
  campaignId Int?
  source     String?
  medium     String?
  url        String?
  timestamp  DateTime @default(now())
  tenantId   Int      @default(1)
}

// ── Web Visitor Tracking ─────────────────────────────────────────

model WebVisitor {
  id         Int      @id @default(autoincrement())
  sessionId  String   @unique
  ipAddress  String?
  userAgent  String?  @db.Text
  country    String?
  city       String?
  pages      String?  @db.LongText // JSON array of {url, timestamp}
  contactId  Int?
  identified Boolean  @default(false)
  firstSeen  DateTime @default(now())
  lastSeen   DateTime @default(now())
  tenantId   Int      @default(1)
}

// ── Chatbot ──────────────────────────────────────────────────────

model Chatbot {
  id        Int      @id @default(autoincrement())
  name      String
  flow      String   @db.LongText // JSON node graph
  isActive  Boolean  @default(false)
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatbotConversation {
  id         Int      @id @default(autoincrement())
  chatbotId  Int
  visitorId  String   // links to WebVisitor.sessionId
