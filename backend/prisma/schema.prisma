  createdAt DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model DataExportRequest {
  id          Int       @id @default(autoincrement())
  contactId   Int? // can be for a contact's data
  userId      Int? // or a user's own data
  status      String    @default("PENDING") // PENDING, PROCESSING, COMPLETE, FAILED
  fileUrl     String? // download URL when complete
  requestedAt DateTime  @default(now())
  completedAt DateTime?

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model RetentionPolicy {
  id         Int      @id @default(autoincrement())
  entity     String // "EmailMessage", "CallLog", "Activity", etc.
  retainDays Int // delete records older than this
  isActive   Boolean  @default(true)
