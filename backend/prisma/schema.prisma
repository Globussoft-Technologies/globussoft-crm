generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./globussoft.db"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  role      String    @default("USER") // ADMIN, USER, MANAGER
  name      String?
  createdAt DateTime  @default(now())
  deals     Deal[]    @relation("OwnerDeals")
  tickets   Ticket[]  @relation("AssignedTickets")
}

model Contact {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  company     String?
  title       String?
  status      String     @default("Lead") // Lead, Prospect, Customer, Churned
  source      String?    @default("Organic")
  createdAt   DateTime   @default(now())
  activities  Activity[]
  deals       Deal[]
}

model Activity {
  id          Int      @id @default(autoincrement())
  type        String   // Email, Call, Meeting, Note
  description String
  createdAt   DateTime @default(now())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Deal {
  id            Int      @id @default(autoincrement())
  title         String
  amount        Float    @default(0.0)
  probability   Int      @default(50)
  stage         String   @default("lead") // lead, contacted, proposal, won, lost
  expectedClose DateTime?
  createdAt     DateTime @default(now())
  
  contactId     Int?
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  
  ownerId       Int?
  owner         User?    @relation("OwnerDeals", fields: [ownerId], references: [id], onDelete: SetNull)
}

model Ticket {
  id          Int      @id @default(autoincrement())
  subject     String
  description String?
  status      String   @default("Open") // Open, Pending, Resolved, Closed
  priority    String   @default("Low") // Low, Medium, High, Urgent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  assigneeId  Int?
  assignee    User?    @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)
}

model Campaign {
  id          Int      @id @default(autoincrement())
  name        String
  status      String   @default("Draft") // Draft, Active, Completed
  sent        Int      @default(0)
  opened      Int      @default(0)
  clicked     Int      @default(0)
  budget      Float    @default(0.0)
  createdAt   DateTime @default(now())
}

model AutomationRule {
  id          Int      @id @default(autoincrement())
  name        String
  triggerType String
  actionType  String
  targetState String?
  isActive    Boolean  @default(true)
}
