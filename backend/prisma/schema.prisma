// ── Wellness vertical (clinics, salons, aesthetics) ──────────────

model Patient {
  id              Int       @id @default(autoincrement())
  name            String
  email           String?
  phone           String?
  // #401 — canonical form of `phone` for dedup. Last-10-digits with
  // country code prepended (per backend/utils/deduplication.js's
  // normalizePhone helper). Backfilled by
  // backend/scripts/backfill-patient-normalized-phone.js. Used as the
  // unique key for (tenantId, normalizedPhone) to PREVENT the
  // recurring "Kavita Reddy × 10" inflation pattern.
  normalizedPhone String?
  dob             DateTime?
  gender          String? // M, F, Other
  bloodGroup      String?
  allergies       String?   @db.Text
  notes           String?   @db.Text
  photoUrl        String?
  source          String? // ad, walk-in, referral, whatsapp
  contactId       Int? // optional link back to CRM Contact

  // PRD Gap §1.1a / §1.1e — Patient lifecycle extras (mirror of Contact's
  // anniversary + walletBalance). dob already exists at line ~2328 above
  // and serves as the patient's birthDate equivalent.
  //   - anniversary   : DateTime? — anniversary-marketing automations.
  //   - walletBalance : Float?    — computed-on-read denorm (Wallet.balance
  //                     for the linked Wallet via Patient.wallet relation).
  //                     Wave 11 FF Wallet model remains the source of
  //                     truth; this column is read-side surface for the
  //                     Patient-detail render, kept intentionally null in
  //                     the DB (writes are dropped by the route handler).
  anniversary   DateTime?
  walletBalance Float?
  // #792 — GSTIN (Goods & Services Tax Identification Number). 15-char
  // alphanumeric (e.g. "27ABCDE1234F1Z5"). Stored as-typed (route-layer
  // upper-cases for canonicality). Surfaced on invoices for B2B billing
  // (corporate-account patients, salon-on-salon recharge, etc.).
  gst           String?   @db.VarChar(15)
  /// Free-text tag list for patient segmentation. Used by #931 bulk-tag-add
  /// UI + filter-by-tag in Patients page. Storage matches the canonical
  /// JSON-string-column convention used elsewhere in this schema
  /// (SequenceStep.conditionJson, AbTest.variantA/B, ReportSchedule.metrics,
  /// Campaign.scheduleFilters, etc. — see CLAUDE.md "Standing rules" §
  /// JSON-string columns): String? @db.Text holding a JSON-stringified
  /// array of strings (e.g. '["vip","diabetic","new"]'). Contact has no
  /// tags column today, so this also establishes the shape for a symmetric
  /// Contact.tags field if/when bulk-tag-add ships for Contact too. Route
  /// layer stringifies on write + JSON.parses on read. Null = no tags.
  tagsJson      String?   @db.Text

  // CRM-style classification used by the create-customer modal.
  //   taxType         : "individual" | "business" — drives downstream
  //                     invoice / accounting flow.
  //   instagramHandle : free-text social handle (no leading @ enforced).
  taxType         String?
  instagramHandle String?

  // S62 — slim-shape PRD additions per S42 carry-over. The slim
  // projection contract surfaces a row's "header" (id + name parts +
  // last-visit anchor) without loading the full PHI payload — useful
  // for list views, Omnibar quick-pick, and external-API minimal
  // projections.
  //   firstName     : structured given name (legacy `name` stays the
  //                   canonical "as-displayed" full name; firstName +
  //                   lastName are additive split fields populated by
  //                   intake form when available).
  //   lastName      : structured family name (paired with firstName).
  //   displayName   : operator-set / computed UI-rendered name. Useful
  //                   for "name-as-displayed" vs canonical legal name
  //                   (e.g. "Dr. K. Reddy" displayName over the legal
  //                   "Kavita Reddy" name). Null falls back to `name`.
  //   lastVisitDate : denormalized cache of MAX(visits.visitDate) for
  //                   this patient. THIS SLICE adds the column ONLY;
  //                   population logic (Visit insert hook + backfill
  //                   cron) is deferred as a follow-up gap row. Reads
  //                   without population logic SHOULD treat null as
  //                   "unknown / not yet computed", not "no visits".
  // All four are additive nullable — no default backfill needed; the
  // slim-projection consumer in lib/listProjection.js will be updated
  // in a paired follow-up slice (S42 consumer extension).
  firstName     String?
  lastName      String?
  displayName   String?
  lastVisitDate DateTime?

  // #413 — Restrict (not Cascade) on Tenant deletion. Patient is PHI
  // (medical history, allergies, photos, prescriptions cascade-from-here).
  // A misclick on tenant.delete() must NOT silently destroy clinical
  // records. Operator must explicitly drain Patient rows first.
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  // Primary clinic location (multi-location ready; nullable for now)
  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // Self-booking user (wellness users can book their own appointments)
  // Composite unique constraint: prevents duplicate userId within a tenant,
  // but allows different tenants to each link a patient to the same user.
  userId Int?
  user   User? @relation("PatientUser", fields: [userId], references: [id], onDelete: SetNull)

  visits              Visit[]
  prescriptions       Prescription[]
  consents            ConsentForm[]
  treatmentPlans      TreatmentPlan[]
  // Agent B: waitlist back-relation
  waitlists           Waitlist[]
  // Agent D: loyalty + referrals back-relations
  loyaltyTransactions LoyaltyTransaction[]
  referrals           Referral[]           @relation("ReferrerOf")
  // Wave 11 Agent EE: memberships (time-bound prepaid service bundles)
  memberships         Membership[]
  // Wave 11 Agent FF: per-patient wallet (one-to-one). Holds running balance
  // + ledger of credits (gift cards, cashback, manual refunds) and debits
  // (purchase, manual reversal). Created lazily on first /wallet read.
  wallet              Wallet?
  // Wave 2 Agent KK: 2-way WhatsApp threads where this patient is counterparty.
  whatsappThreads     WhatsAppThread[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // #628 — soft-delete column (mirrors Contact / Deal pattern from #167).
  // Default lists filter `deletedAt: null`; restore endpoint clears it.
  // Cascading rows (Visit / Prescription / ConsentForm / TreatmentPlan)
  // are NOT cascade-deleted on soft-delete — they remain queryable for
  // audit + clinical-history retention. Hard purge runs through the
  // /privacy retention engine after the configured tombstone window (#576).
  deletedAt DateTime?
  // Wave 2 Agent II — POS sales rung up against this patient.
  sales     Sale[]

  // Patient tag join rows. Soft-deletes leave PatientTag rows orphaned —
  // the route handler filters by patient.deletedAt at read time, so dangling
  // tag links resurrect on patient restore.
  tags PatientTag[]

  // Patient-portal notification inbox (additive — see PatientNotification).
  patientNotifications PatientNotification[]

  /// One Patient per (tenant, normalized phone number). DB-level dedup gate guarding against the recurring "same patient created N times by overlapping intake flows" inflation pattern. Cross-tenant duplicates allowed — different clinics can each have a Patient with phone +91-9876543210.
  // #401 — DB-level dedup gate. Pre-this-constraint, the dedup logic
  // lived in lib/leadJunkFilter + the route handler's best-effort
  // findFirst — both bypassable. With @@unique enforced, Prisma throws
  // P2002 on the second create with the same (tenant, normalizedPhone)
  // pair; the route handler's catch translates to HTTP 409 with code
  // DUPLICATE_PHONE. Backfill + merge MUST run before this can apply
  // — see backend/scripts/backfill-patient-normalized-phone.js.
  @@unique([tenantId, normalizedPhone], name: "patient_tenant_normalized_phone_unique")
  // safe-unique: replaces the single-column `userId @unique` removed in
  // d8aab25; 0c9b59a already verified zero duplicate userId in the live
  // Patient table, and (tenantId, userId) is strictly ≤ as strict.
  @@unique([tenantId, userId], name: "patient_tenant_user_unique")
  @@index([tenantId, name])
  @@index([tenantId, phone])
  @@index([tenantId, email])
  @@index([tenantId, locationId])
  @@index([tenantId, userId])
  @@index([contactId])
  // #534 (PERF-1): Patient list query is `where: { tenantId } orderBy: { createdAt: desc }`.
  // The composite (tenantId, createdAt) index lets MySQL satisfy both the
  // tenant scope AND the orderBy from the index alone, avoiding the filesort
  // observed on cold calls.
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
}

model Service {
  id   Int    @id @default(autoincrement())
  name String

  // Wave 7 Agent A — Service Catalogue depth (PRD Gap §10 item 1).
  // The legacy `category` String column is kept as a transition mirror so
  // older frontends + integrations that read it stay working. New code
  // should write to `categoryId` (FK → ServiceCategory) and only fall back
  // to the string column for back-compat.
  // TODO: drop the legacy `category` column in v3.6.0 once the React
  //       frontend + the wellness external API consumers have migrated.
  category        String? // hair, skin, salon, slimming, ayurveda, aesthetics (DEPRECATED — use categoryId)
  categoryId      Int?
  serviceCategory ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  ticketTier      String  @default("medium") // low, medium, high
  basePrice       Float   @default(0)
  discountedPrice Float? // discounted / promotional price (Zylu import)
  durationMin     Int     @default(30)
  targetRadiusKm  Int? // null = unlimited
  description     String? @db.Text
  isActive        Boolean @default(true)

  // Zylu POS import fields (v3.7.16 Wave 1)
  gender                String? // Unisex, Male, Female (for salon/beauty services)
  code                  String? // service code from POS system (e.g. SKU)
  isStartingPrice       Boolean @default(false)
  isHomeService         Boolean @default(false)
  hidePriceFromCustomer Boolean @default(false)
  tax                   Float? // tax percentage or amount
  isTaxIncluded         Boolean @default(false) // is basePrice inclusive of tax
  displayOrder          Int     @default(0) // sort order in picker/list (lower = earlier)
  imageUrls             String? @db.Text // JSON array of image URLs

  // Wave 2 Agent LL — booking-widget completion (2026-05-08 Google Doc audit).
  // JSON-string column listing the BookingType variants this service supports
  // (e.g. ["CLINIC_VISIT","IN_HOME","VIDEO"]). Public booking widget filters
  // the picker by this list; server cross-checks on POST /public/book and
  // returns 422 BOOKING_TYPE_NOT_SUPPORTED if the chosen type is not allowed.
  // null/empty = legacy default (CLINIC_VISIT only) — preserves backwards
  // compatibility with seeded services that pre-date this column.
  // String? @db.Text per the project's standing JSON-string-column rule
  // (mirrors SequenceStep.conditionJson, MembershipPlan.entitlements, etc.).
  supportedBookingTypes String? @db.Text // JSON array of BookingType strings

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  visits               Visit[]
  treatmentPlans       TreatmentPlan[]
  consents             ConsentForm[]
  // Wave 11 Agent HH — auto-consumption rules per service (back-relation).
  autoConsumptionRules AutoConsumptionRule[]

  createdAt DateTime @default(now())

  @@index([tenantId, isActive])
  @@index([tenantId, ticketTier])
  @@index([tenantId, categoryId])
}

model Visit {
  id            Int      @id @default(autoincrement())
  visitDate     DateTime @default(now())
  status        String   @default("completed") // booked, arrived, in-treatment, completed, no-show, cancelled
  vitals        String?  @db.Text // JSON: bp, pulse, weight, etc.
  notes         String?  @db.Text
  // Patient-supplied chief complaint / reason for the appointment. Required at
  // the self-booking form (BookAppointment.jsx) but nullable in DB so legacy
  // staff-side creates (Calendar drag, public-widget) still validate.
  reason        String?  @db.Text
  photosBefore  String?  @db.Text // JSON array of URLs
  photosAfter   String?  @db.Text // JSON array of URLs
  amountCharged Float?

  // Agent B: telehealth — Jitsi room name (e.g. "gbs-123-john-doe")
  videoRoom String?

  // Wave 2 Agent LL — booking-widget completion (2026-05-08 Google Doc audit).
  // bookingType: which CHANNEL the appointment runs through.
  //   CLINIC_VISIT — patient comes to the clinic (legacy default; visit happens at locationId)
  //   IN_HOME      — staff travels to the patient's address (atHomeAddress + atHomePincode required)
  //   VIDEO        — telehealth call (videoCallUrl populated; locationId optional)
  //   PHONE        — voice-only consult (no address, no video link)
  // String column (not Prisma enum) per project convention — matches the
  // soft-enum pattern used by Visit.status / Service.ticketTier / Patient.source.
  bookingType String @default("CLINIC_VISIT")

  // IN_HOME visits — patient address (NOT the clinic location). Stored on the
  // Visit row rather than the Patient row because the same patient can book
  // an IN_HOME visit at one address (home) one week and a different address
  // (parent's house) the next; no benefit to denormalising onto Patient.
  atHomeAddress     String? @db.Text // multi-line: building, flat, landmark
  atHomeCity        String?
  atHomePincode     String?
  // Estimated travel time (minutes) dispatch allocates for the staff member
  // to reach the address. MVP: defaults to 30 min on IN_HOME.
  // Future: pincode-distance-based + dynamic per location.
  travelTimeMinutes Int?

  // VIDEO visits — auto-generated meet link (Jitsi-style room URL or external
  // provider link if configured). Distinct from videoRoom above (which is the
  // Jitsi room NAME — telehealth-internal); videoCallUrl is the sharable URL
  // the patient receives in the booking-confirmation SMS / email.
  videoCallUrl String?

  // UTM capture from the public booking widget — every public visit can be
  // attributed back to the marketing campaign that drove it. Mirrored across
  // all 5 standard utm_* fields plus the HTTP Referer header. Persisted on
  // Visit (not a separate Booking row) because /public/book is the only
  // public-create surface, and joining a side table for attribution reports
  // doubles the read cost. Per-row null-default keeps existing rows clean.
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  referrer    String? @db.Text // can be a long URL with query params

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  doctorId Int?
  doctor   User? @relation("DoctorVisits", fields: [doctorId], references: [id], onDelete: SetNull)

  serviceId Int?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  treatmentPlanId Int?
  treatmentPlan   TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id], onDelete: SetNull)

  // Optional membership applied to this booking. The patient picks an active
  // membership at booking time; the redemption is recorded on visit completion
  // (not at booking) so cancellations don't drain balance. SetNull on
  // membership deletion so the visit row survives membership purges.
  membershipId Int?
  membership   Membership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  // #413 — Restrict (not Cascade) on Tenant deletion. Visit is PHI
  // (medical encounters, vitals, before/after photos, charged amounts).
  // A misclick on tenant.delete() must NOT silently destroy clinical
  // history. Operator must explicitly drain Visit rows first.
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  // Multi-location: which clinic the visit happened at
  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // Wave 11 Agent GG — optional resource reservation.
  resourceId Int?
  resource   Resource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  prescriptions Prescription[]
  consumptions  ServiceConsumption[]

  // #601 — invoices linked to this visit. Per-visit revenue rollup sums
  // amount across rows where status='PAID'. amountCharged on the visit row
  // is the inline fallback when no invoice has been raised yet.
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, visitDate])
  @@index([patientId, visitDate])
  @@index([tenantId, status])
  @@index([tenantId, locationId, visitDate])
  // Wave 2 Agent LL — tenant-scoped bookingType + UTM filtering
  // (e.g. "show me all IN_HOME visits this week", "GROUP BY utmSource for
  // last-30-day attribution dashboard"). Both predicates are tenant-scoped
  // first per the project's standing tenant-isolation index pattern.
  @@index([tenantId, bookingType, visitDate])
  @@index([tenantId, utmSource])
}

model Prescription {
  id           Int     @id @default(autoincrement())
  drugs        String  @db.Text // JSON array: [{name, dosage, frequency, duration}]
  instructions String? @db.Text
  pdfUrl       String?

  // S62 — slim-shape PRD additions per S42 carry-over.
  //   status       : lifecycle marker. Conventional values:
  //                  'draft'     — composed, not yet issued
  //                  'issued'    — handed to / sent to patient
  //                  'dispensed' — pharmacy filled (paired with dispensedAt)
  //                  'cancelled' — voided post-issue
  //                  Stored as String? (not enum) for additive safety +
  //                  future enum upgrade once the value set stabilises.
  //                  Null = legacy row (pre-S62); route layer treats
  //                  null as 'issued' for back-compat. Enum-upgrade
  //                  decision deferred as a follow-up gap row.
  //   dispensedAt  : timestamp the prescription was dispensed by the
  //                  pharmacy. Set by POS pharmacy-dispense action;
  //                  null until that action fires. Used by clinical-audit
  //                  reports + controlled-substance compliance views.
  // Both additive nullable — no bless marker needed.
  status      String?
  dispensedAt DateTime?

  visitId Int?
  visit   Visit? @relation(fields: [visitId], references: [id], onDelete: SetNull)

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId Int?
  doctor   User? @relation("DoctorPrescriptions", fields: [doctorId], references: [id], onDelete: SetNull)

  // #413 — Restrict (not Cascade) on Tenant deletion. Prescription is PHI
  // (controlled-substance dosages, regulatory record-of-prescriber).
  // A misclick on tenant.delete() must NOT silently destroy prescribing
  // history. Operator must explicitly drain Prescription rows first.
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([patientId])
}

model ConsentForm {
  id              Int     @id @default(autoincrement())
  templateName    String // "hair-transplant", "botox", "fillers", "general"
  signedPdfUrl    String?
  signatureSvg    String? @db.LongText // captured signature SVG/dataURL
  // #564 — immutable snapshot of the consent template body the patient
  // agreed to AT SIGN TIME. Captured server-side in POST /consents from
  // the matching ConsentTemplate.body so future template edits cannot
  // retroactively alter what the patient signed. Required by DPDP §15
  // (the data-fiduciary must produce the exact wording shown to the
  // patient on demand) and by clinical-audit reviewers. Nullable for
  // back-compat with rows captured before the field shipped.
  contentSnapshot String? @db.LongText

  // #564 v3.7.3 — staff-tablet-handoff workflow + DB BLOB storage
  // disposition. captureMethod pins HOW the consent was collected so
  // audit reviewers can grep one verb across the audit log; defaults to
  // 'tablet-handoff' because the wellness staff-tablet flow is the
  // chosen primary workflow. capturedByUserId records WHO facilitated
  // the capture (the staff member operating the tablet). signedPdfBlob
  // is an optional frozen archive — POST /consents/:id/archive renders
  // the PDF once and persists the exact bytes so future PDF-renderer
  // upgrades cannot retroactively alter the document the patient saw.
  captureMethod    String? @default("tablet-handoff") // tablet-handoff | portal-self-serve | imported-pdf
  capturedByUserId Int?
  signedPdfBlob    Bytes?  @db.MediumBlob // stored PDF buffer after signing
  signedPdfMime    String? @default("application/pdf")
  hasPdfBlob       Boolean @default(false) // flag for list queries (avoid loading full BLOB)

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  serviceId Int?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  signedAt DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, signedAt])
  @@index([patientId])
}

/// #612: per-tenant consent template catalogue. Pre-fix the consent
/// dropdown rendered 5 hardcoded options (hair-transplant / botox-fillers
/// / laser / chemical-peel / general). Clinics with paediatric or
/// procedure-specific flows had no way to add their own legally-vetted
/// wording. This row stores the editable catalogue; ConsentForm.templateName
/// continues to reference the chosen template by string key (immutable
/// once signed — that's the whole point).
model ConsentTemplate {
  id        Int      @id @default(autoincrement())
  key       String // stable identifier used by ConsentForm.templateName
  label     String // human-readable name shown in dropdown
  body      String?  @db.LongText // optional HTML body for the consent form
  language  String   @default("en")
  isActive  Boolean  @default(true)
  isSeed    Boolean  @default(false) // true for the 5 seeded starter rows
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, isActive])
}

/// Generic per-tenant key/value settings (PRD §4.7 + 2026-05-24 product-
/// call). Each row is a freeform string value keyed by `(tenantId, key)`;
/// callers parse `value` into whatever shape they need (number, JSON
/// blob, boolean string). Consumers so far:
///   PRD §4.7 travel advance-ratio:
///     key = "travel.advanceRatio.default"             value = "0.5"
///     key = "travel.advanceRatio.travelstall"         value = "0.5"
///     key = "travel.advanceRatio.rfu"                 value = "0.3"
///   2026-05-24 per-tenant budget cap pattern (AdsGPT DC-2, AI_CALLING
///   DC-1, RateHawk DC-1) — values stored as USD cents (integers):
///     key = "budgetCap_adsgpt_monthly_usd_cents"      value = "5000"   ($50.00)
///     key = "budgetCap_ai_calling_monthly_usd_cents"  value = "10000"  ($100.00)
///     key = "budgetCap_ratehawk_monthly_usd_cents"    value = "5000"   ($50.00)
///     key = "budgetCap_llm_monthly_usd_cents"         value = "10000"  ($100.00)
/// Lookup chain in backend/lib/tenantSettings.js:
///   sub-brand-scoped → tenant default → hard-coded fallback (varies by helper).
/// The `@@unique([tenantId, key])` is intentional — every key is
/// per-tenant unique. Brand-new table, zero existing rows when first
/// introduced, so the migration-safety detector's unique-constraint
/// guard was blessed in the introducing commit (`[allow-unique]`).
/// `category` is a NEW nullable column (additive — no bless marker
/// needed) added 2026-05-24 to group settings in the future admin UI
/// ("budget", "feature-flag", "branding", "travel-pricing").
model TenantSetting {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  key       String // dotted/snake namespace, e.g. "travel.advanceRatio.travelstall" or "budgetCap_adsgpt_monthly_usd_cents"
  value     String   @db.Text // freeform; caller parses
  category  String?  @db.VarChar(50) // optional grouping for admin UI: "budget", "feature-flag", "branding"
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, key])
  @@index([tenantId, category])
}

model TreatmentPlan {
  id                Int       @id @default(autoincrement())
  name              String
  totalSessions     Int
  completedSessions Int       @default(0)
  startedAt         DateTime  @default(now())
  nextDueAt         DateTime?
  status            String    @default("active") // active, completed, paused, cancelled
  totalPrice        Float     @default(0)

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)

  serviceId Int?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  visits Visit[]

  @@index([tenantId, status])
  @@index([patientId])
  // #534 (PERF-1): TreatmentPlan list query is `where: { tenantId, patientId? }
  // orderBy: { startedAt: desc }`. Same shape as Patient — composite index
  // covers both the tenant filter and the orderBy. Saves the filesort.
  @@index([tenantId, startedAt])
}

model ServiceConsumption {
  id          Int    @id @default(autoincrement())
  productName String
  qty         Float  @default(1) // quantity in ml (or product's unit)
  unitCost    Float  @default(0)

  visitId Int
  visit   Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  productId Int? // loose ref to Product

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([visitId])
  @@index([tenantId, createdAt])
}

model AgentRecommendation {
  id          Int     @id @default(autoincrement())
  type        String // "campaign_boost", "lead_followup", "occupancy_alert", "schedule_gap"
  title       String
  body        String  @db.Text
  payload     String? @db.Text // JSON action data
  priority    String  @default("medium") // low, medium, high
  status      String  @default("pending") // pending, approved, rejected, snoozed
  goalContext String? // "100% occupancy", "maximize ROAS", etc.

  expectedImpact String? @db.Text // human-readable: "+3 bookings this week, ROAS 4.5x"

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdById  Int? // null = generated by orchestrator
  resolvedById Int?
  resolvedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId, status, priority])
  @@index([tenantId, createdAt])
}

// Multi-location support — one tenant (e.g. Enhanced Wellness) can run several
// physical clinics (Ranchi today, Delhi/Mumbai/Pune tomorrow as franchises).
// Patients and visits link to a Location so per-clinic occupancy and revenue
// are reportable.
model Location {
  id          Int     @id @default(autoincrement())
  name        String // Display name e.g. "Ranchi"
  addressLine String  @db.Text
  city        String
  state       String?
  pincode     String?
  country     String  @default("India")
  phone       String?
  email       String?
  latitude    Float?
  longitude   Float?
  timezone    String  @default("Asia/Kolkata")
  isActive    Boolean @default(true)

  // Operating hours JSON: { mon: ["09:00","20:00"], tue: ..., sun: null }
  hours String? @db.Text

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  patients  Patient[]
  visits    Visit[]
  // Wave 11 Agent GG — resources + holidays scoped to this clinic.
  resources Resource[]
  holidays  Holiday[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  // Wave 2 Agent II — physical/virtual cash registers.
  registers Register[]

  @@index([tenantId, isActive])
  @@index([tenantId, city])
}

// Per-tenant wellness role catalog. Replaces the hard-coded
// VALID_WELLNESS_ROLES whitelist in routes/staff.js so admins can add
// custom roles (e.g. "nurse", "physio") from Settings without a code
// change. `key` is the slug stored on User.wellnessRole; `label` is
// the display name shown in dropdowns. `canTakeVisits` flags roles
// that should appear as columns on the Calendar grid (doctor /
// professional / nurse — but not telecaller / helper, who don't take
// patient visits).
model WellnessRoleType {
  id            Int     @id @default(autoincrement())
  key           String // slug: "doctor", "nurse", "physio"
  label         String // display: "Doctor", "Nurse", "Physiotherapist"
  icon          String? // optional lucide icon name; null = default Stethoscope
  color         String? // optional hex/css color for chip; null = theme default
  canTakeVisits Boolean @default(true)
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, tenantId])
  @@index([tenantId, isActive])
}

// ─────────────────────────────────────────────────────────────────────
// Agent A: low stock support
// Prisma can't extend a model from outside its block, so the actual fields
// (`threshold`, `currentStock`) are added inline on the existing Product
// model. Engine: backend/cron/lowStockEngine.js (daily 09:00 IST, wellness).
// ─────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────
// Agent B: waitlist
// Patients who couldn't be slotted on their preferred date go on a
// waitlist. When a Visit is cancelled, the cancellation hook in
// PUT /visits/:id finds the first matching waitlist entry (same
// serviceId, status=waiting) and transitions it to "offered" while
// queueing an outbound SMS via the existing SmsMessage table.
// ─────────────────────────────────────────────────────────────────────
model Waitlist {
  id                 Int       @id @default(autoincrement())
  patientId          Int
  patient            Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  serviceId          Int?
  locationId         Int?
  preferredDateRange String? // ISO range "2026-04-25..2026-05-05" or "asap"
  status             String    @default("waiting") // waiting, offered, booked, expired, cancelled
  notes              String?   @db.Text
  offeredAt          DateTime?
  expiresAt          DateTime?
  tenantId           Int       @default(1)
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([patientId])
}

// ─────────────────────────────────────────────────────────────────────
// Agent B: patient portal OTP
// Stores 4-digit one-time codes issued via /portal/login/request-otp
// and validated by /portal/login/verify-otp. Plaintext is acceptable
// for v1 (10-min expiry, single-use). Indexed by phone+otp for the
// hot lookup path during verify, and by tenantId+expiresAt for any
// future cleanup cron.
// ─────────────────────────────────────────────────────────────────────
model PatientOtp {
  id        Int      @id @default(autoincrement())
  phone     String
  otp       String // 4-digit code (plaintext OK for v1)
  used      Boolean  @default(false)
  expiresAt DateTime
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([phone, otp])
  @@index([tenantId, expiresAt])
}

// ─────────────────────────────────────────────────────────────────────
// Agent D: loyalty points + referral tracking
// LoyaltyTransaction is an append-only ledger; balance = SUM(points).
// Referral lifecycle: pending -> signed_up -> first_visit -> rewarded.
// ─────────────────────────────────────────────────────────────────────
model LoyaltyTransaction {
  id        Int      @id @default(autoincrement())
  patientId Int
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  type      String // earned, redeemed, expired, referral_bonus, manual_credit
  points    Int // positive = credit, negative = redemption
  reason    String? // human description
  visitId   Int? // optional link to Visit that earned the points
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([tenantId, patientId, createdAt])
}

// #614 — per-tenant Loyalty earn/burn rule config. One row per tenant. Drives:
//   - the auto-credit-on-completed-visit hook in routes/wellness.js
//   - the manager-facing rules card on the Loyalty page (so the rules are
//     no longer invisible / hardcoded in JS)
// Numeric fields are nullable + zero-defaulted; null/0 means "rule disabled".
// All amounts are tenant-currency (formatMoney resolves the unit at render).
model LoyaltyConfig {
  id                  Int      @id @default(autoincrement())
  tenantId            Int      @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Earn rules
  earnPerVisit        Int      @default(0) // flat points per completed visit
  earnPercentOfSpend  Float    @default(10) // % of amountCharged → points (default 10 mirrors the historic hardcoded rule)
  earnPerCurrencyUnit Float    @default(0) // points per 1 currency unit (alt to %); e.g. 0.01 = 1pt per ₹100
  // Burn / redemption
  redeemPointsPerUnit Int      @default(10) // points needed to redeem 1 currency unit (e.g. 10 pts = ₹1)
  // Bonuses
  welcomeBonus        Int      @default(0) // points credited on patient signup
  referralBonus       Int      @default(100) // default points awarded per successful referral
  // Toggles
  autoEarnEnabled     Boolean  @default(true)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

model Referral {
  id                Int       @id @default(autoincrement())
  referrerPatientId Int
  referrer          Patient   @relation("ReferrerOf", fields: [referrerPatientId], references: [id], onDelete: Cascade)
  referredName      String
  referredPhone     String
  referredEmail     String?
  referredPatientId Int? // populated when referred patient signs up
  status            String    @default("pending") // pending, signed_up, first_visit, rewarded
  rewardPoints      Int? // populated when rewarded
  tenantId          Int       @default(1)
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now())
  rewardedAt        DateTime?

  @@index([referrerPatientId])
  @@index([tenantId, status])
}

// Issue #180 — JWT revocation. Stores tokens (by jti claim) that have been
// revoked before their natural 7-day expiry. verifyToken consults this table
// on every request when the incoming token has a jti. expiresAt mirrors the
// JWT's own exp so a future cron job can purge rows whose tokens are already
// dead anyway, keeping the table bounded.
model RevokedToken {
  id        Int      @id @default(autoincrement())
  jti       String   @unique
  userId    Int
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  revokedAt DateTime @default(now())
  expiresAt DateTime
  reason    String?

  @@index([jti])
  @@index([userId, tenantId])
  @@index([expiresAt])
}

// #592 — Dismiss persistence for Contacts → Find Duplicates. The duplicate
// detector at GET /api/contacts/duplicates/find is purely structural (re-runs
// on every call), so without a persisted "the operator already reviewed this
// group and decided it's NOT a duplicate" signal, dismissed pairs would
// re-surface on every refresh. groupKey is a stable hash of the sorted
// contact IDs in the group (primary + duplicates) — re-deriving the same
// group from the same contacts produces the same key, so the dismiss is
// sticky. Soft-deleting any member of a dismissed group invalidates that
// group naturally (the detector won't see the deleted contact), which is
// the desired UX. Per-tenant scoped.
model DismissedDuplicateGroup {
  id          Int      @id @default(autoincrement())
  // SHA-256 hex of the sorted contact-id list, comma-joined. Stable across
  // calls; re-creates that hit the same key are idempotent.
  groupKey    String
  // The sorted contact IDs that made up the group at dismiss time, stored
  // as a comma-separated string. Used for audit/debug only — the dedup
  // check goes through groupKey.
  contactIds  String   @db.Text
  reason      String?
  dismissedBy Int?
  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([tenantId, groupKey])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────
// Wave 11 Agent EE — Memberships (Google Doc audit, 8 May 2026)
//
// Wellness clinics sell time-bound packages of services ("Gold Facial Pack:
// 10 facials over 6 months for ₹15,000"). Three models:
//
//   MembershipPlan         — the catalog row (price, validity, entitlements)
//   Membership             — a patient's purchased instance (with balance)
//   MembershipRedemption   — append-only log of each redemption event
//
// Why entitlements / balance are JSON-stringified Text columns (not relational
// rows): each plan's entitlements are { serviceId, quantity }[] and each
// membership's running balance is { serviceId, remaining }[]. Modelling this
// as a relational table (MembershipPlanEntitlement, MembershipBalanceLine)
// would add 2 extra tables + 4 extra queries per redemption, when in practice
// (a) entitlement counts are 1-5 services per plan and (b) the balance is
// always read+written as a unit during a redemption transaction. JSON-string
// columns mirror the existing pattern for SequenceStep.conditionJson, AbTest
// variantA/B, etc. Decoded shape is documented above each field.
// ─────────────────────────────────────────────────────────────────────
model MembershipPlan {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @default(1)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  description  String?  @db.Text
  durationDays Int
  price        Float
  currency     String   @default("INR")
  // JSON array of { serviceId: Int, quantity: Int } stamped onto each
  // Membership.balance at purchase. Stored as String so older MySQL
  // installs without native JSON aren't required.
  entitlements String   @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]

  @@index([tenantId, isActive])
}

model Membership {
  id               Int            @id @default(autoincrement())
  tenantId         Int            @default(1)
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId        Int
  patient          Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  planId           Int
  plan             MembershipPlan @relation(fields: [planId], references: [id])
  startDate        DateTime
  endDate          DateTime
  // JSON array of { serviceId: Int, remaining: Int } — decremented on each
  // redemption. Stamped from plan.entitlements at purchase. Hits 0 → 409
  // MEMBERSHIP_BALANCE_EXHAUSTED on next redeem for that service.
  balance          String         @db.Text
  status           String         @default("active")
  invoiceId        Int?
  cancelledAt      DateTime?
  cancelReason     String?
  // PRD Gap §12 #4d — single dedup marker for the T-7 expiry notification.
  // The wellnessOps engine sets this the first time it fires the
  // "membership expiring soon" notification so subsequent hourly ticks
  // skip already-notified rows. Cheaper than re-querying the Notification
  // table per membership per tick.
  expiryNotifiedAt DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  redemptions MembershipRedemption[]
  visits      Visit[]

  @@index([tenantId, patientId, status])
  @@index([tenantId, endDate])
}

model MembershipRedemption {
  id           Int        @id @default(autoincrement())
  tenantId     Int        @default(1)
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membershipId Int
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  visitId      Int?
  serviceId    Int
  redeemedAt   DateTime   @default(now())
  redeemedBy   Int

  @@index([tenantId, membershipId])
}

// ─────────────────────────────────────────────────────────────────────
// Wave 11 Agent HH — Inventory backbone (Google Doc audit, 8 May 2026)
//
// Closes 4 explicit gaps + 1 derived: ProductCategory (taxonomy), Vendor
// (supplier master), InventoryReceipt (incoming stock — increments
// Product.currentStock; tenant-scoped human-readable RCP-YYYY-NNNN id),
// InventoryAdjustment (signed quantityDelta for shrinkage/damage/expiry/
// recount/transfer; mirrors QuickBooks' debit-credit semantics where a
// positive delta credits stock and a negative delta debits it),
// AutoConsumptionRule (per-service-per-product quantityPerVisit applied
// on visit-create → decrements Product.currentStock + creates a
// ServiceConsumption row, so reports stay accurate even when staff
// forget to record consumption manually).
//
// Why no Purchase Order model: PO workflow (vendor RFQ → order → partial
// receipts) is intentionally out of scope here. Receipts can be created
// directly without a parent PO; if a clinic needs PO ↔ receipt linkage,
// that's a v3.5+ extension. Documented in TODOS as a follow-up.
// ─────────────────────────────────────────────────────────────────────

model ProductCategory {
  id        Int               @id @default(autoincrement())
  tenantId  Int               @default(1)
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  color     String? // Category color for UI (hex code)
  // Self-referential hierarchy for sub-categories ("Consumables > Sterile >
  // Needles"). SetNull so deleting a parent doesn't cascade-delete children;
  // they bubble up to the root and the admin can re-nest manually.
  parentId  Int?
  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProductCategory[] @relation("CategoryHierarchy")
  isActive  Boolean           @default(true)
  // #845 — optional image/icon thumbnail for the category. Served as a static
  // URL like "/uploads/product-categories/pc-<stamp>.png" via the multer disk
  // pattern from routes/booking_pages.js. Nullable + VarChar(500) keeps the
  // migration additive (no [allow-*] bless marker needed per CLAUDE.md).
  imageUrl  String?           @db.VarChar(500)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  products Product[]

  @@index([tenantId, parentId])
  @@index([tenantId, isActive])
}

model Vendor {
  id            Int      @id @default(autoincrement())
  tenantId      Int      @default(1)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  contactPerson String?
  phone         String?
  email         String?
  gstin         String? // Indian GST ID (15 chars). Optional — non-GST vendors exist.
  addressLine   String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  receipts InventoryReceipt[]

  @@index([tenantId, isActive])
}

model InventoryReceipt {
  id                    Int       @id @default(autoincrement())
  tenantId              Int       @default(1)
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Tenant-scoped human-readable id ("RCP-2026-0001"). Generated server-side
  // per tenant — do NOT use the autoincrement id in customer-facing artefacts.
  receiptNumber         String
  // Supplier's own invoice number (e.g. "LE0155", "BHNS/TI/26/01175") — distinct
  // from our internal receiptNumber. Captured for vendor reconciliation and
  // GST audit trails. Optional because samples / in-kind transfers have no
  // paper invoice.
  supplierInvoiceNumber String?
  vendorId              Int?
  vendor                Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  productId             Int
  product               Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity              Float // received units (Float so we can support fractional mL/g)
  unitCost              Float
  totalCost             Float // computed = quantity * unitCost; stored for fast P&L rollups
  // Optional batch / expiry tracking — wellness clinical inventory needs this
  // for FIFO consumption + expiry alerts.
  batchNumber           String?
  expiryDate            DateTime?
  receivedAt            DateTime  @default(now())
  receivedBy            Int // userId
  notes                 String?   @db.Text
  createdAt             DateTime  @default(now())

  @@unique([tenantId, receiptNumber])
  @@index([tenantId, productId, receivedAt])
}

model InventoryAdjustment {
  id            Int      @id @default(autoincrement())
  tenantId      Int      @default(1)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Signed delta — POSITIVE credits stock (e.g. recount surplus, transfer-in),
  // NEGATIVE debits stock (shrinkage, damage, expiry, transfer-out). Mirrors
  // QuickBooks' debit/credit ledger: every audit-traceable stock change
  // outside of receipts/auto-consumption goes through this row.
  quantityDelta Float
  reason        String // SHRINKAGE | DAMAGE | EXPIRY | RECOUNT | TRANSFER_OUT | TRANSFER_IN | MANUAL
  notes         String?  @db.Text
  performedBy   Int // userId
  createdAt     DateTime @default(now())

  @@index([tenantId, productId, createdAt])
}

model AutoConsumptionRule {
  id               Int      @id @default(autoincrement())
  tenantId         Int      @default(1)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId        Int
  service          Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  productId        Int
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Units of `product` consumed per `service` visit (e.g. 3.5 for 3.5 mL of
  // saline per facial). Float so fractional mL/g/cc are representable.
  quantityPerVisit Float
  // Unit the admin entered the quantity in (ml, gm, kg, piece, unit, bottle,
  // tube, pack, ltr). Nullable for back-compat — when null, the applier falls
  // back to Product.unit. Validated against the allowed enum in the route.
  unit             String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // One rule per (service, product) pair within a tenant. Editing the
  // quantity is an UPDATE, not a duplicate insert.
  @@unique([tenantId, serviceId, productId])
  @@index([tenantId, serviceId, isActive])
}

// ─────────────────────────────────────────────────────────────────────
// Wave 11 Agent FF — Composite ledger system (Google Doc audit, 8 May 2026).
//
// Wallet            — one-per-Patient, holds running balance.
// WalletTransaction — append-only ledger; positive amount = credit, negative
//                     = debit (mirrors QuickBooks convention). balanceAfter
//                     captured at write time so audits don't need to walk the
//                     full history.
// GiftCard          — purchasable code; on redeem credits a Patient's wallet
//                     and flips status=redeemed (one-time use).
// Coupon            — percent or flat discount; preview-able pre-apply, then
//                     atomically applied (incrementing redemptionCount).
// CashbackRule      — % of paid amount earns wallet credit on visit completion.
//
// All rows are tenant-scoped via tenantId (cascade-delete on tenant removal).
// All currency-bearing rows carry an explicit `currency` so multi-currency
// tenants don't lose context when a tenant flips defaultCurrency mid-flight.
// ─────────────────────────────────────────────────────────────────────
model Wallet {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId Int      @unique
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  balance   Float    @default(0)
  currency  String   @default("INR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions  WalletTransaction[]
  // D16 Wallet Top-up (PRD_WALLET_TOPUP §3) — FIFO credit batches for
  // per-record sliding-30-day usage metering. See WalletCreditBatch.
  creditBatches WalletCreditBatch[]

  @@index([tenantId, patientId])
}

model WalletTransaction {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @default(1)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  walletId     Int
  wallet       Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type         String
  amount       Float
  reason       String?
  visitId      Int?
  invoiceId    Int?
  giftCardId   Int?
  couponId     Int?
  balanceAfter Float
  performedBy  Int
  createdAt    DateTime @default(now())

  @@index([tenantId, walletId, createdAt])
  @@index([tenantId, type])
}

// D16 Wallet Top-up — Arc 1 Slice 1 (PRD_WALLET_TOPUP §3 + DD-5.2 round-2
// RESOLVED 2026-05-25). Operator-configurable rules that govern bonus credit
// on wallet top-ups: when a patient tops up ≥ minAmountCents, a bonus batch
// of `amount * bonusPercent / 100` is issued that expires after
// validityMonths. `validFrom` / `validTo` window the rule's active dates
// (null = always-on within `active=true`). Slice 5 (admin rules page) CRUDs
// this; Slice 2 (top-up route) reads the highest-threshold matching active
// rule to compute the bonus batch.
model WalletBonusRule {
  id             Int       @id @default(autoincrement())
  tenantId       Int
  name           String    @db.VarChar(100)
  minAmountCents Int // threshold to trigger bonus
  bonusPercent   Decimal   @db.Decimal(5, 2) // e.g. 10.00 for 10%
  validityMonths Int // expiry window after top-up
  active         Boolean   @default(true)
  validFrom      DateTime?
  validTo        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tenant         Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, active])
}

// D16 Wallet Top-up — Arc 1 Slice 1 (PRD_WALLET_TOPUP §3 + DD-5.2 round-2
// RESOLVED 2026-05-25). FIFO redemption-tracking ledger sibling of Wallet.
// Each top-up creates two batches: a PRINCIPAL batch (`expiresAt` null —
// principal never expires) + an optional BONUS batch (`expiresAt` set per
// the matching WalletBonusRule.validityMonths). On redemption (Slice 3),
// batches deplete in FIFO order — soonest-expiry first, then oldest-issued.
// `remainingCents` reaches 0 → status flips to EXHAUSTED; expiry cron
// (Slice 4) sweeps `expiresAt < now()` for ACTIVE bonus batches and flips
// them to EXPIRED. `sourceTransactionId` links the batch to the
// WalletTransaction that minted it; `sourceRuleId` links bonus batches to
// the rule that triggered them (audit + analytics).
model WalletCreditBatch {
  id                  Int       @id @default(autoincrement())
  tenantId            Int
  walletId            Int
  batchType           String    @db.VarChar(20) // 'PRINCIPAL' | 'BONUS'
  amountCents         Int
  remainingCents      Int // depletes as redeemed
  expiresAt           DateTime? // null for principal (never expires); set for bonus
  sourceRuleId        Int? // FK to WalletBonusRule when batchType=BONUS
  sourceTransactionId Int? // FK to WalletTransaction that created this batch
  status              String    @default("ACTIVE") @db.VarChar(20) // 'ACTIVE' | 'EXHAUSTED' | 'EXPIRED'
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  wallet              Wallet    @relation(fields: [walletId], references: [id])

  @@index([walletId, status])
  @@index([tenantId, expiresAt])
}

model GiftCard {
  id           Int       @id @default(autoincrement())
  tenantId     Int       @default(1)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Wave-B Agent 3 (#653) — `code` is now a masked display value, e.g.
  // "ABCD****WXYZ". It is no longer redeemable; redemption uses codeHash.
  // Existing rows on demo were cleared by Wave-A4 cleanup so no backfill
  // is required. The legacy column is kept for back-compat (UI tables that
  // already render `code` as a column will render the mask instead).
  code         String
  // bcrypt hash of the plaintext gift-card code (cost 10). Set on issue;
  // never reversible. Lookup hashes the incoming code via bcrypt.compare.
  codeHash     String?
  // Last-4 of the original plaintext code, kept in cleartext for UI
  // display ("ending in WXYZ") and to narrow candidates during lookup.
  // Not redeemable on its own.
  codeLast4    String?
  // `amount` = the redeemable "gift value" credited to the recipient on
  // redemption. Kept as-is for back-compat with the existing /giftcards
  // and /giftcards/redeem flows.
  amount       Float
  // v3.7.17 additive fields, matching the Zylu-style "Add Gift Card"
  // form (Name + Validity + Gift Value + Price + Color). All nullable —
  // existing GiftCard rows + the legacy issue flow keep working with
  // these unset; the new fields just enable richer template metadata.
  //
  // `name`         — display label, e.g. "New Year's Gift Card".
  // `price`        — what the buyer paid (may be < amount for promo
  //                  cards or > amount for charity / cause cards).
  // `validityDays` — convenience field driving the Validity dropdown
  //                  (90 = 3 months, 180 = 6 months, etc). expiresAt
  //                  is still authoritative; this is just metadata so
  //                  the UI can render the selection back consistently.
  // `color`        — hex string for the on-card UI accent.
  name         String?
  price        Float?
  validityDays Int?
  color        String?
  currency     String    @default("INR")
  status       String    @default("active")
  expiresAt    DateTime?
  issuedTo     Int?
  issuedFrom   Int?
  redeemedAt   DateTime?
  redeemedBy   Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, codeLast4])
}

model Coupon {
  id              Int       @id @default(autoincrement())
  tenantId        Int       @default(1)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code            String
  discountType    String
  discountValue   Float
  maxRedemptions  Int?
  redemptionCount Int       @default(0)
  validFrom       DateTime?
  validUntil      DateTime?
  serviceIds      String?   @db.Text
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model CashbackRule {
  id          Int       @id @default(autoincrement())
  tenantId    Int       @default(1)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  earnPercent Float
  serviceIds  String?   @db.Text
  minSpend    Float?
  isActive    Boolean   @default(true)
  expiresAt   DateTime? // After this instant the rule is skipped at apply-time; null = no expiry
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId, isActive])
  @@index([tenantId, expiresAt])
}

// ─────────────────────────────────────────────────────────────────────
// Wave 11 Agent GG — Resource availability + holidays + working-hours
// (stub models added defensively here so back-relations on Tenant/User/
// Location/Visit validate while Agent GG's commit is in flight). If GG's
// commit lands first these stubs become no-ops; if mine lands first the
// CI / runtime reads the same field shapes Agent GG declared.
// ─────────────────────────────────────────────────────────────────────
model Resource {
  id         Int       @id @default(autoincrement())
  tenantId   Int       @default(1)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  type       String    @default("ROOM")
  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  isActive   Boolean   @default(true)
  serviceIds String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  visits Visit[]

  @@index([tenantId, isActive])
  @@index([tenantId, locationId])
}

model Holiday {
  id                Int       @id @default(autoincrement())
  tenantId          Int       @default(1)
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date              DateTime
  name              String
  locationId        Int?
  location          Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  doctorId          Int?
  doctor            User?     @relation("DoctorHolidays", fields: [doctorId], references: [id], onDelete: SetNull)
  // When true, the holiday repeats every year on the same month/day —
  // the booking-availability gate matches on month+day instead of the
  // exact stored date. Lets admins mark Diwali / Republic Day once.
  recurringAnnually Boolean   @default(false)
  createdAt         DateTime  @default(now())

  @@unique([tenantId, date, locationId, doctorId])
  @@index([tenantId, date])
}

model WorkingHours {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  doctorId  Int
  doctor    User     @relation("DoctorWorkingHours", fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, doctorId, dayOfWeek])
}

// -----------------------------------------------------------------------
// Wave 2 Agent JJ -- Staff Attendance + Biometric stub + Leave Management
// -----------------------------------------------------------------------

model Attendance {
  id       Int    @id @default(autoincrement())
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  date DateTime

  clockInAt          DateTime?
  clockOutAt         DateTime?
  clockInLocationId  Int?
  clockOutLocationId Int?

  source            String @default("MANUAL")
  biometricDeviceId Int?

  totalMinutes Int?

  status String  @default("PRESENT")
  notes  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, date])
  @@index([tenantId, date])
  @@index([tenantId, userId, date])
}

model BiometricDevice {
  id       Int    @id @default(autoincrement())
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  locationId Int?

  deviceId String
  vendor   String

  apiKey String

  lastSyncAt DateTime?
  isActive   Boolean   @default(true)

  createdAt DateTime @default(now())

  @@unique([tenantId, deviceId])
  @@unique([apiKey])
  @@index([tenantId, isActive])
}

model LeavePolicy {
  id       Int    @id @default(autoincrement())
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String

  leaveType String

  annualEntitlement Int

  accrualPattern String @default("UPFRONT")

  carryForwardCap Int?
  encashable      Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  balances LeaveBalance[]
  requests LeaveRequest[]

  @@index([tenantId, isActive])
  @@index([tenantId, leaveType])
}

model LeaveBalance {
  id       Int    @id @default(autoincrement())
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  policyId Int
  policy   LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  periodStart DateTime
  periodEnd   DateTime

  entitled  Int @default(0)
  accrued   Int @default(0)
  used      Int @default(0)
  pending   Int @default(0)
  available Int @default(0)

  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, policyId, periodStart])
  @@index([tenantId, userId])
}

model LeaveRequest {
  id       Int    @id @default(autoincrement())
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)

  policyId Int
  policy   LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Restrict)

  startDate DateTime
  endDate   DateTime

  days Int

  reason String? @db.Text

  status String @default("PENDING")

  approverId    Int?
  approver      User?   @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approverNotes String? @db.Text

  submittedAt DateTime  @default(now())
  decidedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId, userId, status])
  @@index([tenantId, status])
  @@index([tenantId, startDate])
}

// ─────────────────────────────────────────────────────────────────────
// Wave 2 Agent II — POS / cash-register / shift / sale backbone (Google
// Doc audit, 8 May 2026 — "Confirmed-missing entirely" row 1).
//
// Closes the wellness-vertical POS / "New Sale" gap. Sale is the cash-and-
// carry sibling of Invoice; differs in that it's settled at checkout with
// no due-date / dunning workflow, tied to a Register + Shift + Cashier,
// has a sequential per-tenant invoiceNumber (POS-YYYY-NNNN), and uses a
// polymorphic SaleLineItem (lineType + refId) so future line-types
// (PACKAGE / BUNDLE / RETAIL_PRODUCT / EVENT_TICKET / DEPOSIT) slot in
// without a schema migration.
// ─────────────────────────────────────────────────────────────────────

model Register {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @default(1)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locationId   Int
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name         String
  openingFloat Float    @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shifts Shift[]
  sales  Sale[]

  @@index([tenantId, locationId])
  @@index([tenantId, isActive])
}

model Shift {
  id           Int       @id @default(autoincrement())
  tenantId     Int       @default(1)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registerId   Int
  register     Register  @relation(fields: [registerId], references: [id], onDelete: Cascade)
  userId       Int
  user         User      @relation("CashierShifts", fields: [userId], references: [id], onDelete: Cascade)
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  openingFloat Float     @default(0)
  closingTotal Float?
  expectedCash Float?
  variance     Float?
  notes        String?   @db.Text
  // OPEN | CLOSED. A Register may have at most one OPEN shift at a time
  // (route-layer findFirst+409, not a DB unique constraint).
  status       String    @default("OPEN")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sales           Sale[]
  // #779 — Petty-cash deposits/withdrawals against the open drawer. Each
  // entry is appended once and never edited; the running drawer balance is
  // openingFloat + sum(CASH sales) + sum(DEPOSIT) - sum(WITHDRAWAL).
  pettyCashLedger PettyCashLedger[]

  @@index([tenantId, registerId, status])
  @@index([tenantId, userId, status])
  @@index([tenantId, openedAt])
}

// #779 — Petty-cash drawer ledger. Records ad-hoc deposits (cashier topping
// up the drawer mid-shift, e.g. owner brings ₹2,000 change) and
// withdrawals (cashier removes cash for an expense — e.g. courier payment,
// staff lunch float). Append-only — no UPDATE / DELETE endpoints. The
// running drawer balance computation in /shifts/:id/close uses the sum of
// these entries alongside CASH sales + openingFloat. Tenant-scoped + admin/
// manager-gated.
model PettyCashLedger {
  id        Int      @id @default(autoincrement())
  shiftId   Int
  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  // DEPOSIT | WITHDRAWAL. Free-text would be a footgun for the balance
  // computation; route-layer validates against this 2-value enum.
  type      String
  // Expense category for WITHDRAWAL rows so the Expenses tab can group/label
  // them (GENERAL | SUBSCRIPTION | …). DEPOSITs stay GENERAL. Route-layer
  // validates; default keeps existing rows + uncategorised entries valid.
  category  String   @default("GENERAL")
  amount    Float
  reason    String   @db.Text
  // Cashier id of who recorded the row — kept as a raw int (not an FK)
  // mirroring Sale.cashierId so audit trail survives a User-row delete.
  userId    Int
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([tenantId, shiftId])
  @@index([tenantId, createdAt])
}

model Sale {
  id                   Int       @id @default(autoincrement())
  tenantId             Int       @default(1)
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registerId           Int
  register             Register  @relation(fields: [registerId], references: [id], onDelete: Cascade)
  shiftId              Int
  shift                Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  // Cashier id recorded but not relationally bound — preserves audit
  // trail of who rang the sale even if the User row is later removed.
  cashierId            Int
  patientId            Int?
  patient              Patient?  @relation(fields: [patientId], references: [id], onDelete: SetNull)
  invoiceNumber        String
  subtotal             Float     @default(0)
  taxTotal             Float     @default(0)
  discountTotal        Float     @default(0)
  total                Float     @default(0)
  paidAmount           Float     @default(0)
  // DRAFT | COMPLETED | REFUNDED | CANCELLED.
  status               String    @default("COMPLETED")
  // CASH | CARD | UPI | WALLET | GIFTCARD | COMBINED |
  // CASHBACK | PAYLATER | ONLINE (#789 — extended 2026-05-18). String column
  // (not enum) so future additions are additive — route-layer
  // VALID_PAYMENT_METHODS in routes/pos.js is the source of truth.
  paymentMethod        String    @default("CASH")
  paymentBreakdownJson String?   @db.Text
  // Persisted wallet portion of the sale (in cents) for fast reports
  // without joining + summing WalletTransaction by reason. Default 0
  // makes the column additive — pre-existing rows backfill to "no wallet
  // tender" automatically. Pinned by pos-sale-finalize-api.spec.js:391
  // (test expects body.walletDebitedCents on the create response).
  walletDebitedCents   Int       @default(0)
  refundedAt           DateTime?
  refundReason         String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  lineItems SaleLineItem[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, shiftId])
  @@index([tenantId, registerId, createdAt])
  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// Atomic invoice-number counter per (tenant, year). Replaces the racy
// findFirst+1 pattern in routes/pos.js generateInvoiceNumber().
model InvoiceCounter {
  tenantId Int    @default(1)
  year     Int
  nextSeq  Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, year])
  @@index([tenantId])
}

model SaleLineItem {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @default(1)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleId       Int
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  // Polymorphic line type. refId references the row in the table named
  // by lineType. Allowed: SERVICE | PRODUCT | MEMBERSHIP | GIFTCARD | PACKAGE
  lineType     String
  refId        Int
  // Denormalised display name frozen at sale time.
  name         String
  quantity     Int      @default(1)
  unitPrice    Float    @default(0)
  lineDiscount Float    @default(0)
  // = quantity * unitPrice - lineDiscount. Computed server-side on create.
  lineTotal    Float    @default(0)
  createdAt    DateTime @default(now())

  @@index([tenantId, saleId])
  @@index([tenantId, lineType, refId])
}

// ─────────────────────────────────────────────────────────────────────
// Wave 7 Agent A — Service Catalogue depth + Drug catalogue
// (PRD Gap doc §10 items 1 + 2). 2026-05-10.
//
// ServiceCategory: hierarchical taxonomy (parent/children) for Service.
//   The legacy free-text Service.category column stays as a transition
//   mirror; the FK column Service.categoryId is the new source of truth.
//   Per-tenant, soft-deletable via isActive. Cascade-delete with tenant.
//
// Drug: drug catalogue used by prescription-writing typeahead. Stores
//   defaults for dosage / frequency / duration so the doctor's UI can
//   pre-fill from the catalogue and the writer only types deltas.
//   Indexed by (tenantId, name) and (tenantId, genericName) for the
//   typeahead. Optional link from Prescription via the existing JSON
//   `drugs` column — each entry can carry `drugId` to pin to the
//   catalogue row, while legacy free-text entries (no drugId) remain
//   valid (backwards-compatible).
// ─────────────────────────────────────────────────────────────────────

model ServiceCategory {
  id   Int    @id @default(autoincrement())
  name String

  // Display order in admin UI / picker dropdowns. Lower numbers render
  // first; ties broken by name asc. Default 0 keeps freshly-created rows
  // above the alphabetical floor only when the user hasn't reordered.
  displayOrder Int @default(0)

  // Self-referential hierarchy ("Hair > Restoration > FUE Transplant").
  // SetNull so deleting a parent doesn't cascade-delete children;
  // they re-parent to the root and the admin can re-nest manually.
  parentId Int?
  parent   ServiceCategory?  @relation("ServiceCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ServiceCategory[] @relation("ServiceCategoryHierarchy")

  // Brand color for UI (hex code)
  color       String?
  description String? @db.Text
  imageUrl    String?

  // PRD_TRAVEL_GST_COMPLIANCE G033 / FR-3.1.4 — Service-category default SAC
  // (Services Accounting Code). When an invoice line is created from a
  // catalog service whose category has a defaultSacCode, the line auto-picks
  // this value into hsnSac. Operator may override at line edit time.
  //
  // 4-6 digit string (e.g. "9985" for travel services, "998552" for travel
  // arrangement, "996311" for hotel lodging). Stored verbatim — no
  // validation beyond presence at write-site. Optional + nullable so:
  //   - existing categories backfill on first write
  //   - non-Indian / non-GST tenants ignore it entirely
  //   - wellness categories that have no relevant SAC may stay null
  //
  // Additive nullable — no bless marker needed.
  defaultSacCode String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  services Service[]

  // Tenant-scoped uniqueness on name lets two tenants both have an "Aesthetics"
  // category without colliding, while one tenant cannot duplicate it.
  @@unique([tenantId, name])
  @@index([tenantId, parentId])
  @@index([tenantId, isActive, displayOrder])
}

model Drug {
  id          Int     @id @default(autoincrement())
  name        String // brand or trade name as written on the prescription pad
  genericName String? // generic / INN — used for substitution / formulary cross-ref

  // Dosage form — soft-enum (string) per project convention.
  // tablet | capsule | syrup | injection | topical | drops | inhaler | other
  dosageForm String @default("tablet")

  // Strength as a numeric value + unit pair (e.g. 500 + "mg", 10 + "ml",
  // 5 + "%"). Splitting them lets the UI render "Paracetamol 500 mg" without
  // the doctor having to type the unit each time.
  strengthValue String? // String (not Float) — supports "5/10" combination drugs
  strengthUnit  String? // mg | ml | mcg | % | IU | g | other

  // Defaults pre-populated into the prescription writer; doctor can override
  // per-prescription. All free-text strings — Indian-clinic phrasing varies
  // ("1 tablet", "5 ml", "2 puffs", "1-0-1", "twice daily after food").
  defaultDosage    String? // "1 tablet", "5 ml", "2 puffs"
  defaultFrequency String? // "twice daily", "1-0-1", "every 6 hours"
  defaultDuration  String? // "5 days", "till finished", "as needed"

  notes    String? @db.Text // admin-only — scheduling info, contraindications, etc.
  isActive Boolean @default(true)

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Typeahead lookups go through these. Tenant-first per project
  // tenant-isolation index pattern. genericName is nullable but indexed
  // separately for "search across both" UI.
  @@index([tenantId, name])
  @@index([tenantId, genericName])
  @@index([tenantId, isActive])
}

// ─────────────────────────────────────────────────────────────────────
// PRD Gap §1.5 — Commission Profile
//
// Per-tenant commission rule set. Assigned to a User via
// User.commissionProfileId (SetNull on profile delete). The basis enum
// pins how payroll computes the commission:
//   PER_SERVICE       — % or flat per Service (filtered by appliesToCategory)
//   PER_PRODUCT       — % or flat per Product
//   REVENUE_PERCENT   — % of staff revenue (Sale.cashierId)
//   FLAT_PER_INVOICE  — flat per Invoice/Sale
// Either percentage OR flatAmount is set (validated at the route layer).
// ─────────────────────────────────────────────────────────────────────
model CommissionProfile {
  id                Int      @id @default(autoincrement())
  tenantId          Int      @default(1)
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String
  // Decimal? — % (0-100) when set; null when flatAmount is the rule. Stored as
  // Decimal(8,3) so 12.5% / 0.005% are both representable.
  percentage        Decimal? @db.Decimal(8, 3)
  // Decimal? — flat amount in tenant's defaultCurrency. Stored as Decimal(12,2).
  flatAmount        Decimal? @db.Decimal(12, 2)
  // PER_SERVICE | PER_PRODUCT | REVENUE_PERCENT | FLAT_PER_INVOICE.
  basis             String   @default("REVENUE_PERCENT")
  // Optional Service category filter (e.g. "Aesthetics"). Null = applies to all.
  appliesToCategory String?
  // Optional Product filter (e.g. "Hair Dye"). Null = applies to all.
  appliesToProduct  String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Back-relation: every User assigned to this profile.
  users User[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

// ─────────────────────────────────────────────────────────────────────
// Commission Data — payroll/commission records per employee per period
// Stores historical commission data with detailed revenue breakdowns.
// ─────────────────────────────────────────────────────────────────────
model CommissionData {
  id                                   Int      @id @default(autoincrement())
  tenantId                             Int      @default(1)
  tenant                               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId                               Int?
  user                                 User?    @relation("commissionData", fields: [userId], references: [id], onDelete: SetNull)
  employeeName                         String
  periodStart                          DateTime
  periodEnd                            DateTime
  serviceRevenue                       Decimal  @default(0) @db.Decimal(14, 2)
  packageRedemptionCommissionBase      Decimal  @default(0) @db.Decimal(14, 2)
  packageRedemptionCommissionBasePrice Decimal  @default(0) @db.Decimal(14, 2)
  serviceCount                         Int      @default(0)
  serviceCommissionableAmount          Decimal  @default(0) @db.Decimal(14, 2)
  serviceCommission                    Decimal  @default(0) @db.Decimal(14, 2)
  productRevenue                       Decimal  @default(0) @db.Decimal(14, 2)
  productCount                         Int      @default(0)
  productCommissionableAmount          Decimal  @default(0) @db.Decimal(14, 2)
  productCommission                    Decimal  @default(0) @db.Decimal(14, 2)
  packageRevenue                       Decimal  @default(0) @db.Decimal(14, 2)
  packageCount                         Int      @default(0)
  packageCommissionableAmount          Decimal  @default(0) @db.Decimal(14, 2)
  packageCommission                    Decimal  @default(0) @db.Decimal(14, 2)
  membershipRevenue                    Decimal  @default(0) @db.Decimal(14, 2)
  membershipCount                      Int      @default(0)
  membershipCommissionableAmount       Decimal  @default(0) @db.Decimal(14, 2)
  membershipCommission                 Decimal  @default(0) @db.Decimal(14, 2)
  prepaidCardRevenue                   Decimal  @default(0) @db.Decimal(14, 2)
  prepaidCardCount                     Int      @default(0)
  prepaidCardCommissionableAmount      Decimal  @default(0) @db.Decimal(14, 2)
  prepaidCardCommission                Decimal  @default(0) @db.Decimal(14, 2)
  totalCommissionableAmount            Decimal  @default(0) @db.Decimal(14, 2)
  commission                           Decimal  @default(0) @db.Decimal(14, 2)
  walletRedemption                     Decimal  @default(0) @db.Decimal(14, 2)
  grossSales                           Decimal  @default(0) @db.Decimal(14, 2)
  discount                             Decimal  @default(0) @db.Decimal(14, 2)
  netSales                             Decimal  @default(0) @db.Decimal(14, 2)
  tax                                  Decimal  @default(0) @db.Decimal(14, 2)
  totalSales                           Decimal  @default(0) @db.Decimal(14, 2)
  createdAt                            DateTime @default(now())
  updatedAt                            DateTime @updatedAt

  @@index([tenantId, userId])
  @@index([tenantId, periodStart, periodEnd])
  @@index([employeeName])
}

// ─────────────────────────────────────────────────────────────────────
// PRD Gap §1.6 — Staff Revenue Goal
//
// Distinct from generic Quota (which scopes to sales pipeline). This is
// per-staff revenue targeting for clinics / salons / service businesses.
// achievedAmount is denormalised — refreshed by a payroll cron or a
// computed call site that SUMs Sale.total over [periodStart, periodEnd]
// where Sale.cashierId = userId. scope+scopeFilter narrow the bucket
// (e.g. scope=SERVICE + scopeFilter="Aesthetics").
// ─────────────────────────────────────────────────────────────────────
model StaffRevenueGoal {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @default(1)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // MONTHLY | QUARTERLY | YEARLY. Free-form so future grain (WEEKLY) slots in.
  period         String   @default("MONTHLY")
  periodStart    DateTime
  periodEnd      DateTime
  // Decimal(14,2) so a ₹50 lakh target / $500K target both fit cleanly.
  targetAmount   Decimal  @db.Decimal(14, 2)
  // Updated by the route's GET handler (computed on read) OR a cron pass.
  achievedAmount Decimal  @default(0) @db.Decimal(14, 2)
  // ALL | SERVICE | PRODUCT | MEMBERSHIP. Filters the SUM.
  scope          String   @default("ALL")
  // Optional secondary filter (e.g. specific category name).
  scopeFilter    String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, userId, period, periodStart])
  @@index([tenantId, userId])
  @@index([tenantId, periodStart, periodEnd])
}

model SubscriptionPlan {
  id                  Int      @id @default(autoincrement())
  name                String
  price               Decimal  @db.Decimal(12, 2)
  currency            String   @default("INR")
  billingIntervalDays Int? // 30, 90, 365; null = free trial
  features            String?  @db.Text // JSON array
  description         String?  @db.Text
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  // Marketing-page display fields. Editable from the admin "Manage Plans"
  // UI so prices/features can change without a redeploy. `pricing` carries
  // all 4 display prices (usd/inr × annual/monthly) as JSON; the canonical
  // `price`+`currency` above stays as the legacy Razorpay charge fallback.
  planKey       String? @unique // stable slug: starter | pro | ent
  displayOrder  Int     @default(0)
  popular       Boolean @default(false)
  accentColor   String? // hex for card accent (e.g. #4f46e5)
  cta           String? // CTA button label
  featuresLabel String? // "Includes" or "Everything in Starter, plus"
  pricing       String? @db.Text // JSON: { usd: { annual, monthly, yearAnnualLabel, yearMonthlyLabel }, inr: {...} }

  subscriptions Subscription[]

  @@unique([name, billingIntervalDays])
}

model Subscription {
  id                  Int              @id @default(autoincrement())
  userId              Int
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId              Int
  plan                SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  planName            String
  status              String // ACTIVE | SCHEDULED (queued behind a running period) | EXPIRED | CANCELLED
  amount              Decimal          @db.Decimal(12, 2)
  currency            String           @default("INR")
  billingIntervalDays Int?
  startDate           DateTime
  endDate             DateTime?
  renewalDate         DateTime?
  razorpayOrderId     String?          @unique
  razorpayPaymentId   String?
  features            String?          @db.Text // JSON
  tenantId            Int              @default(1)
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([tenantId, userId, status])
  @@index([tenantId, renewalDate])
  @@index([tenantId, startDate, endDate])
}

// ───────────────────────────────────────────────────────────────────────────
// RBAC Models — Enterprise Role-Based Access Control System
// ───────────────────────────────────────────────────────────────────────────

model Role {
  id          Int      @id @default(autoincrement())
  tenantId    Int? // null = platform-level (OWNER role only)
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String // "ADMIN", "CUSTOMER", "doctor", "sales_rep", etc.
  name        String // display name
  description String?
  isSystem    Boolean  @default(false) // ADMIN, CUSTOMER, OWNER — immutable key
  isActive    Boolean  @default(true)
  userType    String   @default("STAFF") // which user type this role applies to
  // Post-login landing route for users with this role. Null falls back to
  // tenant-vertical default (/wellness or /dashboard). Set per-role from the
  // Roles & Permissions admin UI so adding a new role becomes a config
  // change rather than a code change in Login.jsx / App.jsx.
  landingPath String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions        RolePermission[]
  userRoles          UserRole[]
  widgets            RoleWidget[]
  permissionVersions RolePermissionVersion[]

  @@unique([tenantId, key])
  @@index([tenantId, isActive])
}

// RBAC Hardening Phase 4 — Immutable snapshot of a role's permission
// set after every BULK_UPDATE_PERMISSIONS (PUT /api/roles/:id/permissions).
// Drives the "Role History" UI (Phase 5) and is the primary recovery
// mechanism when an admin saves a broken permission state and needs to
// roll back.
//
// Append-only: existing rows are NEVER updated or deleted (the index
// rejects writes that would collide with an existing versionNumber for
// the same role). Restore creates a NEW version with `changeType: 'RESTORE'`
// pointing at the source version; it does NOT delete or rewrite history.
//
// permissionsJson stores the canonical sorted JSON-stringified array of
// {module, action} objects. The string format is intentional — Prisma's
// MySQL JSON support has compatibility quirks, and the array is always
// hydrated/sorted at read time anyway. Bounded by RolePermission unique
// composite so the max length is ~200 modules × 6 actions ≈ 1200 entries
// per role ≈ 50KB serialized — well under the @db.Text 64KB MySQL cap.
model RolePermissionVersion {
  id                    Int      @id @default(autoincrement())
  roleId                Int
  role                  Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  // Monotonic per-role version number, starting at 1. Versions are
  // never reused — a restore appends a fresh max+1 row pointing back
  // at the source version's permissionsJson.
  versionNumber         Int
  permissionsJson       String   @db.Text
  permissionCount       Int
  // 'UPDATE' (admin save), 'RESTORE' (admin clicked Restore on an
  // older version), 'INITIAL' (the bootstrap snapshot written on
  // first save after deploy of this feature).
  changeType            String   @default("UPDATE")
  // Source version id when changeType=RESTORE so the UI can show
  // "Restored from v7" provenance.
  restoredFromVersionId Int?
  changedById           Int?
  changedBy             User?    @relation(fields: [changedById], references: [id], onDelete: SetNull)
  changedAt             DateTime @default(now())
  // Optional context (e.g. "Lockout-prevented retry"). Free-form,
  // bounded at 500 chars by the route layer.
  note                  String?  @db.VarChar(500)

  @@unique([roleId, versionNumber])
  @@index([roleId, changedAt])
}

// Single-role-per-user enforced at the application layer (the assign
// endpoint at routes/roles.js does a delete-then-create rather than append,
// and ensureRbacOnBoot.js does the same on every boot). The composite
// @@unique([userId, roleId]) blocks duplicate (user, role) pairs but DOES
// NOT prevent a user from having 2+ rows with different roleIds — that
// invariant is application-enforced for now. Adding @@unique([userId]) at
// the DB level is the right long-term fix but requires a one-shot dedupe
// pass against any demo/prod data that pre-dates the contract. Filed for
// follow-up; track it in TODOS.md when this commit lands.
model UserRole {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId       Int
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt   DateTime @default(now())
  assignedById Int?

  @@unique([userId])
  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id     Int    @id @default(autoincrement())
  roleId Int
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module String // "contacts", "patients", "billing", etc.
  action String // "read", "write", "update", "delete", "export", "manage"

  @@unique([roleId, module, action])
  @@index([roleId])
}

// Per-role widget layout for the /home dashboard. Each row pins a widget
// from the static widget registry (frontend/src/components/home/widgets/)
// to a specific role at a specific position. Admin configures this via
// the Roles & Permissions UI; staff with this role see the configured
// widgets on their /home page in the configured order. Widgets the user
// lacks PERMISSIONS for are skipped at render time even if the row exists
// (defence in depth — a role row could have an out-of-date widget after
// permissions are pared back).
//
// position: smaller renders first. Gaps allowed (the configurator inserts
// new widgets at the end with position = max+10).
// isEnabled: soft-disable a widget without losing its position; lets admin
// toggle a widget on/off without re-running the drag-drop layout.
// settings: optional JSON for per-row config (e.g. "show 7-day or 30-day
// window on RevenueVsTarget"). Kept as String? @db.Text because Prisma's
// MySQL connector doesn't have a native JSON type that round-trips cleanly
// — sanitizeJsonForStringColumn pattern applies.
model RoleWidget {
  id        Int      @id @default(autoincrement())
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  widgetKey String // e.g. "today-appointments" — matches widget registry
  position  Int      @default(0)
  isEnabled Boolean  @default(true)
  settings  String?  @db.Text // JSON; null = widget defaults
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, widgetKey])
  @@index([roleId, position])
}

// Wave 3: Staff availability blocks (breaks, leave, personal time, etc.)
// Prevents bookings during these periods. Used by wellness appointment booking
// and calendar availability calculations.
model BlockTime {
  id     Int  @id @default(autoincrement())
  userId Int // Staff member
  user   User @relation("UserBlockTimes", fields: [userId], references: [id], onDelete: Cascade)

  startAt DateTime
  endAt   DateTime
  reason  String // "Lunch Break", "Leave", "Personal", "Maintenance", etc.

  // Recurrence: null (one-time), "daily", "weekly", "monthly"
  recurring String?

  tenantId Int
  tenant   Tenant @relation("TenantBlockTimes", fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, tenantId])
  @@index([startAt, endAt])
  @@index([tenantId])
}

// Tenant-scoped tag (label) assignable to patients. Cross-resource use
// later (e.g. visits, contacts) can extend with additional join tables;
// for now PatientTag is the only join. Soft-delete deferred — drop the
// tag and the @@unique constraint will reject a recreate; we keep this
// simple to start.
model Tag {
  id        Int      @id @default(autoincrement())
  name      String
  // Optional hex like #265855 for chip rendering. Falls back to a
  // deterministic theme colour at the UI layer when null.
  color     String?
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patients PatientTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────
// Travel CRM vertical — Day 2 schema migration (Phase 1 scaffolding)
// ─────────────────────────────────────────────────────────────────────
//
// Hosts four sub-brands under a single tenant (Q25 decision): TMC (school
// trips), RFU (Umrah), Travel Stall (family holidays), Visa Sure (visa).
// `subBrand` String column on every travel-side model isolates per-brand
// data + drives sub-brand-scoped queries via `subBrandAccess[]` on User
// (added below).
//
// Conventions match existing CRM (NOT the PRD draft):
//   - Int @id @default(autoincrement()), not cuid()
//   - tenantId Int @default(1) (Q25: single tenant, sub-brand tags inside)
//   - Decimal(15,2) for INR money (Q24 decision)
//   - Multi-tenant invariant: every model scopes to tenantId
//   - JSON-as-String pattern (String? @db.Text) per CLAUDE.md standing rule
//
// See docs/TRAVEL_CRM_PRD.md §5 for the source spec.

// ── Diagnostic engine (cross-sub-brand) ──────────────────────────────
//
// Weighted-scoring questionnaire that classifies leads into 3-4 tiers
// BEFORE any quote is shown. The Q-set itself (questions + weights) lives
// in TravelDiagnosticQuestionBank, versioned per sub-brand. Each
// TravelDiagnostic captures an immutable snapshot of the Q-set used at
// the time of submission (questionsJson) so changing the bank later
// doesn't retroactively re-classify completed diagnostics.
model TravelDiagnostic {
  id                  Int       @id @default(autoincrement())
  tenantId            Int       @default(1)
  subBrand            String // tmc | rfu | travelstall | visasure
  contactId           Int? // back-link if known at submission
  leadId              Int? // links to Deal/Lead in pipeline
  questionBankId      Int? // FK TravelDiagnosticQuestionBank
  questionsJson       String    @db.Text // immutable Q-bank snapshot at submission
  answersJson         String    @db.Text // {qid: answer}
  score               Decimal?  @db.Decimal(10, 4)
  classification      String? // level_1 .. level_4
  classificationLabel String? // "Confident & Prepared" etc.
  recommendedTier     String? // entry | primary | premium
  reportPdfUrl        String?
  talkingPointsJson   String?   @db.Text // LLM-generated advisor brief
  formVsCallJson      String?   @db.Text // LLM-generated form-vs-call comparison cache
  consentCapturedAt   DateTime?

  // ── TMC Diagnostic & Sales-Routing Engine fields ────────────────────
  // (PRD_TMC_DIAGNOSTIC_SALES_ROUTING_ENGINE §3.8, additive 2026-06-08).
  // All nullable — pre-existing diagnostic rows must remain valid; these
  // fields fill in over the engine's scoring lifecycle.
  //
  // engineState: "strong_match" | "partial_match" | "no_match" — §3.3.1.
  // engineScoresJson: per-signal breakdown per surviving trip, NOT just
  //   totals — required for §3.3.7 disagreement triage + NF-3 audit.
  // recommendedTripId / alternativeTripId: bare ints (NOT FK) to
  //   TmcTripCatalogue.id — keeps catalogue archival cheap during pilot
  //   tuning; the engine module resolves via lookup. alternativeTripId
  //   may be null on single_survivor.
  // icpTier: "amazing" | "breadwinning" | "convenience" | "dangerous" |
  //   "unclassified" — §3.3.6. NEVER shown to the school.
  // leadQuality: "clean" | "suspect" — §3.4. Suspect drops below ALL
  //   clean leads in CRM regardless of icpTier (DD-5.6).
  // leadQualityReasonsJson: JSON array of reason strings — surfaced in
  //   the brief header when lead_quality=suspect.
  // flagsJson: JSON array of: below_min_group, budget_unknown,
  //   scope_budget_conflict, thin_alternative, single_survivor,
  //   needs_custom, suspect.
  // humanPick: trip_id slug; filled by senior reviewer per §3.3.7
  //   protocol (nullable; senior-role-gated UI per DD-5.7).
  // weightsVersion: EngineWeights.version snapshot at scoring time —
  //   required for audit / replay.
  engineState            String?
  engineScoresJson       String? @db.Text
  recommendedTripId      Int?
  alternativeTripId      Int?
  icpTier                String?
  leadQuality            String?
  leadQualityReasonsJson String? @db.Text
  flagsJson              String? @db.Text
  humanPick              String?
  weightsVersion         String?
  // C7 — TMC Curriculum-Fit top-N recommendations per
  // PRD_TMC_CURRICULUM_MAPPING.md FR-5. JSON array snapshot of the
  // computed top-N (default 5) TravelCurriculumMapping rows that
  // best fit the submitter's (board × grade-band × outcome) profile
  // at submit time. Persisted-not-recomputed so the brief / report
  // doesn't drift as advisors edit mappings post-submit. Each entry
  // shape: { mappingId, board, subject, grade, learningOutcome,
  // destinationLabel, destinationId, fitScore, fitRationale }.
  // Empty array when no curriculum mappings exist for the tenant
  // (graceful — engine still recommends a trip via the catalogue).
  curriculumFitJson      String? @db.Text

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, subBrand, contactId])
  @@index([tenantId, subBrand, classification])
  @@index([tenantId, subBrand, engineState])
}

model TravelDiagnosticQuestionBank {
  id               Int      @id @default(autoincrement())
  tenantId         Int      @default(1)
  subBrand         String
  version          Int      @default(1)
  questionsJson    String   @db.Text // ordered Qs + weights + branching rules
  scoringRulesJson String   @db.Text // band thresholds + classification labels
  isActive         Boolean  @default(true)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, subBrand, version])
  @@index([tenantId, subBrand, isActive])
}

// ── Itinerary (multi-product trips: RFU + Travel Stall) ──────────────
model Itinerary {
  id                   Int             @id @default(autoincrement())
  tenantId             Int             @default(1)
  subBrand             String
  contactId            Int
  leadId               Int?
  // status enum extended for Phase 2 50%-advance booking:
  //   draft | sent | revised | accepted | rejected | advance_paid | fully_paid
  // advance_paid means the 50% deposit has been recorded; fully_paid means
  // the balance has cleared. Existing draft/sent/etc. semantics unchanged.
  status               String          @default("draft")
  version              Int             @default(1)
  parentItineraryId    Int? // version-history chain
  // Phase 2 PRD §6.4 — recommended product tier captured at itinerary
  // creation, defaulted from the contact's latest diagnostic
  // (entry | primary | premium). Nullable — TMC + Visa Sure don't carry a
  // tier today. Captured-at-creation so tier-vs-actual analytics stay
  // stable if the diagnostic is re-taken later.
  productTier          String?
  destination          String
  startDate            DateTime?
  endDate              DateTime?
  pricingJson          String?         @db.Text // breakdown
  totalAmount          Decimal?        @db.Decimal(15, 2)
  currency             String          @default("INR")
  // Number of travelers. totalAmount stores the GROUP total (sum of item line
  // totals); the per-person budget is derived as totalAmount / pax. Default 1.
  pax                  Int             @default(1)
  pdfUrl               String?
  shareToken           String?         @unique // WhatsApp/email share link
  shareExpiresAt       DateTime?
  shareRevokedAt       DateTime?
  // Phase 2 — 50% advance booking pattern (PRD §4.7 Travel Stall). All
  // three fields nullable + additive so existing Itinerary rows backfill
  // implicitly. advancePaidAmount is the rupee amount the customer has
  // paid as advance (typically 0.5 * totalAmount but the actual value is
  // recorded — partial pays / over-pays are non-fatal). paymentReference
  // stores the gateway charge id (Razorpay/Stripe) for reconciliation.
  // Wati/payment-gateway integration arrives once Q9 / payment creds land;
  // until then the route's demo-mode endpoint accepts the reference
  // directly so the booking flow can be operated/tested end-to-end.
  advancePaidAmount    Decimal?        @db.Decimal(15, 2)
  advancePaidAt        DateTime?
  paymentReference     String?
  // Pay-or-cancel deposit deadline (2026-06-16). Set by cron/paymentDeadlineEngine
  // when an `accepted`-but-unpaid itinerary passes its T-7 deposit deadline
  // (startDate - 7d) without the 50% advance — i.e. it's now overdue/at-risk.
  // Drives the advisor at-risk badge + the "review for cancellation" flag.
  // Nullable + additive; the engine never auto-changes status (advisor sets
  // "expired" manually). Cleared back to null if a late payment lands.
  paymentOverdueAt     DateTime?
  // Customer's reason/feedback when they DECLINE an offer (PRD §6.1). Free
  // text the customer enters in the portal so the advisor knows what to
  // improve. Nullable; only set on a customer decline.
  declineReason        String?         @db.Text
  // Customer-initiated CANCELLATION of a committed booking (2026-06-19). When a
  // customer cancels an accepted/paid trip from the portal, they give a reason
  // and the advisor is flagged to process a refund per the cancellation policy.
  // cancellationStatus: null | "requested" (customer asked) | "cancelled"
  // (advisor confirmed) | "refunded" (refund done). The engine never
  // auto-refunds — the advisor settles per policy. Additive + nullable.
  cancellationStatus       String?
  cancellationReason       String?     @db.Text
  cancellationRequestedAt  DateTime?
  // LLM-generated draft summary block. Persisted so re-renders don't burn
  // tokens. Operator triggers regeneration via POST /draft/regen. Stays
  // null until the first regen call lands; the customer-facing PDF + share
  // page render conditionally on it. Bulk-text task per PRD §9.1 (Gemini
  // Flash when Q11 keys arrive; stub-mode placeholder text until then).
  draftSummary         String?         @db.Text
  // G047 — Itinerary lineage (PRD_TRAVEL_ITINERARY_UPGRADES FR-3.1.e
  // "Cloned from template"). Nullable Int FK to ItineraryTemplate; set on the
  // clone-from-template path (POST /api/travel/itineraries with
  // clonedFromTemplateId in the body). When set, the editor surfaces a
  // "Cloned from <template name>" chip in the header. Additive-nullable,
  // no bless marker. We intentionally skip the back-relation here because
  // ItineraryTemplate doesn't need a `itineraries` collection at the ORM
  // layer — analytics queries read by templateId index instead.
  clonedFromTemplateId Int?
  items                ItineraryItem[]
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([tenantId, subBrand, contactId, status])
  @@index([tenantId, status])
  @@index([tenantId, clonedFromTemplateId])
}

model ItineraryItem {
  id          Int       @id @default(autoincrement())
  itineraryId Int
  itemType    String // flight | hotel | transfer | activity | visa | insurance
  position    Int
  description String
  detailsJson String?   @db.Text // type-specific payload
  supplierId  Int?
  unitCost    Decimal?  @db.Decimal(15, 2) // "Rate" — cost of ONE unit
  markup      Decimal?  @db.Decimal(15, 2)
  gstAmount   Decimal?  @db.Decimal(15, 2)
  totalPrice  Decimal?  @db.Decimal(15, 2) // auto = unitCost*quantity + markup + gstAmount (line total)
  // Pricing basis so a line is never ambiguous:
  //   unit ∈ per_person | per_night | per_room_night | per_day | per_group
  //   quantity = how many units (e.g. pax, nights, days); line total = rate*qty
  //   direction = one_way | round_trip (transport items only; null otherwise)
  unit        String?   @default("per_person")
  quantity    Decimal?  @default(1) @db.Decimal(10, 2)
  direction   String?
  // S8 — additive nullable columns for FR-3.3 day-by-day editor + FR-3.4 map
  // preview (PRD_TRAVEL_ITINERARY_UPGRADES.md §3.3 + §3.4). All three nullable
  // so pre-existing ItineraryItem rows stay valid without a backfill. S9 (visual
  // editor) groups items by dayNumber; S10 (map preview) plots items with both
  // latitude + longitude set. dayNumber is 1-indexed; Float chosen for lat/lng
  // (sufficient precision for ~11m positioning at typical zoom levels).
  dayNumber   Int?
  latitude    Float?
  longitude   Float?
  // G051 — AI provenance (PRD_TRAVEL_ITINERARY_UPGRADES FR-3.4.h). Set to
  // true on items materialised from POST /itineraries/from-suggestion
  // (the LLM-drafted day skeleton) so the editor can surface a small
  // "AI-drafted" badge on each such row. Defaults to false so all
  // pre-existing items + manual additions stay un-badged. Additive-with-
  // default; no bless marker required.
  draftedByAi Boolean   @default(false)
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([itineraryId, position])
  // S37 — composite index for S9's day-by-day editor: query shape is
  // `WHERE itineraryId = X AND dayNumber = Y ORDER BY position` (group
  // items by day, then preserve in-day order). The existing
  // @@index([itineraryId, position]) covers ordered-list reads but won't
  // be hit on the day-filtered read. Additive index — non-destructive,
  // no bless marker required per CLAUDE.md migration-safety rule.
  @@index([itineraryId, dayNumber])
}

// ── Cost master + seasonal calendar + markup rules ───────────────────
model TravelCostMaster {
  id             Int       @id @default(autoincrement())
  tenantId       Int       @default(1)
  subBrand       String
  category       String // hotel | flight | transport | visa | insurance
  supplierId     Int?
  routeOrSku     String // "MAA-JED" or "Makkah:Hilton:Deluxe-HaramFacing"
  attributesJson String?   @db.Text // floor/view/room category for hotels
  baseRate       Decimal   @db.Decimal(15, 2)
  currency       String    @default("INR")
  seasonId       Int?
  validFrom      DateTime?
  validTo        DateTime?
  isActive       Boolean   @default(true)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId, subBrand, category, isActive])
  @@index([tenantId, supplierId])
}

// ── Sightseeing master (#907 slice 1) ────────────────────────────────
// Destination → POI mapping (description, image, duration, price ref).
// Free-form destinationName for now; future slice may FK to a dedicated
// TravelDestination model. Subsequent slices land CRUD route + admin UI
// page + Cost Master integration (the "6th category" requirement) +
// day-by-day editor + LLM "Suggest itinerary" button.
model TravelSightseeing {
  id                  Int      @id @default(autoincrement())
  tenantId            Int
  destinationName     String // free-form for now; future FK to TravelDestination
  name                String // POI name e.g. "Eiffel Tower"
  description         String?  @db.Text // 1-2 paragraphs
  imageUrl            String?  @db.Text // thumbnail / hero image
  durationMinutes     Int? // typical visit time
  priceReferenceMinor Int? // INR minor units, indicative entry/ticket
  currency            String?  @db.VarChar(3) // ISO 4217; nullable, defaults to tenant default at call site
  category            String? // free-form tag: "monument" | "museum" | "nature" | "religious" | ...
  subBrand            String? // routes inheritance to existing sub-brand filtering
  notes               String?  @db.Text // ops/coordinator notes
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, destinationName])
  @@index([tenantId, subBrand])
}

model ItineraryTemplate {
  id                   Int       @id @default(autoincrement())
  tenantId             Int // each tenant has its own template library
  name                 String // "5-day Paris" / "Goa Beach Holiday" etc.
  destinationName      String // primary destination tag
  durationDays         Int // typical day count
  description          String?   @db.Text // 1-2 paragraph blurb shown to operator
  thumbnailUrl         String?   @db.Text // hero image for the catalog grid
  category             String? // free-form tag: "Adventure" | "Religious" | "Family" | ...
  subBrand             String? // sub-brand affinity; null = visible to all
  defaultMarkupPercent Float? // suggested markup; operator can override
  basePriceMinor       Int? // indicative price in INR minor units
  currency             String?   @db.VarChar(3) // ISO 4217; nullable, tenant default at call site
  templateJson         String?   @db.LongText // serialized day-by-day item template (items[] structure)
  llmGeneratedBy       String? // "anthropic|google|openai|null=manual"
  isActive             Boolean   @default(true)
  usageCount           Int       @default(0) // incremented each time an Itinerary is created from this template
  // G049 — template library metrics (PRD_TRAVEL_ITINERARY_UPGRADES FR-3.1.h).
  // The library grid surfaces which templates actually convert: how many
  // cloned itineraries reached `accepted` status, the rolling-average final
  // sale price across those accepted clones, and when the template was last
  // used. All three are engine-bumped (clone path bumps usageCount +
  // lastUsedAt; accept path bumps acceptedCount + recomputes avgFinalPrice)
  // — never caller-controlled (intentionally absent from MUTABLE_FIELDS in
  // routes/travel_itinerary_templates.js).
  //
  //   acceptedCount   how many `accepted` itineraries lineaged back to this
  //                   template (incremented on /itineraries/:id/accept when
  //                   the itinerary has clonedFromTemplateId set)
  //   avgFinalPrice   rolling average of accepted-itinerary.totalAmount,
  //                   recomputed as ((avg * (n-1)) + newPrice) / n on each
  //                   accept. Decimal(15,2) matches Itinerary.totalAmount.
  //                   Null until the first accepted clone lands.
  //   lastUsedAt      bumped to `now()` on every clone-from-template event.
  //                   Null until the first clone lands. Used for "Stale
  //                   templates" library filtering.
  //
  // All additive-nullable / additive-with-default; no bless marker required.
  acceptedCount        Int       @default(0)
  avgFinalPrice        Decimal?  @db.Decimal(15, 2)
  lastUsedAt           DateTime?
  // G048 — Template versioning (PRD_TRAVEL_ITINERARY_UPGRADES FR-3.5.a +
  // FR-3.5.b). Operators iterate templates over time (refining destinations,
  // adjusting day plans, fixing typos). The library should:
  //   - keep a HISTORY of every version a template ever had (so older
  //     itineraries that cloned from version N retain a working FK even
  //     after the operator has rolled the template forward to N+1),
  //   - filter the library grid to JUST the latest version by default
  //     (operator picks from "the current recommended set", not a long
  //     history of stale rows),
  //   - allow archiving + restoring rows (soft-stash) so the operator can
  //     hide a stale template without losing its history.
  //
  // Semantics:
  //   version       1-indexed. First create lands @ version=1. PATCH inserts
  //                 a NEW row with version=N+1 and flips the prior row's
  //                 isLatest=false. The id of the new row is fresh — the
  //                 old row keeps its id so existing Itinerary.clonedFromTemplateId
  //                 FKs stay valid (a previously-cloned itinerary still points
  //                 at the version it was cloned from, not the latest).
  //   isLatest      Library list filters to `isLatest=true AND
  //                 archivedAt IS NULL` by default. Adminish callers can
  //                 set ?includeArchived=true or ?includeAllVersions=true
  //                 to see the full history. Prior rows in the version
  //                 chain stay queryable by id (the GET /:id surface
  //                 returns them regardless of isLatest) so the lineage
  //                 chip's template-name lookup keeps working.
  //   archivedAt    Nullable timestamp. Set by POST /:id/archive (zaps
  //                 from the default list). Cleared by POST /:id/restore.
  //
  // All three additive-with-default-or-nullable; no bless marker required.
  // The `isLatest` Boolean defaults to `true` so existing rows (every row
  // pre-G048) implicitly become "the latest version" with no backfill.
  version              Int       @default(1)
  isLatest             Boolean   @default(true)
  archivedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, destinationName])
  @@index([tenantId, category])
  @@index([tenantId, subBrand])
  @@index([tenantId, isActive])
  // G048 — composite index for the "isLatest + archivedAt IS NULL" library
  // filter. The default library grid runs `WHERE tenantId = X AND
  // isLatest = true AND archivedAt IS NULL ORDER BY createdAt DESC` —
  // this index covers the predicate scan without falling back to
  // tenantId-only + filter. Additive index, no bless marker required per
  // CLAUDE.md migration-safety rule.
  @@index([tenantId, isLatest, archivedAt])
}

model TravelSeasonCalendar {
  id         Int      @id @default(autoincrement())
  tenantId   Int      @default(1)
  subBrand   String
  seasonName String // peak | lean | ramadan-peak | school-holiday
  startDate  DateTime
  endDate    DateTime
  multiplier Decimal? @db.Decimal(6, 4) // optional uniform multiplier
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, subBrand, startDate, endDate])
}

/// TMC school-term / holiday / exam-blackout windows used to warn when a school
/// trip is scheduled during term-time or exams. V1 captures schoolName as free
/// text. Baseline India windows are seeded; each school's ACTUAL dates are
/// captured by asking the school (there is no public API for per-school term
/// calendars). `source` distinguishes seed/manual/website — the last reserved
/// for a future "import from the school's website" feed.
model TravelSchoolTerm {
  id         Int      @id @default(autoincrement())
  tenantId   Int      @default(1)
  subBrand   String   @default("tmc")
  // Free-text school name. null = a baseline window that applies to ALL schools
  // (e.g. national summer break) until a school provides its own dates.
  schoolName String?
  board      String? // CBSE | ICSE | IB | Cambridge | State | null
  kind       String   @default("holiday") // term | holiday | exam-blackout
  label      String // "Summer Break 2026", "Half-yearly exams", etc.
  startDate  DateTime
  endDate    DateTime
  source     String   @default("manual") // manual | seed | website
  isActive   Boolean  @default(true)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, subBrand, startDate, endDate])
  @@index([tenantId, schoolName])
}

model TravelMarkupRule {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @default(1)
  subBrand     String
  scope        String // flight | hotel | transport | package
  matchKeyJson String   @db.Text // airline+route+fareBucket / hotel+city / route
  markupPct    Decimal? @db.Decimal(6, 4)
  markupFlat   Decimal? @db.Decimal(15, 2)
  ownerUserId  Int? // agent-level markup (flight plugin)
  priority     Int      @default(100)
  isActive     Boolean  @default(true)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, subBrand, scope, isActive])
}

// ── TMC trip + children ──────────────────────────────────────────────
model TmcTrip {
  id                   Int                       @id @default(autoincrement())
  tenantId             Int                       @default(1)
  tripCode             String // "bali2026"
  schoolContactId      Int // FK Contact (B2B school)
  destination          String
  departDate           DateTime
  returnDate           DateTime
  legalEntity          String                    @default("tmc_nexus")
  micrositeUrl         String?
  micrositeUuid        String?                   @unique
  pricePerStudent      Decimal?                  @db.Decimal(15, 2)
  status               String                    @default("confirmed") // confirmed | in-trip | completed | cancelled
  driveFolderId        String?
  participants         TripParticipant[]
  rooming              RoomingAssignment[]
  paymentPlan          TripPaymentPlan?
  documentRequirements TripDocumentRequirement[]
  microsite            TripMicrosite?
  tenant               Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@unique([tenantId, tripCode])
  @@index([tenantId, status])
  @@index([tenantId, departDate])
}

model TripParticipant {
  id                     Int                 @id @default(autoincrement())
  tripId                 Int
  fullName               String
  passportNumber         String?
  passportExpiry         DateTime?
  passportDocId          Int? // ContactAttachment id
  // Slice C2 (docs/PRD_PASSPORT_OCR.md FR-5/FR-6/FR-9) — additive nullable
  // columns for the OCR extraction → verification queue → audit flow.
  // passportExtractionJson holds the raw vendor envelope (extraction +
  // confidence + provider + extractedAt) per PRD §5.3 "stub-mode-v1"
  // shape; passportExtractedAt is set on upload + populates the
  // verification queue's pending list (where extractedAt IS NOT NULL AND
  // verifiedAt IS NULL). passportVerifiedAt/ById close the loop; the
  // verifying user's id is captured for the audit trail. passportRejectedAt
  // is set on operator reject + clears with the next re-upload.
  passportExtractionJson String?             @db.Text
  passportExtractedAt    DateTime?
  passportVerifiedAt     DateTime?
  passportVerifiedById   Int?
  passportRejectedAt     DateTime?
  aadhaarLast4           String?
  aadhaarTokenId         String? // DigiLocker token, encrypted
  parentName             String?
  parentPhone            String?
  parentEmail            String?
  medicalNotes           String?             @db.Text
  consentCapturedAt      DateTime?
  trip                   TmcTrip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  digilockerSessions     DigilockerSession[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@index([tripId])
}

// Unified customer-portal passport store — PRD_PASSPORT_OCR, all 4 sub-brands
// (TMC parents, RFU pilgrims, Travel Stall families, Visa Sure applicants).
// Customers register the people travelling with them + upload each passport
// from the portal, keyed to the owning Contact (contactId) rather than to a
// sub-brand-specific booking model (TmcTrip / Itinerary / VisaApplication) —
// so the one "Travel Documents" surface works regardless of sub-brand.
//
// Mirrors the passport extraction + verification columns on TripParticipant
// so the staff verification queue (routes/travel_passport.js) reviews both
// sources in one place. contactId / tenantId are bare scalars (no relation
// navigation needed; tenant scoping is enforced in the route WHERE clause).
model CustomerTraveller {
  id                     Int       @id @default(autoincrement())
  tenantId               Int       @default(1)
  contactId              Int // owning portal customer (Contact)
  subBrand               String // tmc | rfu | travel_stall | visa_sure (snapshot of Contact.subBrand)
  fullName               String
  relationship           String? // self | spouse | child | parent | other
  passportNumber         String?
  passportExpiry         DateTime?
  passportExtractionJson String?   @db.Text
  passportExtractedAt    DateTime?
  passportVerifiedAt     DateTime?
  passportVerifiedById   Int?
  passportRejectedAt     DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([tenantId, contactId])
  @@index([tenantId, passportVerifiedAt])
}

// PRD §4.5 + §4.7 — DigiLocker OAuth flow state. Created on /initiate
// (status="initiated"), updated to "verified" on /callback after the
// stub (or real, once Q3 creds land) DigiLocker token exchange. The
// `state` column doubles as the OAuth CSRF token AND the dedup key
// (replay protection — a session that's already "verified" can't be
// re-callbacked).
//
// resultLast4 / resultTokenId mirror what gets written to
// TripParticipant on a successful callback — the row is kept as an
// audit trail of the verification event.
model DigilockerSession {
  id            Int              @id @default(autoincrement())
  tenantId      Int              @default(1)
  // Polymorphic subject — exactly ONE of participantId / contactId is
  // non-null. subjectType picks which. Existing TripParticipant flow
  // sets subjectType="participant"; new customer-portal flow sets
  // "contact" and stores the Contact.id in contactId. Keeps a single
  // session table so the OAuth state plumbing (state @unique, status
  // FSM, replay protection) is shared across all KYC subjects.
  subjectType   String           @default("participant") // "participant" | "contact"
  participantId Int?
  contactId     Int?
  state         String           @unique // OAuth state (CSRF token); dedup/replay-protection key
  status        String           @default("initiated") // initiated | verified | failed | expired
  redirectUri   String           @db.Text
  initiatedAt   DateTime         @default(now())
  verifiedAt    DateTime?
  failedReason  String?
  // Stub-mode: holds the synthetic last-4 + token written by the stub
  // client. Real-mode: holds the values returned from DigiLocker's
  // signed Aadhaar XML after callback exchange.
  resultLast4   String?
  resultTokenId String?
  participant   TripParticipant? @relation(fields: [participantId], references: [id], onDelete: Cascade)
  contact       Contact?         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([tenantId, status])
  @@index([participantId])
  @@index([contactId])
}

model RoomingAssignment {
  id             Int      @id @default(autoincrement())
  tripId         Int
  roomNumber     String
  roomType       String // single | twin | triple | quad
  participantIds String   @db.Text // JSON array of TripParticipant ids
  trip           TmcTrip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tripId])
}

model TripPaymentPlan {
  id              Int      @id @default(autoincrement())
  tripId          Int      @unique
  instalmentsJson String   @db.Text // [{dueDate, amount, reminderDays}]
  graceDays       Int      @default(0)
  trip            TmcTrip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TripInstalmentPayment {
  id              Int       @id @default(autoincrement())
  tripId          Int
  participantId   Int
  instalmentIndex Int
  dueDate         DateTime
  amount          Decimal   @db.Decimal(15, 2)
  paidAmount      Decimal   @default(0) @db.Decimal(15, 2)
  paidAt          DateTime?
  invoiceId       Int? // FK Invoice (existing model)
  status          String    @default("pending") // pending | partial | paid | overdue
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tripId, status])
  @@index([dueDate])
}

model TripDocumentRequirement {
  id        Int      @id @default(autoincrement())
  tripId    Int
  docType   String // passport | aadhaar | medical-form | consent-form | school-id
  required  Boolean  @default(true)
  trip      TmcTrip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
}

// ── Web check-in (cross-cutting) ─────────────────────────────────────
//
// Records each pending web check-in window. Cron sweeps when departureAt
// crosses T-48h / T-24h and the Chrome extension processes; if no
// extension is available (or DOM-change broke the adapter) the row
// transitions to "fallback-agent" with a Task for manual handling.
model WebCheckin {
  id                 Int       @id @default(autoincrement())
  tenantId           Int       @default(1)
  contactId          Int
  itineraryId        Int?
  pnr                String
  airlineCode        String
  flightNumber       String
  departureAt        DateTime
  windowOpenAt       DateTime // T-48h or T-24h
  passengerName      String
  seatPref           String?
  mealPref           String?
  status             String    @default("pending") // pending | reminded | in-progress | done | fallback-agent | failed
  attemptsJson       String?   @db.Text // [{at, result, errorReason}]
  // Customer-facing web check-in reminder EMAILS sent by cron/webCheckinEngine.js
  // (2026-06-16) — distinct from the scheduler's WhatsApp/status lifecycle.
  // JSON array of milestone tags already emailed: e.g. ["h36","h24"] (T-36/24/12h
  // before departureAt). Idempotency guard so a re-tick doesn't double-send.
  emailRemindersJson String?   @db.Text
  boardingPassUrl    String?
  deliveredAt        DateTime?
  assignedAgentId    Int?
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([tenantId, status, windowOpenAt])
  @@index([tenantId, contactId])
}

/// Post-trip customer review (2026-06-16). One per completed itinerary. The
/// cron/travelReviewEngine.js creates a row (status "requested" + a public
/// token) ~after the trip's endDate passes and emails the customer a review
/// link; the customer submits via the public page (/p/review/:token) OR the
/// logged-in portal — both write the same row. Questions are a fixed set in
/// lib/travelReviewQuestions.js ({destination}-interpolated); answersJson holds
/// the structured submission and overallRating is the rounded average of the
/// star ratings (headline metric for advisor reporting). All sub-brands except
/// Visa Sure.
model TravelTripReview {
  id            Int       @id @default(autoincrement())
  tenantId      Int       @default(1)
  itineraryId   Int       @unique // one review per trip
  contactId     Int
  token         String    @unique // public review-link slug
  status        String    @default("requested") // requested | submitted
  overallRating Int? // rounded avg of the 1-5 star answers (set on submit)
  answersJson   String?   @db.Text // { questionId: value } for the full submission
  requestedAt   DateTime  @default(now())
  submittedAt   DateTime?
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, contactId])
}

/// Travel customer-portal in-app notification inbox (2026-06-17). Contact-scoped
/// (the travel customer is a Contact with a portal login), SEPARATE from the
/// staff `Notification` table (userId-scoped). Emitted when an advisor sends/
/// revises an itinerary or when a payment is recorded; surfaced in the portal
/// bell. Mirrors the wellness `PatientNotification` pattern.
model TravelPortalNotification {
  id        Int       @id @default(autoincrement())
  title     String
  message   String    @db.Text
  type      String    @default("info") // info | itinerary | payment | system
  link      String? // optional portal deep-link (e.g. "bookings")
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  contactId Int
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([contactId, isRead])
  @@index([contactId, createdAt])
}

// ── Supplier credentials vault ───────────────────────────────────────
//
// Login + 2FA seed material for airline / hotel / GDS / visa portals,
// encrypted via backend/lib/fieldEncryption.js (AES-256-GCM). Access is
// logged in SupplierCredentialAccessLog for audit. ADMIN-gated.
model SupplierCredential {
  id                Int                           @id @default(autoincrement())
  tenantId          Int                           @default(1)
  category          String // airline | hotel | gds | visa-portal | payment-gateway | insurance | government
  supplierName      String
  loginIdEncrypted  String                        @db.Text // AES-256-GCM ciphertext
  passwordEncrypted String                        @db.Text
  metadataJson      String?                       @db.Text // 2FA backup codes, MFA seed, notes
  ownerUserId       Int?
  lastUsedAt        DateTime?
  tenant            Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accessLog         SupplierCredentialAccessLog[]
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  @@index([tenantId, category])
}

model SupplierCredentialAccessLog {
  id           Int                @id @default(autoincrement())
  credentialId Int
  userId       Int
  action       String // viewed | used-in-checkin | rotated | deleted
  ip           String?
  credential   SupplierCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  at           DateTime           @default(now())

  @@index([credentialId, at])
}

// ── Visa Sure (Phase 3 model, schema-defined now for Phase 1 stability) ──
model VisaApplication {
  id                   Int                         @id @default(autoincrement())
  tenantId             Int                         @default(1)
  contactId            Int
  applicationType      String // tourist | business | student | work | umrah | hajj
  destinationCountry   String
  status               String                      @default("intake") // intake | docs-pending | filed | approved | rejected | appeal
  readinessLevel       Int? // 1-4 from diagnostic
  complexCase          Boolean                     @default(false)
  rejectionHistoryJson String?                     @db.Text // [{country, date, reason}]
  /// Family/dependents trigger for risk-flag engine FR-3.1(c) — PC-8 RESOLVED 2026-05-24.
  familySize           Int?
  advisorRiskFlag      String? // null | low | medium | high | priority
  filedAt              DateTime?
  decidedAt            DateTime?
  outcome              String? // null | approved | rejected
  outcomeReason        String?                     @db.Text
  recoveryProgramId    Int? // FK to RejectionRecoveryProgram model (G107 — PRD_VISA_SURE_PHASE_3 §FR-7)
  recoveryProgram      RejectionRecoveryProgram?   @relation(fields: [recoveryProgramId], references: [id], onDelete: SetNull)
  /// Self-FK to a prior rejected application — used by visaRiskFlagEngine R13 cooldown rule (PC-4 RESOLVED 2026-05-24). Pure FK; full rejection-recovery diagnostic linkage is Phase 2 (PC-2 deferred until VisaDiagnostic model materializes).
  priorApplicationId   Int?
  priorApplication     VisaApplication?            @relation("PriorRejection", fields: [priorApplicationId], references: [id], onDelete: SetNull)
  recoveryApplications VisaApplication[]           @relation("PriorRejection")
  documentChecklist    VisaDocumentChecklistItem[]
  tenant               Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([tenantId, status, advisorRiskFlag])
  @@index([tenantId, contactId])
  @@index([priorApplicationId])
  @@index([recoveryProgramId])
}

/// G107 — RejectionRecoveryProgram (PRD_VISA_SURE_PHASE_3 §FR-7).
/// Advisor-curated second-attempt programs for previously-rejected applicants.
/// VisaApplication.recoveryProgramId references this; enrolment happens via
/// POST /api/travel/visa/applications/:id/enrol-recovery.
model RejectionRecoveryProgram {
  id                    Int               @id @default(autoincrement())
  tenantId              Int
  name                  String // e.g. "USA B1/B2 second-attempt program"
  destinationCountry    String
  visaType              String? // tourist | business | student | work | umrah | hajj | null = any
  description           String?           @db.Text
  durationDays          Int? // typical program length
  successRate           Decimal?          @db.Decimal(5, 2) // historical %
  feeAmount             Decimal?          @db.Decimal(15, 2)
  feeCurrency           String?
  enrolmentCriteriaJson String?           @db.Text // who qualifies (JSON-stringified per sanitizeJson convention)
  programSteps          String?           @db.Text // markdown checklist
  isActive              Boolean           @default(true)
  createdBy             Int?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  applications          VisaApplication[]

  @@index([tenantId, destinationCountry, isActive])
}

model VisaDocumentChecklistItem {
  id                Int             @id @default(autoincrement())
  applicationId     Int
  docType           String
  required          Boolean         @default(true)
  status            String          @default("pending") // pending | uploaded | verified | rejected
  attachmentId      Int?
  notes             String?         @db.Text
  // FR-6.2 customer self-serve upload — the file the applicant uploaded
  // against this checklist item. attachmentStorage/attachmentKey let the
  // re-upload path supersede (delete) the prior file from its backend.
  attachmentUrl     String?         @db.Text // served URL (/api/uploads/visa-docs/… or S3)
  attachmentName    String? // original client filename (display only)
  attachmentStorage String? // "s3" | "disk"
  attachmentKey     String? // storage key/object name
  uploadedAt        DateTime? // when the applicant uploaded the current file
  application       VisaApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([applicationId, status])
}

/// Canonical document-checklist templates per applicationType × destinationCountry
/// (PRD_VISA_SURE_PHASE_3 FR-6.1). Managed by ADMIN/MANAGER via
/// /travel/visa/checklists; consumed by GET /checklists/template?applicationType=
/// &destinationCountry= to seed a new application's VisaDocumentChecklistItem rows.
/// Standalone reference data — no FK to applications.
model VisaChecklistTemplate {
  id                 Int      @id @default(autoincrement())
  tenantId           Int
  applicationType    String // tourist | business | student | work | umrah | hajj
  destinationCountry String // free-text or ISO code (e.g. "US", "United States")
  docType            String // e.g. "Passport", "Bank statement", "CAS letter"
  required           Boolean  @default(true)
  sortOrder          Int      @default(0)
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId, applicationType, destinationCountry])
}

/// Curated quotation templates for Visa Sure (PRD_VISA_SURE_PHASE_3 FR-5.2).
/// For standard cases the advisor picks a template (e.g. "Tourist visa —
/// standard") and the system auto-populates quote line items. Managed via the
/// /travel/visa/checklists admin page (the checklist admin extends to manage
/// quotation templates too). `linesJson` is a JSON-stringified array of
/// { label, amount } line items (amount may be negative for credits/
/// adjustments, e.g. crediting the free entry-diagnostic fee).
model VisaQuotationTemplate {
  id              Int      @id @default(autoincrement())
  tenantId        Int
  name            String // e.g. "Tourist visa — standard", "Student visa — UK"
  applicationType String // tourist | business | student | work | umrah | hajj
  currency        String   @default("INR")
  linesJson       String   @db.Text // JSON array of { label, amount }
  notes           String?  @db.Text
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, applicationType])
}

/// Transient email-OTP store for self-service registration (org signup +
/// customer/portal registration). Pre-registration, identity-by-email — it is
/// deliberately NOT tenant-scoped (at org-signup time no tenant exists yet).
/// Codes are bcrypt-hashed, expire in ~10 min, and are deleted/marked used.
/// The permanent "verified" marker lands on Tenant/User/Contact.emailVerifiedAt.
model EmailVerificationOtp {
  id        Int       @id @default(autoincrement())
  email     String
  purpose   String // signup | customer-register
  otpHash   String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([email, purpose])
}

/// Password-reset tokens, persisted to the DB so they survive backend
/// restarts / redeploys / multiple instances (the old in-memory Map lost every
/// outstanding link on any restart → "Invalid or expired" immediately).
/// One row per forgot-password request; consumed (usedAt set) on success.
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Idempotency + audit ledger for pre-trip "countdown" nudge emails fired by
/// cron/tripCountdownEngine.js. One row per (itinerary, day-bucket) — the
/// @@unique guarantees a given day's nudge is sent at most once even if the
/// hourly cron ticks multiple times that day. Tenant-scoped (derived from the
/// itinerary).
model TripCountdownNudge {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  itineraryId Int
  dayTag      String // "d30" | "d14" | "d7" … "d0"
  channel     String   @default("email")
  status      String   @default("sent") // sent | failed | logged (no email key)
  subject     String?  @db.Text
  llmSourced  Boolean  @default(false) // true when copy came from the LLM (not the template fallback)
  sentAt      DateTime @default(now())

  @@unique([itineraryId, dayTag])
  @@index([tenantId, itineraryId])
}

/// Pay-or-cancel deposit-deadline nudges (2026-06-16). For an `accepted` (but
/// not yet paid) itinerary that owes a 50% deposit, the paymentDeadlineEngine
/// chases the customer T-10 → T-7 (deadline = startDate - 7d) then, if still
/// unpaid at T-6, flags the advisor + warns the customer (no auto-cancel —
/// an advisor manually sets status "expired" to cancel). One row per
/// (itineraryId, dayTag); dayTag ∈ {d10,d9,d8,d7,overdue}. Kept distinct from
/// TripCountdownNudge so a later packing-d7 row can't collide with a payment-d7.
model PaymentDeadlineNudge {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  itineraryId Int
  dayTag      String // "d10" | "d9" | "d8" | "d7" | "overdue"
  channel     String   @default("email")
  status      String   @default("sent") // sent | failed | logged (no email key) | flagged (overdue advisor notice)
  subject     String?  @db.Text
  llmSourced  Boolean  @default(false)
  sentAt      DateTime @default(now())

  @@unique([itineraryId, dayTag])
  @@index([tenantId, itineraryId])
}

/// Per-destination embassy quirks for Visa Sure risk-flag engine. PRD §PC-3 resolved 2026-05-24: Phase 3 in-scope structured rules; advisor-head + admin UI maintainer (PC-7).
model EmbassyRule {
  id                 Int     @id @default(autoincrement())
  tenantId           Int
  ruleType           String // document_required | cooldown_period | interview_required | minimum_funds
  destinationCountry String // ISO-3166-1 alpha-2 (e.g. US, AE)
  applicationType    String? // null = all | tourist | business | family | student
  conditionJson      String? @db.Text // rule logic JSON-stringified per sanitizeJson convention
  actionLabel        String // human-readable advisor warning text
  severity           String // info | warning | blocker
  isActive           Boolean @default(true)
  createdById        Int?

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdBy User?    @relation("EmbassyRuleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, destinationCountry, applicationType, ruleType])
  @@index([tenantId])
}

// ── RFU customer profile extension ───────────────────────────────────
model RfuLeadProfile {
  id                    Int       @id @default(autoincrement())
  tenantId              Int       @default(1)
  contactId             Int       @unique // 1:1 with Contact
  passportNumber        String?
  passportExpiry        DateTime?
  visaHistoryJson       String?   @db.Text
  frequentFlyerJson     String?   @db.Text
  seatPref              String?
  mealPref              String?
  travelStyle           String?
  budgetMin             Decimal?  @db.Decimal(15, 2)
  budgetMax             Decimal?  @db.Decimal(15, 2)
  emergencyContactName  String?
  emergencyContactPhone String?
  medicalNotes          String?   @db.Text
  specialAssistance     String?   @db.Text
  pastComplaintsJson    String?   @db.Text
  productTier           String? // entry | primary | premium
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([tenantId, productTier])
}

// ── Religious-guidance content library (RFU) ─────────────────────────
//
// PRD §4.8 + §4.10 RFU sub-brand. Admin-curated content packets fired
// at fixed pre-departure offsets (T-14d / T-7d / T-1d, etc.) for
// pilgrims on the RFU (Reach for Umrah) journey. Library is editable
// via /api/travel/religious-packets; cron firing lives in
// backend/cron/religiousGuidanceEngine.js.
//
// Phase 1 ships placeholder copy at dayOffset 14 / 7 / 1; Yasin's Q1
// canonical Hajj/Umrah ritual guidance replaces the placeholder via
// admin PATCH — no schema change required.
//
// subBrand kept as a freeform string (not enum) so the same library
// pattern can be reused for future sub-brands (TMC parent-trip prep,
// Travel Stall destination tips) without a schema migration. Phase 1
// only seeds "rfu" rows.
//
// dayOffset semantics: positive = days BEFORE departure (14 = T-14d).
// Negative reserved for future "thank-you / share-your-journey"
// post-trip packets but Phase 1 ships only pre-trip (positive).
//
// channels = comma-separated subset of "wa","email","sms". Phase 1
// defaults to "wa,email"; wa goes through the Wati stub (Q9-blocked),
// email + sms log dispatch intent only until the scheduledEmail engine
// wire-in lands.
//
// NOT user-input-bound — admin-only CRUD; contentHtml passes through
// the standard sanitizeHtml pipeline at create time.
//
// No UNIQUE on (tenantId, subBrand, dayOffset) — multiple packets at
// the same offset (e.g. "ritual prep" + "documents reminder" both at
// T-7d) are intentional.
model ReligiousGuidancePacket {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  subBrand    String // "rfu" | future "tmc" | "travelstall" | "visasure"
  dayOffset   Int // 14, 7, 3, 1, 0 (= day of departure); positive = pre-trip
  title       String
  contentHtml String   @db.Text
  channels    String   @default("wa,email") // CSV: wa|email|sms
  isActive    Boolean  @default(true)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, subBrand, isActive])
  @@index([tenantId, subBrand, dayOffset])
}

// ── Trip microsite (TMC) — public, OTP-gated for sensitive views ─────
model TripMicrosite {
  id            Int                @id @default(autoincrement())
  tenantId      Int                @default(1)
  tripId        Int                @unique
  publicUuid    String             @unique
  subdomain     String // "trip-bali2026" (subdomain on tmc.travelstall.in per Q21)
  itineraryHtml String             @db.Text
  faqJson       String?            @db.Text
  publishedAt   DateTime?
  expiresAt     DateTime?
  otps          TripMicrositeOtp[]
  trip          TmcTrip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([tenantId, subdomain])
}

model TripMicrositeOtp {
  id          Int           @id @default(autoincrement())
  micrositeId Int
  phone       String
  purpose     String // registration | payment-plan | document-checklist | teacher-access
  otpHash     String
  expiresAt   DateTime
  usedAt      DateTime?
  microsite   TripMicrosite @relation(fields: [micrositeId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@index([micrositeId, phone, purpose])
}

// ── Travel-vertical financial fork (PRD_TRAVEL_{QUOTE_BUILDER,BILLING,SUPPLIER_MASTER} DD-5.1 [RESOLVED 2026-05-24]) ──
//
// Per the 2026-05-24 product-call session, the travel vertical forks its
// financial models rather than extending Quote / Invoice / Vendor in place.
// These 3 models live alongside the originals; generic CRM operator UI
// continues using the originals; travel-vertical operator UI routes to these.
//
// Field set here is INTENTIONALLY MINIMAL — establishes the schema beachhead
// + indexes. Real PRD §3 fields (TCS, supplier-payable, multi-stage
// settlement, commission ledger) land in follow-up commits per PRD spec.
//
// Sub-brand scoping (Q25): every row carries .subBrand and is indexed by
// (tenantId, subBrand). The voyagrAuth + apiKeyAuth.requireSubBrandMatch
// helpers enforce sub-brand isolation at the route layer.
model TravelQuote {
  id                   Int                   @id @default(autoincrement())
  tenantId             Int                   @default(1)
  subBrand             String
  contactId            Int
  status               String                @default("Draft") // Draft | Sent | Accepted | Rejected | Expired
  totalAmount          Decimal?              @db.Decimal(15, 2)
  currency             String                @default("INR")
  validUntil           DateTime?
  // S47 — FX-lock dedicated columns. Populated at customer-accept time
  // by routes/travel_quotes_public.js (mirrors the fxLock block also
  // persisted in TravelQuoteSnapshot.snapshotJson for forensic history /
  // pre-S47 backward-compat). Letting aggregate-level reporting + billing
  // joins query the locked rate without parsing snapshot JSON.
  //   fxRateSnapshot:        source→target rate at lock-time (e.g. 83.4
  //                          means 1 sourceCurrency = 83.4 targetCurrency).
  //                          Null when same-currency / no source rate / lookup
  //                          failed (the route's fail-soft contract).
  //   fxRateSourceCurrency:  the quote's currency at lock-time (mirror of
  //                          quote.currency captured at accept; kept here
  //                          so a later currency change on the quote doesn't
  //                          lose the lock's original source).
  //   fxRateTargetCurrency:  tenant.defaultCurrency at lock-time.
  //   fxRateLockedAt:        accept-time timestamp.
  //   fxRateExpiresAt:       optional expiry for the lock (PRD §3.4.2 — not
  //                          enforced today; reserved for future "lock
  //                          expires after N days" gate).
  fxRateSnapshot       Decimal?              @db.Decimal(15, 6)
  fxRateSourceCurrency String?
  fxRateTargetCurrency String?
  fxRateLockedAt       DateTime?
  fxRateExpiresAt      DateTime?
  // G017 (PRD §3.3 FR-3.6) — clone-with-margin lineage. When a sub-agent
  // operator duplicates a quote via POST /quotes/:id/duplicate?marginPercent=X,
  // we record both the source quote id (clonedFromQuoteId) and the markup
  // percent applied (appliedMarkupPercent). Lets a sub-agent revenue
  // report later sum margin across their cloned quotes. Both nullable —
  // unmarked clones (or non-clone source quotes) leave them null.
  clonedFromQuoteId    Int?
  appliedMarkupPercent Decimal?              @db.Decimal(5, 2)
  lines                TravelQuoteLine[]
  invoices             TravelInvoice[]
  snapshots            TravelQuoteSnapshot[]
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([tenantId, subBrand])
  @@index([tenantId, subBrand, status])
}

// Slice C9 — TravelQuoteSnapshot — immutable version history rows.
//
// One row is written every time a TravelQuote's status transitions:
//   - Customer-side: accept / reject / counter (via public landing page,
//     no auth — share-link JWT authorizes the write).
//   - Operator-side: future slices can emit snapshots from internal
//     accept/decline routes too; today only the public-side endpoints
//     write here (additive — operator audit chain via writeAudit() stays
//     authoritative for staff-driven transitions).
//   - System: quoteExpirySweep cron flips status Draft|Sent → Expired
//     when validUntil < now and writes a snapshot with changedBy='system'.
//
// snapshotJson stores the full TravelQuote + lines as observed at the
// transition instant. Schema is intentionally append-only — no UPDATE /
// DELETE on existing rows; the cron's idempotency check looks for an
// existing system-authored Expired snapshot before re-writing.
//
// Additive nullable schema — no bless marker required. statusBefore can
// be null for genesis rows; statusAfter is required (every snapshot
// represents a definite transition). changedById is nullable because
// customer-side transitions have no req.user.userId (the JWT only carries
// quoteId + tenantId).
model TravelQuoteSnapshot {
  id            Int      @id @default(autoincrement())
  quoteId       Int
  tenantId      Int
  versionNumber Int
  snapshotJson  String   @db.Text
  statusBefore  String?
  statusAfter   String
  changedById   Int?
  changedBy     String? // 'customer' | 'staff' | 'system'
  changeReason  String?  @db.Text
  createdAt     DateTime @default(now())

  quote TravelQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([quoteId])
  @@index([createdAt])
}

// PRD_TRAVEL_QUOTE_BUILDER §3.2 — line-item composition.
//
// Stores the composite line items that make up a quote (hotel rooms,
// flight segments, transport, visa fees, ad-hoc services). Each row
// carries its own lineType for downstream supplier-PO routing + tax
// classification (DD-5.3, pending product call). Amount is stored
// derived (quantity * unitPrice) at write time so the operator UI
// + PDF render don't need to recompute on every read.
//
// supplierId is optional — set when the operator has picked a vendor
// for that line (so supplier-payable ledgers can be backfilled).
// sortOrder controls display order in the quote PDF + builder UI.
//
// onDelete: Cascade on quoteId — if the parent quote is hard-deleted
// (TravelQuote.delete is a hard-delete per route comment at the
// DELETE handler), the line rows go with it.
model TravelQuoteLine {
  id              Int         @id @default(autoincrement())
  tenantId        Int         @default(1)
  quoteId         Int
  lineType        String      @default("other") // hotel | flight | transport | visa | service | other
  description     String
  quantity        Int         @default(1)
  unitPrice       Decimal     @db.Decimal(15, 2)
  amount          Decimal     @db.Decimal(15, 2)
  currency        String      @default("INR")
  supplierId      Int?
  sortOrder       Int         @default(0)
  notes           String?     @db.Text
  // G020 (PRD §3.2 FR-3.2.1-3) — line extension columns for GST + dimension
  // rendering + add-on flagging. All additive nullable / safe default.
  //   hsnSac:          per-line tax classification when operator overrides
  //                    the lineType-derived default (lib/hsnSacMapper).
  //   taxPercent:      per-line tax rate. Null → fallback to the lineType
  //                    GST default in routes/travel_quotes.js pricing.
  //   discountPercent: per-line discount on top of unitPrice.
  //   dimension:       quote-PDF rendering pivot for the qty column.
  //                    Enum string: perPax | perRoomPerNight | perTrip |
  //                    flatRate. Validated in route. Null → "flatRate".
  //   isAddOn:         flags this line as an optional add-on (operator can
  //                    let the customer toggle it on the customer-facing
  //                    share page in a future slice). Defaults to false so
  //                    pre-G020 rows render unchanged.
  hsnSac          String?
  taxPercent      Decimal?    @db.Decimal(5, 2)
  discountPercent Decimal?    @db.Decimal(5, 2)
  dimension       String? // perPax | perRoomPerNight | perTrip | flatRate
  isAddOn         Boolean     @default(false)
  quote           TravelQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantId, quoteId])
  @@index([quoteId, sortOrder])
}

// PRD_TRAVEL_QUOTE_BUILDER §3.5 — Template library.
//
// S31 slice (#920 / TRAVEL_BIG_SCOPE_BACKLOG). A TravelQuoteTemplate is a
// saved pre-filled set of TravelQuoteLine shapes that operators can clone
// into a new quote at build-time. Canonical examples: Umrah-7d, Golden-
// Triangle-5d, Schengen-visa-checklist. Saves operator typing on common
// itineraries.
//
// linesJson holds a JSON array of line shapes (without binding prices —
// prices may re-resolve at quote-build time via the pricing engine; the
// snapshot here is the operator's reference set). Each item in the array:
//   {
//     lineType: "hotel" | "flight" | "transport" | "visa" | "service" | "other",
//     description: string,
//     quantity: int (default 1),
//     unitPrice: number,
//     currency: string (3-letter ISO; defaults to template.currency),
//     supplierId: int|null,
//     sortOrder: int (default 0),
//     notes: string|null
//   }
//
// Sub-brand scoping: nullable subBrand. NULL = tenant-wide (visible to all
// users); named sub-brand = scoped to caller's subBrandAccess[] (mirrors
// ItineraryTemplate semantics from commit 1c01111a).
//
// category provides a coarse filter dimension ("Umrah" / "India-tour" /
// "Europe-tour" / "Visa" / etc.) for the dropdown picker UI.
//
// Additive nullable schema — NO bless marker. Brand-new model; no UNIQUE
// constraints, no backfilled NOT NULL columns. Per CLAUDE.md standing
// rule: only re-shapes need bless markers, fresh additive models don't.
model TravelQuoteTemplate {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  subBrand    String? // tmc | rfu | travelstall | visasure | null (tenant-wide)
  category    String? // Umrah | India-tour | Europe-tour | Visa | etc.
  currency    String   @default("INR")
  linesJson   String   @db.LongText // JSON array of line shapes; see model docs
  isActive    Boolean  @default(true)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, isActive])
  @@index([tenantId, subBrand, isActive])
}

model TravelInvoice {
  id                   Int                             @id @default(autoincrement())
  tenantId             Int                             @default(1)
  subBrand             String
  contactId            Int
  // Optional FK to TravelQuote — an invoice can be generated without a
  // prior quote (direct billing, supplier-passthrough scenarios).
  quoteId              Int?
  // Link back to the source Itinerary when this invoice was auto-created from a
  // public itinerary payment (flight quote / proposal). Nullable + additive —
  // quote-sourced + manual invoices leave it null. Lets the public payment flow
  // find + update the SAME invoice as the advance → balance clears (one
  // evolving ledger record per booking).
  itineraryId          Int?
  // Tenant-scoped human-readable identifier (e.g. "TINV-2026-0001"). The
  // route layer assigns sequentially per tenant + sub-brand at create time.
  invoiceNum           String
  status               String                          @default("Draft") // Draft | Issued | Partial | Paid | Voided
  totalAmount          Decimal?                        @db.Decimal(15, 2)
  currency             String                          @default("INR")
  dueDate              DateTime?
  paidAt               DateTime?
  // Arc 2 #901 slice 10 — Section 206C(1G) TCS persistence (PRD_TRAVEL_BILLING
  // UC-2.6 + FR-3.5). All four fields nullable + additive — invoices that
  // never get TCS applied (domestic, below-threshold, pre-slice-10 historical)
  // leave them null. tcsAppliedAt doubles as the idempotency sentinel — once
  // set, POST /:id/apply-tcs rejects with TCS_ALREADY_APPLIED. Line-level
  // TCS persistence (separate TravelInvoiceLine row) is deferred to slice 11.
  tcsAmount            Decimal?                        @db.Decimal(15, 2)
  tcsRate              Decimal?                        @db.Decimal(5, 2)
  tcsExceedingAmount   Decimal?                        @db.Decimal(15, 2)
  tcsAppliedAt         DateTime?
  // PRD_TRAVEL_GST_COMPLIANCE FR-3.2.1 (G028 + G029) — invoice-level
  // CGST/SGST/IGST persistence + place-of-supply. Persisted by the
  // POST /:id/tax-persist endpoint; populated by computing the
  // existing tax-preview pipeline once and writing the result. NULL
  // means "not yet persisted" — the route falls back to the on-the-fly
  // tax-preview compute for backwards-compat with pre-G028 rows.
  //
  //   placeOfSupply  — 2-char (or ISO-3166-2-style "IN-MH") state code
  //                    matching the gstStateCode/Contact.stateCode shape.
  //                    Persisted at compute-time so issued PDFs/exports
  //                    stay pinned to the historical place-of-supply
  //                    even if Contact.stateCode changes later.
  //   cgst/sgst/igst Percent/Amount — invoice-level totals (aggregated
  //                    across all lines). Decimal(15,2) for amounts;
  //                    Decimal(5,2) for percent rates (max 100.00).
  //                    For intra-state supplies cgstAmount + sgstAmount
  //                    are populated and igstAmount=0; for inter-state
  //                    igstAmount is populated and cgst/sgst=0.
  //   totalTaxAmount — sum of cgst + sgst + igst (denorm for fast
  //                    "what was the total tax?" reads in reports).
  //   gstComputedAt  — sentinel timestamp; NULL means uncomputed;
  //                    non-NULL means the tax-persist endpoint has run
  //                    at least once. Idempotency: re-running overwrites.
  placeOfSupply        String?
  cgstAmount           Decimal?                        @db.Decimal(15, 2)
  sgstAmount           Decimal?                        @db.Decimal(15, 2)
  igstAmount           Decimal?                        @db.Decimal(15, 2)
  cgstPercent          Decimal?                        @db.Decimal(5, 2)
  sgstPercent          Decimal?                        @db.Decimal(5, 2)
  igstPercent          Decimal?                        @db.Decimal(5, 2)
  totalTaxAmount       Decimal?                        @db.Decimal(15, 2)
  gstComputedAt        DateTime?
  // Arc 2 #901 slice 11 — Doc-type taxonomy (PRD_TRAVEL_BILLING FR-3.x).
  // Nullable with default "TaxInvoice"; new rows get the default, existing
  // rows remain NULL (route layer treats NULL as "TaxInvoice"). Enum values:
  // Proforma | TaxInvoice | CreditNote | DebitNote | TravelVoucher.
  // Separate CreditNote/DebitNote workflows deferred to slice 12; this slice
  // ships the field + validation + filter only.
  docType              String?                         @default("TaxInvoice")
  // Arc 2 #901 slice 14 — CreditNote workflow (PRD_TRAVEL_BILLING UC-2.7).
  // Self-relation linking a CreditNote (or DebitNote) row back to the
  // original invoice it adjusts. Nullable + onDelete SetNull — if the parent
  // is hard-deleted the credit-note row remains as an orphan financial
  // record (audit-trail preservation; deletion of a parent in Issued/Paid
  // state is already prevented at the route layer). Existing rows get NULL
  // (additive safe — no bless marker needed).
  parentInvoiceId      Int?
  parentInvoice        TravelInvoice?                  @relation("InvoiceCreditNotes", fields: [parentInvoiceId], references: [id], onDelete: SetNull)
  creditNotes          TravelInvoice[]                 @relation("InvoiceCreditNotes")
  // S33 (#920) — PRD_TRAVEL_BILLING FR-3.7 cancellation-policy wire-up.
  // Optional FK pointing at a CancellationPolicy row the operator chose
  // at issue-time (or auto-picked at void-time as the sub-brand's active
  // default). NULL means "fall back to sub-brand default at cancel-time"
  // so historical invoices and policy-less sub-brands keep working.
  // onDelete: SetNull — deleting a policy mid-flight leaves the invoice
  // intact + falls back to default resolution on the next cancel.
  // Nullable + additive (no bless marker needed).
  cancellationPolicyId Int?
  cancellationPolicy   CancellationPolicy?             @relation(fields: [cancellationPolicyId], references: [id], onDelete: SetNull)
  lines                TravelInvoiceLine[]
  schedule             TravelPaymentSchedule[]
  quote                TravelQuote?                    @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  tenant               Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // PRD_TRAVEL_SUPPLIER_MASTER G045 — back-relation for supplier commission
  // entries pinned to this customer-facing invoice (FR-3.5.a).
  commissionEntries    TravelSupplierCommissionEntry[]
  // PRD_TRAVEL_SUPPLIER_MASTER G039 — customer-side chargebacks reference
  // the originating invoice for refund / ledger reconciliation.
  supplierDisputes     TravelSupplierDispute[]
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt

  @@unique([tenantId, invoiceNum])
  @@index([tenantId, subBrand])
  @@index([tenantId, subBrand, status])
  @@index([tenantId, parentInvoiceId])
  @@index([tenantId, cancellationPolicyId])
  @@index([tenantId, itineraryId])
  // Draft-invoice dedup guard (routes/travel_invoices.js POST /invoices).
  // The duplicate check filters on (tenantId, contactId, subBrand, status,
  // currency, totalAmount, dueDate); the first four cover selectivity, the
  // rest filter in-row. Without this, the dedup query scanned every invoice
  // for the contact regardless of status — fine at seed scale, bad once
  // a tenant accumulates >10k invoices per contact. Also serves the
  // "all invoices for one contact" lookups that the UI hits on contact
  // detail pages.
  @@index([tenantId, contactId, status])
}

// S33 (#920) — PRD_TRAVEL_BILLING FR-3.7.a cancellation-policy table.
//
// Per-tenant policy rows mapping "days before service start" → refund
// percent. When an invoice is voided (cancellation), the route layer
// walks the tiers (sorted DESC by daysBeforeServiceStart) and picks the
// first tier whose threshold is <= the actual days-before-start; the
// matched tier's refundPercent drives the credit-note amount.
//
// tiersJson stores the policy as a JSON array of
//   { daysBeforeServiceStart: <int>, refundPercent: <0..100> }
// e.g. [
//   {"daysBeforeServiceStart": 30, "refundPercent": 100},  // full refund 30d+ out
//   {"daysBeforeServiceStart": 7,  "refundPercent": 50},   // 50% refund 7..29d
//   {"daysBeforeServiceStart": 0,  "refundPercent": 0}     // no refund <7d
// ]
//
// PRD note: PRD uses "retentionPercent" (% kept by operator). We store
// the inverse "refundPercent" (% returned to customer) because that's
// the value that directly drives the credit-note amount — saves an
// arithmetic flip in every consumer. refundPercent + retentionPercent
// always = 100. Operator-facing UI may render either; the route layer
// reports both in the cancel-preview response.
//
// subBrand is OPTIONAL — NULL means "tenant-wide default applied to any
// sub-brand without its own policy"; a named sub-brand scopes the
// policy to that sub-brand only. Sub-brand-specific overrides win over
// tenant-wide defaults at lookup time.
//
// @@unique([tenantId, name]) prevents duplicate policy names per tenant
// (humans address policies by name in the admin UI). Multiple active
// policies per tenant are legal — they just need distinct names.
//
// Additive nullable schema — NO bless marker. Brand-new model; the FK
// on TravelInvoice.cancellationPolicyId is nullable.
model CancellationPolicy {
  id          Int             @id @default(autoincrement())
  tenantId    Int             @default(1)
  name        String          @db.VarChar(255) // e.g. "TMC Default" / "RFU Default"
  subBrand    String? // tmc | rfu | travelstall | visasure | null (tenant-wide)
  description String?         @db.Text
  tiersJson   String          @db.LongText // JSON array; see model docs above
  isActive    Boolean         @default(true)
  invoices    TravelInvoice[]
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@index([tenantId, subBrand, isActive])
}

// PRD_TRAVEL_BILLING FR-3.1.a — line-item composition under TravelInvoice.
//
// Mirrors TravelQuoteLine (commit f7203b8e) — same auth/audit conventions,
// same parent-total recompute pattern, same amount-derived-server-side
// contract. Stores the composite line items that make up an invoice
// (hotel rooms, flight segments, transport, visa fees, taxes, fees, addons,
// TCS/TDS withholding lines, ad-hoc services).
//
// Slice-1 minimal field set (matches TravelQuoteLine):
//   - lineType enum extended to include tax/fee/addon/tcs/tds for the
//     billing-side line-classification surface
//   - amount stored derived (quantity * unitPrice) at write time so the
//     operator UI + PDF render don't need to recompute on every read
//
// Future slices (NOT in this commit — land when downstream PRDs ship):
//   - supplierId FK (lands with #903 Supplier Master wire-in)
//   - cost-vs-sell + GST breakdown (PRD §3.5 TCS Sec 206C + tax engine)
//
// Slice 4 (this commit) — PRD_TRAVEL_BILLING FR-3.1.b + FR-3.1.d.
//   PNR / booking-ref + service-dates. All NULLABLE — additive safe
//   migration (no bless marker needed). Free-form strings; no FK to a
//   PNR-master table because PNR is a vendor-side identifier and a single
//   booking can carry multiple (airline PNR + GDS reference + supplier
//   booking-ref) — operator picks which to record per line.
//
// onDelete: Cascade on invoiceId — if the parent invoice is hard-deleted
// (TravelInvoice.delete is a hard-delete for Draft invoices per route
// comment at the DELETE handler), the line rows go with it.
model TravelInvoiceLine {
  id               Int                     @id @default(autoincrement())
  tenantId         Int                     @default(1)
  invoiceId        Int
  lineType         String                  @default("other") // per_pax | per_room | per_night | per_trip | tax | fee | addon | tcs | tds | other
  description      String
  quantity         Int                     @default(1)
  unitPrice        Decimal                 @db.Decimal(15, 2)
  amount           Decimal                 @db.Decimal(15, 2)
  currency         String                  @default("INR")
  sortOrder        Int                     @default(0)
  notes            String?                 @db.Text
  // FR-3.1.b — per-line PNR / supplier booking-reference (free-form).
  // pnr: 6-char airline/GDS PNR typically; cap at 20 to allow supplier
  //   suffix variants (e.g. "ABC123-LEG2"). bookingRef is the alternative
  //   confirmation number some suppliers (hotels, transfers) use; cap at
  //   50 to accommodate longer hotel/cruise confirmation strings.
  pnr              String?
  bookingRef       String?
  // FR-3.1.d — per-line service dates. Drives accrual-period reporting
  // (revenue recognized when service rendered, not when invoiced).
  // Inclusive range semantics: serviceEndDate >= serviceStartDate (same-day
  // allowed for single-night stays / single-day transfers).
  serviceStartDate DateTime?
  serviceEndDate   DateTime?
  // Arc 2 #901 slice 12 — UC-2.1 multi-currency support.
  // Operator captures the day's FX rate when entering a line in a non-base
  // currency (e.g. USD line on an INR invoice). baseAmount = amount *
  // fxRateToBase, server-computed + persisted for accrual reporting.
  // NULL means the line is single-currency (no FX conversion needed;
  // baseAmount === amount). Live FX-rate lookup deferred (Q-blocker).
  // 6dp precision on the rate accommodates inverse-quote pairs like
  // USD→INR=0.012048 (1 / 83.00); 2dp on baseAmount matches the existing
  // Decimal(15,2) convention used across TravelInvoice + TravelQuote.
  fxRateToBase     Decimal?                @db.Decimal(15, 6)
  baseAmount       Decimal?                @db.Decimal(15, 2)
  // PRD_TRAVEL_BILLING FR-3.1.c, e, f, g + PRD_TRAVEL_GST_COMPLIANCE FR-3.2.2
  // (G021 + G029). Per-line supplier + cost/sell margin + HSN/SAC + per-line
  // GST split persistence. All ADDITIVE NULLABLE — pre-G021 rows leave the
  // columns NULL; the route layer treats NULL as "uncomputed" and falls
  // back to the on-the-fly tax-preview path. Existing on-the-fly tax-preview
  // continues to work unchanged for legacy rows.
  //
  //   supplierId  — FK to TravelSupplier. NULL = customer-direct line (no
  //                 supplier involved, e.g. service-fee). onDelete:
  //                 SetNull so deleting a supplier mid-flight doesn't
  //                 cascade through historical lines (matches the
  //                 supplier-aware policies elsewhere in the schema).
  //   isAddon     — true for upsell add-ons (excursions, lounge access,
  //                 travel insurance riders). Drives margin reporting +
  //                 commission gating per FR-3.1.g. Default false so
  //                 unmarked lines stay base-package by default.
  //   lineCost    — what WE pay the supplier. Persisted for COGS reporting.
  //   lineSell    — what the customer pays for THIS line (typically equals
  //                 `amount` but kept separate for promo/discount surfaces
  //                 where sell != amount-charged-to-invoice).
  //   hsnSac      — HSN (goods) or SAC (services) code resolved at
  //                 issue-time. Persisted so the GSTR-1 export pins the
  //                 historical SAC even if hsnSacMapper.js's mapping
  //                 changes in a future release.
  //   cgst/sgst/igst Percent/Amount — per-line GST split. populated by the
  //                 POST /:id/tax-persist endpoint. Same Decimal(15,2)
  //                 convention as totalAmount; rates use Decimal(5,2)
  //                 (max 100.00).
  supplierId       Int?
  isAddon          Boolean                 @default(false)
  lineCost         Decimal?                @db.Decimal(15, 2)
  lineSell         Decimal?                @db.Decimal(15, 2)
  hsnSac           String?
  cgstPercent      Decimal?                @db.Decimal(5, 2)
  cgstAmount       Decimal?                @db.Decimal(15, 2)
  sgstPercent      Decimal?                @db.Decimal(5, 2)
  sgstAmount       Decimal?                @db.Decimal(15, 2)
  igstPercent      Decimal?                @db.Decimal(5, 2)
  igstAmount       Decimal?                @db.Decimal(15, 2)
  invoice          TravelInvoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier         TravelSupplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  // PRD_TRAVEL_BILLING G022 (FR-3.3.a) — supplier payables that settle this
  // customer-facing invoice line. Many-to-zero/one — one line can be settled
  // across multiple supplier payables (split fares, fee-only sub-charges).
  payables         TravelSupplierPayable[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([tenantId, invoiceId])
  @@index([invoiceId, sortOrder])
  @@index([tenantId, supplierId])
  @@index([tenantId, hsnSac])
}

// PRD_TRAVEL_BILLING FR-3.2.a — payment-schedule milestones.
// Staged settlement: a single TravelInvoice can have multiple milestones
// (e.g. 25% advance, 50% pre-departure, 25% on-return). Each row is
// one milestone with its own dueDate + expectedAmount + status.
//
// status flow: pending → partial → paid (or waived / overdue at any point)
// onDelete: Cascade on invoiceId — if parent invoice is hard-deleted
// the milestones go with it.
//
// receivedAmount tracks partial settlement (operator manually records
// receipts in slice 6; slice 8 will wire it to the Stripe/Razorpay
// payment-webhook surface). All decimal columns share the existing
// Decimal(15,2) convention used across TravelInvoice + TravelQuote.
//
// Future slices (NOT in this slice):
//   slice 7 — auto-create a default 25/50/25 schedule on POST /:id/issue
//   slice 8 — payment-webhook wires receivedAmount + paidAt automatically
//   slice 9 — overdue cron flips status to 'overdue' on dueDate < now
model TravelPaymentSchedule {
  id                 Int           @id @default(autoincrement())
  tenantId           Int           @default(1)
  invoiceId          Int
  milestoneOrder     Int // 1-based; operator-controlled sequencing
  dueDate            DateTime?
  expectedAmount     Decimal       @db.Decimal(15, 2)
  expectedCurrency   String        @default("INR")
  receivedAmount     Decimal?      @db.Decimal(15, 2)
  status             String        @default("pending") // pending | partial | paid | overdue | waived
  paidAt             DateTime?
  notes              String?       @db.Text
  // C8 (PRD_TRAVEL_BILLING UC-2.4 reminder cron) — additive nullable
  // counters consumed by paymentScheduleReminderEngine.js. Idempotency
  // guard: engine skips schedules where remindersSentCount >= 3 so the
  // T-7 / T-3 / T-1 sweep can't double-fire on a re-run within the same
  // window. lastReminderSentAt powers an operator-visible "last chased"
  // surface in the future Aged Receivable drill-down.
  remindersSentCount Int?          @default(0)
  lastReminderSentAt DateTime?
  // PRD_TRAVEL_BILLING G025 (FR-3.2.e) — anchor-relative due date.
  // When set, the route layer computes `dueDate = anchor_date + anchorOffset days`
  // from the linked invoice / trip. anchorType ∈ {booking_date, departure_date,
  // return_date, issue_date}. anchorOffset is signed (negative = before anchor,
  // positive = after). Both NULLABLE so legacy / operator-set schedules with a
  // direct dueDate keep working unchanged. Operator override stores both:
  // anchor metadata stays for audit + an explicit dueDate stays the source of
  // truth (see scheduleAnchorResolver.js for the resolution shape).
  anchorType         String? // booking_date | departure_date | return_date | issue_date
  anchorOffset       Int? // signed days offset from the anchor
  // PRD_TRAVEL_BILLING G026 (FR-3.2.g) — overdue escalation level.
  // 0 = no escalation fired; 1 = T+3 fired; 2 = T+7 fired; 3 = T+14 fired.
  // Engine bumps this monotonically — once at level N, never re-fires N or
  // anything below. Reset only via operator-action route (out of scope).
  escalationLevel    Int           @default(0)
  lastEscalationAt   DateTime?
  invoice            TravelInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([tenantId, invoiceId])
  @@index([tenantId, invoiceId, milestoneOrder])
  @@index([tenantId, status, dueDate])
  // PRD_TRAVEL_BILLING G026 — escalation cron scans by (status, escalationLevel).
  @@index([tenantId, status, escalationLevel])
}

model TravelSupplier {
  id                    Int                                 @id @default(autoincrement())
  tenantId              Int                                 @default(1)
  subBrand              String
  name                  String
  contactPerson         String?
  phone                 String?
  email                 String?
  gstin                 String?
  addressLine           String?
  // hotel | flight | transport | visa-consul | other
  supplierCategory      String                              @default("other")
  isActive              Boolean                             @default(true)
  // PRD_TRAVEL_SUPPLIER_MASTER G040 — supplier governance status enum.
  // Values: active | paused | blocked_disputed | archived.
  // isActive STAYS as the back-compat derived flag (status='active' → isActive=true;
  // other → false). Existing rows default to "active" via the column default —
  // additive migration, no bless marker needed.
  status                String                              @default("active")
  // PRD_TRAVEL_SUPPLIER_MASTER G041 — payment-terms kind enum.
  // Values: net | prepay | on_departure | on_arrival.
  // When kind='net', paymentTermsDays is the N (NET-N days). For non-net kinds
  // paymentTermsDays MUST be null — the route auto-nulls on write.
  paymentTermsKind      String                              @default("net")
  // PRD_TRAVEL_SUPPLIER_MASTER slice 1 (#903) — payment terms + credit tracking.
  // All NULLABLE — additive safe migration (no bless marker needed).
  // paymentTermsDays: free-form NET-N day count (e.g. 30 for NET-30, 45 for NET-45).
  // creditLimit:      max outstanding payable before booking-confirm guard fires (FR-3.1.c).
  // creditCurrency:   ISO-4217 code, defaults to INR.
  // taxRegimeCode:    "regular" | "composite" | "exempt" (free-form; will tighten in Phase 2).
  // primaryContactRole: e.g. "Accounts payable" | "Sales rep" — distinct from contactPerson name.
  // notes:            unstructured operator notes blob.
  paymentTermsDays      Int?
  creditLimit           Decimal?                            @db.Decimal(15, 2)
  creditCurrency        String?                             @default("INR")
  taxRegimeCode         String?
  primaryContactRole    String?
  notes                 String?                             @db.Text
  // PRD_TRAVEL_SUPPLIER_MASTER G045 (FR-3.1.e) — default supplier-side
  // commission rate (e.g. 7.50% IATA inward commission for air bookings,
  // 10% hotel commission, etc.). Override-able per
  // TravelSupplierCommissionEntry row at accrue time. Nullable + additive
  // (no bless marker needed).
  commissionPercent     Decimal?                            @db.Decimal(5, 2)
  tenant                Tenant                              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payables              TravelSupplierPayable[]
  // PRD_TRAVEL_SUPPLIER_MASTER G045 — supplier-side commission ledger per FY
  // (FR-3.5.a, FR-3.5.b).
  commissionEntries     TravelSupplierCommissionEntry[]
  // PRD_TRAVEL_SUPPLIER_MASTER G038 — KYC + onboarding checklist (FR-3.1.h).
  kyc                   TravelSupplierKyc?
  // PRD_TRAVEL_SUPPLIER_MASTER G039 — dispute history + chargeback log
  // (FR-3.1.g, FR-3.6.a-c).
  disputes              TravelSupplierDispute[]
  // PRD_TRAVEL_SUPPLIER_MASTER G044 (FR-3.4.a-c) — supplier-statement
  // reconciliation batches (per supplier + statementMonth).
  reconciliationBatches TravelSupplierReconciliationBatch[]
  // PRD_TRAVEL_SUPPLIER_MASTER G046 (FR-3.3.c) — invoice PDF uploads,
  // optionally linked to a TravelSupplierPayable.
  invoiceUploads        TravelSupplierInvoiceUpload[]
  createdAt             DateTime                            @default(now())
  updatedAt             DateTime                            @updatedAt
  travelPurchaseOrders  TravelPurchaseOrder[]
  // PRD_TRAVEL_BILLING FR-3.1.c (G021) — back-relation for per-line
  // supplier attribution on customer invoice lines. Each TravelInvoiceLine
  // may optionally pin which supplier the line was sourced from for
  // COGS / margin reporting; onDelete: SetNull at the child side keeps
  // historical lines intact when a supplier row is removed.
  invoiceLines          TravelInvoiceLine[]

  @@index([tenantId, subBrand])
  @@index([tenantId, subBrand, supplierCategory])
}

// PRD_TRAVEL_BILLING UC-2.3 — supplier-payable ledger.
// Tracks A/P (accounts payable) entries: what we owe each supplier.
// Status flow: pending → scheduled → paid (or cancelled).
// Each row is a single payable obligation (one PO, one supplier).
//
// Slice 3 of #903 (Supplier Master). All NULLABLE / additive — new model,
// no migration risk. Status enum enforced at the route layer
// (pending | scheduled | paid | cancelled); status='paid' auto-sets
// paidAt=now() if not already set. Sub-brand isolation is inherited via
// the parent TravelSupplier — every payable is scoped through its
// supplier's subBrand + tenantId.
model TravelSupplierPayable {
  id                  Int                                @id @default(autoincrement())
  tenantId            Int                                @default(1)
  supplierId          Int
  poNumber            String? // free-form purchase-order or booking reference
  description         String // "50 PNRs Apr 2026" / "Hotel block 25-28 May" etc.
  amount              Decimal                            @db.Decimal(15, 2)
  currency            String                             @default("INR")
  dueDate             DateTime?
  status              String                             @default("pending") // pending | scheduled | paid | cancelled
  paidAt              DateTime?
  notes               String?                            @db.Text
  // PRD_TRAVEL_SUPPLIER_MASTER FR-3.3.a (G037) — optional PO→Payable linkage.
  // Set on auto-creation when a TravelPurchaseOrder transitions to `fulfilled`.
  purchaseOrderId     Int?
  // PRD_TRAVEL_BILLING G022 (FR-3.3.a) — optional InvoiceLine→Payable linkage.
  // The customer-facing invoice line that this payable settles against.
  // Populated by the route layer when a payable is created in the context of
  // an existing invoice line (e.g. operator manually links a hotel payable
  // to the "Hotel block 25-28 May" line on the customer invoice). NULL = no
  // direct invoice-line attribution (most legacy + PO-auto-created payables
  // leave this NULL since the PO→Payable path doesn't surface line-level
  // attribution today). onDelete: SetNull so deleting an invoice line
  // doesn't cascade through historical payable rows.
  invoiceLineId       Int?
  // PRD_TRAVEL_BILLING G022 (FR-3.5.e) — optional Payable→Batch linkage.
  // Set on POST /payable-batches/:id/add-payable. NULL = not in a batch.
  payableBatchId      Int?
  supplier            TravelSupplier                     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  tenant              Tenant                             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder       TravelPurchaseOrder?               @relation(fields: [purchaseOrderId], references: [id])
  invoiceLine         TravelInvoiceLine?                 @relation(fields: [invoiceLineId], references: [id], onDelete: SetNull)
  payableBatch        TravelSupplierPayableBatch?        @relation(fields: [payableBatchId], references: [id], onDelete: SetNull)
  // PRD_TRAVEL_SUPPLIER_MASTER G039 — disputes tied to a specific payable.
  disputes            TravelSupplierDispute[]
  // PRD_TRAVEL_SUPPLIER_MASTER G044 (FR-3.4.a) — reconciliation lines that
  // matched THIS payable. Optional; a payable can be matched against many
  // statement lines across batches (e.g. partial payments).
  reconciliationLines TravelSupplierReconciliationLine[]
  // PRD_TRAVEL_SUPPLIER_MASTER G046 (FR-3.3.c) — invoice uploads matched to
  // this payable.
  invoiceUploads      TravelSupplierInvoiceUpload[]
  createdAt           DateTime                           @default(now())
  updatedAt           DateTime                           @updatedAt

  @@index([tenantId, supplierId])
  @@index([tenantId, supplierId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, purchaseOrderId])
  // PRD_TRAVEL_BILLING G022 — invoice-line attribution + batch lookup.
  @@index([tenantId, invoiceLineId])
  @@index([tenantId, payableBatchId])
}

// PRD_TRAVEL_BILLING G022 (FR-3.5.e) — supplier-payable batch runs.
//
// Groups N TravelSupplierPayable rows into a single "payment run" that an
// operator approves + sends to the bank as a CSV/transfer file. State
// machine:
//
//   draft → approved → sent_to_bank → settled
//                                       └──→ cancelled (terminal)
//   draft / approved / sent_to_bank ─────→ cancelled
//
// Batch numbering: TPB-YYYY-NNNN per-tenant per-year, race-safe via
// $transaction. Same numbering pattern as TravelPurchaseOrder (TPO-…).
//
// On `settled`, every child payable's status flips pending/scheduled → paid
// in a single transaction with the batch flip. Cancelling the batch frees
// the children back to pending (FK SetNull on payableBatchId).
//
// CSV export: GET /:id/payment-csv returns bank-friendly CSV columns
// (supplierName / accountNumber / ifsc / amount / currency / reference).
// Bank account details come from supplier.bankAccountMasked (already on
// TravelSupplier) — masked for display, never exported with full digits in
// CSV (operator pulls the unmasked version from the supplier-vault separately).
model TravelSupplierPayableBatch {
  id            Int                     @id @default(autoincrement())
  tenantId      Int                     @default(1)
  batchNumber   String // TPB-YYYY-NNNN per-tenant per-year
  status        String                  @default("draft") // draft | approved | sent_to_bank | settled | cancelled
  paymentMethod String? // bank_transfer | upi | cheque | rtgs | neft | wire
  bankAccount   String? // masked display string (e.g. "HDFC ****1234")
  totalAmount   Decimal                 @default(0) @db.Decimal(15, 2)
  payableCount  Int                     @default(0)
  scheduledFor  DateTime?
  approvedBy    Int?
  approvedAt    DateTime?
  sentAt        DateTime?
  settledAt     DateTime?
  cancelledAt   DateTime?
  cancelReason  String?                 @db.Text
  notes         String?                 @db.Text
  createdBy     Int?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payables      TravelSupplierPayable[]

  @@unique([tenantId, batchNumber])
  @@index([tenantId, status, scheduledFor])
  @@index([tenantId, createdAt])
}

// PRD_TRAVEL_SUPPLIER_MASTER FR-3.2 (G035/G036/G037) — supplier purchase orders.
//
// First-class PO ledger sitting BETWEEN the supplier and the payable. State
// machine: draft → sent → acknowledged → fulfilled → cancelled. A PO can be
// auto-created from a confirmed booking/trip (G037) OR manually drafted by
// an operator. When a PO transitions to `fulfilled`, the route layer
// auto-creates matching TravelSupplierPayable rows linking back via
// purchaseOrderId (FR-3.3.a).
//
// All NULLABLE / additive — new model, no migration risk. State enum +
// transition matrix enforced at the route layer (see
// backend/routes/travel_purchase_orders.js). PO numbering: TPO-YYYY-NNNN
// per-tenant per-year, race-safe via transaction. Sub-brand isolation is
// inherited via the parent TravelSupplier.
model TravelPurchaseOrder {
  id             Int                       @id @default(autoincrement())
  tenantId       Int                       @default(1)
  supplierId     Int
  bookingId      Int?
  poNumber       String
  // draft | sent | acknowledged | fulfilled | cancelled
  status         String                    @default("draft")
  currency       String                    @default("INR")
  subtotal       Decimal?                  @db.Decimal(15, 2)
  taxAmount      Decimal?                  @db.Decimal(15, 2)
  totalAmount    Decimal?                  @db.Decimal(15, 2)
  notes          String?                   @db.Text
  sentAt         DateTime?
  acknowledgedAt DateTime?
  fulfilledAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?                   @db.Text
  createdBy      Int?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  tenant         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       TravelSupplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  booking        Booking?                  @relation(fields: [bookingId], references: [id])
  lines          TravelPurchaseOrderLine[]
  payables       TravelSupplierPayable[]

  @@unique([tenantId, poNumber])
  @@index([tenantId, supplierId, status])
  @@index([tenantId, bookingId])
}

// Line items on a TravelPurchaseOrder.
model TravelPurchaseOrderLine {
  id                  Int                                @id @default(autoincrement())
  tenantId            Int                                @default(1)
  purchaseOrderId     Int
  lineType            String // service | tax | fee | discount
  description         String
  quantity            Decimal                            @default(1) @db.Decimal(10, 2)
  unitPrice           Decimal                            @db.Decimal(15, 2)
  lineTotal           Decimal                            @db.Decimal(15, 2)
  pnr                 String?
  bookingRef          String?
  sortOrder           Int                                @default(0)
  createdAt           DateTime                           @default(now())
  purchaseOrder       TravelPurchaseOrder                @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  // PRD_TRAVEL_SUPPLIER_MASTER G044 (FR-3.4.a) — supplier-statement
  // reconciliation lines that matched THIS PO line by pnr+amount.
  reconciliationLines TravelSupplierReconciliationLine[]

  @@index([tenantId, purchaseOrderId])
  @@index([pnr])
}

// ── Per-sub-brand brand kit (PRD_TRAVEL_PER_SUBBRAND_BRANDING DD-5.2 [RESOLVED 2026-05-24]) ──
//
// Per the 2026-05-24 product-call session, brand-kit storage forks from the
// Tenant.subBrandConfigJson blob into a dedicated BrandKit model. Each
// (tenantId, subBrand) pair can have multiple versions; only one is
// isActive=true at a time per (tenantId, subBrand). Version history retained
// (DD-5.6: last 10 versions per sub-brand; older purged by future cron).
//
// Consumer surfaces: per-sub-brand theme application (THEME_MANAGEMENT),
// wellness mini-site editor (ZYLU MINI-001), marketing flyer studio
// (MARKETING_FLYER), travel invoice PDF templates, customer portal headers.
model BrandKit {
  id                Int      @id @default(autoincrement())
  tenantId          Int
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Sub-brand scope (Q25 — required for travel-vertical). For non-travel
  // tenants (generic / wellness), subBrand stays null = tenant-wide default.
  subBrand          String?  @db.VarChar(50)
  // Version number — increments on every save. Latest version per
  // (tenantId, subBrand) is the active one. Older versions kept for revert
  // (DD-5.6 retention policy: last 10 versions; future cron purges).
  version           Int      @default(1)
  isActive          Boolean  @default(false)
  // Brand assets
  logoUrl           String?  @db.VarChar(500) // light-mode logo
  logoDarkUrl       String?  @db.VarChar(500) // dark-mode logo (DD-5.5 — required when light inverts poorly)
  faviconUrl        String?  @db.VarChar(500)
  // Brand colors (hex; WCAG checked at save time per DD-5.5e)
  primaryColor      String?  @db.VarChar(20)
  secondaryColor    String?  @db.VarChar(20)
  accentColor       String?  @db.VarChar(20)
  bgColor           String?  @db.VarChar(20)
  textColor         String?  @db.VarChar(20)
  // Typography (DD-5.1: Google Fonts only for v1)
  fontFamily        String?  @db.VarChar(100) // e.g. "Inter, sans-serif"
  fontUrl           String?  @db.VarChar(500) // Google Fonts URL when used
  // Copy
  tagline           String?  @db.VarChar(200)
  // ── W4.A G089 — BrandKit schema extension (FR-3.1.a-g) ────────────────────
  // Additive nullable columns enabling the broader branding surface beyond
  // logo+colors+font: wordmark/hero imagery, status-state badges, separate
  // heading/body/code typography slots, CMYK color anchors for print, an
  // email-signature template + invoice header/footer + invoice stamp, plus
  // mission/social/support copy for portals + microsites. All optional —
  // existing kits continue to load and render via the v1 columns; new
  // surfaces opt in per-field as they're populated.
  wordmarkUrl       String?  @db.VarChar(500) // text-only logotype variant (no glyph)
  heroUrl           String?  @db.VarChar(500) // landing-page hero image (3:1 to 1:1 aspect)
  successBadge      String?  @db.VarChar(20) // hex; success-state accent (badges, toasts)
  warningBadge      String?  @db.VarChar(20) // hex; warning-state accent
  headingFontFamily String?  @db.VarChar(100)
  headingFontUrl    String?  @db.VarChar(500)
  bodyFontFamily    String?  @db.VarChar(100)
  bodyFontUrl       String?  @db.VarChar(500)
  codeFontFamily    String?  @db.VarChar(100)
  codeFontUrl       String?  @db.VarChar(500)
  cmykPrimary       String?  @db.VarChar(40) // "C,M,Y,K" tuple for print pipelines
  cmykSecondary     String?  @db.VarChar(40)
  cmykAccent        String?  @db.VarChar(40)
  signatureTemplate String?  @db.Text // HTML email-signature template
  headerImageUrl    String?  @db.VarChar(500) // invoice / PDF header art
  footerText        String?  @db.Text // invoice / PDF footer copy
  invoiceStampUrl   String?  @db.VarChar(500) // notarised stamp / chop image
  missionStatement  String?  @db.Text // portal/microsite "about" copy
  supportEmail      String?  @db.VarChar(254)
  supportPhone      String?  @db.VarChar(40)
  socialLinksJson   String?  @db.Text // JSON array of {network, url} entries
  // Audit
  createdBy         Int? // userId who saved this version (FK omitted — User model has too many relations already; SetNull semantics via app)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, subBrand, version])
  @@index([tenantId, subBrand, isActive])
  @@index([tenantId, isActive])
}

/// TMC curriculum→destination mapping for Travel Stall's school-trip pitching.
/// PC-1 RESOLVED 2026-05-24: GS drafts 100-200 starter rows + TMC academic team
/// validates over 6 weeks. Referenced by /quotes builder + /diagnostics engine.
///
/// Fine-grain key (curriculum, grade, subject, learningOutcome) per PC-3 — one
/// row represents "this learning outcome maps to this destination with this fit
/// score". PC-2 scopes V1 to CBSE + ICSE; IB + Cambridge enabled but unseeded.
/// PC-4 uses a 1-100 fitScore (human-judged for V1; rule-based pre-filter is
/// Phase 2). PC-5 references TMC's existing trip catalogue via TmcTrip with a
/// free-text destinationLabel fallback for advisor-suggested destinations not
/// yet in the catalogue.
model TravelCurriculumMapping {
  id               Int     @id @default(autoincrement())
  tenantId         Int
  // Curriculum standard: 'CBSE' | 'ICSE' | 'IB' | 'Cambridge' (PC-2 — V1
  // ships CBSE + ICSE only; IB + Cambridge enabled but rows unseeded).
  // VarChar(32) tightened from default(191) for MySQL key-byte budget — see
  // @@unique key-budget note below.
  curriculum       String  @db.VarChar(32)
  // Grade level — free-text since formats differ across curricula:
  // CBSE/ICSE use 'Class 9', 'Class 10'; IB uses 'IB Year 1', 'IB Year 2';
  // Cambridge uses 'IGCSE Year 10', etc. VarChar(32) for key-byte budget.
  grade            String  @db.VarChar(32)
  // Subject — e.g. 'Geography', 'History', 'Biology', 'Physics'.
  // VarChar(64) for key-byte budget.
  subject          String  @db.VarChar(64)
  // Specific learning outcome the trip teaches (PC-3 — fine grain). Bounded
  // VARCHAR (not Text) so it can participate in the composite @@unique below;
  // 300 chars is enough for a concise outcome statement like "Plate tectonics
  // + landform formation". Use fitRationale (@db.Text) for long-form notes.
  // Tightened from 500 → 300 for MySQL key-byte budget (see @@unique below).
  learningOutcome  String? @db.VarChar(300)
  // PC-5 — optional FK to TMC's TravelTrip catalogue (TmcTrip). When the
  // recommended destination exists as a trip template, link to it. Otherwise
  // leave null and use destinationLabel as a free-text fallback. FK omitted
  // here (Int? only, no @relation) to keep the model unbound from cascade
  // semantics — the route layer resolves TmcTrip on read.
  destinationId    Int?
  // PC-5 — free-text destination fallback (e.g. "Italy + Iceland", "Mussoorie
  // + Dehradun"). Required when destinationId is null.
  destinationLabel String?
  // PC-4 — human-judged 1-100 fit score for V1 (50 = no opinion yet).
  // Rule-based pre-filter scoring is Phase 2.
  fitScore         Int?    @default(50)
  // Advisor's free-text explanation of why this destination fits this outcome.
  fitRationale     String? @db.Text
  // Soft-disable a mapping without deleting (preserves history).
  isActive         Boolean @default(true)
  // Authoring advisor (academic-team member or GS template author).
  createdById      Int?
  createdBy        User?   @relation("CurriculumMappingCreator", fields: [createdById], references: [id], onDelete: SetNull)

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Block duplicate rows for the same (tenant, curriculum, grade, subject,
  // outcome) combination — advisors should edit existing rows, not duplicate.
  // Key-byte budget: 8 (Int) + 32*4 + 32*4 + 64*4 + 300*4 = 1720 bytes,
  // well under MySQL's 3072-byte utf8mb4 limit. Tick #178's 500-char
  // learningOutcome overflowed the budget (4300 bytes) — tick #179 triage.
  @@unique([tenantId, curriculum, grade, subject, learningOutcome])
  // Diagnostic-engine lookup path: "given a student's curriculum+grade+subject,
  // surface candidate destinations sorted by fitScore."
  @@index([curriculum, grade, subject])
  @@index([tenantId, isActive])
}

model PatientTag {
  patientId Int
  tagId     Int
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([patientId, tagId])
  @@index([patientId])
  @@index([tagId])
}

// PRD_TRAVEL_B2B_AGENT_PORTAL #905 slice 2 — commission profiles.
//
// Each profile is a JSON blob matching one of the 4 shapes consumed by
// lib/agentCommissionCalculator.js (flat_percent | tiered | per_pax_flat |
// hybrid). Stored as a JSON String column (@db.Text) so the calculator
// can be swapped or extended without schema migrations as more profile
// types ship in future slices.
//
// Sub-brand isolation (Q25): profiles MAY be restricted to one sub-brand
// (tmc / rfu / travelstall / visasure). NULL subBrand means the profile
// applies tenant-wide and any agent in any sub-brand can be assigned it.
// Operator-side guards in routes/travel_commission_profiles.js enforce
// sub-brand access via getSubBrandAccessSet (mirrors travel_quotes.js).
//
// profileType validation is enforced at the route layer (whitelist match
// against the 4 calculator types). profileJson is JSON.parse-validated
// at the route boundary; deep-shape validation against profileType is
// deferred to a future slice — the calculator itself returns
// commission=0 with a "unknown profile type" breakdown if the shape is
// malformed (defensive 200-with-zero, not a runtime throw).
//
// Future slices (not in this commit): mount in server.js, assignment of
// profiles to specific User / TravelAgent rows (currently a profile is
// a standalone catalog row), audit-trail of profile edits, computed
// commission ledger.
model TravelCommissionProfile {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  name        String // operator-facing label, e.g. "Standard 5%"
  subBrand    String? // optional sub-brand restriction (tmc/rfu/travelstall/visasure)
  profileType String // flat_percent | tiered | per_pax_flat | hybrid
  profileJson String   @db.Text // JSON serialization of profile shape
  isActive    Boolean  @default(true)
  notes       String?  @db.Text
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, subBrand])
  @@index([tenantId, isActive])
}

// PRD_TRAVEL_MARKETING_FLYER #908 slice 3 — saved flyer template.
//
// Operator-composed JSON blob (palette + layout + asset placeholders)
// validated via lib/flyerTemplateValidator.js (slice 1 commit 28146498)
// before persistence. Replaces the frontend STUB in FlyerTemplates.jsx
// (slice 2 commit a64c1058). The renderer (future slice) consumes the
// same JSON columns at PDF/PNG export time.
//
// Why three JSON columns instead of separate models for palette / layout /
// assets: a template is operator-composed as a single editor session, and
// the renderer wants all three blobs together — splitting would force a
// 3-way join on every read with no callsite that wants just one piece.
//
// Slice scope (slice 3): schema + CRUD endpoints. The server.js mount,
// frontend wire-in (replacing the STUB), and renderer pipeline are
// separate slices.
model TravelFlyerTemplate {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @default(1)
  name        String // operator-facing label, e.g. "Summer Umrah 2026"
  subBrand    String? // optional sub-brand restriction (tmc/rfu/travelstall/visasure)
  paletteJson String   @db.Text // JSON: { primaryHex, secondaryHex, accentHex?, textHex, bgHex }
  layoutJson  String   @db.Text // JSON: [{type, x, y, width, height, content?, src?, href?}, ...]
  assetsJson  String?  @db.Text // JSON: { logo?, hero?, footer? } URLs (optional)
  isActive    Boolean  @default(true)
  notes       String?  @db.Text
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, subBrand])
  @@index([tenantId, isActive])
}

// ── TMC Diagnostic & Sales-Routing Engine catalogue ─────────────────
//
// PRD_TMC_DIAGNOSTIC_SALES_ROUTING_ENGINE §3.2 + §3.8, DD-5.1 RESOLVED
// 2026-06-08. The curated trip catalogue the engine recommends from.
// Distinct lifecycle from `Itinerary` (which carries the per-school
// instance state machine draft/sent/revised/accepted/rejected) and from
// `TmcTrip` (which is the booked-trip operational record): catalogue
// rows carry `status: active | archived`, are read by the engine where
// status=active, and are tuned independently of any specific school
// engagement.
//
// Foundational engine invariants from the PRD:
//
//   - priceBand MUST match a Q9 band exactly: "upto-5k" | "10k-30k" |
//     "30k-75k" | "1l-2l" | "2l-plus". Hard filter; non-negotiable.
//     §3.2 + §3.3.2 step 1.
//   - primaryOutcomesJson are EXACT Q1 keys; skillsDevelopedJson are
//     EXACT keys from the 7 canonical skills (no fuzzy matching).
//     §3.2 tagging rules + §3.3 skill catalogue.
//   - status defaults to "archived" — humans flip to "active" only
//     after curriculum_hooks + price_band are verified (NF-9 +
//     §5.5 hard launch gate).
//   - reportSkillBlurb MUST NOT name the destination (school-facing
//     report guardrail §3.5 + §3.7.1 Layer 2).
//   - indicativePricePerStudent is brief-only, NEVER in the school
//     report. Nullable for variable-price trips.
//
// Indexes: (tenantId, status) for engine queries (only active rows),
// (tenantId, status, tier) for tier-filtered surveys, (tenantId,
// status, priceBand) for budget-filtered surveys. The hot path is
// "give me all active trips matching budget X tier Y board Z grade W"
// — the multi-column indexes cover the first two filter steps.
model TmcTripCatalogue {
  id                        Int      @id @default(autoincrement())
  tenantId                  Int      @default(1)
  tripId                    String // unique slug per tenant — e.g. "golden-triangle-delhi-agra-jaipur"
  title                     String
  tagline                   String?  @db.Text
  tier                      String // "day" | "domestic" | "international"
  region                    String?
  durationDays              Int
  durationNights            Int      @default(0)
  minGradeBand              String // "4-6" | "6-8" | "9-10" | "11-12"
  maxGradeBand              String
  boardsSupportedJson       String   @db.Text // JSON array of board names
  minGroupSize              Int
  priceBand                 String // MUST match a Q9 band exactly: "upto-5k" | "10k-30k" | "30k-75k" | "1l-2l" | "2l-plus"
  indicativePricePerStudent Int? // null when variable; brief-only, never in the report
  primaryOutcomesJson       String   @db.Text // JSON array of Q1 option keys this trip serves strongly
  skillsDevelopedJson       String   @db.Text // JSON array of the 7 canonical skill keys
  subjectsTouchedJson       String   @db.Text // JSON array, for the brief
  anchorExperiencesJson     String   @db.Text // JSON array of {name, what_students_do, skill_link, subject_link}
  curriculumHooksJson       String   @db.Text // JSON array of {board, grade_band, subject, topic, hook_text}
  reportSkillBlurb          String   @db.Text // 2-3 sentences; NEVER names destination
  summaryForBrief           String   @db.Text // 2-3 sentences destination-specific note for the executive
  imageUrl                  String?
  status                    String   @default("archived") // "active" | "archived" — engine recommends active only
  tenant                    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Unique slug per tenant — catalogue lookup key from the engine
  @@unique([tenantId, tripId])
  // Engine-hot index: list all active trips for this tenant
  @@index([tenantId, status])
  // Engine-hot index: list all active trips of a specific tier
  @@index([tenantId, status, tier])
  // Engine-hot index: list all active trips in a specific price band
  @@index([tenantId, status, priceBand])
}

// ── TMC Diagnostic Engine tunable weights ────────────────────────────
//
// PRD_TMC_DIAGNOSTIC_SALES_ROUTING_ENGINE §3.3.3 + §3.3.7 + §3.8.
// SINGLE config row per tenant (enforced by @unique on tenantId) so
// tuning is a config change, never a redeploy (NF-2 hot-reloadable).
//
// Defaults match the §3.3.3 scoring table exactly:
//   - weightPrimaryOutcome      = 50  (Q1 primary-outcome match)
//   - weightSecondarySkill      = 20  per match, capped at 40 (max 2 Q2 secondaries)
//   - weightGrowthArea          = 15  once; 0 if duplicates a Q2 pick (no double-pay)
//   - weightCurriculumHook      = 10  (board × grade-band hook present)
//   - weightGradeBandCenter     = 10  (school band ≥ trip range midpoint ceiling)
//   - weightTierValueLean       = 8   (only when geo_preference=open AND budget allows)
//   - scoresWellThreshold       = 70  (§3.3.5 "scores well" floor)
//
// version: bumped on every config change so each scored submission's
// captured weightsVersion (on TravelDiagnostic) is replayable for audit
// and §3.3.7 weight-tuning disagreement triage.
model EngineWeights {
  id                    Int      @id @default(autoincrement())
  // Enforces single-row-per-tenant — every Tenant has 0 or 1 EngineWeights.
  tenantId              Int      @unique @default(1)
  version               String   @default("v1") // bumped on every config change
  weightPrimaryOutcome  Int      @default(50)
  weightSecondarySkill  Int      @default(20) // applied per match, capped at 40 (max 2 secondaries)
  weightGrowthArea      Int      @default(15) // awarded once; 0 if duplicates a Q2 pick
  weightCurriculumHook  Int      @default(10)
  weightGradeBandCenter Int      @default(10)
  weightTierValueLean   Int      @default(8) // applied only when geo_preference=open
  scoresWellThreshold   Int      @default(70) // §3.3.5 "scores well" floor
  // G103 — PRD_TMC_DIAGNOSTIC_SALES_ROUTING_ENGINE §3.5.5 standing-facts overrides.
  // Per-tenant override for the renderer-injected assurance + trust blocks.
  // JSON-stringified per sanitizeJson convention. Empty / null → renderer falls
  // back to DEFAULT_STANDING_FACTS in routes/travel_diagnostics.js.
  // Shape mirrors DEFAULT_STANDING_FACTS.{assurance,trust} (supervision_ratio,
  // tour_directors, governance_pack[], schools_served_since_2015, etc.).
  assuranceFactsJson    String?  @db.Text
  trustFactsJson        String?  @db.Text
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────
// PRD_TRAVEL_SECURITY_ARCHITECTURE FR-3.7 (S5) — security-telemetry sink.
//
// Three incident classes ship in S5 (more can follow without schema change):
//   - 'csp-violation'         POST /api/security/csp-report (browser-emitted)
//   - 'cross-tenant-attempt'  middleware/crossTenantInterceptor.js logs +
//                             returns 404 when an authenticated caller asks
//                             for a row id whose owning tenant differs from
//                             their JWT tenantId.
//   - 'rate-limit-exceeded'   reserved for future rate-limit handler hooks.
//
// Why tenantId is nullable
// ────────────────────────
// CSP reports are emitted by the BROWSER, not by an authenticated session
// — there's no Authorization header on a `Content-Security-Policy-Report-
// Only` ping. The route resolves the tenant best-effort from the Host
// header, but a CSP report on an unknown host (during DNS bring-up, on the
// localhost dev environment, or against a proxy mid-deploy) is still
// useful telemetry; we'd rather persist it with tenantId=null than drop
// it. Cross-tenant-attempt rows are ALWAYS attributable (the requesting
// JWT carried a tenantId by definition) so those land with a real id.
//
// Why reportJson is String @db.Text
// ─────────────────────────────────
// Each incident class carries different shape — CSP reports follow the
// W3C csp-report envelope, cross-tenant-attempt rows carry our own
// {attemptedModel, attemptedRowId, ...} shape. Modelling as relational
// columns would either require N nullable columns or N child tables;
// JSON-string Text mirrors the existing pattern (AuditLog.details,
// SequenceStep.conditionJson, AbTest variantA/B, etc.) and the read sites
// JSON.parse it on demand.
//
// severity bucket
// ───────────────
// CSP: script-src violation = 'high' (active-content risk); style-src
// = 'medium' (CSS injection / data exfil); everything else = 'low'.
// Cross-tenant-attempt = 'high' (potential IDOR / enumeration probe).
//
// Review trail
// ────────────
// reviewedAt / reviewedById / reviewNote let an ADMIN mark an incident as
// triaged ("known false positive — the SDK we're integrating injects
// inline styles, widening style-src nonce-allowlist is tracked under #N").
// ─────────────────────────────────────────────────────────────────────
model SecurityIncident {
  id                 Int       @id @default(autoincrement())
  tenantId           Int? // nullable — CSP reports may arrive before auth resolves
  incidentType       String // 'csp-violation' | 'cross-tenant-attempt' | 'rate-limit-exceeded' | ...
  severity           String    @default("medium") // 'low' | 'medium' | 'high' | 'critical'
  reportJson         String    @db.Text // raw report payload (JSON-stringified shape-per-incidentType)
  userAgent          String?
  ipAddress          String?
  url                String? // violating URL for CSP reports / request URL for cross-tenant
  blockedUri         String? // CSP blockedUri (null for non-CSP rows)
  effectiveDirective String? // CSP directive that was violated (null for non-CSP rows)
  reviewedAt         DateTime?
  reviewedById       Int?
  reviewNote         String?   @db.Text
  createdAt          DateTime  @default(now())
  tenant             Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([incidentType])
  @@index([createdAt])
}

// ── Travel POI catalog (S11 — PRD_TRAVEL_ITINERARY_UPGRADES FR-3.5) ──
//
// Points-of-interest catalog populated from OpenTripMap (+ future
// providers). Rows are shared across tenants by default (tenantId NULL —
// catalog data). Tenant-pinned overrides land in a later slice via
// tenantId-scoped duplicates.
//
// Idempotent upsert key: (externalSource, externalId). Re-running the
// seeder doesn't create duplicates — re-runs refresh name / category /
// imageUrl / descriptionShort while preserving the local id and any
// pendingApproval / tenant-tagging fields set after import.
//
// Additive model — no FKs, no UNIQUE on existing data, no column changes
// elsewhere. Migration-safety bless markers not required.
//
// S12 (Inline Add-POI modal) uses pendingApproval=true for rep-suggested
// POIs that need ADMIN approval before being itinerary-eligible. The
// seeder always upserts with pendingApproval=false (catalog imports are
// pre-approved by virtue of being curated by the seeder script).
model TravelPoi {
  id               Int      @id @default(autoincrement())
  tenantId         Int? // null = catalog-wide; set when an admin pins / forks a row to a tenant
  externalSource   String // 'opentripmap' | future providers
  externalId       String // upstream xid / external identifier
  name             String
  nameLocal        String? // transliteration / local-language label
  category         String? // 'religious' | 'historical' | 'natural' | 'cultural' | ...
  latitude         Float?
  longitude        Float?
  country          String? // ISO-3166-1-alpha-2
  destinationSlug  String? // grouping key for top-N destinations (e.g. 'goa', 'paris')
  imageUrl         String?
  wikidataId       String?
  descriptionShort String?  @db.Text // cached short description
  pendingApproval  Boolean  @default(false) // S12 uses this for rep-suggested rows
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([externalSource, externalId])
  @@index([tenantId, destinationSlug])
  @@index([country, category])
  @@index([pendingApproval])
}

// PRD_TRAVEL_SUPPLIER_MASTER G045 (FR-3.1.e, FR-3.5.a, FR-3.5.b) —
// Supplier-side commission ledger per fiscal year.
//
// Distinct from TravelCommissionProfile (which scopes B2B sub-agent
// commission shapes — see #905 slice 2). This ledger tracks supplier-side
// commissions EARNED on confirmed bookings — IATA inward commission for
// air bookings, hotel commission percentages, RFU Umrah supplier kickbacks
// etc. — and settles per fiscal year.
//
// Lifecycle: accrued → settled → reversed.
//   - accrued:   recorded against a confirmed booking / invoice. baseAmount
//                + commissionPercent → commissionAmount. Optional TDS
//                (section 194H, default 5%) → netAmount.
//   - settled:   payment received from supplier; settledAt stamped.
//   - reversed:  refund / cancellation; reversedAt + reversalReason stamped.
//   - adjustment: manual operator correction (rare).
//
// All-NULLABLE FK strategy on bookingId / purchaseOrderId / invoiceId —
// a commission can accrue against a manual operator entry with no upstream
// link, or against any combination of the three. purchaseOrderId is
// reserved for future G035 PO landing (no FK constraint yet — defer until
// the PO model lands).
//
// Sub-brand isolation: inherited through the parent TravelSupplier
// (.subBrand). The route layer scopes every list / get / write via
// getSubBrandAccessSet + canAccessSubBrand against the parent supplier.
//
// Schema additivity: net-new model + nullable FKs. No bless marker
// required.
model TravelSupplierCommissionEntry {
  id                Int            @id @default(autoincrement())
  tenantId          Int            @default(1)
  supplierId        Int
  // Optional FK shapes — see model comment. Booking + PO stay as Int? with
  // no relation block (deferred until those models land). Invoice has a
  // real relation (the model exists today).
  bookingId         Int?
  purchaseOrderId   Int?
  invoiceId         Int?
  // Indian FY label e.g. "FY2025-26" (matches the public-facing FY
  // shape used in supplier statements + CSV exports). Computed by the
  // route layer via lib/travelFiscalYear.js fiscalYearLabelLong() at
  // accrue time; stored verbatim so historical queries are stable across
  // any future FY-helper changes.
  fiscalYear        String
  // accrued | settled | reversed | adjustment
  entryType         String         @default("accrued")
  // Override-able per entry (defaults from TravelSupplier.commissionPercent
  // when accrued through the auto-path). Free-form Decimal 5,2 so e.g.
  // 7.50, 12.00, 0.25 all fit.
  commissionPercent Decimal?       @db.Decimal(5, 2)
  baseAmount        Decimal        @db.Decimal(15, 2)
  commissionAmount  Decimal        @db.Decimal(15, 2)
  currency          String         @default("INR")
  // Section 194H TDS (commission / brokerage). Default 5% per DD-5.5;
  // configurable via accrue body. Stored verbatim — auto-deduct workflow
  // is deferred to a future slice.
  tdsAmount         Decimal?       @db.Decimal(15, 2)
  // commissionAmount - tdsAmount. Stored verbatim so statement queries
  // don't recompute on every list.
  netAmount         Decimal?       @db.Decimal(15, 2)
  // accrued | settled | reversed. Distinct from entryType — status tracks
  // the lifecycle stage; entryType tracks the row's origin shape.
  status            String         @default("accrued")
  accruedAt         DateTime       @default(now())
  settledAt         DateTime?
  reversedAt        DateTime?
  reversalReason    String?        @db.Text
  notes             String?        @db.Text
  createdBy         Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier          TravelSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  invoice           TravelInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId, supplierId, fiscalYear])
  @@index([tenantId, fiscalYear, status])
  @@index([tenantId, supplierId, status])
  @@index([tenantId, invoiceId])
}

// ─── PRD_TRAVEL_SUPPLIER_MASTER G038 — Supplier KYC + onboarding checklist ───
//
// Per PRD FR-3.1.h: every TravelSupplier gets a 1-to-1 KYC record tracking
// onboarding artefacts (PAN / GSTIN / bank proof / IATA cert / signed
// contract / insurance). The KYC record holds top-level status + verified
// flags; the TravelSupplierKycChecklistItem children give per-document
// granularity (status / documentUrl / verifiedBy / verifiedAt per item).
//
// State flow: pending → submitted → verified (or → rejected). The route
// layer enforces transitions (only submitted → verified; only submitted →
// rejected; resubmit from rejected via /submit).
//
// PAN encryption: panNumber is encrypted at the application layer via
// backend/lib/fieldEncryption.js BEFORE persistence (AES-256-GCM, no-op
// when WELLNESS_FIELD_KEY isn't set per fieldEncryption.js conventions).
//
// Additive — no bless marker needed.
model TravelSupplierKyc {
  id                  Int                              @id @default(autoincrement())
  tenantId            Int
  supplierId          Int                              @unique
  status              String                           @default("pending")
  panNumber           String?
  gstinVerified       Boolean                          @default(false)
  bankAccountVerified Boolean                          @default(false)
  iataNumber          String?
  iataExpiry          DateTime?
  tafiNumber          String?
  contractSigned      Boolean                          @default(false)
  contractSignedAt    DateTime?
  contractDocumentUrl String?
  submittedAt         DateTime?
  verifiedAt          DateTime?
  verifiedBy          Int?
  rejectedAt          DateTime?
  rejectionReason     String?                          @db.Text
  notes               String?                          @db.Text
  createdAt           DateTime                         @default(now())
  updatedAt           DateTime                         @updatedAt
  tenant              Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier            TravelSupplier                   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  checklistItems      TravelSupplierKycChecklistItem[]

  @@index([tenantId, status])
}

// Per-document onboarding checklist seeded at KYC init. Default seed:
//   pan_card / gstin_cert / bank_proof / iata_cert (flight only) / contract / insurance
model TravelSupplierKycChecklistItem {
  id          Int               @id @default(autoincrement())
  tenantId    Int
  kycId       Int
  itemKey     String
  itemLabel   String
  required    Boolean           @default(true)
  status      String            @default("pending")
  documentUrl String?
  notes       String?           @db.Text
  submittedAt DateTime?
  verifiedAt  DateTime?
  verifiedBy  Int?
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  kyc         TravelSupplierKyc @relation(fields: [kycId], references: [id], onDelete: Cascade)
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, kycId, status])
}

// ─── PRD_TRAVEL_SUPPLIER_MASTER G039 — Supplier dispute history + chargeback log ───
//
// Per PRD FR-3.1.g + FR-3.6.a-c: a polymorphic ledger of disputes between
// operator and supplier. `direction`:
//   - outbound = operator → supplier
//   - inbound  = supplier → operator
// Optional payableId / invoiceId tie a dispute to a specific A/P entry or
// customer invoice (customer-side chargeback).
//
// Status flow: open → in_review → resolved (or → rejected → escalated)
//
// Additive — no bless marker needed.
model TravelSupplierDispute {
  id             Int                    @id @default(autoincrement())
  tenantId       Int
  supplierId     Int
  payableId      Int?
  invoiceId      Int?
  direction      String
  type           String
  status         String                 @default("open")
  amount         Decimal                @db.Decimal(15, 2)
  currency       String                 @default("INR")
  description    String                 @db.Text
  evidenceUrls   String?                @db.Text
  raisedBy       Int?
  raisedAt       DateTime               @default(now())
  resolvedAt     DateTime?
  resolvedBy     Int?
  resolution     String?                @db.Text
  refundedAmount Decimal?               @db.Decimal(15, 2)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       TravelSupplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  payable        TravelSupplierPayable? @relation(fields: [payableId], references: [id], onDelete: SetNull)
  invoice        TravelInvoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId, supplierId, status])
  @@index([tenantId, status, raisedAt])
}

// PRD_TRAVEL_SUPPLIER_MASTER G044 (FR-3.4.a-c) — supplier-statement
// reconciliation batches.
//
// Supplier statements arrive monthly with a list of PNR / booking-ref +
// amounts. Operators load a batch (CSV or hand-entered) and the
// auto-matcher (backend/lib/supplierReconciliation.js) pairs each line
// against TravelPurchaseOrderLine rows by PNR (case-insensitive) +
// amount within tolerancePct. State machine: draft → reviewed → reconciled
// (or disputed). All fields nullable / additive — new model, no migration
// risk. Sub-brand isolation inherited via TravelSupplier.subBrand.
model TravelSupplierReconciliationBatch {
  id                  Int                                @id @default(autoincrement())
  tenantId            Int
  supplierId          Int
  // Free-form "YYYY-MM" label (e.g. "2026-05") — what month of statement
  // this batch represents. NOT used in unique index because operators
  // may re-issue corrected statements within the same month.
  statementMonth      String
  // Optional uploaded statement PDF / CSV reference (free-form URL or
  // storage key). The line-items themselves live in
  // TravelSupplierReconciliationLine; this is just a pointer back to
  // the source file the operator uploaded.
  statementUrl        String?
  // Reported totals (from the supplier statement) and our side (sum of
  // matched-PoLine lineTotals) — kept side-by-side so operators see the
  // discrepancy at a glance on the dashboard panel.
  totalSupplierAmount Decimal                            @db.Decimal(15, 2)
  totalOursAmount     Decimal                            @db.Decimal(15, 2)
  // % tolerance within which auto-match accepts an amount mismatch as
  // "matched" (e.g. 1.0 = ±1% accepted). Default 1.00; override per batch.
  tolerancePct        Decimal                            @default(1) @db.Decimal(5, 2)
  // draft | reviewed | reconciled | disputed
  status              String                             @default("draft")
  reviewedBy          Int?
  reviewedAt          DateTime?
  reconciledBy        Int?
  reconciledAt        DateTime?
  notes               String?                            @db.Text
  createdBy           Int?
  createdAt           DateTime                           @default(now())
  updatedAt           DateTime                           @updatedAt
  tenant              Tenant                             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier            TravelSupplier                     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  lines               TravelSupplierReconciliationLine[]

  @@index([tenantId, supplierId, statementMonth])
  @@index([tenantId, status])
}

// PRD_TRAVEL_SUPPLIER_MASTER G044 (FR-3.4.a) — individual statement line.
//
// One row per line in the supplier's monthly statement. matchStatus
// progresses from `unmatched` (initial), to `auto_matched` (set by the
// auto-matcher when a PoLine is found within tolerance), or
// `manual_matched` (operator-set via the manual-match endpoint), or
// `disputed` / `resolved`. matchedPoLineId is the FK to the PoLine that
// satisfied the match; matchedPayableId is the FK to the payable that
// settles it (set later in the lifecycle, often when the payment fires).
// varianceAmount = supplierAmount - PoLine.lineTotal at match time.
model TravelSupplierReconciliationLine {
  id               Int                               @id @default(autoincrement())
  tenantId         Int
  batchId          Int
  pnr              String?
  bookingRef       String?
  supplierAmount   Decimal                           @db.Decimal(15, 2)
  // FK to TravelPurchaseOrderLine when matched
  matchedPoLineId  Int?
  // FK to TravelSupplierPayable when matched
  matchedPayableId Int?
  // unmatched | auto_matched | manual_matched | disputed | resolved
  matchStatus      String                            @default("unmatched")
  varianceAmount   Decimal?                          @db.Decimal(15, 2)
  notes            String?                           @db.Text
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt
  tenant           Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch            TravelSupplierReconciliationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  matchedPoLine    TravelPurchaseOrderLine?          @relation(fields: [matchedPoLineId], references: [id], onDelete: SetNull)
  matchedPayable   TravelSupplierPayable?            @relation(fields: [matchedPayableId], references: [id], onDelete: SetNull)

  @@index([tenantId, batchId, matchStatus])
  @@index([tenantId, pnr])
}

// PRD_TRAVEL_SUPPLIER_MASTER G046 (FR-3.3.c) — supplier invoice PDF uploads.
//
// When a supplier sends an invoice PDF (separate from the monthly
// statement), the operator uploads it and links it to a
// TravelSupplierPayable row. The actual file lives on disk under
// `backend/uploads/supplier-invoices/`; this row stores the metadata +
// match-to-payable linkage. matchStatus flips to `matched` when the
// operator confirms which payable the invoice covers. DELETE is
// ADMIN-only (audit-trail concern — invoice PDFs are tax-evidence).
model TravelSupplierInvoiceUpload {
  id                    Int                    @id @default(autoincrement())
  tenantId              Int
  supplierId            Int
  // FK to TravelSupplierPayable when matched. Null until the operator
  // confirms which payable this invoice covers.
  payableId             Int?
  filename              String
  // Storage path (relative to the uploads dir or absolute URL when
  // backed by Vault / S3). Non-guessable; multer.diskStorage names files
  // `<uuid>.<ext>` (ext pinned to validated mimeType).
  fileUrl               String
  fileMimeType          String
  fileSize              Int
  // Metadata extracted from the supplier's PDF — operator fills these in
  // post-upload (OCR is out of scope for slice 1).
  supplierInvoiceNumber String?
  invoiceDate           DateTime?
  invoiceAmount         Decimal?               @db.Decimal(15, 2)
  currency              String                 @default("INR")
  // unmatched | matched | disputed
  matchStatus           String                 @default("unmatched")
  uploadedBy            Int?
  uploadedAt            DateTime               @default(now())
  matchedBy             Int?
  matchedAt             DateTime?
  notes                 String?                @db.Text
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier              TravelSupplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  payable               TravelSupplierPayable? @relation(fields: [payableId], references: [id], onDelete: SetNull)

  @@index([tenantId, supplierId, matchStatus])
  @@index([tenantId, payableId])
}

// PRD_TRAVEL_MULTICHANNEL_LEADS G009 (FR-3.7.3, FR-3.3.6) — Meta lead-ad
// form-ID → sub-brand → assignment-team mapping. Surfaced via the
// /settings/lead-capture admin UI; consumed by the inbound intake route to
// resolve sub-brand + initial assignee from a webhook's externalFormId.
// Brand-new model with zero existing rows — the (tenantId, channel,
// externalFormId) UNIQUE is vacuously safe but the [allow-unique] bless
// marker is in the commit body per migration-check gate convention.
model FormRoutingMapping {
  id             Int      @id @default(autoincrement())
  tenantId       Int
  channel        String // typically 'meta_ad'; also 'google_ad', 'web_form'
  externalFormId String
  subBrand       String?
  assignedTeamId Int?
  isActive       Boolean  @default(true)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel, externalFormId])
  @@index([tenantId, channel])
}

// PRD_TRAVEL_QUOTE_BUILDER G018 (DD-5.4) — FX-rate cache for per-line FX
// conversion in the operator quote builder.
//
// fxRateEngine.js polls a free open-data FX source (frankfurter.dev) hourly
// and upserts one row per (baseCurrency, quoteCurrency) pair. The
// /api/fx/latest endpoint returns the freshest row; /api/fx/history returns
// a date-range slice for charting / trend display in the QuoteBuilder
// FX panel.
//
// Brand-new model — zero existing rows; the @@unique on
// (baseCurrency, quoteCurrency, fetchedAt) is vacuously safe but the
// [allow-unique] bless marker is in the commit body per migration-check.
//
// rate is stored as a Decimal(15, 8) — eight fractional digits handles
// currencies with very small unit values (e.g. USD→IDR ~15500) plus the
// inverse pair (IDR→USD ~0.000064) without precision loss. Source defaults
// to "frankfurter" but the column is intentionally open so a future
// provider swap (yahoo / fxapi / manual override) doesn't need a migration.
model FxRate {
  id            Int      @id @default(autoincrement())
  baseCurrency  String // 3-char ISO 4217, e.g. "INR"
  quoteCurrency String // 3-char ISO 4217, e.g. "USD"
  rate          Decimal  @db.Decimal(15, 8)
  fetchedAt     DateTime @default(now())
  source        String   @default("frankfurter")

  @@unique([baseCurrency, quoteCurrency, fetchedAt])
  @@index([baseCurrency, quoteCurrency])
}
