model Campaign {
  id        Int      @id @default(autoincrement())
  name      String
  channel   String   @default("EMAIL") // EMAIL, SMS, PUSH, WHATSAPP
  status    String   @default("Draft") // Draft, Active, Completed
  sent      Int      @default(0)
  opened    Int      @default(0)
  clicked   Int      @default(0)
  budget    Float    @default(0.0)
  createdAt DateTime @default(now())

  // Schedule persistence (#412): replaces in-memory global._campaignSchedules
  // map which silently dropped pending schedules on backend restart and could
  // not survive multi-instance deploys. All three columns are nullable so
  // existing rows survive `prisma db push --accept-data-loss` without a
  // backfill.
  //
  //   scheduledAt     — when the campaign should dispatch (UTC). Null on
  //                     Draft rows. The cron engine queries `lte: now()`.
  //   scheduleStatus  — 'PENDING' (waiting on cron) | 'SENT' (cron
  //                     dispatched successfully) | 'CANCELLED' (paused
  //                     before dispatch) | null. Cron matches PENDING.
  //   scheduleFilters — JSON-serialised audience filter (formerly
  //                     schedule.filters in the in-memory map). Read by
  //                     sendCampaign via campaign._audienceFilter.
  scheduledAt     DateTime?
  scheduleStatus  String?
  scheduleFilters String?   @db.Text

  // #932 — Campaign → Sequence linkage (follow-up to #898 acceptance #4).
  // When sequenceId is set, sendCampaign auto-enrolls every recipient into
  // the linked Sequence after dispatch completes. Nullable so existing rows
  // survive `prisma db push` without a backfill; onDelete: SetNull keeps
  // the campaign row valid if the linked sequence is later removed.
  sequenceId Int?
  sequence   Sequence? @relation(fields: [sequenceId], references: [id], onDelete: SetNull)

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  smsMessages       SmsMessage[]
  pushNotifications PushNotification[]

  @@index([sequenceId])
}

model AutomationRule {
  id          Int     @id @default(autoincrement())
  name        String
  triggerType String
  actionType  String
  targetState String?
  // #20: optional JSON-encoded array of clauses, AND-joined.
  // Format: [{"field":"deal.amount","op":"gt","value":50000}, ...]
  // Operators: eq, neq, gt, gte, lt, lte, in, nin, contains, startsWith.
  // Empty/null = always-fire (backwards compat with pre-#20 rules).
  condition   String? @db.Text
  isActive    Boolean @default(true)

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model EmailMessage {
  id                   Int       @id @default(autoincrement())
  subject              String
  body                 String    @db.Text
  from                 String
  to                   String
  // #623 — cc/bcc are comma-separated lists, persisted exactly as the
  // composer's parseRecipients() returns them (deduped, lowercase-keyed).
  // Null when no carbon-copy / blind-carbon-copy recipients were attached.
  cc                   String?   @db.Text
  bcc                  String?   @db.Text
  direction            String    @default("INBOUND") // INBOUND, OUTBOUND
  read                 Boolean   @default(false)
  sentiment            String? // positive, neutral, negative
  sentimentScore       Float? // -1 to 1
  threadId             String? // for conversation threading
  // #7 — set by sequenceEngine.processInboundReplies() once an inbound row
  // matching a `seq-<enrollmentId>` thread has paused its enrollment. Acts
  // as the dedup gate so a single reply only pauses once, even if the cron
  // tick fires repeatedly.
  sequenceReplyHandled DateTime?
  createdAt            DateTime  @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, direction])
  @@index([tenantId, contactId])
  @@index([tenantId, createdAt])
}

