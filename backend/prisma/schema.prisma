generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  role      String    @default("USER") // ADMIN, USER, MANAGER
  name      String?
  createdAt DateTime  @default(now())
  deals         Deal[]    @relation("OwnerDeals")
  tickets       Ticket[]  @relation("AssignedTickets")
  apiKeys       ApiKey[]
  webhooks      Webhook[]
  tasks         Task[]
  expenses      Expense[]
  projects      Project[] @relation("ProjectOwner")
  notifications Notification[]
  auditLogs     AuditLog[]
  assignedContacts Contact[] @relation("AssignedContacts")
  activities    Activity[]
  callLogs      CallLog[]
  emailMessages EmailMessage[]
  reportSchedules ReportSchedule[]
  smsMessages     SmsMessage[]
  whatsappMessages WhatsAppMessage[]
  pushSubscriptions PushSubscription[]
  landingPages    LandingPage[]
}

model Contact {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  phone       String?
  company     String?
  title       String?
  status      String     @default("Lead") // Lead, Prospect, Customer, Churned
  source      String?    @default("Organic")
  aiScore     Int        @default(0) // 1-100 predictive close probability
  createdAt   DateTime   @default(now())

  assignedToId Int?
  assignedTo   User?     @relation("AssignedContacts", fields: [assignedToId], references: [id], onDelete: SetNull)

  activities  Activity[]
  deals       Deal[]
  emails      EmailMessage[]
  callLogs    CallLog[]
  invoices    Invoice[]
  sequenceEnrollments SequenceEnrollment[]
  tasks       Task[]
  expenses    Expense[]
  contracts   Contract[]
  estimates   Estimate[]
  projects    Project[]
  marketplaceLeads MarketplaceLead[]
  smsMessages      SmsMessage[]
  whatsappMessages WhatsAppMessage[]
  pushSubscriptions PushSubscription[]
}

model Activity {
  id          Int      @id @default(autoincrement())
  type        String   // Email, Call, Meeting, Note
  description String
  createdAt   DateTime @default(now())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Deal {
  id            Int      @id @default(autoincrement())
  title         String
  amount        Float    @default(0.0)
  probability   Int      @default(50)
  stage         String   @default("lead") // lead, contacted, proposal, won, lost
  expectedClose DateTime?
  createdAt     DateTime @default(now())
  
  contactId     Int?
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  
  ownerId       Int?
  owner         User?    @relation("OwnerDeals", fields: [ownerId], references: [id], onDelete: SetNull)
  attachments   Attachment[]
  invoices      Invoice[]
  quotes        Quote[]
  contracts     Contract[]
  estimates     Estimate[]
  projects      Project[]
}

model Ticket {
  id          Int      @id @default(autoincrement())
  subject     String
  description String?
  status      String   @default("Open") // Open, Pending, Resolved, Closed
  priority    String   @default("Low") // Low, Medium, High, Urgent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  assigneeId  Int?
  assignee    User?    @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)
}

model Campaign {
  id          Int      @id @default(autoincrement())
  name        String
  channel     String   @default("EMAIL") // EMAIL, SMS, PUSH, WHATSAPP
  status      String   @default("Draft") // Draft, Active, Completed
  sent        Int      @default(0)
  opened      Int      @default(0)
  clicked     Int      @default(0)
  budget      Float    @default(0.0)
  createdAt   DateTime @default(now())
  smsMessages SmsMessage[]
  pushNotifications PushNotification[]
}

model AutomationRule {
  id          Int      @id @default(autoincrement())
  name        String
  triggerType String
  actionType  String
  targetState String?
  isActive    Boolean  @default(true)
}

model EmailMessage {
  id        Int      @id @default(autoincrement())
  subject   String
  body      String   @db.Text
  from      String
  to        String
  direction String   @default("INBOUND") // INBOUND, OUTBOUND
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CallLog {
  id             Int      @id @default(autoincrement())
  duration       Int      // seconds
  notes          String?
  direction      String   @default("OUTBOUND")
  recordingUrl   String?
  provider       String?  // "myoperator", "knowlarity", "twilio", "webrtc"
  providerCallId String?
  status         String   @default("COMPLETED") // INITIATED, RINGING, CONNECTED, COMPLETED, MISSED, FAILED
  callerNumber   String?
  calleeNumber   String?
  createdAt      DateTime @default(now())

  contactId      Int?
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  userId         Int?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Attachment {
  id        Int      @id @default(autoincrement())
  filename  String
  fileUrl   String
  createdAt DateTime @default(now())
  
  dealId    Int
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        Int      @id @default(autoincrement())
  keySecret String   @unique // Hashed or raw token
  name      String
  createdAt DateTime @default(now())
  lastUsed  DateTime?
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Webhook {
  id        Int      @id @default(autoincrement())
  event     String   // e.g. "deal.*", "contact.created"
  targetUrl String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          Int      @id @default(autoincrement())
  invoiceNum  String   @unique
  amount      Float
  status      String   @default("UNPAID") // UNPAID, PAID, OVERDUE
  dueDate     DateTime
  issuedDate  DateTime @default(now())
  
  dealId      Int?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Integration {
  id        Int      @id @default(autoincrement())
  provider  String   @unique // slack, google, stripe, mailchimp
  token     String?
  isActive  Boolean  @default(false)
  settings  String?  @db.Text // JSON stringified configuration
  updatedAt DateTime @updatedAt
}

model CustomEntity {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  fields      CustomField[]
  records     CustomRecord[]
}

model CustomField {
  id         Int      @id @default(autoincrement())
  name       String
  type       String   @default("Text") // Text, Number, Date, Boolean
  entityId   Int
  entity     CustomEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  values     CustomValue[]
}

model CustomRecord {
  id         Int      @id @default(autoincrement())
  entityId   Int
  entity     CustomEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  values     CustomValue[]
  createdAt  DateTime @default(now())
}

model CustomValue {
  id         Int      @id @default(autoincrement())
  valueStr   String?
  valueNum   Float?
  valueBool  Boolean?
  valueDate  DateTime?
  recordId   Int
  record     CustomRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  fieldId    Int
  field      CustomField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model Sequence {
  id          Int      @id @default(autoincrement())
  name        String
  isActive    Boolean  @default(false)
  nodes       String?  @db.Text // JSON string
  edges       String?  @db.Text // JSON string
  enrollments SequenceEnrollment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SequenceEnrollment {
  id          Int      @id @default(autoincrement())
  sequenceId  Int
  sequence    Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentNode String?  
  nextRun     DateTime? 
  status      String   @default("Active") // Active, Completed, Paused
  createdAt   DateTime @default(now())
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String?  @unique
  description String?
  price       Float
  isRecurring Boolean  @default(true) // true = MRR, false = One-Time
  createdAt   DateTime @default(now())
  lineItems   QuoteLineItem[]
}

model Quote {
  id          Int      @id @default(autoincrement())
  title       String
  totalAmount Float    @default(0.0)
  mrr         Float    @default(0.0)
  status      String   @default("Draft") // Draft, Sent, Accepted, Rejected
  dealId      Int
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lineItems   QuoteLineItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuoteLineItem {
  id          Int      @id @default(autoincrement())
  quantity    Int      @default(1)
  unitPrice   Float
  quoteId     Int
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String   
  isRecurring Boolean  @default(true)
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  dueDate   DateTime?
  status    String   @default("Pending") // Pending, Completed
  priority  String   @default("Medium") // Low, Medium, High, Critical
  notes     String?
  createdAt DateTime @default(now())

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model Expense {
  id          Int      @id @default(autoincrement())
  title       String
  amount      Float
  category    String   @default("General") // General, Travel, Software, Office, Marketing, Other
  status      String   @default("Pending") // Pending, Approved, Rejected, Reimbursed
  receiptUrl  String?
  notes       String?  @db.Text
  expenseDate DateTime @default(now())
  createdAt   DateTime @default(now())

  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  contactId   Int?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model Contract {
  id          Int       @id @default(autoincrement())
  title       String
  status      String    @default("Draft") // Draft, Sent, Active, Expired, Terminated
  startDate   DateTime?
  endDate     DateTime?
  value       Float     @default(0.0)
  terms       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contactId   Int?
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId      Int?
  deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
}

model Estimate {
  id          Int              @id @default(autoincrement())
  estimateNum String           @unique
  title       String
  status      String           @default("Draft") // Draft, Sent, Accepted, Rejected, Converted
  totalAmount Float            @default(0.0)
  validUntil  DateTime?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())

  contactId   Int?
  contact     Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId      Int?
  deal        Deal?            @relation(fields: [dealId], references: [id], onDelete: SetNull)
  lineItems   EstimateLineItem[]
}

model EstimateLineItem {
  id          Int      @id @default(autoincrement())
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  estimateId  Int
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  isRead    Boolean  @default(false)
  link      String?  // optional URL to navigate to
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String   // CREATE, UPDATE, DELETE
  entity     String   // Contact, Deal, Invoice, etc.
  entityId   Int?
  details    String?  @db.Text // JSON diff or description
  createdAt  DateTime @default(now())

  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PipelineStage {
  id        Int      @id @default(autoincrement())
  name      String
  color     String   @default("#3b82f6")
  position  Int      @default(0) // ordering
  createdAt DateTime @default(now())
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  subject   String
  body      String   @db.Text
  category  String   @default("General") // General, Follow-up, Onboarding, Sales, Support
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  status      String   @default("Planning") // Planning, Active, On Hold, Completed, Cancelled
  priority    String   @default("Medium") // Low, Medium, High, Critical
  startDate   DateTime?
  endDate     DateTime?
  budget      Float    @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId     Int?
  owner       User?    @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  contactId   Int?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId      Int?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  tasks       Task[]
}

model ReportSchedule {
  id            Int      @id @default(autoincrement())
  name          String
  reportType    String   @default("deals") // deals, agent-performance, pipeline, contacts, tasks
  metrics       String?  @db.Text // JSON: ["revenue","count"]
  groupBy       String?  // stage, owner, source, status
  frequency     String   @default("weekly") // daily, weekly, monthly
  cronExpression String  @default("0 8 * * 1") // default Monday 8am
  recipients    String   @db.Text // JSON array of email addresses
  format        String   @default("PDF") // PDF, CSV
  enabled       Boolean  @default(true)
  lastRunAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MarketplaceLead {
  id              Int      @id @default(autoincrement())
  provider        String   // "indiamart", "justdial", "tradeindia"
  externalLeadId  String?  // provider's lead ID for dedup
  rawPayload      String?  @db.Text // JSON of original webhook/API payload
  name            String?
  email           String?
  phone           String?
  company         String?
  product         String?  // what they inquired about
  message         String?  @db.Text
  city            String?
  status          String   @default("New") // New, Imported, Duplicate, Dismissed
  contactId       Int?
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@unique([provider, externalLeadId])
}

model MarketplaceConfig {
  id          Int      @id @default(autoincrement())
  provider    String   @unique // "indiamart", "justdial", "tradeindia"
  apiKey      String?
  apiSecret   String?
  glueCrmKey  String?  // IndiaMART CRM key
  isActive    Boolean  @default(false)
  lastSyncAt  DateTime?
  settings    String?  @db.Text // JSON for extra config
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── SMS ───────────────────────────────────────────────────────────

model SmsMessage {
  id            Int       @id @default(autoincrement())
  to            String
  from          String?
  body          String    @db.Text
  direction     String    @default("OUTBOUND") // INBOUND, OUTBOUND
  status        String    @default("QUEUED") // QUEUED, SENT, DELIVERED, FAILED, RECEIVED
  provider      String?   // "msg91", "twilio"
  providerMsgId String?
  dltTemplateId String?
  errorMessage  String?
  read          Boolean   @default(false)
  createdAt     DateTime  @default(now())
  contactId     Int?
  contact       Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userId        Int?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaignId    Int?
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

model SmsTemplate {
  id            Int      @id @default(autoincrement())
  name          String
  body          String   @db.Text
  category      String   @default("Promotional") // Promotional, Transactional, OTP
  dltTemplateId String?
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SmsConfig {
  id          Int      @id @default(autoincrement())
  provider    String   @unique // "msg91", "twilio"
  apiKey      String?
  authToken   String?
  senderId    String?
  dltEntityId String?
  isActive    Boolean  @default(false)
  settings    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── WhatsApp ──────────────────────────────────────────────────────

model WhatsAppMessage {
  id              Int      @id @default(autoincrement())
  to              String
  from            String?
  body            String?  @db.Text
  mediaUrl        String?
  mediaType       String?
  direction       String   @default("OUTBOUND")
  status          String   @default("QUEUED") // QUEUED, SENT, DELIVERED, READ, FAILED
  providerMsgId   String?
  templateName    String?
  errorMessage    String?
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())
  contactId       Int?
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WhatsAppTemplate {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  language        String   @default("en")
  category        String   @default("MARKETING") // MARKETING, UTILITY, AUTHENTICATION
  headerType      String?  // TEXT, IMAGE, DOCUMENT, VIDEO, NONE
  headerContent   String?
  body            String   @db.Text
  footer          String?
  buttons         String?  @db.Text // JSON
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  metaTemplateId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WhatsAppConfig {
  id                 Int      @id @default(autoincrement())
  provider           String   @unique // "meta_cloud", "twilio_whatsapp", "gupshup"
  phoneNumberId      String?
  businessAccountId  String?
  accessToken        String?
  webhookVerifyToken String?
  isActive           Boolean  @default(false)
  settings           String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ── Telephony ─────────────────────────────────────────────────────

model TelephonyConfig {
  id            Int      @id @default(autoincrement())
  provider      String   @unique // "myoperator", "knowlarity", "twilio"
  apiKey        String?
  apiSecret     String?
  virtualNumber String?
  agentNumber   String?
  isActive      Boolean  @default(false)
  settings      String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Push Notifications ────────────────────────────────────────────

model PushSubscription {
  id          Int      @id @default(autoincrement())
  endpoint    String   @unique @db.VarChar(500)
  p256dh      String
  auth        String
  type        String   @default("CRM_USER") // CRM_USER, WEBSITE_VISITOR
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId   Int?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userAgent   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model PushNotification {
  id             Int       @id @default(autoincrement())
  title          String
  body           String    @db.Text
  icon           String?
  url            String?
  imageUrl       String?
  type           String    @default("INTERNAL") // INTERNAL, MARKETING
  status         String    @default("QUEUED")
  sentCount      Int       @default(0)
  deliveredCount Int       @default(0)
  clickedCount   Int       @default(0)
  failedCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  campaignId     Int?
  campaign       Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

model PushTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  title     String
  body      String   @db.Text
  icon      String?
  url       String?
  category  String   @default("General")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Landing Pages ─────────────────────────────────────────────────

model LandingPage {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  description     String?
  templateType    String?
  content         String?   @db.LongText // JSON component array
  cssOverrides    String?   @db.Text
  metaTitle       String?
  metaDescription String?
  status          String    @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  visits          Int       @default(0)
  submissions     Int       @default(0)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  userId          Int?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  analytics       LandingPageAnalytics[]
}

model LandingPageAnalytics {
  id            Int         @id @default(autoincrement())
  landingPageId Int
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  eventType     String      // VISIT, FORM_SUBMIT, BUTTON_CLICK
  visitorIp     String?
  userAgent     String?
  referrer      String?
  metadata      String?     @db.Text
  createdAt     DateTime    @default(now())
}
