  provider      String // "myoperator", "knowlarity", "twilio"
  apiKey        String?
  apiSecret     String?
  virtualNumber String?
  agentNumber   String?
  isActive      Boolean  @default(false)
  settings      String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One telephony credentials row per (tenant, provider). A tenant configures e.g. MyOperator once; the virtual number + API key live there. Different tenants run on different virtual-number pools.
  @@unique([tenantId, provider])
}

