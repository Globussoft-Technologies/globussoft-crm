generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  plan        String   @default("starter") // starter, professional, enterprise
  isActive    Boolean  @default(true)
  ownerEmail  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users                 User[]
  contacts              Contact[]
  activities            Activity[]
  deals                 Deal[]
  tickets               Ticket[]
  campaigns             Campaign[]
  automationRules       AutomationRule[]
  emailMessages         EmailMessage[]
  callLogs              CallLog[]
  attachments           Attachment[]
  apiKeys               ApiKey[]
  webhooks              Webhook[]
  invoices              Invoice[]
  integrations          Integration[]
  customEntities        CustomEntity[]
  customRecords         CustomRecord[]
  sequences             Sequence[]
  sequenceEnrollments   SequenceEnrollment[]
  products              Product[]
  quotes                Quote[]
  tasks                 Task[]
  expenses              Expense[]
  contracts             Contract[]
  estimates             Estimate[]
  projects              Project[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  pipelineStages        PipelineStage[]
  emailTemplates        EmailTemplate[]
  reportSchedules       ReportSchedule[]
  marketplaceLeads      MarketplaceLead[]
  marketplaceConfigs    MarketplaceConfig[]
  smsMessages           SmsMessage[]
  smsTemplates          SmsTemplate[]
  smsConfigs            SmsConfig[]
  whatsappMessages      WhatsAppMessage[]
  whatsappTemplates     WhatsAppTemplate[]
  whatsappConfigs       WhatsAppConfig[]
  telephonyConfigs      TelephonyConfig[]
  pushSubscriptions     PushSubscription[]
  pushNotifications     PushNotification[]
  pushTemplates         PushTemplate[]
  landingPages          LandingPage[]
  landingPageAnalytics  LandingPageAnalytics[]
  contactAttachments    ContactAttachment[]
  emailTrackings        EmailTracking[]
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  role      String    @default("USER") // ADMIN, USER, MANAGER
  name      String?
  createdAt DateTime  @default(now())

  // 2FA
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  backupCodes      String? @db.Text // JSON array of hashed codes

  // Personalization
  emailSignature   String? @db.Text
  language         String  @default("en")
  timezone         String  @default("UTC")

  // SSO
  googleId    String? @unique
  microsoftId String? @unique
  ssoProvider String? // "google", "microsoft", null = local

  tenantId  Int       @default(1)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  deals         Deal[]    @relation("OwnerDeals")
  tickets       Ticket[]  @relation("AssignedTickets")
  apiKeys       ApiKey[]
  webhooks      Webhook[]
  tasks         Task[]
  expenses      Expense[]
  projects      Project[] @relation("ProjectOwner")
  notifications Notification[]
  auditLogs     AuditLog[]
  assignedContacts Contact[] @relation("AssignedContacts")
  activities    Activity[]
  callLogs      CallLog[]
  emailMessages EmailMessage[]
  reportSchedules ReportSchedule[]
  smsMessages     SmsMessage[]
  whatsappMessages WhatsAppMessage[]
  pushSubscriptions PushSubscription[]
  landingPages    LandingPage[]
}

model Contact {
  id          Int        @id @default(autoincrement())
  name        String
  email       String
  phone       String?
  company     String?
  title       String?
  status      String     @default("Lead") // Lead, Prospect, Customer, Churned
  source      String?    @default("Organic")
  aiScore     Int        @default(0) // 1-100 predictive close probability

  // Data enrichment
  industry      String?
  companySize   String?
  linkedin      String?
  website       String?
  lastEnrichedAt DateTime?

  // Marketing attribution
  firstTouchSource String?
  lastTouchSource  String?

  // Territory
  territoryId   Int?

  // Customer portal
  portalPasswordHash String?

  createdAt   DateTime   @default(now())

  tenantId    Int        @default(1)
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assignedToId Int?
  assignedTo   User?     @relation("AssignedContacts", fields: [assignedToId], references: [id], onDelete: SetNull)

  activities  Activity[]
  deals       Deal[]
  emails      EmailMessage[]
  callLogs    CallLog[]
  invoices    Invoice[]
  sequenceEnrollments SequenceEnrollment[]
  tasks       Task[]
  expenses    Expense[]
  contracts   Contract[]
  estimates   Estimate[]
  projects    Project[]
  marketplaceLeads MarketplaceLead[]
  smsMessages      SmsMessage[]
  whatsappMessages WhatsAppMessage[]
  pushSubscriptions PushSubscription[]
  attachments      ContactAttachment[]

  @@unique([email, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, assignedToId])
}

model Activity {
  id          Int      @id @default(autoincrement())
  type        String   // Email, Call, Meeting, Note
  description String
  createdAt   DateTime @default(now())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([contactId, createdAt])
  @@index([tenantId, createdAt])
}

model Deal {
  id            Int      @id @default(autoincrement())
  title         String
  amount        Float    @default(0.0)
  currency      String   @default("USD")
  probability   Int      @default(50)
  stage         String   @default("lead") // lead, contacted, proposal, won, lost
  pipelineId    Int?     // links to Pipeline.id
  expectedClose DateTime?
  lostReason    String?
  winLossReasonId Int?
  createdAt     DateTime @default(now())

  tenantId      Int      @default(1)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId     Int?
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  ownerId       Int?
  owner         User?    @relation("OwnerDeals", fields: [ownerId], references: [id], onDelete: SetNull)
  attachments   Attachment[]
  invoices      Invoice[]
  quotes        Quote[]
  contracts     Contract[]
  estimates     Estimate[]
  projects      Project[]

  @@index([tenantId, stage])
  @@index([tenantId, ownerId])
  @@index([tenantId, createdAt])
}

model Ticket {
  id          Int      @id @default(autoincrement())
  subject     String
  description String?
  status      String   @default("Open") // Open, Pending, Resolved, Closed
  priority    String   @default("Low") // Low, Medium, High, Urgent
  slaResponseDue DateTime?
  slaResolveDue  DateTime?
  firstResponseAt DateTime?
  resolvedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assigneeId  Int?
  assignee    User?    @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, priority])
}

model Campaign {
  id          Int      @id @default(autoincrement())
  name        String
  channel     String   @default("EMAIL") // EMAIL, SMS, PUSH, WHATSAPP
  status      String   @default("Draft") // Draft, Active, Completed
  sent        Int      @default(0)
  opened      Int      @default(0)
  clicked     Int      @default(0)
  budget      Float    @default(0.0)
  createdAt   DateTime @default(now())

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  smsMessages SmsMessage[]
  pushNotifications PushNotification[]
}

model AutomationRule {
  id          Int      @id @default(autoincrement())
  name        String
  triggerType String
  actionType  String
  targetState String?
  isActive    Boolean  @default(true)

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model EmailMessage {
  id        Int      @id @default(autoincrement())
  subject   String
  body      String   @db.Text
  from      String
  to        String
  direction String   @default("INBOUND") // INBOUND, OUTBOUND
  read      Boolean  @default(false)
  sentiment String?  // positive, neutral, negative
  sentimentScore Float? // -1 to 1
  threadId  String?  // for conversation threading
  createdAt DateTime @default(now())

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, direction])
  @@index([tenantId, contactId])
  @@index([tenantId, createdAt])
}

model CallLog {
  id             Int      @id @default(autoincrement())
  duration       Int      // seconds
  notes          String?
  direction      String   @default("OUTBOUND")
  recordingUrl   String?
  provider       String?  // "myoperator", "knowlarity", "twilio", "webrtc"
  providerCallId String?
  status         String   @default("COMPLETED") // INITIATED, RINGING, CONNECTED, COMPLETED, MISSED, FAILED
  callerNumber   String?
  calleeNumber   String?
  createdAt      DateTime @default(now())

  tenantId       Int      @default(1)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId      Int?
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  userId         Int?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
}

model Attachment {
  id        Int      @id @default(autoincrement())
  filename  String
  fileUrl   String
  createdAt DateTime @default(now())

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  dealId    Int
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        Int      @id @default(autoincrement())
  keySecret String   @unique // Hashed or raw token
  name      String
  createdAt DateTime @default(now())
  lastUsed  DateTime?

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Webhook {
  id        Int      @id @default(autoincrement())
  event     String   // e.g. "deal.*", "contact.created"
  targetUrl String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNum    String   @unique
  amount        Float
  status        String   @default("UNPAID") // UNPAID, PAID, OVERDUE, VOID
  dueDate       DateTime
  issuedDate    DateTime @default(now())
  isRecurring   Boolean  @default(false)
  recurFrequency String? // "monthly", "quarterly", "yearly"
  nextRecurDate DateTime?
  parentInvoiceId Int?   // original invoice this was generated from

  tenantId      Int      @default(1)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  dealId        Int?
  deal          Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contactId     Int
  contact       Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, contactId])
}

model Integration {
  id        Int      @id @default(autoincrement())
  provider  String   // slack, google, stripe, mailchimp
  token     String?
  isActive  Boolean  @default(false)
  settings  String?  @db.Text // JSON stringified configuration
  updatedAt DateTime @updatedAt

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
}

model CustomEntity {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fields      CustomField[]
  records     CustomRecord[]

  @@unique([tenantId, name])
}

model CustomField {
  id         Int      @id @default(autoincrement())
  name       String
  type       String   @default("Text") // Text, Number, Date, Boolean
  entityId   Int
  entity     CustomEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  values     CustomValue[]
}

model CustomRecord {
  id         Int      @id @default(autoincrement())
  entityId   Int
  entity     CustomEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  values     CustomValue[]
  createdAt  DateTime @default(now())

  tenantId   Int      @default(1)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CustomValue {
  id         Int      @id @default(autoincrement())
  valueStr   String?
  valueNum   Float?
  valueBool  Boolean?
  valueDate  DateTime?
  recordId   Int
  record     CustomRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  fieldId    Int
  field      CustomField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model Sequence {
  id          Int      @id @default(autoincrement())
  name        String
  isActive    Boolean  @default(false)
  nodes       String?  @db.Text // JSON string
  edges       String?  @db.Text // JSON string
  enrollments SequenceEnrollment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SequenceEnrollment {
  id          Int      @id @default(autoincrement())
  sequenceId  Int
  sequence    Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentNode String?
  nextRun     DateTime?
  status      String   @default("Active") // Active, Completed, Paused
  createdAt   DateTime @default(now())

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String?  @unique
  description String?
  price       Float
  isRecurring Boolean  @default(true) // true = MRR, false = One-Time
  createdAt   DateTime @default(now())
  lineItems   QuoteLineItem[]

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Quote {
  id          Int      @id @default(autoincrement())
  title       String
  totalAmount Float    @default(0.0)
  mrr         Float    @default(0.0)
  status      String   @default("Draft") // Draft, Sent, Accepted, Rejected
  dealId      Int
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lineItems   QuoteLineItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model QuoteLineItem {
  id          Int      @id @default(autoincrement())
  quantity    Int      @default(1)
  unitPrice   Float
  quoteId     Int
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  isRecurring Boolean  @default(true)
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  dueDate   DateTime?
  status    String   @default("Pending") // Pending, Completed
  priority  String   @default("Medium") // Low, Medium, High, Critical
  notes     String?
  createdAt DateTime @default(now())

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, userId])
}

model Expense {
  id          Int      @id @default(autoincrement())
  title       String
  amount      Float
  category    String   @default("General") // General, Travel, Software, Office, Marketing, Other
  status      String   @default("Pending") // Pending, Approved, Rejected, Reimbursed
  receiptUrl  String?
  notes       String?  @db.Text
  expenseDate DateTime @default(now())
  createdAt   DateTime @default(now())

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  contactId   Int?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
}

model Contract {
  id          Int       @id @default(autoincrement())
  title       String
  status      String    @default("Draft") // Draft, Sent, Active, Expired, Terminated
  startDate   DateTime?
  endDate     DateTime?
  value       Float     @default(0.0)
  terms       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenantId    Int       @default(1)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId   Int?
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId      Int?
  deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
}

model Estimate {
  id          Int              @id @default(autoincrement())
  estimateNum String           @unique
  title       String
  status      String           @default("Draft") // Draft, Sent, Accepted, Rejected, Converted
  totalAmount Float            @default(0.0)
  validUntil  DateTime?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())

  tenantId    Int              @default(1)
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId   Int?
  contact     Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId      Int?
  deal        Deal?            @relation(fields: [dealId], references: [id], onDelete: SetNull)
  lineItems   EstimateLineItem[]
}

model EstimateLineItem {
  id          Int      @id @default(autoincrement())
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  estimateId  Int
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  isRead    Boolean  @default(false)
  link      String?  // optional URL to navigate to
  createdAt DateTime @default(now())

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([tenantId, createdAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String   // CREATE, UPDATE, DELETE
  entity     String   // Contact, Deal, Invoice, etc.
  entityId   Int?
  details    String?  @db.Text // JSON diff or description
  createdAt  DateTime @default(now())

  tenantId   Int      @default(1)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, entity])
  @@index([tenantId, createdAt])
}

model PipelineStage {
  id        Int      @id @default(autoincrement())
  name      String
  color     String   @default("#3b82f6")
  position  Int      @default(0) // ordering
  createdAt DateTime @default(now())

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, position])
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  subject   String
  body      String   @db.Text
  category  String   @default("General") // General, Follow-up, Onboarding, Sales, Support
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  status      String   @default("Planning") // Planning, Active, On Hold, Completed, Cancelled
  priority    String   @default("Medium") // Low, Medium, High, Critical
  startDate   DateTime?
  endDate     DateTime?
  budget      Float    @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  ownerId     Int?
  owner       User?    @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  contactId   Int?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId      Int?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  tasks       Task[]
}

model ReportSchedule {
  id            Int      @id @default(autoincrement())
  name          String
  reportType    String   @default("deals") // deals, agent-performance, pipeline, contacts, tasks
  metrics       String?  @db.Text // JSON: ["revenue","count"]
  groupBy       String?  // stage, owner, source, status
  frequency     String   @default("weekly") // daily, weekly, monthly
  cronExpression String  @default("0 8 * * 1") // default Monday 8am
  recipients    String   @db.Text // JSON array of email addresses
  format        String   @default("PDF") // PDF, CSV
  enabled       Boolean  @default(true)
  lastRunAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId      Int      @default(1)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MarketplaceLead {
  id              Int      @id @default(autoincrement())
  provider        String   // "indiamart", "justdial", "tradeindia"
  externalLeadId  String?  // provider's lead ID for dedup
  rawPayload      String?  @db.Text // JSON of original webhook/API payload
  name            String?
  email           String?
  phone           String?
  company         String?
  product         String?  // what they inquired about
  message         String?  @db.Text
  city            String?
  status          String   @default("New") // New, Imported, Duplicate, Dismissed
  contactId       Int?
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  tenantId        Int      @default(1)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([provider, externalLeadId])
}

model MarketplaceConfig {
  id          Int      @id @default(autoincrement())
  provider    String   // "indiamart", "justdial", "tradeindia"
  apiKey      String?
  apiSecret   String?
  glueCrmKey  String?  // IndiaMART CRM key
  isActive    Boolean  @default(false)
  lastSyncAt  DateTime?
  settings    String?  @db.Text // JSON for extra config
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
