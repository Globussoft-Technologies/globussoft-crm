generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  role      String    @default("USER") // ADMIN, USER, MANAGER
  name      String?
  createdAt DateTime  @default(now())
  deals     Deal[]    @relation("OwnerDeals")
  tickets   Ticket[]  @relation("AssignedTickets")
  apiKeys   ApiKey[]
  webhooks  Webhook[]
  tasks     Task[]
}

model Contact {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  company     String?
  title       String?
  status      String     @default("Lead") // Lead, Prospect, Customer, Churned
  source      String?    @default("Organic")
  aiScore     Int        @default(0) // 1-100 predictive close probability
  createdAt   DateTime   @default(now())
  activities  Activity[]
  deals       Deal[]
  emails      EmailMessage[]
  callLogs    CallLog[]
  invoices    Invoice[]
  sequenceEnrollments SequenceEnrollment[]
  tasks       Task[]
}

model Activity {
  id          Int      @id @default(autoincrement())
  type        String   // Email, Call, Meeting, Note
  description String
  createdAt   DateTime @default(now())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Deal {
  id            Int      @id @default(autoincrement())
  title         String
  amount        Float    @default(0.0)
  probability   Int      @default(50)
  stage         String   @default("lead") // lead, contacted, proposal, won, lost
  expectedClose DateTime?
  createdAt     DateTime @default(now())
  
  contactId     Int?
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  
  ownerId       Int?
  owner         User?    @relation("OwnerDeals", fields: [ownerId], references: [id], onDelete: SetNull)
  attachments   Attachment[]
  invoices      Invoice[]
  quotes        Quote[]
}

model Ticket {
  id          Int      @id @default(autoincrement())
  subject     String
  description String?
  status      String   @default("Open") // Open, Pending, Resolved, Closed
  priority    String   @default("Low") // Low, Medium, High, Urgent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  assigneeId  Int?
  assignee    User?    @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)
}

model Campaign {
  id          Int      @id @default(autoincrement())
  name        String
  status      String   @default("Draft") // Draft, Active, Completed
  sent        Int      @default(0)
  opened      Int      @default(0)
  clicked     Int      @default(0)
  budget      Float    @default(0.0)
  createdAt   DateTime @default(now())
}

model AutomationRule {
  id          Int      @id @default(autoincrement())
  name        String
  triggerType String
  actionType  String
  targetState String?
  isActive    Boolean  @default(true)
}

model EmailMessage {
  id        Int      @id @default(autoincrement())
  subject   String
  body      String
  from      String
  to        String
  direction String   @default("INBOUND") // INBOUND, OUTBOUND
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  
  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model CallLog {
  id           Int      @id @default(autoincrement())
  duration     Int      // seconds
  notes        String?
  direction    String   @default("OUTBOUND")
  recordingUrl String?
  createdAt    DateTime @default(now())
  
  contactId    Int?
  contact      Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model Attachment {
  id        Int      @id @default(autoincrement())
  filename  String
  fileUrl   String
  createdAt DateTime @default(now())
  
  dealId    Int
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        Int      @id @default(autoincrement())
  keySecret String   @unique // Hashed or raw token
  name      String
  createdAt DateTime @default(now())
  lastUsed  DateTime?
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Webhook {
  id        Int      @id @default(autoincrement())
  event     String   // e.g. "deal.*", "contact.created"
  targetUrl String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          Int      @id @default(autoincrement())
  invoiceNum  String   @unique
  amount      Float
  status      String   @default("UNPAID") // UNPAID, PAID, OVERDUE
  dueDate     DateTime
  issuedDate  DateTime @default(now())
  
  dealId      Int?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Integration {
  id        Int      @id @default(autoincrement())
  provider  String   @unique // slack, google, stripe, mailchimp
  token     String?
  isActive  Boolean  @default(false)
  settings  String?  @db.Text // JSON stringified configuration
  updatedAt DateTime @updatedAt
}

model CustomEntity {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  fields      CustomField[]
  records     CustomRecord[]
}

model CustomField {
  id         Int      @id @default(autoincrement())
  name       String
  type       String   @default("Text") // Text, Number, Date, Boolean
  entityId   Int
  entity     CustomEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  values     CustomValue[]
}

model CustomRecord {
  id         Int      @id @default(autoincrement())
  entityId   Int
  entity     CustomEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  values     CustomValue[]
  createdAt  DateTime @default(now())
}

model CustomValue {
  id         Int      @id @default(autoincrement())
  valueStr   String?
  valueNum   Float?
  valueBool  Boolean?
  valueDate  DateTime?
  recordId   Int
  record     CustomRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  fieldId    Int
  field      CustomField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model Sequence {
  id          Int      @id @default(autoincrement())
  name        String
  isActive    Boolean  @default(false)
  nodes       String?  @db.Text // JSON string
  edges       String?  @db.Text // JSON string
  enrollments SequenceEnrollment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SequenceEnrollment {
  id          Int      @id @default(autoincrement())
  sequenceId  Int
  sequence    Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentNode String?  
  nextRun     DateTime? 
  status      String   @default("Active") // Active, Completed, Paused
  createdAt   DateTime @default(now())
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String?  @unique
  description String?
  price       Float
  isRecurring Boolean  @default(true) // true = MRR, false = One-Time
  createdAt   DateTime @default(now())
  lineItems   QuoteLineItem[]
}

model Quote {
  id          Int      @id @default(autoincrement())
  title       String
  totalAmount Float    @default(0.0)
  mrr         Float    @default(0.0)
  status      String   @default("Draft") // Draft, Sent, Accepted, Rejected
  dealId      Int
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lineItems   QuoteLineItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuoteLineItem {
  id          Int      @id @default(autoincrement())
  quantity    Int      @default(1)
  unitPrice   Float
  quoteId     Int
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String   
  isRecurring Boolean  @default(true)
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  dueDate   DateTime?
  status    String   @default("Pending") // Pending, Completed
  notes     String?
  createdAt DateTime @default(now())

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
