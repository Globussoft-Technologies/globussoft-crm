  groupBy        String? // stage, owner, source, status
  frequency      String    @default("weekly") // daily, weekly, monthly
  cronExpression String    @default("0 8 * * 1") // default Monday 8am
  recipients     String    @db.Text // JSON array of email addresses
  format         String    @default("PDF") // PDF, CSV
  enabled        Boolean   @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MarketplaceLead {
  id             Int      @id @default(autoincrement())
  provider       String // "indiamart", "justdial", "tradeindia"
  externalLeadId String? // provider's lead ID for dedup
  rawPayload     String?  @db.Text // JSON of original webhook/API payload
  name           String?
  email          String?
  phone          String?
  company        String?
  product        String? // what they inquired about
  message        String?  @db.Text
  city           String?
  status         String   @default("New") // New, Imported, Duplicate, Dismissed
  contactId      Int?
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// #414 — Prevents the same external lead from being ingested twice by the same tenant; cross-tenant duplicates are allowed (different customers using the same source-system, e.g. IndiaMART, may legitimately receive the same external lead independently). Pre-fix: this constraint excluded tenantId, which globally locked any (provider, externalLeadId) pair to the first tenant that imported it.
  @@unique([tenantId, provider, externalLeadId])
  @@index([tenantId, status])
  @@index([tenantId, provider])
}

model MarketplaceConfig {
  id         Int       @id @default(autoincrement())
  provider   String // "indiamart", "justdial", "tradeindia"
  apiKey     String?
  apiSecret  String?
  glueCrmKey String? // IndiaMART CRM key
  isActive   Boolean   @default(false)
  lastSyncAt DateTime?
  settings   String?   @db.Text // JSON for extra config
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One credentials row per (tenant, marketplace provider). A tenant has at most one IndiaMART API key on file; rotating the key updates this row in place. Different tenants of course have their own independent provider credentials.
  @@unique([tenantId, provider])
}

// ── SMS ───────────────────────────────────────────────────────────

model SmsMessage {
  id            Int      @id @default(autoincrement())
  to            String
  from          String?
  body          String   @db.Text
  direction     String   @default("OUTBOUND") // INBOUND, OUTBOUND
  status        String   @default("QUEUED") // QUEUED, SENT, DELIVERED, FAILED, RECEIVED
  provider      String? // "msg91", "twilio"
  providerMsgId String?
  dltTemplateId String?
  errorMessage  String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId  Int?
  contact    Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userId     Int?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaignId Int?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
}

model SmsTemplate {
  id            Int      @id @default(autoincrement())
  name          String
  body          String   @db.Text
  category      String   @default("Promotional") // Promotional, Transactional, OTP
  dltTemplateId String?
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SmsConfig {
  id            Int       @id @default(autoincrement())
  provider      String // "msg91", "twilio", "fast2sms"
  // #651 — credential columns widened to @db.Text so AES-256-GCM ciphertext
  // (ENC:v1:<iv>:<tag>:<ct> wrapper) fits regardless of plaintext length.
  apiKey        String?   @db.Text
  authToken     String?   @db.Text
  senderId      String?
  dltEntityId   String?
  isActive      Boolean   @default(false)
  settings      String?   @db.Text
  // #651 — Stamp every credential rotation so the admin UI can show
  // "Last rotated <date>" and so the audit chain has a corroborating
  // signal alongside the ProviderConfig.ROTATE row.
  lastRotatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One SMS provider credential row per (tenant, provider). A tenant configures MSG91 once; reconfiguring updates the row. Different tenants run their own MSG91 / Twilio accounts independently.
  @@unique([tenantId, provider])
}

// ── WhatsApp ──────────────────────────────────────────────────────

model WhatsAppMessage {
  id            Int      @id @default(autoincrement())
  to            String
  from          String?
  body          String?  @db.Text
  mediaUrl      String?
  mediaType     String?
  direction     String   @default("OUTBOUND")
  status        String   @default("QUEUED") // QUEUED, SENT, DELIVERED, READ, FAILED
  providerMsgId String?
  templateName  String?
  errorMessage  String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Wave 2 Agent KK: 2-way messaging - thread keyed by (tenantId, contactPhone).
  threadId Int?
  thread   WhatsAppThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([threadId, createdAt])
}

// -- WhatsApp 2-way: Thread aggregation + opt-out (Wave 2 Agent KK) --
model WhatsAppThread {
  id            Int       @id @default(autoincrement())
  contactPhone  String
  status        String    @default("OPEN")
  lastMessageAt DateTime  @default(now())
  lastInboundAt DateTime?
  snoozedUntil  DateTime?
  unreadCount   Int       @default(0)
  labels        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  patientId Int?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  assignedToId Int?
  assignedTo   User? @relation("WhatsAppThreadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  messages WhatsAppMessage[]

  @@unique([tenantId, contactPhone])
  @@index([tenantId, status, lastMessageAt])
  @@index([assignedToId, status])
}

model WhatsAppOptOut {
  id           Int      @id @default(autoincrement())
  contactPhone String
  reason       String   @default("USER_REQUESTED")
  capturedAt   DateTime @default(now())
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  tenantId Int    @default(1)
