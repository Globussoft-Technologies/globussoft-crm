// ── Multi-Currency ───────────────────────────────────────────────

model Currency {
  id           Int      @id @default(autoincrement())
  code         String // "USD", "INR", "EUR"
  symbol       String
  name         String
  exchangeRate Float    @default(1.0) // relative to base
  isBase       Boolean  @default(false)
  tenantId     Int      @default(1)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// One Currency row per (ISO code, tenant). Each tenant maintains its own exchange-rate table relative to its base currency, so "USD" can exist in tenant A (rate=1.0 base) and tenant B (rate=83.4 vs INR base) independently.
  @@unique([code, tenantId])
}

// ── Field-Level Permissions ──────────────────────────────────────

model FieldPermission {
  id        Int      @id @default(autoincrement())
  role      String // ADMIN, MANAGER, USER (also accepts wellness sub-roles via action-aware paths)
  entity    String // Deal, Contact, etc. — also doubles as a "module" identifier when field='*'
  field     String // amount, email, etc. Use '*' for module-level (action-only) rules.
  // PRD Gap §1.3 — module × action permissions. Defaults to "WRITE" so
  // existing rows preserve the historical canWrite-as-permission semantics
  // (a row with canWrite=false / canRead=true on action=WRITE blocks
  // writes the same way the old shape did). Other actions opt in:
  //   READ   — additional read gate (rare; canRead already covers most cases)
  //   WRITE  — POST/PUT/PATCH-style mutations (the legacy default)
  //   DELETE — DELETE-style removals
  //   EXPORT — CSV / PDF / report-export gates
  action    String   @default("WRITE")
  canRead   Boolean  @default(true)
  canWrite  Boolean  @default(true)
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  /// One field-permission row per (role, entity, field, action, tenant). Tenants configure their own RBAC rules — tenant A can hide "Deal.amount" from MANAGER while tenant B exposes it. The compound key prevents duplicate rules within one tenant while keeping permissions per-tenant configurable. action is part of the key so per-action toggles (READ/WRITE/DELETE/EXPORT) coexist for the same field.
  @@unique([role, entity, field, action, tenantId])
}

// ── Payments (Stripe + Razorpay) ─────────────────────────────────

model Payment {
  id        Int       @id @default(autoincrement())
  invoiceId Int?
  amount    Float
  currency  String    @default("USD")
  gateway   String // stripe, razorpay
  gatewayId String? // their charge/payment ID
  status    String    @default("PENDING") // PENDING, SUCCESS, FAILED, REFUNDED
  paidAt    DateTime?
  metadata  String?   @db.Text
  // #413 — Restrict (not Cascade) on Tenant deletion. Payments are
  // financial records-of-record (Stripe/Razorpay charges, refunds, gateway
  // IDs). A misclick on tenant.delete() must NOT silently nuke payment
  // history. Operator must explicitly drain Payment rows first.
  tenantId  Int       @default(1)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt DateTime  @default(now())

  @@index([tenantId, status])
}

// ── Accounting Sync ──────────────────────────────────────────────

model AccountingSync {
  id         Int      @id @default(autoincrement())
  provider   String // quickbooks, xero, tally
  entityType String // Invoice, Expense, Customer
  entityId   Int
  externalId String // ID in external system
  syncedAt   DateTime @default(now())
  tenantId   Int      @default(1)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Mapping table from local entity → external accounting system ID. One mapping per (provider, entityType, entityId) within a tenant — Invoice #42 in tenant A maps to ONE QuickBooks invoice ID. tenantId prevents cross-tenant mapping bleed; entityId is only unique within a tenant in our schema.
  @@unique([provider, entityType, entityId, tenantId])
}

