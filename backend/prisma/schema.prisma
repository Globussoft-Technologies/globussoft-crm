// ── Landing Pages ─────────────────────────────────────────────────

model LandingPage {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String
  description     String?
  templateType    String?
  content         String?   @db.LongText // JSON component array
  cssOverrides    String?   @db.Text
  metaTitle       String?
  metaDescription String?
  status          String    @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  visits          Int       @default(0)
  submissions     Int       @default(0)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Travel-vertical metadata (nullable; backfilled only by travel pages
  // generated via the Generate Destination Landing Page flow OR seeded
  // from the Japan migration). Generic / non-travel pages leave these
  // null. Index supports "list this sub-brand's travel pages" filter.
  destination   String?
  subBrand      String?
  generatedByAi Boolean   @default(false)
  generatedAt   DateTime?

  // "Featured" pointer for the dynamic /trips public route. At most ONE
  // PUBLISHED page per (tenantId, subBrand) should carry isFeatured=true;
  // the feature/unfeature route handlers enforce that invariant
  // transactionally. /trips resolves to the most recently featured row;
  // direct /p/<slug> URLs continue to work in parallel.
  isFeatured Boolean   @default(false)
  featuredAt DateTime?

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId    Int?
  user      User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  analytics LandingPageAnalytics[]
  versions  LandingPageVersion[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, subBrand, status])
  @@index([tenantId, subBrand, isFeatured])
}

// Lightweight version-history snapshot of a LandingPage. Captured on
// AI generation, manual save, publish, and restore so operators can
// roll back to a known-good state during UAT / client demos / AI
// experimentation. Restore writes a NEW version (source=RESTORE)
// rather than overwriting history, so the chain is append-only.
model LandingPageVersion {
  id                    Int         @id @default(autoincrement())
  landingPageId         Int
  landingPage           LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  versionNumber         Int
  title                 String
  slug                  String
  content               String      @db.LongText
  // CREATE | MANUAL_SAVE | PUBLISH | AI_GENERATION | RESTORE
  source                String
  // When source=RESTORE, points to the version that was restored.
  restoredFromVersionId Int?
  createdAt             DateTime    @default(now())
  createdById           Int?

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([landingPageId, versionNumber])
  @@index([tenantId, landingPageId, createdAt])
}

model LandingPageAnalytics {
  id            Int         @id @default(autoincrement())
  landingPageId Int
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  eventType     String // VISIT, FORM_SUBMIT, BUTTON_CLICK
  visitorIp     String?
  userAgent     String?
  referrer      String?
  metadata      String?     @db.Text
  createdAt     DateTime    @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── Contact Attachments ───────────────────────────────────────────

model ContactAttachment {
  id        Int      @id @default(autoincrement())
  filename  String
  fileUrl   String
  fileSize  Int? // bytes
  mimeType  String?
  createdAt DateTime @default(now())
  contactId Int
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── Email Tracking ────────────────────────────────────────────────

model EmailTracking {
  id         Int       @id @default(autoincrement())
  emailId    Int // references EmailMessage.id
  trackingId String    @unique // UUID for tracking pixel/link
  type       String // "open", "click"
  url        String? // original URL for click tracking
  openedAt   DateTime?
  clickedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── SSO Configuration ────────────────────────────────────────────

model SsoConfig {
  id           Int      @id @default(autoincrement())
  provider     String // "google", "microsoft"
  clientId     String?
  clientSecret String?
  redirectUri  String?
  isActive     Boolean  @default(false)
  tenantId     Int      @default(1)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// One SSO config row per (tenant, identity provider). A tenant binds to Google Workspace ONCE with their own clientId/secret. Different tenants of course own separate Google Workspace tenants and separate Microsoft Entra IDs.
  @@unique([tenantId, provider])
}

// ── Calendar Integration ─────────────────────────────────────────

model CalendarIntegration {
  id           Int       @id @default(autoincrement())
  userId       Int
  provider     String // "google", "microsoft"
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  calendarId   String? // primary calendar id
  syncEnabled  Boolean   @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One calendar connection per (user, provider). A user connects their Google calendar once; reconnecting refreshes tokens in place. Note: scoped on userId (already globally unique across tenants), so tenantId is redundant in this key.
  @@unique([userId, provider])
}

/// Per-user Gmail connection (OAuth2 via the Gmail API). Mirrors
/// CalendarIntegration: each staff user connects their own mailbox once;
/// reconnecting refreshes tokens in place. `emailAddress` is the connected
/// Gmail address (resolved from the Gmail profile at callback) so the UI can
/// show "Connected as x@y.com" and the sync can stamp the owning address.
/// `lastHistoryId` supports incremental sync (Gmail users.history.list) and
/// the future Pub/Sub push (users.watch) — full sync falls back to
/// messages.list when it's null.
model GmailIntegration {
  id            Int       @id @default(autoincrement())
  userId        Int
  provider      String    @default("google") // "google" — kept for parity / future providers
  emailAddress  String? // the connected mailbox address
  accessToken   String    @db.Text
  refreshToken  String?   @db.Text
  expiresAt     DateTime?
  syncEnabled   Boolean   @default(true)
  lastHistoryId String? // Gmail historyId watermark for incremental sync
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One Gmail connection per (user, provider) — same convention as CalendarIntegration.
  @@unique([userId, provider])
}

model CalendarEvent {
  id          Int      @id @default(autoincrement())
  externalId  String // provider's event ID
  provider    String
  title       String
  description String?  @db.Text
  startTime   DateTime
  endTime     DateTime
  location    String?
  attendees   String?  @db.Text // JSON
  meetingUrl  String?
  userId      Int
  contactId   Int?
  dealId      Int?
  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Dedup key for inbound calendar sync. Originally `@@unique([provider, externalId])` on the load-bearing assumption that Google/Microsoft event IDs are globally unique by construction — but that put CalendarEvent as the ONLY tenant-scoped model in the codebase whose unique key didn't include tenantId, and a hostile or buggy provider that re-used an externalId across tenants would silently collide. Adding tenantId as the first key field is strictly more permissive than the old constraint (every prior unique pair is still unique under the new one) so no migration risk. Provider-globally-unique IDs still work; tenant-local provider IDs no longer collide. (#424, wave 17.)
  @@unique([tenantId, provider, externalId])
}

// ── GDPR / Compliance ────────────────────────────────────────────

model ConsentRecord {
  id        Int      @id @default(autoincrement())
  contactId Int
  type      String // "marketing_email", "marketing_sms", "marketing_whatsapp", "data_processing"
  granted   Boolean
  ipAddress String?
  userAgent String?
  source    String? // where consent was captured
  createdAt DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model DataExportRequest {
  id          Int       @id @default(autoincrement())
  contactId   Int? // can be for a contact's data
  userId      Int? // or a user's own data
  status      String    @default("PENDING") // PENDING, PROCESSING, COMPLETE, FAILED
  fileUrl     String? // download URL when complete
  requestedAt DateTime  @default(now())
  completedAt DateTime?

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model RetentionPolicy {
  id         Int      @id @default(autoincrement())
  entity     String // "EmailMessage", "CallLog", "Activity", etc.
  retainDays Int // delete records older than this
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One GDPR retention policy row per (tenant, entity-type). A tenant declares "delete EmailMessage older than 90 days" exactly once; policies are tenant-specific because retention is a tenant compliance choice (e.g. EU vs APAC tenants set different windows).
  @@unique([tenantId, entity])
}

// ── Voice / Telephony Sessions ───────────────────────────────────

model VoiceSession {
