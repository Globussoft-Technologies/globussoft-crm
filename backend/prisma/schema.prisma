  icon      String?
  url       String?
  category  String   @default("General")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── Landing Pages ─────────────────────────────────────────────────

model LandingPage {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  description     String?
  templateType    String?
  content         String?   @db.LongText // JSON component array
  cssOverrides    String?   @db.Text
  metaTitle       String?
  metaDescription String?
  status          String    @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  visits          Int       @default(0)
  submissions     Int       @default(0)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId    Int?
  user      User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  analytics LandingPageAnalytics[]

  @@index([tenantId, status])
}

model LandingPageAnalytics {
  id            Int         @id @default(autoincrement())
  landingPageId Int
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  eventType     String // VISIT, FORM_SUBMIT, BUTTON_CLICK
  visitorIp     String?
  userAgent     String?
  referrer      String?
  metadata      String?     @db.Text
  createdAt     DateTime    @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── Contact Attachments ───────────────────────────────────────────

model ContactAttachment {
  id        Int      @id @default(autoincrement())
  filename  String
  fileUrl   String
  fileSize  Int? // bytes
  mimeType  String?
  createdAt DateTime @default(now())
  contactId Int
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── Email Tracking ────────────────────────────────────────────────

model EmailTracking {
  id         Int       @id @default(autoincrement())
  emailId    Int // references EmailMessage.id
  trackingId String    @unique // UUID for tracking pixel/link
  type       String // "open", "click"
  url        String? // original URL for click tracking
  openedAt   DateTime?
  clickedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── SSO Configuration ────────────────────────────────────────────

model SsoConfig {
  id           Int      @id @default(autoincrement())
  provider     String // "google", "microsoft"
  clientId     String?
  clientSecret String?
  redirectUri  String?
  isActive     Boolean  @default(false)
  tenantId     Int      @default(1)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// One SSO config row per (tenant, identity provider). A tenant binds to Google Workspace ONCE with their own clientId/secret. Different tenants of course own separate Google Workspace tenants and separate Microsoft Entra IDs.
  @@unique([tenantId, provider])
}

// ── Calendar Integration ─────────────────────────────────────────

model CalendarIntegration {
  id           Int       @id @default(autoincrement())
  userId       Int
  provider     String // "google", "microsoft"
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  calendarId   String? // primary calendar id
  syncEnabled  Boolean   @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One calendar connection per (user, provider). A user connects their Google calendar once; reconnecting refreshes tokens in place. Note: scoped on userId (already globally unique across tenants), so tenantId is redundant in this key.
  @@unique([userId, provider])
}

model CalendarEvent {
  id          Int      @id @default(autoincrement())
  externalId  String // provider's event ID
  provider    String
  title       String
  description String?  @db.Text
  startTime   DateTime
  endTime     DateTime
  location    String?
  attendees   String?  @db.Text // JSON
  meetingUrl  String?
  userId      Int
  contactId   Int?
  dealId      Int?
  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Dedup key for inbound calendar sync. Originally `@@unique([provider, externalId])` on the load-bearing assumption that Google/Microsoft event IDs are globally unique by construction — but that put CalendarEvent as the ONLY tenant-scoped model in the codebase whose unique key didn't include tenantId, and a hostile or buggy provider that re-used an externalId across tenants would silently collide. Adding tenantId as the first key field is strictly more permissive than the old constraint (every prior unique pair is still unique under the new one) so no migration risk. Provider-globally-unique IDs still work; tenant-local provider IDs no longer collide. (#424, wave 17.)
  @@unique([tenantId, provider, externalId])
}

// ── GDPR / Compliance ────────────────────────────────────────────

model ConsentRecord {
  id        Int      @id @default(autoincrement())
  contactId Int
  type      String // "marketing_email", "marketing_sms", "marketing_whatsapp", "data_processing"
  granted   Boolean
  ipAddress String?
  userAgent String?
  source    String? // where consent was captured
  createdAt DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model DataExportRequest {
  id          Int       @id @default(autoincrement())
  contactId   Int? // can be for a contact's data
  userId      Int? // or a user's own data
  status      String    @default("PENDING") // PENDING, PROCESSING, COMPLETE, FAILED
  fileUrl     String? // download URL when complete
  requestedAt DateTime  @default(now())
  completedAt DateTime?

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model RetentionPolicy {
  id         Int      @id @default(autoincrement())
  entity     String // "EmailMessage", "CallLog", "Activity", etc.
  retainDays Int // delete records older than this
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One GDPR retention policy row per (tenant, entity-type). A tenant declares "delete EmailMessage older than 90 days" exactly once; policies are tenant-specific because retention is a tenant compliance choice (e.g. EU vs APAC tenants set different windows).
  @@unique([tenantId, entity])
}

// ── Voice / Telephony Sessions ───────────────────────────────────

model VoiceSession {
  id           Int       @id @default(autoincrement())
  sessionId    String    @unique // Twilio call SID or provider session
  status       String    @default("INITIATED") // INITIATED, RINGING, IN_PROGRESS, COMPLETED, FAILED
  fromNumber   String?
  toNumber     String?
  duration     Int? // seconds
  recordingUrl String?
  transcript   String?   @db.Text
  userId       Int?
  contactId    Int?
  tenantId     Int       @default(1)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  endedAt      DateTime?
}

// ── Multiple Sales Pipelines ─────────────────────────────────────

model Pipeline {
  id          Int      @id @default(autoincrement())
  name        String
  isDefault   Boolean  @default(false)
  description String?
  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Forecasting + Win/Loss ───────────────────────────────────────

model Forecast {
  id               Int      @id @default(autoincrement())
  period           String // "2026-Q1", "2026-04"
  expectedRevenue  Float    @default(0)
  committedRevenue Float    @default(0)
  bestCaseRevenue  Float    @default(0)
  closedRevenue    Float    @default(0)
  userId           Int?
  tenantId         Int      @default(1)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WinLossReason {
  id        Int      @id @default(autoincrement())
  type      String // "won" or "lost"
  reason    String
  count     Int      @default(0)
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ── Sales Quotas ─────────────────────────────────────────────────

model Quota {
  id        Int      @id @default(autoincrement())
  userId    Int
  period    String // "2026-Q1"
  target    Float
  achieved  Float    @default(0)
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// One quota row per (user, period, tenant). A sales rep has exactly one quota per quarter; resetting the target updates this row in place. tenantId is included defensively even though userId already constrains tenant — guards against cross-tenant userId collision in the unlikely event a user is moved.
  @@unique([userId, period, tenantId])
}

// ── Lead Routing ─────────────────────────────────────────────────

model LeadRoutingRule {
  id         Int      @id @default(autoincrement())
  name       String
  conditions String   @db.Text // JSON
  assignType String   @default("round_robin") // round_robin, specific_user, territory
  assignTo   Int? // userId if specific_user
  priority   Int      @default(100)
  isActive   Boolean  @default(true)
  tenantId   Int      @default(1)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

