// ── Knowledge Base ───────────────────────────────────────────────

model KbCategory {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String
  parentId  Int?
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  /// KB category slug uniqueness is tenant-scoped; "/billing" can exist as a category in tenant A's knowledge base AND tenant B's independently. Slugs are user-facing URL segments, so collisions only matter within one tenant's KB tree.
  @@unique([slug, tenantId])
}

model KbArticle {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String
  content     String   @db.LongText
  categoryId  Int?
  isPublished Boolean  @default(false)
