  contactId  Int?
  status     String   @default("ACTIVE") // ACTIVE, COMPLETED, ABANDONED
  tenantId   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Knowledge Base ───────────────────────────────────────────────

model KbCategory {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String
  parentId  Int?
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
  @@unique([slug, tenantId])
}

model KbArticle {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String
  content     String   @db.LongText
  categoryId  Int?
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  tenantId    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([slug, tenantId])
}

// ── SLA Management ───────────────────────────────────────────────

model SlaPolicy {
  id              Int      @id @default(autoincrement())
  name            String
  priority        String   // Low, Medium, High, Urgent
  responseMinutes Int      // first response target
  resolveMinutes  Int      // resolution target
  isActive        Boolean  @default(true)
  tenantId        Int      @default(1)
  createdAt       DateTime @default(now())
}

model CannedResponse {
  id        Int      @id @default(autoincrement())
  name      String
  content   String   @db.Text
  category  String   @default("General")
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── NPS / CSAT Surveys ───────────────────────────────────────────

model Survey {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   @default("NPS") // NPS, CSAT, CUSTOM
  question  String
  isActive  Boolean  @default(true)
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SurveyResponse {
  id          Int      @id @default(autoincrement())
  surveyId    Int
  contactId   Int?
  score       Int      // 0-10 for NPS, 1-5 for CSAT
  comment     String?  @db.Text
  respondedAt DateTime @default(now())
  tenantId    Int      @default(1)
}

// ── E-Signature ──────────────────────────────────────────────────

model SignatureRequest {
  id         Int      @id @default(autoincrement())
  documentType String  // "Contract", "Estimate", "Quote", "Custom"
  documentId Int
  signerName String
  signerEmail String
  signature  String?  @db.LongText // base64 data URL once signed
  signedAt   DateTime?
  status     String   @default("PENDING") // PENDING, SIGNED, DECLINED, EXPIRED
  signToken  String   @unique // unique URL token for signer
  tenantId   Int      @default(1)
  createdAt  DateTime @default(now())
  expiresAt  DateTime?
}

// ── Document Templates ───────────────────────────────────────────

model DocumentTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   @default("PROPOSAL") // PROPOSAL, NDA, CONTRACT, EMAIL
  content   String   @db.LongText // HTML with {{variable}} placeholders
  variables String?  @db.Text // JSON list of expected vars
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Meeting Scheduler ────────────────────────────────────────────

model BookingPage {
  id           Int      @id @default(autoincrement())
  slug         String   @unique
  title        String
  description  String?
  ownerId      Int
  durationMins Int      @default(30)
  bufferMins   Int      @default(0)
  availability String   @db.Text // JSON: weekly schedule
  isActive     Boolean  @default(true)
  tenantId     Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Booking {
  id            Int      @id @default(autoincrement())
  bookingPageId Int
  contactName   String
  contactEmail  String
  contactPhone  String?
  scheduledAt   DateTime
  durationMins  Int
  meetingUrl    String?
  notes         String?
  status        String   @default("CONFIRMED") // CONFIRMED, CANCELED, COMPLETED
  contactId     Int?
  tenantId      Int      @default(1)
  createdAt     DateTime @default(now())
}

// ── Email Scheduling + Signatures ────────────────────────────────

model ScheduledEmail {
  id           Int      @id @default(autoincrement())
  to           String
  subject      String
  body         String   @db.Text
  scheduledFor DateTime
  status       String   @default("PENDING") // PENDING, SENT, FAILED, CANCELED
  sentAt       DateTime?
  errorMessage String?
  contactId    Int?
  userId       Int?
  tenantId     Int      @default(1)
  createdAt    DateTime @default(now())
}

// ── Custom Dashboards ────────────────────────────────────────────

model Dashboard {
  id        Int      @id @default(autoincrement())
  name      String
  isDefault Boolean  @default(false)
  layout    String   @db.LongText // JSON: array of widgets {type, x, y, w, h, config}
  userId    Int?
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Custom Reports ───────────────────────────────────────────────

model CustomReport {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  config      String   @db.LongText // JSON: entity, filters, columns, groupBy, chartType
  userId      Int?
  tenantId    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Multi-Currency ───────────────────────────────────────────────

model Currency {
  id           Int      @id @default(autoincrement())
  code         String   // "USD", "INR", "EUR"
  symbol       String
  name         String
  exchangeRate Float    @default(1.0) // relative to base
  isBase       Boolean  @default(false)
  tenantId     Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([code, tenantId])
}

// ── Field-Level Permissions ──────────────────────────────────────

model FieldPermission {
  id        Int      @id @default(autoincrement())
  role      String   // ADMIN, MANAGER, USER
  entity    String   // Deal, Contact, etc.
  field     String   // amount, email, etc.
  canRead   Boolean  @default(true)
  canWrite  Boolean  @default(true)
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
  @@unique([role, entity, field, tenantId])
}

// ── Payments (Stripe + Razorpay) ─────────────────────────────────

model Payment {
  id          Int      @id @default(autoincrement())
  invoiceId   Int?
  amount      Float
  currency    String   @default("USD")
  gateway     String   // stripe, razorpay
  gatewayId   String?  // their charge/payment ID
  status      String   @default("PENDING") // PENDING, SUCCESS, FAILED, REFUNDED
  paidAt      DateTime?
  metadata    String?  @db.Text
  tenantId    Int      @default(1)
  createdAt   DateTime @default(now())
}

// ── Accounting Sync ──────────────────────────────────────────────

model AccountingSync {
  id          Int      @id @default(autoincrement())
  provider    String   // quickbooks, xero, tally
  entityType  String   // Invoice, Expense, Customer
  entityId    Int
  externalId  String   // ID in external system
  syncedAt    DateTime @default(now())
  tenantId    Int      @default(1)
  @@unique([provider, entityType, entityId, tenantId])
}

// ── AI Deal Insights ─────────────────────────────────────────────

model DealInsight {
  id          Int      @id @default(autoincrement())
  dealId      Int
  type        String   // RISK, OPPORTUNITY, NEXT_BEST_ACTION
  insight     String   @db.Text
  severity    String   @default("INFO") // INFO, WARNING, CRITICAL
  isResolved  Boolean  @default(false)
  generatedAt DateTime @default(now())
  tenantId    Int      @default(1)
}

// ── Group / Shared Inbox ─────────────────────────────────────────

model SharedInbox {
  id        Int      @id @default(autoincrement())
  name      String
  emailAddress String  @unique
  members   String?  @db.Text // JSON array of userIds
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
}

// ── SCIM ─────────────────────────────────────────────────────────

model ScimToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  name      String
  lastUsed  DateTime?
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
}

// ── Live Chat ────────────────────────────────────────────────────

model LiveChatSession {
  id           Int      @id @default(autoincrement())
  visitorId    String
  visitorName  String?
  visitorEmail String?
  status       String   @default("OPEN") // OPEN, ASSIGNED, CLOSED
  agentId      Int?
  startedAt    DateTime @default(now())
  closedAt     DateTime?
  rating       Int?     // 1-5 satisfaction
  tenantId     Int      @default(1)
}

model LiveChatMessage {
  id         Int      @id @default(autoincrement())
  sessionId  Int
  sender     String   // "visitor", "agent", "system"
  agentId    Int?
  body       String   @db.Text
  createdAt  DateTime @default(now())
  tenantId   Int      @default(1)
}

// ── Sales Playbooks ──────────────────────────────────────────────

model Playbook {
  id        Int      @id @default(autoincrement())
  name      String
  stage     String   // matches deal stage: lead, contacted, proposal, etc.
  steps     String   @db.Text // JSON array of {title, description, order}
  isActive  Boolean  @default(true)
  tenantId  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlaybookProgress {
  id          Int      @id @default(autoincrement())
  dealId      Int
  playbookId  Int
  completedSteps String? @db.Text // JSON array of step indices
  tenantId    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([dealId, playbookId])
}

// ── Document View Tracking ───────────────────────────────────────

model DocumentView {
  id           Int      @id @default(autoincrement())
  documentType String   // "Quote", "Estimate", "Contract", "Proposal"
  documentId   Int
  trackingId   String   @unique
  viewerEmail  String?
  viewedAt     DateTime?
  ipAddress    String?
  userAgent    String?  @db.Text
  duration     Int?     // seconds spent viewing
  tenantId     Int      @default(1)
  createdAt    DateTime @default(now())
}

// ── Industry Templates ───────────────────────────────────────────

model IndustryTemplate {
  id          Int      @id @default(autoincrement())
  industry    String   @unique // "real-estate", "healthcare", "education", "legal", "saas"
  name        String
  description String?  @db.Text
  config      String   @db.LongText // JSON: pipelines, customFields, customObjects, sampleContacts
  createdAt   DateTime @default(now())
}

// ── Social Media ─────────────────────────────────────────────────

model SocialPost {
  id         Int      @id @default(autoincrement())
  platform   String   // "linkedin", "twitter", "facebook"
  content    String   @db.Text
  mediaUrl   String?
  scheduledFor DateTime?
  publishedAt DateTime?
  externalId String?
  status     String   @default("DRAFT") // DRAFT, SCHEDULED, PUBLISHED, FAILED
  tenantId   Int      @default(1)
  createdAt  DateTime @default(now())
}

model SocialMention {
  id         Int      @id @default(autoincrement())
  platform   String
  authorName String?
  authorHandle String?
  content    String?  @db.Text
  url        String?
  sentiment  String?  // positive, neutral, negative
  contactId  Int?
  fetchedAt  DateTime @default(now())
  tenantId   Int      @default(1)
}

// ── Sandbox ──────────────────────────────────────────────────────

model SandboxSnapshot {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  data        String   @db.LongText // JSON dump of major entities
  tenantId    Int      @default(1)
  userId      Int?
  createdAt   DateTime @default(now())
}
