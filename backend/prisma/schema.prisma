  toNumber     String?
  duration     Int? // seconds
  recordingUrl String?
  transcript   String?   @db.Text
  userId       Int?
  contactId    Int?
  tenantId     Int       @default(1)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  endedAt      DateTime?
}

// ── Multiple Sales Pipelines ─────────────────────────────────────

model Pipeline {
  id          Int      @id @default(autoincrement())
  name        String
  isDefault   Boolean  @default(false)
  description String?
  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// ── Forecasting + Win/Loss ───────────────────────────────────────

model Forecast {
  id               Int      @id @default(autoincrement())
  period           String // "2026-Q1", "2026-04"
  expectedRevenue  Float    @default(0)
  committedRevenue Float    @default(0)
  bestCaseRevenue  Float    @default(0)
  closedRevenue    Float    @default(0)
  userId           Int?
  tenantId         Int      @default(1)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WinLossReason {
  id        Int      @id @default(autoincrement())
  type      String // "won" or "lost"
  reason    String
  count     Int      @default(0)
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ── Sales Quotas ─────────────────────────────────────────────────

model Quota {
  id        Int      @id @default(autoincrement())
  userId    Int
  period    String // "2026-Q1"
  target    Float
  achieved  Float    @default(0)
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// One quota row per (user, period, tenant). A sales rep has exactly one quota per quarter; resetting the target updates this row in place. tenantId is included defensively even though userId already constrains tenant — guards against cross-tenant userId collision in the unlikely event a user is moved.
  @@unique([userId, period, tenantId])
}

// ── Lead Routing ─────────────────────────────────────────────────

model LeadRoutingRule {
  id         Int     @id @default(autoincrement())
  name       String
  conditions String  @db.Text // JSON
  assignType String  @default("round_robin") // round_robin, specific_user, territory
  assignTo   Int? // userId if specific_user
  priority   Int     @default(100)
  isActive   Boolean @default(true)

  // PRD_TRAVEL_MULTICHANNEL_LEADS §3.3 (G007 — FR-3.3.1, 3.3.2, 3.3.4).
  // First-class routing dimensions promoted out of the generic JSON
  // `conditions` blob so the resolver can compute specificity scores
  // cheaply WITHOUT JSON.parse on every rule per intake.
  //  - channel   exact match against intake / Lead.channel ("whatsapp",
  //              "voice", "voyagr", "meta_ad", ...); NULL = wildcard
  //              (back-compat with every pre-travel rule)
  //  - subBrand  exact match against Contact.subBrand (canonical codes
  //              tmc | rfu | travelstall | visasure per PRD §4.1 gap
  //              A8); NULL = wildcard
  //  - rrCursor  per-rule round-robin cursor for FR-3.3.4. Atomic
  //              increment via Prisma `{ rrCursor: { increment: 1 } }`
  //              keeps the cursor race-safe across concurrent intake.
  //  - fallbackUserId  per FR-3.3.5: when every round-robin candidate
  //              is unavailable, fall back to this user. NULL = leave
  //              unassigned with routingFailureReason.
  channel        String?
  subBrand       String?
  rrCursor       Int     @default(0)
  fallbackUserId Int?

  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Territory Management ─────────────────────────────────────────

model Territory {
  id              Int      @id @default(autoincrement())
  name            String
  regions         String?  @db.Text // JSON array
  assignedUserIds String?  @db.Text // JSON array
  tenantId        Int      @default(1)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Approval Workflows ───────────────────────────────────────────

model ApprovalRequest {
  id          Int       @id @default(autoincrement())
  entity      String // "Deal", "Quote", "Discount", etc.
  entityId    Int
  reason      String?
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedBy Int
  approvedBy  Int?
  comment     String?
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  tenantId    Int       @default(1)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── A/B Testing ──────────────────────────────────────────────────

model AbTest {
  id              Int      @id @default(autoincrement())
  name            String
  campaignId      Int?
  variantA        String   @db.Text // JSON
  variantB        String   @db.Text // JSON
  variantASent    Int      @default(0)
  variantBSent    Int      @default(0)
  variantAClicked Int      @default(0)
  variantBClicked Int      @default(0)
  winningVariant  String? // "A" or "B"
  status          String   @default("DRAFT") // DRAFT, RUNNING, COMPLETED
  tenantId        Int      @default(1)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Marketing Attribution ────────────────────────────────────────

model Touchpoint {
  id           Int       @id @default(autoincrement())
  contactId    Int
  channel      String // "email", "social", "search", "direct", etc.
  campaignId   Int?
  source       String?
  medium       String?
  url          String?
  timestamp    DateTime  @default(now())
  // PRD_TRAVEL_MULTICHANNEL_LEADS G005 (FR-3.1.3) — UTM + producer attribution
  // fields. All nullable + additive — pre-existing Touchpoint rows ignore them;
  // intake parsers populate per-channel. utm_* mirror the standard Google
  // Analytics UTM taxonomy (campaign / term / content); source + medium
  // already exist above and carry utm_source + utm_medium respectively.
  utmCampaign  String?
  utmTerm      String?
  utmContent   String?
  // Voyagr microsite slug ("tmc.voyagr.in" → "tmc"), advertiser id (ads/meta_ad
  // platforms), web-form id (which form on the landing page), full landing-page
  // URL (Text — can be long with query params). firstTouchAt pins the
  // first-touch timestamp distinct from `timestamp` (which is touchpoint write
  // time) so multi-touch attribution can compute time-to-conversion.
  siteSlug     String?
  advertiserId String?
  formId       String?
  landingPage  String?   @db.Text
  firstTouchAt DateTime?
  tenantId     Int       @default(1)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // #571 follow-up: lead scoring engine includes contact.touchpoints in
  // its scoring fan-out; the back-relation must be declared explicitly or
  // Prisma rejects the `include: { touchpoints: ... }` validator.
  contact      Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId])
}

// ── Web Visitor Tracking ─────────────────────────────────────────

model WebVisitor {
  id         Int      @id @default(autoincrement())
  sessionId  String   @unique
  ipAddress  String?
  userAgent  String?  @db.Text
  country    String?
  city       String?
  pages      String?  @db.LongText // JSON array of {url, timestamp}
  contactId  Int?
  identified Boolean  @default(false)
  firstSeen  DateTime @default(now())
  lastSeen   DateTime @default(now())
  tenantId   Int      @default(1)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, lastSeen])
}

// ── Chatbot ──────────────────────────────────────────────────────

model Chatbot {
  id        Int      @id @default(autoincrement())
  name      String
  flow      String   @db.LongText // JSON node graph
  isActive  Boolean  @default(false)
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model ChatbotConversation {
  id        Int      @id @default(autoincrement())
  chatbotId Int
  visitorId String // links to WebVisitor.sessionId
  messages  String   @db.LongText // JSON
  contactId Int?
  status    String   @default("ACTIVE") // ACTIVE, COMPLETED, ABANDONED
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ── Knowledge Base ───────────────────────────────────────────────

model KbCategory {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String
  parentId  Int?
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  /// KB category slug uniqueness is tenant-scoped; "/billing" can exist as a category in tenant A's knowledge base AND tenant B's independently. Slugs are user-facing URL segments, so collisions only matter within one tenant's KB tree.
  @@unique([slug, tenantId])
}

model KbArticle {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String
  content     String   @db.LongText
  categoryId  Int?
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// KB article slug uniqueness is tenant-scoped; "/getting-started" is a perfectly valid slug for tenant A's article AND tenant B's article. Slugs feed public KB URLs (/portal/kb/<slug>) so collisions only matter within one tenant's portal.
  @@unique([slug, tenantId])
}

// ── SLA Management ───────────────────────────────────────────────

model SlaPolicy {
  id              Int      @id @default(autoincrement())
  name            String
  priority        String // Low, Medium, High, Urgent
  responseMinutes Int // first response target
  resolveMinutes  Int // resolution target
  isActive        Boolean  @default(true)
  tenantId        Int      @default(1)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

model CannedResponse {
  id        Int      @id @default(autoincrement())
  name      String
  content   String   @db.Text
  category  String   @default("General")
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ── NPS / CSAT Surveys ───────────────────────────────────────────

model Survey {
  id              Int      @id @default(autoincrement())
  // `name` is the legacy short-id key used by the NPS cron
  // (wellnessOpsEngine.js); keep it so existing surveys + the
  // auto-NPS flow keep working unchanged.
  name            String
  // `title` is the human-readable form name used by the multi-question
  // builder. Nullable so legacy NPS rows aren't forced to backfill.
  title           String?
  // String-as-enum (matches the codebase convention — see Tenant.vertical,
  // SignatureRequest.documentType, etc.). Allowed values:
  //   Legacy single-question: NPS | CSAT | CUSTOM
  //   New multi-question:     PRODUCT | SERVICE | DOCTOR
  // The wellnessOpsEngine cron continues to write NPS rows; the new
  // builder writes PRODUCT / SERVICE / DOCTOR / CUSTOM rows.
  type            String   @default("NPS")
  // Legacy single-question text — nullable because new multi-question
  // surveys carry their questions in SurveyQuestion rows instead.
  question        String?
  // Polymorphic FK; the route validates by `type`:
  //   PRODUCT → relatedEntityId references Product.id
  //   SERVICE → references Service.id
  //   DOCTOR  → references User.id (wellnessRole=doctor)
  //   CUSTOM / NPS / CSAT → null
  // Not enforced as a Prisma relation because it spans multiple tables.
  relatedEntityId Int?
  // Admin who created the survey. Nullable so cron-created NPS rows
  // (which have no user actor) don't need a synthetic user.
  createdById     Int?
  isActive        Boolean  @default(true)
  tenantId        Int      @default(1)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  questions SurveyQuestion[]
  answers   SurveyAnswer[]

  @@unique([tenantId, name])
}

model SurveyResponse {
  id          Int      @id @default(autoincrement())
  surveyId    Int
  contactId   Int?
  score       Int // 0-10 for NPS, 1-5 for CSAT
  comment     String?  @db.Text
  respondedAt DateTime @default(now())
  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, surveyId])
}

// Multi-question review form child table — each Survey of type
// PRODUCT/SERVICE/DOCTOR/CUSTOM owns an ordered list of SurveyQuestion
// rows. Legacy NPS/CSAT Survey rows have zero SurveyQuestion children
// (they store their single question in Survey.question).
model SurveyQuestion {
  id         Int      @id @default(autoincrement())
  surveyId   Int
  survey     Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question   String
  // String-as-enum: TEXT | TEXTAREA | SELECT | RATE | RADIO | YES_NO
  fieldType  String
  // JSON-encoded array of option strings — only set for SELECT, RADIO,
  // and YES_NO (server-forced to ["True","False"] for YES_NO).
  // Storage layer follows the JSON-string-column standing rule from
  // CLAUDE.md: the column is text, callers stringify before write.
  options    String?  @db.Text
  // Rating bounds — only set for fieldType=RATE. Both required when set.
  minRating  Int?
  maxRating  Int?
  // Ordering within the parent Survey form (0-based, ascending).
  order      Int      @default(0)
  isRequired Boolean  @default(true)
  isActive   Boolean  @default(true)
  tenantId   Int      @default(1)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  answers SurveyAnswer[]

  @@index([tenantId, surveyId, order])
}

// Per-question submission row — one row per (questionId, submission).
// SurveyResponse remains the legacy single-score table used by the NPS
// flow; SurveyAnswer is the new per-question store. Both can coexist on
// the same Survey if needed (e.g. an NPS-tagged survey that later grows
// custom questions), and reports consume each independently.
model SurveyAnswer {
  id           Int            @id @default(autoincrement())
  surveyId     Int
  survey       Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  questionId   Int
  question     SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId       Int?
  // Free-form text storage — RATE answers stringify the number,
  // YES_NO stringify "True"/"False", SELECT/RADIO stringify the chosen
  // option label. Keeps the schema uniform regardless of fieldType.
  answer       String?        @db.Text
  // Submission grouping key. All SurveyAnswer rows produced by one
  // POST /respond/:token/submit (or POST /:id/submit) share the same
  // submissionId — generated server-side per submit call via crypto
  // (UUID-shaped, 32 hex chars). Nullable so pre-v3.7.17 rows (single-
  // row "submission") still load; the answers endpoint treats null as
  // a one-row group keyed by id.
  submissionId String?
  // Recipient identification — copied from the responseTokens entry on
  // submit so the admin's submission detail view can show WHO answered
  // (Contact name + email, Patient name + phone). Both nullable: any
  // given submission resolves to ONE of these (the token carried either
  // contactId or patientId, never both) and rows submitted before this
  // column existed leave both null. Not declared as Prisma relations
  // because Contact and Patient already cascade on tenant delete and
  // this row's lifetime tracks Survey, not its recipient.
  contactId    Int?
  patientId    Int?
  tenantId     Int            @default(1)
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())

  @@index([tenantId, surveyId])
  @@index([tenantId, questionId])
  @@index([tenantId, surveyId, submissionId])
}

// ── E-Signature ──────────────────────────────────────────────────

model SignatureRequest {
  id           Int       @id @default(autoincrement())
  documentType String // "Contract", "Estimate", "Quote", "Custom"
  documentId   Int
  signerName   String
  signerEmail  String
  signature    String?   @db.LongText // base64 data URL once signed
  signedAt     DateTime?
  status       String    @default("PENDING") // PENDING, SIGNED, DECLINED, EXPIRED
  signToken    String    @unique // unique URL token for signer
  tenantId     Int       @default(1)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?
}

// ── Document Templates ───────────────────────────────────────────

model DocumentTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   @default("PROPOSAL") // PROPOSAL, NDA, CONTRACT, EMAIL
  content   String   @db.LongText // HTML with {{variable}} placeholders
  variables String?  @db.Text // JSON list of expected vars
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
