  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Wave 2 Agent KK: 2-way messaging - thread keyed by (tenantId, contactPhone).
  threadId Int?
  thread   WhatsAppThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([threadId, createdAt])
}

// -- WhatsApp 2-way: Thread aggregation + opt-out (Wave 2 Agent KK) --
model WhatsAppThread {
  id            Int       @id @default(autoincrement())
  contactPhone  String
  status        String    @default("OPEN")
  lastMessageAt DateTime  @default(now())
  lastInboundAt DateTime?
  snoozedUntil  DateTime?
  unreadCount   Int       @default(0)
  labels        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId Int?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  patientId Int?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  assignedToId Int?
  assignedTo   User? @relation("WhatsAppThreadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  messages WhatsAppMessage[]

  @@unique([tenantId, contactPhone])
  @@index([tenantId, status, lastMessageAt])
  @@index([assignedToId, status])
}

model WhatsAppOptOut {
  id           Int      @id @default(autoincrement())
  contactPhone String
  reason       String   @default("USER_REQUESTED")
  capturedAt   DateTime @default(now())
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contactPhone])
  @@index([tenantId, capturedAt])
}

model WhatsAppTemplate {
  id             Int      @id @default(autoincrement())
  name           String
  language       String   @default("en")
  category       String   @default("MARKETING") // MARKETING, UTILITY, AUTHENTICATION
  headerType     String? // TEXT, IMAGE, DOCUMENT, VIDEO, NONE
  headerContent  String?
  body           String   @db.Text
  footer         String?
  buttons        String?  @db.Text // JSON
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  metaTemplateId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// WhatsApp template names are tenant-scoped. Meta itself enforces uniqueness within a Business Account, so a tenant cannot have two templates named "appointment_reminder", but tenant A and tenant B can each independently register a template named "appointment_reminder" against their own WABA.
  @@unique([tenantId, name])
}

model WhatsAppConfig {
  id                 Int      @id @default(autoincrement())
  provider           String // "meta_cloud", "twilio_whatsapp", "gupshup"
  phoneNumberId      String?
  businessAccountId  String?
  accessToken        String?
  webhookVerifyToken String?
  isActive           Boolean  @default(false)
  settings           String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One WhatsApp credentials row per (tenant, provider). A tenant connects to Meta Cloud API once with their WABA + phone number ID. Different tenants own different WABAs and operate independently.
  @@unique([tenantId, provider])
}

// ── Telephony ─────────────────────────────────────────────────────

model TelephonyConfig {
