  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  date DateTime

  clockInAt          DateTime?
  clockOutAt         DateTime?
  clockInLocationId  Int?
  clockOutLocationId Int?

  source            String @default("MANUAL")
  biometricDeviceId Int?

  totalMinutes Int?

  status String  @default("PRESENT")
  notes  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, date])
  @@index([tenantId, date])
  @@index([tenantId, userId, date])
}

model BiometricDevice {
  id       Int    @id @default(autoincrement())
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  locationId Int?

  deviceId String
  vendor   String

  apiKey String

  lastSyncAt DateTime?
  isActive   Boolean   @default(true)

  createdAt DateTime @default(now())

  @@unique([tenantId, deviceId])
  @@unique([apiKey])
  @@index([tenantId, isActive])
}

model LeavePolicy {
  id       Int    @id @default(autoincrement())
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name String

  leaveType String

  annualEntitlement Int

  accrualPattern String @default("UPFRONT")

  carryForwardCap Int?
  encashable      Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  balances LeaveBalance[]
  requests LeaveRequest[]

  @@index([tenantId, isActive])
  @@index([tenantId, leaveType])
}

model LeaveBalance {
  id       Int    @id @default(autoincrement())
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  policyId Int
  policy   LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  periodStart DateTime
  periodEnd   DateTime

  entitled  Int @default(0)
  accrued   Int @default(0)
  used      Int @default(0)
  pending   Int @default(0)
