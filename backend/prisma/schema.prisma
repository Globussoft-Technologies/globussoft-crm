}

model WhatsAppConfig {
  id                 Int      @id @default(autoincrement())
  provider           String   // "meta_cloud", "twilio_whatsapp", "gupshup"
  phoneNumberId      String?
  businessAccountId  String?
  accessToken        String?
  webhookVerifyToken String?
  isActive           Boolean  @default(false)
  settings           String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenantId           Int      @default(1)
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
}

// ── Telephony ─────────────────────────────────────────────────────

model TelephonyConfig {
  id            Int      @id @default(autoincrement())
  provider      String   // "myoperator", "knowlarity", "twilio"
  apiKey        String?
  apiSecret     String?
  virtualNumber String?
  agentNumber   String?
  isActive      Boolean  @default(false)
  settings      String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId      Int      @default(1)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
}

// ── Push Notifications ────────────────────────────────────────────

model PushSubscription {
  id          Int      @id @default(autoincrement())
  endpoint    String   @unique @db.VarChar(500)
  p256dh      String
  auth        String
  type        String   @default("CRM_USER") // CRM_USER, WEBSITE_VISITOR

  tenantId    Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId   Int?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  userAgent   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model PushNotification {
  id             Int       @id @default(autoincrement())
  title          String
  body           String    @db.Text
  icon           String?
  url            String?
  imageUrl       String?
  type           String    @default("INTERNAL") // INTERNAL, MARKETING
  status         String    @default("QUEUED")
  sentCount      Int       @default(0)
  deliveredCount Int       @default(0)
  clickedCount   Int       @default(0)
  failedCount    Int       @default(0)
