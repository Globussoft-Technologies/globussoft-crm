# WhatsApp Gateway service env. Copy to .env for local runs.
# See docs/WHATSAPP_GATEWAY_EXTRACTION.md.

# Port the gateway listens on (backend's WA_GATEWAY_URL must point here).
WA_GATEWAY_PORT=5100

# Shared secret — MUST match the backend's WA_GATEWAY_INTERNAL_KEY. Sent as
# X-Internal-Key in both directions.
WA_GATEWAY_INTERNAL_KEY=

# Where the gateway posts transport events (the CRM backend's base URL).
# The gateway calls <this>/internal/whatsapp/events.
WA_BACKEND_EVENTS_URL=http://127.0.0.1:5000/api

# Optional: reuse a system Chromium instead of Puppeteer's bundled one
# (storage/memory — see docs/BACKEND_MEMORY_AND_STORAGE_OPTIMIZATION.md).
# WHATSAPP_WEB_CHROME_PATH=

# Never launch a browser (parity with the backend's CI/dev guard).
# WHATSAPP_WEB_DISABLED=
